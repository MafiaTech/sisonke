<section class="report-card @CssClass">
    <div class="report-card-head">
        <div>
            <span class="report-kicker">@Eyebrow</span>
            <h3>@Title</h3>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <p>@Subtitle</p>
            }
        </div>
    </div>

    <div class="report-bar-list">
        @foreach (var item in Items)
        {
            var width = GetWidth(item.Value);
            <div class="report-bar-row">
                <div class="report-bar-row-top">
                    <span>@item.Label</span>
                    <strong>@FormatValue(item.Value)</strong>
                </div>
                <div class="report-bar-track" role="progressbar" aria-label="@($"{item.Label} {FormatValue(item.Value)}")" aria-valuenow="@width" aria-valuemin="0" aria-valuemax="100">
                    <span style="@($"width:{width}%;background:{item.Color}")"></span>
                </div>
                @if (!string.IsNullOrWhiteSpace(item.Detail))
                {
                    <small>@item.Detail</small>
                }
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public string Eyebrow { get; set; } = "Report";
    [Parameter] public string Title { get; set; } = "Summary";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string CssClass { get; set; } = string.Empty;
    [Parameter] public IReadOnlyList<ReportDatum> Items { get; set; } = [];
    [Parameter] public decimal? MaxValue { get; set; }
    [Parameter] public Func<decimal, string>? ValueFormatter { get; set; }

    private decimal EffectiveMax => Math.Max(1, MaxValue ?? (Items.Count == 0 ? 1 : Items.Max(item => item.Value)));

    private string FormatValue(decimal value) => ValueFormatter?.Invoke(value) ?? value.ToString("0.#");

    private decimal GetWidth(decimal value) => Math.Clamp(Math.Round(value / EffectiveMax * 100, 1), 0, 100);
}

