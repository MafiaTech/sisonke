<div class="alert @AlertClass d-flex gap-3 align-items-start" role="alert">
    @if (!string.IsNullOrWhiteSpace(Icon))
    {
        <i class="@Icon flex-shrink-0 mt-1 fs-5" aria-hidden="true"></i>
    }
    <div>
        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <strong class="d-block">@Title</strong>
        }
        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <span class="d-block mt-1" style="font-size:.9rem;">@Message</span>
        }
    </div>
</div>

@code {
    [Parameter] public string Type    { get; set; } = "info";
    [Parameter] public string Title   { get; set; } = string.Empty;
    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public string? Icon   { get; set; }

    private string AlertClass => Type.ToLowerInvariant() switch
    {
        "success" => "alert-success",
        "warning" => "alert-warning",
        "danger"  => "alert-danger",
        "info"    => "alert-info",
        _         => "alert-info"
    };
}
