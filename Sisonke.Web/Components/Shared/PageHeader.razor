@if (!string.IsNullOrWhiteSpace(BackText) && !string.IsNullOrWhiteSpace(BackHref))
{
    <a class="back-nav" href="@BackHref">
        <i class="bi bi-chevron-left"></i>@BackText
    </a>
}

<div class="page-header-text mb-4">
    <h1>@Title</h1>
    @if (!string.IsNullOrWhiteSpace(Subtitle))
    {
        <p class="page-subtitle mb-0">@Subtitle</p>
    }
</div>

@code {
    [Parameter] public string  Title     { get; set; } = string.Empty;
    [Parameter] public string? Subtitle  { get; set; }
    [Parameter] public string? BackText  { get; set; }
    [Parameter] public string? BackHref  { get; set; }
}
