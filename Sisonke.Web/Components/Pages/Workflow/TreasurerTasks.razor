@page "/treasurer-tasks/{StokvelId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services
@using Sisonke.Web.Services.Dto

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccessService MemberAccessService
@inject FineService FineService
@inject FuneralClaimService FuneralClaimService
@inject ContributionPaymentService ContributionPaymentService
@inject RotationalTaskService RotationalTaskService
@inject RotationalPayoutService RotationalPayoutService
@inject NavigationManager NavigationManager

<PageTitle>Treasurer Task List</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading finance tasks...
    </div>
}
else if (!canViewTreasurerTasks)
{
    <div class="sisonke-alert sisonke-alert-gold" role="alert">
        You do not have access to the treasurer task list for this stokvel.
    </div>

    <a class="sisonke-btn sisonke-btn-outline" href="/my-workspace">
        Back to My Workspace
    </a>
}
else
{
    <section class="sisonke-hero-card mb-4">
        <div>
            <span class="sisonke-badge sisonke-badge-gold">Treasurer</span>
            <h1>Treasurer Task List</h1>
            <p>Financial items requiring capture, confirmation or follow-up.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="sisonke-btn sisonke-btn-outline" href="@($"/stokvel-dashboard/{StokvelId}")">Back to Dashboard</a>
            <a class="sisonke-btn sisonke-btn-outline" href="#payout-audit">Payout Audit</a>
            <a class="sisonke-btn sisonke-btn-gold" href="@($"/finance-summary/{StokvelId}")">Finance Summary Report</a>
            <a class="sisonke-btn sisonke-btn-primary" href="@($"/members/{StokvelId}")">Open Members</a>
        </div>
    </section>

    @if (outstandingFines.Count == 0 && approvedClaimsAwaitingPayout.Count == 0 && RotationalPayoutTask is null)
    {
        <div class="sisonke-alert sisonke-alert-green mb-4">
            No pending finance tasks. Everything is up to date.
        </div>
    }

    <div class="sisonke-grid sisonke-grid-2 mb-4">
        <div class="sisonke-card">
            <div class="sisonke-card-body">
                <div class="sisonke-card-head">
                    <div>
                        <h2>Outstanding Fines</h2>
                        <p>Unpaid fines that may need payment confirmation.</p>
                    </div>
                    <span class="sisonke-badge sisonke-badge-red">@outstandingFines.Count Open</span>
                </div>

                @if (outstandingFines.Count == 0)
                {
                    <div class="sisonke-alert sisonke-alert-green mb-0">
                        No outstanding fines recorded.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="sisonke-table mb-0">
                            <thead>
                                <tr>
                                    <th>Member</th>
                                    <th>Fine</th>
                                    <th>Amount</th>
                                    <th>Date Issued</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var fine in outstandingFines)
                                {
                                    <tr>
                                        <td class="fw-semibold">@(fine.Member?.FullName ?? "Member unavailable")</td>
                                        <td>
                                            <div>@(fine.FineType?.Name ?? "Fine")</div>
                                            <div class="text-muted small">@(string.IsNullOrWhiteSpace(fine.Reason) ? "-" : fine.Reason)</div>
                                        </td>
                                        <td>@FormatZAR(fine.Amount)</td>
                                        <td>@fine.FineDate.ToString("dd MMM yyyy")</td>
                                        <td><span class="sisonke-badge sisonke-badge-red">@fine.Status</span></td>
                                        <td>
                                            <div class="d-flex flex-wrap gap-2 justify-content-end">
                                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/member-profile/{fine.MemberId}")">Open Profile</a>
                                                @if (canManagePayments)
                                                {
                                                    <a class="sisonke-btn sisonke-btn-gold" href="@($"/mark-fine-paid/{fine.Id}")">Mark Paid</a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="sisonke-card">
            <div class="sisonke-card-body">
                <div class="sisonke-card-head">
                    <div>
                        <h2>Approved Claims Awaiting Payout</h2>
                        <p>Claims approved by the chairperson and awaiting finance follow-up.</p>
                    </div>
                    <span class="sisonke-badge sisonke-badge-gold">@approvedClaimsAwaitingPayout.Count Open</span>
                </div>

                @if (approvedClaimsAwaitingPayout.Count == 0)
                {
                    <div class="sisonke-alert sisonke-alert-green mb-0">
                        No approved claims are awaiting payout.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="sisonke-table mb-0">
                            <thead>
                                <tr>
                                    <th>Claim</th>
                                    <th>Member</th>
                                    <th>Subject</th>
                                    <th>Approved Date</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var claim in approvedClaimsAwaitingPayout)
                                {
                                    <tr>
                                        <td class="fw-semibold">@GetClaimReference(claim)</td>
                                        <td>@(claim.Member?.FullName ?? "Member unavailable")</td>
                                        <td>
                                            <div>@claim.DeceasedFullName</div>
                                            <div class="text-muted small">@claim.SubjectType</div>
                                        </td>
                                        <td>@((claim.ApprovedAt ?? claim.ChairpersonDecisionAt)?.ToString("dd MMM yyyy") ?? "-")</td>
                                        <td><span class="sisonke-badge sisonke-badge-green">@claim.Status</span></td>
                                        <td>
                                            <a class="sisonke-btn sisonke-btn-outline" href="@($"/claim/{claim.Id}")">Open Claim</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="sisonke-card mb-4">
        <div class="sisonke-card-body">
            <div class="sisonke-card-head">
                <div>
                    <h2>Rotational Payouts Awaiting Payment</h2>
                    <p>Chairperson-approved rotational payouts that still need Treasurer payment confirmation.</p>
                </div>
                <span class="sisonke-badge sisonke-badge-gold">@RotationalPayoutTaskCount Open</span>
            </div>

            @if (RotationalPayoutTask is null)
            {
                <div class="sisonke-alert sisonke-alert-green mb-0">
                    No rotational payouts are awaiting Treasurer payment.
                </div>
            }
            else
            {
                var payout = RotationalPayoutTask;
                <div class="table-responsive">
                    <table class="sisonke-table mb-0">
                        <thead>
                            <tr>
                                <th>Cycle</th>
                                <th>Payout Member</th>
                                <th>Amount</th>
                                <th>Chairperson Review</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="fw-semibold">@payout.Cycle.CycleName</td>
                                <td>@DisplayOrDash(payout.PayoutMember.FullName)</td>
                                <td>@FormatZAR(payout.PayoutAmount)</td>
                                <td>
                                    <div><span class="sisonke-badge sisonke-badge-green">Approved</span></div>
                                    <div class="text-muted small mt-1">@DisplayOrDash(payout.ChairpersonReviewNotes)</div>
                                </td>
                                <td><span class="sisonke-badge sisonke-badge-gold">Awaiting Treasurer payout</span></td>
                                <td>
                                    @if (canManagePayments)
                                    {
                                        <button class="sisonke-btn sisonke-btn-primary sisonke-btn-sm"
                                                type="button"
                                                @onclick="OpenRotationalPayoutPayment"
                                                disabled="@isConfirmingRotationalPayout">
                                            Capture Payout Payment
                                        </button>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                @if (showRotationalPayoutPaymentForm)
                {
                    <div class="rotational-payout-payment-form mt-3">
                        <div>
                            <label class="form-label" for="rotational-payout-method">Payment method</label>
                            <InputSelect id="rotational-payout-method" class="form-select form-select-sm" @bind-Value="rotationalPayoutPaymentMethod">
                                <option value="">Select method</option>
                                <option value="@PaymentMethod.EFT">EFT</option>
                                <option value="@PaymentMethod.Cash">Cash</option>
                                <option value="@PaymentMethod.BankDeposit">Bank deposit</option>
                                <option value="@PaymentMethod.MobilePayment">Mobile payment</option>
                                <option value="@PaymentMethod.Other">Other</option>
                            </InputSelect>
                        </div>
                        <div>
                            <label class="form-label" for="rotational-payout-reference">Payment reference</label>
                            <InputText id="rotational-payout-reference" class="form-control form-control-sm" @bind-Value="rotationalPayoutPaymentReference" />
                        </div>
                        <div>
                            <label class="form-label" for="rotational-payout-date">Paid date</label>
                            <InputDate id="rotational-payout-date" class="form-control form-control-sm" @bind-Value="rotationalPayoutPaidAt" />
                        </div>
                        <div class="rotational-payout-payment-notes">
                            <label class="form-label" for="rotational-payout-notes">Notes</label>
                            <InputTextArea id="rotational-payout-notes" class="form-control form-control-sm" rows="2" @bind-Value="rotationalPayoutNotes" />
                        </div>
                        <div class="d-flex flex-wrap gap-2 align-items-end">
                            <button class="sisonke-btn sisonke-btn-primary sisonke-btn-sm"
                                    type="button"
                                    @onclick="ConfirmRotationalPayoutPaidAsync"
                                    disabled="@isConfirmingRotationalPayout">
                                Mark Payout Paid
                            </button>
                            <button class="sisonke-btn sisonke-btn-outline sisonke-btn-sm"
                                    type="button"
                                    @onclick="CloseRotationalPayoutPayment"
                                    disabled="@isConfirmingRotationalPayout">
                                Cancel
                            </button>
                        </div>
                    </div>
                }

                @if (rotationalPayoutErrors.Count > 0)
                {
                    <div class="sisonke-alert sisonke-alert-red mt-3 mb-0">
                        <ul class="mb-0 ps-3">
                            @foreach (var error in rotationalPayoutErrors)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(rotationalPayoutSuccessMessage))
                {
                    <div class="sisonke-alert sisonke-alert-green mt-3 mb-0">
                        @rotationalPayoutSuccessMessage
                    </div>
                }
            }
        </div>
    </div>

    <div id="payout-audit" class="sisonke-card mb-4">
        <div class="sisonke-card-body">
            <div class="sisonke-card-head">
                <div>
                    <h2>Recent Payout Activity</h2>
                    <p>Recently captured claim and rotational payout actions.</p>
                </div>
                <span class="sisonke-badge sisonke-badge-gold">@(recentPayoutActivity.Count + recentRotationalPayoutActivity.Count) Recent</span>
            </div>

            @if (recentPayoutActivity.Count == 0 && recentRotationalPayoutActivity.Count == 0)
            {
                <div class="sisonke-alert sisonke-alert-blue mb-0">
                    No payout activity has been recorded yet.
                </div>

                @if (canManagePayments)
                {
                    @* TODO: Remove after pilot data stabilisation. *@
                    <button class="sisonke-btn sisonke-btn-outline mt-3" type="button" @onclick="BackfillPayoutAuditTrailAsync" disabled="@isBackfillingPayoutAudits">
                        @(isBackfillingPayoutAudits ? "Backfilling..." : "Backfill Payout Audit Trail")
                    </button>
                }
            }
            else
            {
                <div class="table-responsive">
                    <table class="sisonke-table mb-0">
                        <thead>
                            <tr>
                                <th>Date/time</th>
                                <th>Claim reference</th>
                                <th>Member</th>
                                <th>Action</th>
                                <th>Amount</th>
                                <th>Reference</th>
                                <th>Captured by</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var audit in recentPayoutActivity)
                            {
                                <tr>
                                    <td class="text-muted small">@audit.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                    <td class="fw-semibold">@GetClaimReference(audit)</td>
                                    <td>@(audit.Member?.FullName ?? "Member unavailable")</td>
                                    <td><span class="sisonke-badge sisonke-badge-gold">@audit.Action</span></td>
                                    <td>@FormatZAR(audit.NewPayoutAmount)</td>
                                    <td>@(audit.PayoutReference ?? "-")</td>
                                    <td>@(audit.CapturedByMember?.FullName ?? "-")</td>
                                    <td>
                                        <a class="sisonke-btn sisonke-btn-outline" href="@($"/claim/{audit.FuneralClaimId}")">Open Claim</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (recentRotationalPayoutActivity.Count > 0)
            {
                <div class="table-responsive mt-3">
                    <table class="sisonke-table mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Cycle</th>
                                <th>Payout Member</th>
                                <th>Amount</th>
                                <th>Reference</th>
                                <th>Method</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var payout in recentRotationalPayoutActivity)
                            {
                                <tr>
                                    <td class="text-muted small">@(payout.PaidAt?.ToLocalTime().ToString("dd MMM yyyy") ?? "-")</td>
                                    <td class="fw-semibold">@payout.Cycle.CycleName</td>
                                    <td>@DisplayOrDash(payout.PayoutMember.FullName)</td>
                                    <td>@FormatZAR(payout.PayoutAmount)</td>
                                    <td>@DisplayOrDash(payout.PaymentReference)</td>
                                    <td>@(payout.PaymentMethod?.ToString() ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(payoutAuditBackfillMessage))
            {
                <div class="sisonke-alert sisonke-alert-green mt-3 mb-0">
                    @payoutAuditBackfillMessage
                </div>
            }
        </div>
    </div>

    <div class="sisonke-grid sisonke-grid-2">
        <div class="sisonke-card">
            <div class="sisonke-card-body">
                <div class="sisonke-card-head">
                    <div>
                        <h2>Contributions to Capture</h2>
                        <p>@CurrentMonthLabel monthly contribution capture workspace.</p>
                    </div>
                    <span class="sisonke-badge sisonke-badge-blue">@currentMonthContributionSummary.RecordsGenerated Records</span>
                </div>
                @if (currentMonthContributionSummary.RecordsGenerated == 0)
                {
                    <div class="sisonke-alert sisonke-alert-blue">
                        No contribution records have been generated for this month yet.
                    </div>
                }
                <div class="sisonke-grid sisonke-grid-2 mb-3">
                    <div class="sisonke-alert sisonke-alert-blue mb-0">
                        <strong>@FormatZAR(currentMonthContributionSummary.ExpectedContributions)</strong> expected
                    </div>
                    <div class="sisonke-alert sisonke-alert-green mb-0">
                        <strong>@FormatZAR(currentMonthContributionSummary.ActualContributions)</strong> actual
                    </div>
                    <div class="sisonke-alert sisonke-alert-gold mb-0">
                        <strong>@FormatZAR(currentMonthContributionSummary.OutstandingContributions)</strong> outstanding
                    </div>
                    <div class="sisonke-alert sisonke-alert-blue mb-0">
                        <strong>@currentMonthContributionSummary.CollectionRatePercentage.ToString("0.#")%</strong> collection rate
                    </div>
                </div>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="sisonke-badge sisonke-badge-green">@currentMonthContributionSummary.PaidCount Paid</span>
                    <span class="sisonke-badge sisonke-badge-gold">@currentMonthContributionSummary.PartiallyPaidCount Partial</span>
                    <span class="sisonke-badge sisonke-badge-red">@currentMonthContributionSummary.OverdueCount Overdue</span>
                    <span class="sisonke-badge sisonke-badge-gray">@currentMonthContributionSummary.UnpaidCount Unpaid</span>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    @if (canManagePayments)
                    {
                        <a class="sisonke-btn sisonke-btn-primary" href="@($"/contribution-capture/{StokvelId}")">Open Contribution Capture</a>
                    }
                    <a class="sisonke-btn sisonke-btn-outline" href="@($"/contribution-rules/{StokvelId}")">Contribution Rules</a>
                </div>
            </div>
        </div>

        <div class="sisonke-card">
            <div class="sisonke-card-body">
                <div class="sisonke-card-head">
                    <div>
                        <h2>Financial Reports</h2>
                        <p>Monthly contribution, arrears and payment overview.</p>
                    </div>
                    <span class="sisonke-badge sisonke-badge-blue">Ready</span>
                </div>
                <a class="sisonke-btn sisonke-btn-primary" href="@($"/finance-summary/{StokvelId}")">Finance Summary Report</a>
            </div>
        </div>
    </div>
}

<style>
    .rotational-payout-payment-form {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: .75rem;
        padding: 1rem;
        border: 1px solid var(--sk-border, #e5e7eb);
        border-radius: var(--r-md, .5rem);
        background: var(--sk-surface-2, #f8f9fa);
    }

    .rotational-payout-payment-notes {
        grid-column: 1 / -1;
    }

    @@media (max-width: 768px) {
        .rotational-payout-payment-form {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private bool isLoading = true;
    private bool isBackfillingPayoutAudits;
    private bool isConfirmingRotationalPayout;
    private bool showRotationalPayoutPaymentForm;
    private bool canViewTreasurerTasks;
    private bool canManagePayments;
    private string? currentUserId;
    private Guid? loggedInTreasurerMemberId;
    private List<MemberFine> outstandingFines = [];
    private List<FuneralClaim> approvedClaimsAwaitingPayout = [];
    private List<ClaimPayoutAudit> recentPayoutActivity = [];
    private List<RotationalPayout> recentRotationalPayoutActivity = [];
    private List<MemberContribution> currentMonthContributions = [];
    private ContributionMonthSummaryDto currentMonthContributionSummary = new();
    private RotationalTaskState? rotationalTaskState;
    private PaymentMethod? rotationalPayoutPaymentMethod;
    private string? rotationalPayoutPaymentReference;
    private DateTime? rotationalPayoutPaidAt;
    private string? rotationalPayoutNotes;
    private string? rotationalPayoutSuccessMessage;
    private List<string> rotationalPayoutErrors = [];
    private string CurrentMonthLabel => DateTime.Today.ToString("MMMM yyyy");
    private RotationalPayout? RotationalPayoutTask => rotationalTaskState?.ApprovedPayout;
    private int RotationalPayoutTaskCount => RotationalPayoutTask is null ? 0 : 1;
    private int CurrentMonthPaidContributionCount => currentMonthContributions.Count(contribution => contribution.Status == PaymentStatus.Paid);
    private int CurrentMonthOpenContributionCount => currentMonthContributions.Count(contribution =>
        contribution.Status is PaymentStatus.Unpaid or PaymentStatus.PartiallyPaid or PaymentStatus.Late);

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        isBackfillingPayoutAudits = false;
        isConfirmingRotationalPayout = false;
        showRotationalPayoutPaymentForm = false;
        canViewTreasurerTasks = false;
        canManagePayments = false;
        currentUserId = null;
        loggedInTreasurerMemberId = null;
        outstandingFines = [];
        approvedClaimsAwaitingPayout = [];
        recentPayoutActivity = [];
        recentRotationalPayoutActivity = [];
        currentMonthContributions = [];
        currentMonthContributionSummary = new();
        rotationalTaskState = null;
        rotationalPayoutErrors = [];
        rotationalPayoutSuccessMessage = null;
        payoutAuditBackfillMessage = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
        currentUserId = userId;

        if (string.IsNullOrWhiteSpace(userId))
        {
            isLoading = false;
            return;
        }

        canViewTreasurerTasks = await MemberAccessService.CanViewTreasurerTasksAsync(userId, StokvelId);
        canManagePayments = await MemberAccessService.CanManagePaymentsAsync(userId, StokvelId);

        if (!canViewTreasurerTasks)
        {
            isLoading = false;
            return;
        }

        if (canManagePayments)
        {
            var treasurerMember = await MemberAccessService.GetLinkedMemberForUserAsync(userId, StokvelId);
            loggedInTreasurerMemberId = treasurerMember?.Id;
        }

        outstandingFines = await FineService.GetOutstandingFinesByStokvelIdAsync(StokvelId);
        approvedClaimsAwaitingPayout = await FuneralClaimService.GetApprovedClaimsAwaitingPayoutByStokvelIdAsync(StokvelId);
        rotationalTaskState = await RotationalTaskService.GetTaskStateAsync(StokvelId);
        recentRotationalPayoutActivity = await RotationalPayoutService.GetRecentPaidPayoutsAsync(StokvelId, 10);
        recentPayoutActivity = await FuneralClaimService.GetClaimPayoutAuditsByStokvelIdAsync(StokvelId, 10);
        currentMonthContributions = await ContributionPaymentService.GetMonthlyContributionsAsync(
            StokvelId,
            DateTime.Today.Year,
            DateTime.Today.Month);
        currentMonthContributionSummary = await ContributionPaymentService.GetMonthlyContributionSummaryAsync(
            StokvelId,
            DateTime.Today.Year,
            DateTime.Today.Month);
        isLoading = false;
    }

    private void OpenRotationalPayoutPayment()
    {
        rotationalPayoutPaymentMethod = PaymentMethod.EFT;
        rotationalPayoutPaymentReference = null;
        rotationalPayoutPaidAt = DateTime.Today;
        rotationalPayoutNotes = null;
        rotationalPayoutErrors = [];
        rotationalPayoutSuccessMessage = null;
        showRotationalPayoutPaymentForm = true;
    }

    private void CloseRotationalPayoutPayment()
    {
        showRotationalPayoutPaymentForm = false;
        rotationalPayoutErrors = [];
    }

    private async Task ConfirmRotationalPayoutPaidAsync()
    {
        rotationalPayoutErrors = [];
        rotationalPayoutSuccessMessage = null;

        if (RotationalPayoutTask is null || string.IsNullOrWhiteSpace(currentUserId))
        {
            rotationalPayoutErrors = ["No rotational payout is awaiting payment."];
            return;
        }

        isConfirmingRotationalPayout = true;
        var result = await RotationalPayoutService.ConfirmPayoutPaidAsync(
            RotationalPayoutTask.Id,
            currentUserId,
            new ConfirmPayoutPaidRequest(
                rotationalPayoutPaymentMethod,
                rotationalPayoutPaymentReference,
                rotationalPayoutPaidAt,
                rotationalPayoutNotes));
        isConfirmingRotationalPayout = false;

        if (!result.Success)
        {
            rotationalPayoutErrors = result.Errors;
            return;
        }

        rotationalPayoutSuccessMessage = "Rotational payout marked as paid.";
        showRotationalPayoutPaymentForm = false;
        rotationalTaskState = await RotationalTaskService.GetTaskStateAsync(StokvelId);
        recentRotationalPayoutActivity = await RotationalPayoutService.GetRecentPaidPayoutsAsync(StokvelId, 10);
    }

    private async Task BackfillPayoutAuditTrailAsync()
    {
        payoutAuditBackfillMessage = null;

        if (!canManagePayments || loggedInTreasurerMemberId is null)
        {
            return;
        }

        isBackfillingPayoutAudits = true;
        var addedCount = await FuneralClaimService.BackfillMissingPayoutAuditsAsync(StokvelId, loggedInTreasurerMemberId.Value);
        recentPayoutActivity = await FuneralClaimService.GetClaimPayoutAuditsByStokvelIdAsync(StokvelId, 10);
        payoutAuditBackfillMessage = addedCount == 0
            ? "No missing payout audit records were found."
            : $"{addedCount} payout audit record{(addedCount == 1 ? string.Empty : "s")} backfilled.";
        isBackfillingPayoutAudits = false;
    }

    private static string FormatZAR(decimal amount) =>
        amount.ToString("C0", new System.Globalization.CultureInfo("en-ZA"));

    private static string FormatZAR(decimal? amount) =>
        amount?.ToString("C0", new System.Globalization.CultureInfo("en-ZA")) ?? "-";

    private static string DisplayOrDash(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string GetClaimReference(ClaimPayoutAudit audit)
    {
        return audit.FuneralClaim is not null && !string.IsNullOrWhiteSpace(audit.FuneralClaim.ClaimReference)
            ? audit.FuneralClaim.ClaimReference
            : $"CLM-{audit.FuneralClaimId.ToString("N")[..8].ToUpperInvariant()}";
    }

    private static string GetClaimReference(FuneralClaim claim)
    {
        return string.IsNullOrWhiteSpace(claim.ClaimReference)
            ? $"CLM-{claim.Id.ToString("N")[..8].ToUpperInvariant()}"
            : claim.ClaimReference;
    }

    private string? payoutAuditBackfillMessage;
}
