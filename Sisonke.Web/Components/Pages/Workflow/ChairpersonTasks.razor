@page "/chairperson-tasks/{StokvelId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccessService MemberAccessService
@inject FuneralClaimService FuneralClaimService
@inject MeetingService MeetingService
@inject RotationalTaskService RotationalTaskService
@inject RotationalPayoutService RotationalPayoutService
@inject NavigationManager NavigationManager

<PageTitle>Chairperson Approval Tasks</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading chairperson tasks...
    </div>
}
else if (!canViewChairpersonTasks)
{
    <div class="d-flex flex-column gap-3">
        <AlertBanner
            Type="warning"
            Title="You do not have access to the chairperson approval tasks for this stokvel."
            Message=""
            Icon="bi bi-exclamation-triangle-fill" />

        <div>
            <a class="sisonke-btn sisonke-btn-outline" href="/my-workspace">
                <i class="bi bi-arrow-left me-1"></i>Back to My Workspace
            </a>
        </div>
    </div>
}
else
{
    <section class="sisonke-hero-card mb-4">
        <div>
            <span class="sisonke-badge sisonke-badge-gold">Approvals</span>
            <h1>Chairperson Approval Tasks</h1>
            <p>Review claims and decisions awaiting final approval.</p>
        </div>
        <div class="chairperson-tasks-hero-meta">
            <div>
                <span>Claims awaiting approval</span>
                <strong>@claimsAwaitingApproval.Count</strong>
            </div>
            <div>
                <span>Minutes awaiting approval</span>
                <strong>@minutesAwaitingApprovalCount</strong>
            </div>
            <div>
                <span>Rotational payouts</span>
                <strong>@RotationalApprovalTaskCount</strong>
            </div>
        </div>
    </section>

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a class="sisonke-btn sisonke-btn-outline" href="@DashboardHref">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
        @if (canViewSecretaryTasks)
        {
            <a class="sisonke-btn sisonke-btn-primary" href="@SecretaryTasksHref">
                <i class="bi bi-list-check me-1"></i>Open Secretary Tasks
            </a>
        }
    </div>

    <div class="sisonke-grid sisonke-grid-2">
    <section class="sisonke-card">
        <div class="sisonke-card-head">
            <div>
                <h2>Claims Awaiting Approval</h2>
                <p>Secretary-reviewed claims ready for chairperson decision.</p>
            </div>
            <span class="sisonke-badge sisonke-badge-blue">@claimsAwaitingApproval.Count</span>
        </div>
        <div class="sisonke-card-body">
            @if (claimsAwaitingApproval.Count == 0)
            {
                <div class="sisonke-alert sisonke-alert-green mb-0">
                    No claims are currently awaiting chairperson approval.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="sisonke-table mb-0">
                        <thead>
                            <tr>
                                <th>Claim</th>
                                <th>Member</th>
                                <th>Subject</th>
                                <th>Date Submitted</th>
                                <th>Secretary Review</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var claim in claimsAwaitingApproval)
                            {
                                <tr>
                                    <td class="fw-semibold">@GetClaimReference(claim)</td>
                                    <td>@DisplayOrDash(claim.Member?.FullName)</td>
                                    <td>
                                        <div>@claim.SubjectType</div>
                                        <div class="text-muted small">@DisplayOrDash(claim.DeceasedFullName)</div>
                                    </td>
                                    <td>@(claim.SubmittedAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "-")</td>
                                    <td>
                                        <div><span class="sisonke-badge sisonke-badge-green">Complete</span></div>
                                        <div class="text-muted small mt-1">@DisplayOrDash(claim.SecretaryReviewNotes)</div>
                                    </td>
                                    <td><span class="@GetClaimStatusBadgeClass(claim.Status.ToString())">@claim.Status</span></td>
                                    <td class="text-end">
                                        <a class="sisonke-btn sisonke-btn-primary" href="@($"/claim/{claim.Id}")">
                                            Open Claim
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>

    <section class="sisonke-card">
        <div class="sisonke-card-head">
            <div>
                <h2>Rotational Payout Approval</h2>
                <p>Secretary-reviewed rotational payouts ready for chairperson decision.</p>
            </div>
            <span class="sisonke-badge sisonke-badge-blue">@RotationalApprovalTaskCount</span>
        </div>
        <div class="sisonke-card-body">
            @if (!string.IsNullOrWhiteSpace(payoutDecisionSuccessMessage))
            {
                <div class="sisonke-alert sisonke-alert-green">
                    @payoutDecisionSuccessMessage
                </div>
            }
            @if (payoutDecisionErrors.Count > 0)
            {
                <div class="sisonke-alert sisonke-alert-red">
                    <ul class="mb-0 ps-3">
                        @foreach (var error in payoutDecisionErrors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }
            @if (rotationalTaskState?.PendingApprovalPayout is null)
            {
                <div class="sisonke-alert sisonke-alert-green mb-0">
                    No rotational payouts are currently awaiting chairperson approval.
                </div>
            }
            else
            {
                var payout = rotationalTaskState.PendingApprovalPayout;
                <div class="table-responsive">
                    <table class="sisonke-table mb-0">
                        <thead>
                            <tr>
                                <th>Cycle</th>
                                <th>Payout Member</th>
                                <th>Amount</th>
                                <th>Secretary Review</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="fw-semibold">@payout.Cycle.CycleName</td>
                                <td>@DisplayOrDash(payout.PayoutMember.FullName)</td>
                                <td>@FormatZAR(payout.PayoutAmount)</td>
                                <td><span class="sisonke-badge sisonke-badge-green">Complete</span></td>
                                <td><span class="sisonke-badge sisonke-badge-gold">Awaiting approval</span></td>
                                <td>
                                    <div class="payout-decision-form">
                                        <label class="visually-hidden" for="payout-decision">Payout decision</label>
                                        <select id="payout-decision" class="form-select form-select-sm" @bind="payoutDecision">
                                            <option value="@RotationalPayoutDecision.Approve">Approve payout</option>
                                            <option value="@RotationalPayoutDecision.Reject">Reject payout</option>
                                            <option value="@RotationalPayoutDecision.RequestChanges">Send back to Secretary / Request changes</option>
                                        </select>
                                        <label class="visually-hidden" for="payout-decision-notes">Decision notes</label>
                                        <textarea id="payout-decision-notes"
                                                  class="form-control form-control-sm"
                                                  rows="2"
                                                  @bind="payoutDecisionNotes"
                                                  placeholder="@PayoutDecisionNotesPlaceholder"></textarea>
                                        <button class="sisonke-btn sisonke-btn-primary sisonke-btn-sm"
                                                type="button"
                                                disabled="@(!CanSubmitPayoutDecision)"
                                                @onclick="SubmitPayoutDecisionAsync">
                                            Submit Decision
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>

    <section class="sisonke-card">
        <div class="sisonke-card-head">
            <div>
                <h2>Minutes Awaiting Approval</h2>
                <p>Submitted meeting minutes ready for chairperson review.</p>
            </div>
            <span class="sisonke-badge sisonke-badge-gold">@minutesAwaitingApprovalCount</span>
        </div>
        <div class="sisonke-card-body">
            @if (minutesAwaitingApprovalCount == 0)
            {
                <div class="sisonke-alert sisonke-alert-green mb-0">
                    No meeting minutes are currently awaiting approval.
                </div>
            }
            else
            {
                <p class="text-muted">There are @minutesAwaitingApprovalCount submitted meeting minute(s) awaiting approval.</p>
                <a class="sisonke-btn sisonke-btn-gold" href="@MeetingsHref">Open Meetings</a>
            }
        </div>
    </section>
    </div>
}

<style>
    .chairperson-tasks-hero-meta {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: .75rem;
        min-width: min(18rem, 100%);
    }

    .chairperson-tasks-hero-meta div {
        background: rgb(255 255 255 / .12);
        border: 1px solid rgb(255 255 255 / .2);
        border-radius: var(--r-md);
        padding: .85rem 1rem;
    }

    .chairperson-tasks-hero-meta span {
        display: block;
        color: rgb(255 255 255 / .72);
        font-size: .72rem;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .chairperson-tasks-hero-meta strong {
        color: #fff;
        font-size: 1.8rem;
        line-height: 1.1;
    }

    .payout-decision-form {
        display: grid;
        grid-template-columns: minmax(13rem, 1fr);
        gap: .45rem;
        min-width: min(22rem, 100%);
    }
</style>

@code {
    private List<FuneralClaim> claimsAwaitingApproval = [];
    private int minutesAwaitingApprovalCount;
    private RotationalTaskState? rotationalTaskState;
    private bool isLoading = true;
    private bool canViewChairpersonTasks;
    private bool canViewSecretaryTasks;
    private bool isSubmittingPayoutDecision;
    private string? currentUserId;
    private string? payoutDecisionNotes;
    private string? payoutDecisionSuccessMessage;
    private List<string> payoutDecisionErrors = [];
    private RotationalPayoutDecision payoutDecision = RotationalPayoutDecision.Approve;
    private int RotationalApprovalTaskCount => rotationalTaskState?.PendingApprovalPayout is not null ? 1 : 0;
    private string DashboardHref => $"/stokvel-dashboard/{StokvelId}";
    private string SecretaryTasksHref => $"/secretary-tasks/{StokvelId}";
    private string MeetingsHref => $"/meetings/{StokvelId}";
    private string PayoutDecisionNotesPlaceholder => payoutDecision == RotationalPayoutDecision.Approve
        ? "Decision notes (optional)"
        : "Notes required";
    private bool CanSubmitPayoutDecision =>
        !isSubmittingPayoutDecision &&
        (payoutDecision == RotationalPayoutDecision.Approve || !string.IsNullOrWhiteSpace(payoutDecisionNotes));

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        claimsAwaitingApproval = [];
        minutesAwaitingApprovalCount = 0;
        rotationalTaskState = null;
        canViewChairpersonTasks = false;
        canViewSecretaryTasks = false;
        payoutDecisionErrors = [];
        payoutDecisionSuccessMessage = null;
        payoutDecisionNotes = null;
        payoutDecision = RotationalPayoutDecision.Approve;
        currentUserId = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
        currentUserId = userId;

        if (string.IsNullOrWhiteSpace(userId))
        {
            isLoading = false;
            return;
        }

        canViewChairpersonTasks = await MemberAccessService.CanViewChairpersonTasksAsync(userId, StokvelId);
        canViewSecretaryTasks = await MemberAccessService.CanViewSecretaryTasksAsync(userId, StokvelId);

        if (!canViewChairpersonTasks)
        {
            isLoading = false;
            return;
        }

        claimsAwaitingApproval = await FuneralClaimService.GetClaimsRequiringChairpersonApprovalByStokvelIdAsync(StokvelId);
        minutesAwaitingApprovalCount = await MeetingService.GetMinutesAwaitingApprovalCountByStokvelIdAsync(StokvelId);
        rotationalTaskState = await RotationalTaskService.GetTaskStateAsync(StokvelId);
        isLoading = false;
    }

    private async Task SubmitPayoutDecisionAsync()
    {
        payoutDecisionErrors = [];
        payoutDecisionSuccessMessage = null;

        if (rotationalTaskState?.PendingApprovalPayout is null || string.IsNullOrWhiteSpace(currentUserId))
        {
            payoutDecisionErrors = ["No payout is available for decision."];
            return;
        }

        if (payoutDecision != RotationalPayoutDecision.Approve && string.IsNullOrWhiteSpace(payoutDecisionNotes))
        {
            payoutDecisionErrors = ["Decision notes are required for reject or request changes."];
            return;
        }

        isSubmittingPayoutDecision = true;
        var result = await RotationalPayoutService.SubmitChairpersonDecisionAsync(
            rotationalTaskState.PendingApprovalPayout.Id,
            currentUserId,
            payoutDecision,
            payoutDecisionNotes);
        isSubmittingPayoutDecision = false;

        if (!result.Success)
        {
            payoutDecisionErrors = result.Errors;
            return;
        }

        payoutDecisionSuccessMessage = payoutDecision switch
        {
            RotationalPayoutDecision.Approve => "Payout approved. Treasurer payment is still required.",
            RotationalPayoutDecision.Reject => "Payout rejected.",
            RotationalPayoutDecision.RequestChanges => "Payout sent back to the Secretary for changes.",
            _ => "Payout decision submitted."
        };
        payoutDecisionNotes = null;
        payoutDecision = RotationalPayoutDecision.Approve;
        rotationalTaskState = await RotationalTaskService.GetTaskStateAsync(StokvelId);
    }

    private static string DisplayOrDash(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string GetClaimReference(FuneralClaim claim)
    {
        return string.IsNullOrWhiteSpace(claim.ClaimReference)
            ? $"CLM-{claim.Id.ToString("N")[..8].ToUpperInvariant()}"
            : claim.ClaimReference;
    }

    private static string GetClaimStatusBadgeClass(string status)
    {
        return status switch
        {
            "Submitted" => "sisonke-badge sisonke-badge-blue",
            "UnderReview" => "sisonke-badge sisonke-badge-teal",
            "OnHold" => "sisonke-badge sisonke-badge-gold",
            "Approved" => "sisonke-badge sisonke-badge-green",
            "Rejected" => "sisonke-badge sisonke-badge-red",
            "Paid" => "sisonke-badge sisonke-badge-green",
            _ => "sisonke-badge sisonke-badge-gray"
        };
    }

    private static string FormatZAR(decimal amount) =>
        amount.ToString("C0", new System.Globalization.CultureInfo("en-ZA"));
}
