@page "/secretary-tasks/{StokvelId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccessService MemberAccessService
@inject MeetingApologyService MeetingApologyService
@inject MemberWarningService MemberWarningService
@inject FuneralClaimService FuneralClaimService
@inject MeetingService MeetingService
@inject StokvelService StokvelService
@inject NavigationManager NavigationManager

<PageTitle>Secretary Task List</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading secretary tasks...
    </div>
}
else if (!canViewSecretaryTasks)
{
    <div class="d-flex flex-column gap-3">
        <AlertBanner
            Type="warning"
            Title="You do not have access to the secretary task list for this stokvel."
            Message=""
            Icon="bi bi-exclamation-triangle-fill" />

        <div>
            <a class="sisonke-btn sisonke-btn-outline" href="/my-workspace">
                <i class="bi bi-arrow-left me-1"></i>Back to My Workspace
            </a>
        </div>
    </div>
}
else
{
    <section class="sisonke-hero-card mb-4">
        <div>
            <span class="sisonke-badge sisonke-badge-gold">Workflow</span>
            <h1>Secretary Task List</h1>
            <p>Review apologies, claims, attendance and meeting administration tasks.</p>
            <div class="secretary-tasks-hero-context">
                @if (stokvel is not null)
                {
                    <span class="sisonke-badge sisonke-badge-green">@stokvel.Name</span>
                }
                @if (linkedMember is not null)
                {
                    <span class="sisonke-badge sisonke-badge-blue">@linkedMember.DefaultRole</span>
                }
            </div>
        </div>
        <div class="secretary-tasks-hero-meta">
            <div>
                <span>Pending apologies</span>
                <strong>@pendingApologies.Count</strong>
            </div>
            <div>
                <span>Claims to review</span>
                <strong>@claimsToReview.Count</strong>
            </div>
            <div>
                <span>Attendance to capture</span>
                <strong>@attendanceToCaptureCount</strong>
            </div>
            <div>
                <span>Open warnings</span>
                <strong>@openWarningCount</strong>
            </div>
            <div>
                <span>Minutes pending</span>
                <strong>@minutesToCompleteCount</strong>
            </div>
        </div>
    </section>

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a class="sisonke-btn sisonke-btn-outline" href="@DashboardHref">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
        <a class="sisonke-btn sisonke-btn-primary" href="@MeetingsHref">
            <i class="bi bi-calendar-event me-1"></i>Open Meetings
        </a>
    </div>

    @if (!HasPendingTasks)
    {
        <div class="sisonke-alert sisonke-alert-green mb-4">
            No pending secretary tasks. Everything is up to date.
        </div>
    }

    <div class="sisonke-grid sisonke-grid-2 secretary-task-page-grid">
        <section class="sisonke-card">
            <div class="sisonke-card-head">
                <div>
                    <h2>Pending Apologies</h2>
                    <p>Submitted meeting apologies awaiting attendance review.</p>
                </div>
                <span class="sisonke-badge sisonke-badge-blue">@pendingApologies.Count</span>
            </div>
            <div class="sisonke-card-body">
                @if (pendingApologies.Count == 0)
                {
                    <div class="sisonke-alert sisonke-alert-green mb-0">No pending apologies.</div>
                }
                else
                {
                    <div class="secretary-task-list">
                        @foreach (var apology in pendingApologies)
                        {
                            <article class="secretary-task-item">
                                <div class="secretary-task-item-head">
                                    <div>
                                        <h3>@DisplayOrDash(apology.Meeting?.Title ?? apology.Meeting?.Purpose)</h3>
                                        <p>@(apology.Meeting?.MeetingDate.ToString("dd MMM yyyy HH:mm") ?? "-")</p>
                                    </div>
                                    <span class="sisonke-badge sisonke-badge-gold">@DisplayOrDash(apology.Status)</span>
                                </div>
                                <dl class="secretary-task-dl">
                                    <div><dt>Member</dt><dd>@DisplayOrDash(apology.Member?.FullName)</dd></div>
                                    <div><dt>Apology Type</dt><dd>@DisplayApologyType(apology.ApologyType)</dd></div>
                                    <div><dt>Reason</dt><dd>@DisplayOrDash(apology.Reason)</dd></div>
                                    <div><dt>Submitted At</dt><dd>@apology.SubmittedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</dd></div>
                                </dl>
                                @if (apology.Meeting is not null)
                                {
                                    <div class="d-flex flex-wrap gap-2">
                                        <a class="sisonke-btn sisonke-btn-primary" href="@($"/meeting-attendance/{apology.MeetingId}")">
                                            Open Attendance
                                        </a>
                                        <a class="sisonke-btn sisonke-btn-outline" href="@($"/meeting/{apology.MeetingId}")">
                                            Open Meeting
                                        </a>
                                    </div>
                                }
                            </article>
                        }
                    </div>
                }
            </div>
        </section>

        <section class="sisonke-card">
            <div class="sisonke-card-head">
                <div>
                    <h2>Claims to Review</h2>
                    <p>Claims submitted or on hold that still need secretary review.</p>
                </div>
                <span class="sisonke-badge sisonke-badge-blue">@claimsToReview.Count</span>
            </div>
            <div class="sisonke-card-body">
                @if (claimsToReview.Count == 0)
                {
                    <div class="sisonke-alert sisonke-alert-green mb-0">No claims require secretary review.</div>
                }
                else
                {
                    <div class="secretary-task-list">
                        @foreach (var claim in claimsToReview)
                        {
                            <article class="secretary-task-item">
                                <div class="secretary-task-item-head">
                                    <div>
                                        <h3>@GetClaimReference(claim)</h3>
                                        <p>@DisplayOrDash(claim.Member?.FullName)</p>
                                    </div>
                                    <span class="@GetClaimStatusBadgeClass(claim.Status.ToString())">@claim.Status</span>
                                </div>
                                <dl class="secretary-task-dl">
                                    <div><dt>Subject</dt><dd>@claim.SubjectType</dd></div>
                                    <div><dt>Deceased Person</dt><dd>@DisplayOrDash(claim.DeceasedFullName)</dd></div>
                                    <div><dt>Date Submitted</dt><dd>@(claim.SubmittedAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "-")</dd></div>
                                    <div><dt>Status</dt><dd>@claim.Status</dd></div>
                                </dl>
                                <a class="sisonke-btn sisonke-btn-primary" href="@($"/claim/{claim.Id}")">
                                    Review Claim
                                </a>
                            </article>
                        }
                    </div>
                }
            </div>
        </section>

        <section class="sisonke-card">
            <div class="sisonke-card-head">
                <div>
                    <h2>Attendance to Capture</h2>
                    <p>Recent meetings where attendance appears uncaptured.</p>
                </div>
                <span class="sisonke-badge sisonke-badge-gold">@attendanceToCaptureCount</span>
            </div>
            <div class="sisonke-card-body">
                @if (attendanceToCaptureCount == 0)
                {
                    <div class="sisonke-alert sisonke-alert-green mb-0">No attendance capture tasks are currently pending.</div>
                }
                else
                {
                    <p class="text-muted">There are @attendanceToCaptureCount meeting(s) where attendance may still need to be captured.</p>
                    <a class="sisonke-btn sisonke-btn-gold" href="@MeetingsHref">Capture Attendance</a>
                }
            </div>
        </section>

        <section class="sisonke-card">
            <div class="sisonke-card-head">
                <div>
                    <h2>Attendance Warnings</h2>
                    <p>Open member warnings generated from absences without apology.</p>
                </div>
                <span class="sisonke-badge sisonke-badge-gold">@openWarningCount</span>
            </div>
            <div class="sisonke-card-body">
                @if (openWarningCount == 0)
                {
                    <div class="sisonke-alert sisonke-alert-green mb-0">No attendance warnings are currently open.</div>
                }
                else
                {
                    <p class="text-muted">There are @openWarningCount open attendance warning(s) requiring review.</p>
                    <a class="sisonke-btn sisonke-btn-gold" href="@($"/member-warnings/{StokvelId}")">Review Warnings</a>
                }
            </div>
        </section>

        <section class="sisonke-card">
            <div class="sisonke-card-head">
                <div>
                    <h2>Minutes to Complete</h2>
                    <p>Meetings with no minutes yet or minutes still in draft.</p>
                </div>
                <span class="sisonke-badge sisonke-badge-gold">@minutesToCompleteCount</span>
            </div>
            <div class="sisonke-card-body">
                @if (minutesToCompleteCount == 0)
                {
                    <div class="sisonke-alert sisonke-alert-green mb-0">No meeting minutes tasks are currently pending.</div>
                }
                else
                {
                    <p class="text-muted">There are @minutesToCompleteCount meeting minutes task(s) pending.</p>
                    <a class="sisonke-btn sisonke-btn-gold" href="@MeetingsHref">Open Meetings</a>
                }
            </div>
        </section>
    </div>
}

<style>
    .secretary-tasks-hero-meta {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: .75rem;
        min-width: min(28rem, 100%);
    }

    .secretary-tasks-hero-context {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
        margin-top: .9rem;
    }

    .secretary-tasks-hero-meta div {
        background: rgb(255 255 255 / .12);
        border: 1px solid rgb(255 255 255 / .2);
        border-radius: var(--r-md);
        padding: .85rem 1rem;
    }

    .secretary-tasks-hero-meta span {
        display: block;
        color: rgb(255 255 255 / .72);
        font-size: .72rem;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .secretary-tasks-hero-meta strong {
        color: #fff;
        font-size: 1.8rem;
        line-height: 1.1;
    }

    .secretary-task-page-grid {
        align-items: start;
    }

    .secretary-task-list {
        display: grid;
        gap: 1rem;
    }

    .secretary-task-item {
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        padding: 1rem;
        background: var(--cream);
    }

    .secretary-task-item-head {
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: .85rem;
    }

    .secretary-task-item-head h3 {
        color: var(--text);
        font-size: 1rem;
        font-weight: 800;
        margin: 0;
    }

    .secretary-task-item-head p {
        color: var(--muted);
        font-size: .86rem;
        margin: .2rem 0 0;
    }

    .secretary-task-dl {
        display: grid;
        gap: .45rem;
        margin: 0 0 1rem;
    }

    .secretary-task-dl div {
        display: grid;
        grid-template-columns: 9rem 1fr;
        gap: .75rem;
        font-size: .88rem;
    }

    .secretary-task-dl dt {
        color: var(--muted);
        font-weight: 600;
    }

    .secretary-task-dl dd {
        color: var(--text);
        margin: 0;
    }

    @@media (max-width: 760px) {
        .secretary-tasks-hero-meta,
        .secretary-task-dl div {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private Stokvel? stokvel;
    private Member? linkedMember;
    private List<MeetingApology> pendingApologies = [];
    private List<FuneralClaim> claimsToReview = [];
    private int attendanceToCaptureCount;
    private int minutesToCompleteCount;
    private int openWarningCount;
    private bool isLoading = true;
    private bool canViewSecretaryTasks;
    private bool HasPendingTasks =>
        pendingApologies.Count > 0 ||
        claimsToReview.Count > 0 ||
        attendanceToCaptureCount > 0 ||
        openWarningCount > 0 ||
        minutesToCompleteCount > 0;
    private string DashboardHref => $"/stokvel-dashboard/{StokvelId}";
    private string MeetingsHref => $"/meetings/{StokvelId}";

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        pendingApologies = [];
        claimsToReview = [];
        stokvel = null;
        linkedMember = null;
        attendanceToCaptureCount = 0;
        minutesToCompleteCount = 0;
        openWarningCount = 0;
        canViewSecretaryTasks = false;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            isLoading = false;
            return;
        }

        canViewSecretaryTasks = await MemberAccessService.CanViewSecretaryTasksAsync(userId, StokvelId);
        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);
        linkedMember = await MemberAccessService.GetLinkedMemberForUserAsync(userId, StokvelId);

        if (!canViewSecretaryTasks)
        {
            isLoading = false;
            return;
        }

        pendingApologies = await MeetingApologyService.GetPendingApologiesByStokvelIdAsync(StokvelId);
        claimsToReview = await FuneralClaimService.GetClaimsRequiringSecretaryReviewByStokvelIdAsync(StokvelId);
        attendanceToCaptureCount = await MeetingService.GetMeetingsNeedingAttendanceCountByStokvelIdAsync(StokvelId);
        openWarningCount = (await MemberWarningService.GetOpenWarningsByStokvelIdAsync(StokvelId)).Count;
        minutesToCompleteCount = await MeetingService.GetMeetingsNeedingMinutesCountByStokvelIdAsync(StokvelId);
        isLoading = false;
    }

    private static string DisplayOrDash(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string DisplayApologyType(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not specified" : value;
    }

    private static string GetClaimReference(FuneralClaim claim)
    {
        return $"CLM-{claim.Id.ToString("N")[..8].ToUpperInvariant()}";
    }

    private static string GetClaimStatusBadgeClass(string status)
    {
        return status switch
        {
            "Submitted" => "sisonke-badge sisonke-badge-blue",
            "UnderReview" => "sisonke-badge sisonke-badge-teal",
            "OnHold" => "sisonke-badge sisonke-badge-gold",
            "Approved" => "sisonke-badge sisonke-badge-green",
            "Rejected" => "sisonke-badge sisonke-badge-red",
            "Paid" => "sisonke-badge sisonke-badge-green",
            _ => "sisonke-badge sisonke-badge-gray"
        };
    }
}
