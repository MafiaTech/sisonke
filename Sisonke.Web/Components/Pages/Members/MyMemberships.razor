@page "/my-memberships"
@rendermode InteractiveServer
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using System.Security.Claims
@using Sisonke.Web.Data
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject MemberAccountLinkingService MemberAccountLinkingService
@inject MemberAccessService MemberAccessService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject StokvelService StokvelService
@inject NavigationManager NavigationManager

<PageTitle>My Memberships</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading your memberships...
    </div>
}
else if (!isLoggedIn)
{
    <AlertBanner
        Type="warning"
        Title="Please sign in to view your memberships."
        Message=""
        Icon="bi bi-exclamation-triangle-fill" />
}
else
{
    <PageHeader
        Title="My Memberships"
        Subtitle="Memberships linked to your registered ID number"
        BackText="Dashboard"
        BackHref="/" />

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <AlertBanner Type="success" Title="@successMessage" Message="" Icon="bi bi-check-circle-fill" />
    }

    @if (currentUser is not null && string.IsNullOrWhiteSpace(currentUser.IdNumber))
    {
        <AlertBanner
            Type="warning"
            Title="Your ID number is not captured on your user profile. Please update your profile or contact support."
            Message=""
            Icon="bi bi-exclamation-triangle-fill" />
    }

    @if (currentUser is not null)
    {
        <div class="card mb-3">
            <div class="card-body p-4">
                <div class="card-section-title">Registered User Details</div>
                <div class="membership-user-grid">
                    <div>
                        <div class="membership-detail-label">Full Name</div>
                        <div class="membership-detail-value">@(currentUser.FullName ?? "-")</div>
                    </div>
                    <div>
                        <div class="membership-detail-label">ID Number</div>
                        <div class="membership-detail-value">@(currentUser.IdNumber ?? "-")</div>
                    </div>
                    <div>
                        <div class="membership-detail-label">Cellphone Number</div>
                        <div class="membership-detail-value">@(currentUser.CellphoneNumber ?? "-")</div>
                    </div>
                    <div>
                        <div class="membership-detail-label">Residential Area</div>
                        <div class="membership-detail-value">@(currentUser.ResidentialArea ?? "-")</div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="d-flex justify-content-end mb-3">
        <button class="btn btn-primary btn-sm" type="button" @onclick="RefreshLinkedMembershipsAsync">
            <i class="bi bi-arrow-clockwise me-1"></i>Refresh Linked Memberships
        </button>
    </div>

    @if (memberships.Count == 0)
    {
        <div class="ms-empty-state">
            <div class="ms-empty-icon-ring">
                <i class="bi bi-person-vcard" aria-hidden="true"></i>
            </div>
            <h2 class="ms-empty-title">No linked memberships found yet.</h2>
            <p class="ms-empty-text">Make sure your ID number matches the one captured by your stokvel secretary.</p>
        </div>
    }
    else
    {
        <div class="membership-card-grid">
            @foreach (var member in memberships)
            {
                var stokvel = GetStokvelForMember(member);
                var isOfficeBearer = officeBearerMemberIds.Contains(member.Id);
                <div class="card membership-card">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between gap-3 align-items-start mb-3">
                            <div>
                                <div class="membership-detail-label">Stokvel</div>
                                <h2 class="membership-card-title">@(stokvel?.Name ?? member.Tenant.Name)</h2>
                            </div>
                            <StatusBadge Text="@member.Status.ToString()" Type="@GetMemberStatusBadgeType(member)" />
                        </div>

                        <div class="membership-card-details">
                            <div>
                                <div class="membership-detail-label">Member</div>
                                <div class="membership-detail-value">@member.FullName</div>
                            </div>
                            <div>
                                <div class="membership-detail-label">Member Number</div>
                                <div class="membership-detail-value">@member.MemberNumber</div>
                            </div>
                            <div>
                                <div class="membership-detail-label">Role</div>
                                <div class="membership-detail-value">@member.DefaultRole</div>
                            </div>
                            <div>
                                <div class="membership-detail-label">Access Type</div>
                                <div class="membership-detail-value">@(isOfficeBearer ? "Office Bearer" : "Member")</div>
                            </div>
                        </div>

                        <div class="membership-card-actions mt-4">
                            @if (isOfficeBearer && stokvel is not null)
                            {
                                <a class="btn btn-sm btn-primary" href="@($"/stokvel-dashboard/{stokvel.Id}")">
                                    Open Management Dashboard
                                </a>
                            }
                            else
                            {
                                <a class="btn btn-sm btn-primary" href="@($"/member-home/{member.Id}")">
                                    Open My Member View
                                </a>
                            }
                            <a class="btn btn-sm btn-outline-primary" href="@($"/member-profile/{member.Id}")">
                                View Profile
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

<style>
    .fw-600 { font-weight: 600; }
    .membership-user-grid,
    .membership-card-details {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .membership-card-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    }
    .membership-card {
        height: 100%;
    }
    .membership-card-title {
        color: var(--sk-text);
        font-size: 1.125rem;
        font-weight: 800;
        margin: .15rem 0 0;
    }
    .membership-detail-label {
        color: var(--sk-text-muted);
        font-size: .7rem;
        font-weight: 800;
        letter-spacing: .07em;
        text-transform: uppercase;
    }
    .membership-detail-value {
        color: var(--sk-text);
        font-size: .925rem;
        font-weight: 600;
        margin-top: .2rem;
        overflow-wrap: anywhere;
    }
    .membership-card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
    }
    @@media (max-width: 640px) {
        .membership-user-grid,
        .membership-card-details {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private List<Member> memberships = [];
    private Dictionary<Guid, Stokvel> stokvelsByTenantId = new();
    private HashSet<Guid> officeBearerMemberIds = [];
    private ApplicationUser? currentUser;
    private string? userId;
    private string? successMessage;
    private bool isLoading = true;
    private bool isLoggedIn;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isLoggedIn = user.Identity?.IsAuthenticated == true;

        if (isLoggedIn)
        {
            userId = user.FindFirstValue(ClaimTypes.NameIdentifier);
            currentUser = await UserManager.GetUserAsync(user);
            memberships = string.IsNullOrWhiteSpace(userId)
                ? []
                : await MemberAccountLinkingService.GetMembershipsForUserAsync(userId);
            await LoadMembershipAccessAsync();
        }

        isLoading = false;
    }

    private async Task RefreshLinkedMembershipsAsync()
    {
        successMessage = null;

        if (string.IsNullOrWhiteSpace(userId) || currentUser is null)
        {
            return;
        }

        await MemberAccountLinkingService.RefreshUserMembershipLinksAsync(userId, currentUser.IdNumber);
        memberships = await MemberAccountLinkingService.GetMembershipsForUserAsync(userId);
        await LoadMembershipAccessAsync();
        successMessage = "Membership links refreshed.";
    }

    private async Task LoadMembershipAccessAsync()
    {
        stokvelsByTenantId = new();
        officeBearerMemberIds = [];

        if (string.IsNullOrWhiteSpace(userId))
        {
            return;
        }

        foreach (var tenantId in memberships.Select(member => member.TenantId).Distinct())
        {
            var stokvel = await StokvelService.GetStokvelByTenantIdAsync(tenantId);

            if (stokvel is null)
            {
                continue;
            }

            stokvelsByTenantId[tenantId] = stokvel;
        }

        foreach (var member in memberships)
        {
            var stokvel = GetStokvelForMember(member);

            if (stokvel is not null && await MemberAccessService.IsOfficeBearerAsync(userId, stokvel.Id))
            {
                officeBearerMemberIds.Add(member.Id);
            }
        }
    }

    private Stokvel? GetStokvelForMember(Member member)
    {
        return stokvelsByTenantId.TryGetValue(member.TenantId, out var stokvel)
            ? stokvel
            : null;
    }

    private static string GetMemberStatusBadgeType(Member member) =>
        member.Status.ToString() switch
        {
            "Active" => "success",
            "Suspended" => "warning",
            _ => "secondary"
        };
}
