@page "/my-memberships"
@rendermode InteractiveServer
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using Sisonke.Web.Data
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IServiceScopeFactory ScopeFactory
@inject MemberAccountLinkingService MemberAccountLinkingService

<PageTitle>My Memberships</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading your memberships...
    </div>
}
else if (!isLoggedIn)
{
    <AlertBanner
        Type="warning"
        Title="Please sign in to view your memberships."
        Message=""
        Icon="bi bi-exclamation-triangle-fill" />
}
else
{
    <section class="sisonke-hero-card mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-4 align-items-lg-end">
            <div>
                <p class="my-memberships-eyebrow">
                    Memberships linked to your Sisonke account.
                </p>
                <h1>My Memberships</h1>
                <p class="mt-3">@GetUserDisplayName()</p>
            </div>
            <div class="d-flex flex-wrap gap-2">
                <span class="sisonke-badge sisonke-badge-green">@memberships.Count linked</span>
                <span class="sisonke-badge sisonke-badge-gold">@officeBearerMemberIds.Count managed</span>
                <span class="sisonke-badge sisonke-badge-blue">@OrdinaryMembershipCount member</span>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <AlertBanner Type="success" Title="@successMessage" Message="" Icon="bi bi-check-circle-fill" />
    }

    @if (currentUser is not null && string.IsNullOrWhiteSpace(currentUser.IdNumber))
    {
        <AlertBanner
            Type="warning"
            Title="Your ID number is not captured on your user profile. Please update your profile or contact support."
            Message=""
            Icon="bi bi-exclamation-triangle-fill" />
    }

    @if (currentUser is not null)
    {
        <div class="sisonke-card mb-3">
            <div class="sisonke-card-head">
                <div class="d-flex align-items-center gap-2">
                    <div class="sisonke-card-icon">
                        <i class="bi bi-person-circle"></i>
                    </div>
                    <div class="card-section-title mb-0">Registered User Details</div>
                </div>
            </div>
            <div class="sisonke-card-body">
                <div class="sisonke-detail-grid">
                    <div>
                        <div class="sisonke-detail-label">Full Name</div>
                        <div class="sisonke-detail-value">@(currentUser.FullName ?? "-")</div>
                    </div>
                    <div>
                        <div class="sisonke-detail-label">Email</div>
                        <div class="sisonke-detail-value">@SensitiveDataMasker.MaskEmail(currentUser.Email)</div>
                    </div>
                    <div>
                        <div class="sisonke-detail-label">ID Number</div>
                        <div class="sisonke-detail-value">@SensitiveDataMasker.MaskIdNumber(currentUser.IdNumber)</div>
                    </div>
                    <div>
                        <div class="sisonke-detail-label">Cellphone Number</div>
                        <div class="sisonke-detail-value">@SensitiveDataMasker.MaskPhoneNumber(currentUser.CellphoneNumber)</div>
                    </div>
                    <div>
                        <div class="sisonke-detail-label">Residential Area</div>
                        <div class="sisonke-detail-value">@(currentUser.ResidentialArea ?? "-")</div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="d-flex justify-content-end mb-3">
        <button class="sisonke-btn sisonke-btn-primary" type="button" @onclick="RefreshLinkedMembershipsAsync">
            <i class="bi bi-arrow-clockwise me-1"></i>Refresh Linked Memberships
        </button>
    </div>

    @if (memberships.Count == 0)
    {
        <div class="sisonke-alert sisonke-alert-blue">
            <i class="bi bi-info-circle-fill mt-1"></i>
            <div>
                <strong>No linked memberships found yet.</strong>
                <div>Make sure your ID number matches the one captured by your stokvel secretary.</div>
            </div>
        </div>
    }
    else
    {
        <div class="sisonke-grid sisonke-grid-2">
            @foreach (var member in memberships)
            {
                var stokvel = GetStokvelForMember(member);
                var isOfficeBearer = officeBearerMemberIds.Contains(member.Id);
                var stokvelName = stokvel?.Name ?? member.Tenant?.Name ?? "Stokvel unavailable";
                <div class="sisonke-card membership-card">
                    <div class="sisonke-card-body">
                        <div class="d-flex justify-content-between gap-3 align-items-start mb-3">
                            <div>
                                <div class="sisonke-detail-label">Stokvel</div>
                                <h2 class="membership-card-title">@stokvelName</h2>
                                @if (stokvel is null)
                                {
                                    <div class="small text-warning mt-1">Stokvel unavailable</div>
                                }
                            </div>
                            <span class="@GetMemberStatusBadgeClass(member)">@member.Status</span>
                        </div>

                        <span class="@(isOfficeBearer ? "sisonke-badge sisonke-badge-gold" : "sisonke-badge sisonke-badge-green")">
                            @(isOfficeBearer ? "Office Bearer" : "Member")
                        </span>

                        <div class="membership-card-details">
                            <div>
                                <div class="sisonke-detail-label">Member</div>
                                <div class="sisonke-detail-value">@Display(member.FullName)</div>
                            </div>
                            <div>
                                <div class="sisonke-detail-label">Member Number</div>
                                <div class="sisonke-detail-value">@Display(member.MemberNumber)</div>
                            </div>
                            <div>
                                <div class="sisonke-detail-label">Role</div>
                                <div class="sisonke-detail-value">@member.DefaultRole</div>
                            </div>
                            <div>
                                <div class="sisonke-detail-label">Access Type</div>
                                <div class="sisonke-detail-value">@(isOfficeBearer ? "Office Bearer" : "Member")</div>
                            </div>
                        </div>

                        <div class="membership-card-actions mt-4">
                            @if (isOfficeBearer && stokvel is not null)
                            {
                                <a class="sisonke-btn sisonke-btn-primary" href="@($"/stokvel-dashboard/{stokvel.Id}")">
                                    Open Management Dashboard
                                </a>
                            }
                            else if (isOfficeBearer)
                            {
                                <button type="button" class="sisonke-btn sisonke-btn-outline" disabled>
                                    Management Dashboard Unavailable
                                </button>
                            }
                            <a class="sisonke-btn @(isOfficeBearer ? "sisonke-btn-outline" : "sisonke-btn-primary")" href="@($"/member-home/{member.Id}")">
                                Open My Member View
                            </a>
                            <a class="sisonke-btn sisonke-btn-outline" href="@($"/member-profile/{member.Id}")">
                                View Profile
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

<style>
    .fw-600 { font-weight: 600; }
    .membership-user-grid,
    .membership-card-details {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .membership-card-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    }
    .my-memberships-eyebrow {
        color: rgba(255, 255, 255, .68);
        font-size: .72rem;
        font-weight: 800;
        letter-spacing: .1em;
        margin-bottom: .5rem;
        text-transform: uppercase;
    }
    .membership-card {
        height: 100%;
    }
    .membership-card-title {
        color: var(--text);
        font-family: "Playfair Display", Georgia, "Times New Roman", serif;
        font-size: 1.18rem;
        font-weight: 700;
        letter-spacing: 0;
        line-height: 1.2;
        margin: .15rem 0 0;
    }
    .membership-detail-label {
        color: var(--muted);
        font-size: .7rem;
        font-weight: 800;
        letter-spacing: .07em;
        text-transform: uppercase;
    }
    .membership-detail-value {
        color: var(--text);
        font-size: .925rem;
        font-weight: 600;
        margin-top: .2rem;
        overflow-wrap: anywhere;
    }
    .membership-card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
    }
    @@media (max-width: 640px) {
        .membership-user-grid,
        .membership-card-details {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private List<Member> memberships = [];
    private Dictionary<Guid, Stokvel> stokvelsByTenantId = new();
    private HashSet<Guid> officeBearerMemberIds = [];
    private ApplicationUser? currentUser;
    private string? userId;
    private string? successMessage;
    private bool isLoading = true;
    private bool isLoggedIn;
    private int OrdinaryMembershipCount => Math.Max(0, memberships.Count - officeBearerMemberIds.Count);

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isLoggedIn = user.Identity?.IsAuthenticated == true;

        if (isLoggedIn)
        {
            userId = user.FindFirstValue(ClaimTypes.NameIdentifier);

            if (!string.IsNullOrWhiteSpace(userId))
            {
                currentUser = await LoadCurrentUserAsync(userId);
                memberships = await LoadMembershipsForUserAsync(userId, currentUser);
                await LoadMembershipAccessAsync();
            }
        }

        isLoading = false;
    }

    private async Task RefreshLinkedMembershipsAsync()
    {
        successMessage = null;

        if (string.IsNullOrWhiteSpace(userId) || currentUser is null)
        {
            return;
        }

        await MemberAccountLinkingService.RefreshUserMembershipLinksAsync(
            userId,
            currentUser.IdNumber,
            GetVerifiedEmailForFallback(currentUser));
        memberships = await LoadMembershipsForUserAsync(userId, currentUser);
        await LoadMembershipAccessAsync();
        successMessage = "Membership links refreshed.";
    }

    private async Task<ApplicationUser?> LoadCurrentUserAsync(string currentUserId)
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

        return await db.Users
            .AsNoTracking()
            .FirstOrDefaultAsync(user => user.Id == currentUserId);
    }

    private async Task<List<Member>> LoadMembershipsForUserAsync(string currentUserId, ApplicationUser? user)
    {
        return await MemberAccountLinkingService.GetMembershipsForUserAsync(
            currentUserId,
            user?.IdNumber,
            GetVerifiedEmailForFallback(user));
    }

    private async Task LoadMembershipAccessAsync()
    {
        stokvelsByTenantId = new();
        officeBearerMemberIds = [];

        if (string.IsNullOrWhiteSpace(userId))
        {
            return;
        }

        var tenantIds = memberships
            .Select(member => member.TenantId)
            .Distinct()
            .ToList();

        if (tenantIds.Count == 0)
        {
            return;
        }

        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

        var stokvels = await db.Stokvels
            .AsNoTracking()
            .Include(stokvel => stokvel.Tenant)
            .Where(stokvel => tenantIds.Contains(stokvel.TenantId) && stokvel.IsActive)
            .OrderBy(stokvel => stokvel.Name)
            .ToListAsync();

        stokvelsByTenantId = stokvels
            .GroupBy(stokvel => stokvel.TenantId)
            .ToDictionary(group => group.Key, group => group.First());

        foreach (var member in memberships)
        {
            var stokvel = GetStokvelForMember(member);

            if (stokvel is not null && IsOfficeBearerRole(member.DefaultRole.ToString()))
            {
                officeBearerMemberIds.Add(member.Id);
            }
        }
    }

    private Stokvel? GetStokvelForMember(Member member)
    {
        return stokvelsByTenantId.TryGetValue(member.TenantId, out var stokvel)
            ? stokvel
            : null;
    }

    private static string GetMemberStatusBadgeType(Member member) =>
        member.Status.ToString() switch
        {
            "Active" => "success",
            "Suspended" => "warning",
            _ => "secondary"
        };

    private static string GetMemberStatusBadgeClass(Member member) =>
        member.Status.ToString() switch
        {
            "Active" => "sisonke-badge sisonke-badge-green",
            "Suspended" => "sisonke-badge sisonke-badge-gold",
            "Deceased" => "sisonke-badge sisonke-badge-red",
            _ => "sisonke-badge sisonke-badge-gray"
        };

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not captured" : value;
    }

    private static bool IsOfficeBearerRole(string? role)
    {
        return role?.Trim().Equals("Chairperson", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("Secretary", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("Treasurer", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("Admin", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("StokvelAdmin", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("Creator", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("Office Bearer", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("OfficeBearer", StringComparison.OrdinalIgnoreCase) == true;
    }

    private string GetUserDisplayName()
    {
        return currentUser?.FullName ?? currentUser?.Email ?? "Your Sisonke account";
    }

    private static string? GetVerifiedEmailForFallback(ApplicationUser? user)
    {
        if (user?.EmailConfirmed != true)
        {
            return null;
        }

        return user.Email;
    }
}
