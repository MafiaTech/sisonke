@page "/add-dependent/{MemberId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject MemberService MemberService
@inject StokvelService StokvelService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccessService MemberAccessService
@inject NavigationManager NavigationManager

<PageTitle>Add Dependent</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading dependent form...
    </div>
}
else if (member is null)
{
    <AlertBanner Type="danger" Title="Member not found." Message="" Icon="bi bi-x-circle-fill" />
}
else if (!IsDependentsAvailable)
{
    <AlertBanner
        Type="warning"
        Title="Covered lives are not enabled for this stokvel type."
        Message="@GetDependentsDisabledMessage()"
        Icon="bi bi-exclamation-triangle-fill" />

    <a class="sisonke-btn sisonke-btn-outline" href="@($"/member-profile/{MemberId}")">
        <i class="bi bi-arrow-left me-2"></i>Back to Member Profile
    </a>
}
else if (!canManageDependents)
{
    <AlertBanner
        Type="warning"
        Title="You do not have permission to add dependents for this member."
        Message="Dependent records are managed by society office bearers."
        Icon="bi bi-exclamation-triangle-fill" />

    <a class="sisonke-btn sisonke-btn-outline" href="@($"/member-profile/{MemberId}")">
        <i class="bi bi-arrow-left me-2"></i>Back to Member Profile
    </a>
}
else
{
    <section class="sisonke-hero-card mb-4">
        <div>
            <span class="sisonke-badge sisonke-badge-green">Covered Life</span>
            <h1>Add Dependent</h1>
            <p>Add a covered life for @member.FullName.</p>
        </div>
        <div class="dependent-hero-meta">
            <span>Member</span>
            <strong>@member.FullName</strong>
        </div>
    </section>

    <div class="mb-4">
        <a class="sisonke-btn sisonke-btn-outline" href="@($"/member-profile/{MemberId}")">
            <i class="bi bi-arrow-left me-2"></i>Back to Member Profile
        </a>
    </div>

    @if (saveFailed)
    {
        <AlertBanner
            Type="warning"
            Title="Dependent could not be added."
            Message="The maximum dependent limit may have been reached."
            Icon="bi bi-exclamation-triangle-fill" />
    }

    <div class="form-page">
        <div class="sisonke-card">
            <div class="sisonke-card-body">
                <EditForm Model="@model" OnValidSubmit="@HandleValidSubmit" FormName="AddDependentForm">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="alert alert-danger" />

                    <div class="sisonke-card-head">
                        <div>
                            <h2>Dependent Details</h2>
                            <p>Capture the covered life information for this member.</p>
                        </div>
                    </div>

                    <div class="sisonke-grid sisonke-grid-2">
                        <div class="member-form-field">
                            <label class="form-label" for="full-name">Full name <span class="text-danger">*</span></label>
                            <InputText id="full-name" class="form-control" placeholder="e.g. Zanele Nkosi" @bind-Value="model.FullName" />
                        </div>

                        <div class="member-form-field">
                            <label class="form-label" for="relationship">Relationship</label>
                            <InputSelect id="relationship" class="form-select" @bind-Value="model.Relationship">
                                @foreach (var relationship in relationshipOptions)
                                {
                                    <option value="@relationship">@relationship</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="member-form-field">
                            <label class="form-label" for="date-of-birth">Date of birth</label>
                            <InputDate id="date-of-birth" class="form-control" @bind-Value="model.DateOfBirth" />
                        </div>

                        <div class="member-form-field">
                            <label class="form-label" for="id-number">ID number</label>
                            <InputText id="id-number" class="form-control" placeholder="13-digit SA ID number" @bind-Value="model.IdNumber" />
                        </div>

                        <div class="member-form-field">
                            <label class="form-label" for="cellphone-number">Cellphone number</label>
                            <InputText id="cellphone-number" class="form-control" placeholder="e.g. 0821234567" @bind-Value="model.CellphoneNumber" />
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2 flex-wrap">
                        <button class="sisonke-btn sisonke-btn-primary" type="submit">
                            <i class="bi bi-person-check me-2"></i>Save Dependent
                        </button>
                        <a class="sisonke-btn sisonke-btn-outline" href="@($"/member-profile/{MemberId}")">Cancel</a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<style>
    .dependent-hero-meta {
        display: grid;
        gap: .25rem;
        min-width: 14rem;
        padding: 1rem;
        border: 1px solid rgb(255 255 255 / .28);
        border-radius: var(--r-md);
        background: rgb(255 255 255 / .12);
    }

    .dependent-hero-meta span {
        color: rgb(255 255 255 / .78);
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .dependent-hero-meta strong {
        color: #fff;
        font-size: 1rem;
    }
</style>

@code {
    private static readonly string[] relationshipOptions =
    [
        "Spouse",
        "Child",
        "Parent",
        "Sibling",
        "Extended Family",
        "Other"
    ];

    private Member? member;
    private Stokvel? stokvel;
    private MemberDependent model = new()
    {
        Relationship = "Child"
    };
    private bool isLoading = true;
    private bool saveFailed;
    private bool canManageDependents;
    private bool IsDependentsAvailable => stokvel is not null &&
        (stokvel.Archetype == StokvelArchetype.BurialSociety || stokvel.EnableDependents);

    [Parameter]
    public Guid MemberId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        member = await MemberService.GetMemberByIdAsync(MemberId);
        stokvel = member is null ? null : await StokvelService.GetStokvelByTenantIdAsync(member.TenantId);
        canManageDependents = await CanManageDependentsAsync();
        isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        saveFailed = false;

        if (!IsDependentsAvailable)
        {
            saveFailed = true;
            return;
        }

        if (!canManageDependents)
        {
            saveFailed = true;
            return;
        }

        var dependent = new MemberDependent
        {
            FullName = model.FullName,
            Relationship = model.Relationship,
            DateOfBirth = model.DateOfBirth,
            IdNumber = model.IdNumber,
            CellphoneNumber = model.CellphoneNumber
        };

        var savedDependent = await MemberService.AddDependentAsync(MemberId, dependent);

        if (savedDependent is null)
        {
            saveFailed = true;
            return;
        }

        NavigationManager.NavigateTo($"/member-profile/{MemberId}");
    }

    private async Task<bool> CanManageDependentsAsync()
    {
        if (stokvel is null)
        {
            return false;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        return !string.IsNullOrWhiteSpace(userId) &&
            await MemberAccessService.CanManageStokvelAsync(userId, stokvel.Id);
    }

    private string GetDependentsDisabledMessage()
    {
        return stokvel?.Archetype == StokvelArchetype.Rotational
            ? "Covered lives belong to Burial Society workflows. This rotational stokvel can still use members, contributions, meetings and rotation schedule features."
            : "Covered lives are a Burial Society feature. Enable dependents in the stokvel setup if this group requires them.";
    }
}
