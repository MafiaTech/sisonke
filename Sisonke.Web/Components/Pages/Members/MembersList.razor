@page "/members/{StokvelId:guid}"

@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject MemberService MemberService
@inject StokvelService StokvelService

<PageTitle>Members</PageTitle>

@if (isLoading)
{
    <p>Loading members...</p>
}
else if (stokvel is null)
{
    <div class="alert alert-danger" role="alert">
        Stokvel not found.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1>Members</h1>
            <h2 class="h4">@stokvel.Name</h2>
            <p class="text-muted mb-0">Manage members for this stokvel.</p>
        </div>
        <a class="btn btn-primary" href="@($"/add-member/{StokvelId}")">Add Member</a>
    </div>

    <div class="mb-3">
        <a href="@($"/stokvel-dashboard/{StokvelId}")">Back to Dashboard</a>
    </div>

    @if (members.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No members have been added yet.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Member Number</th>
                        <th>Full Name</th>
                        <th>Cellphone</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Joining Date</th>
                        <th>Cooling Period</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in members)
                    {
                        <tr>
                            <td>@member.MemberNumber</td>
                            <td>@member.FullName</td>
                            <td>@member.CellphoneNumber</td>
                            <td>@member.DefaultRole</td>
                            <td>@member.Status</td>
                            <td>@member.JoiningDate.ToString("yyyy-MM-dd")</td>
                            <td>@(member.IsInCoolingPeriod ? "Yes" : "No")</td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary" href="@($"/member-profile/{member.Id}")">View</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private Stokvel? stokvel;
    private List<Member> members = [];
    private bool isLoading = true;

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;

        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);
        members = stokvel is null
            ? []
            : await MemberService.GetMembersByStokvelIdAsync(StokvelId);

        isLoading = false;
    }
}
