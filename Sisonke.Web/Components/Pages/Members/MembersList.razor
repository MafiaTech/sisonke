@page "/members/{StokvelId:guid}"
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject MemberService MemberService
@inject StokvelService StokvelService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccessService MemberAccessService

<PageTitle>Members</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading members…
    </div>
}
else if (stokvel is null)
{
    <AlertBanner Type="danger" Title="Stokvel not found." Message="" Icon="bi bi-x-circle-fill" />
}
else if (!canManageMembers)
{
    <div class="d-flex flex-column gap-3">
        <AlertBanner Type="warning"
                     Title="Access restricted."
                     Message="Only office bearers can manage members."
                     Icon="bi bi-exclamation-triangle-fill" />
        <div>
            <a class="btn btn-outline-secondary" href="/my-memberships">
                <i class="bi bi-grid me-1"></i>Back to My Memberships
            </a>
        </div>
    </div>
}
else
{
    <div class="page-header">
        <div class="page-header-text">
            <h1>Members</h1>
            <p class="page-subtitle">@stokvel.Name · @members.Count member@(members.Count == 1 ? "" : "s") captured</p>
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <a class="btn btn-outline-secondary btn-sm" href="@($"/stokvel-dashboard/{StokvelId}")">
                <i class="bi bi-speedometer2 me-1"></i>Dashboard
            </a>
            <a class="btn btn-primary btn-sm" href="@($"/add-member/{StokvelId}")">
                <i class="bi bi-person-plus-fill me-1"></i>Add Member
            </a>
        </div>
    </div>

    @if (members.Count == 0)
    {
        <div class="ms-empty-state">
            <div class="ms-empty-icon-ring">
                <i class="bi bi-people" aria-hidden="true"></i>
            </div>
            <h2 class="ms-empty-title">No members yet</h2>
            <p class="ms-empty-text">Add your first member to start capturing profiles, next of kin, beneficiaries and fines.</p>
            <a class="btn btn-primary" href="@($"/add-member/{StokvelId}")">
                <i class="bi bi-person-plus-fill me-2"></i>Add First Member
            </a>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th style="width:2.5rem"></th>
                            <th>Member</th>
                            <th>Cellphone</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Joined</th>
                            <th>Cooling</th>
                            <th style="width:5rem"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var member in members)
                        {
                            <tr>
                                <td>
                                    <div class="member-avatar" style="width:2.25rem;height:2.25rem;font-size:.75rem" aria-hidden="true">
                                        @GetInitials(member.FullName)
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-600">@member.FullName</div>
                                    <div class="text-muted" style="font-size:.75rem">@member.MemberNumber</div>
                                </td>
                                <td class="text-muted small">@member.CellphoneNumber</td>
                                <td><StatusBadge Text="@member.DefaultRole.ToString()" Type="secondary" /></td>
                                <td>
                                    @{
                                        var statusType = member.Status.ToString() switch
                                        {
                                            "Active"    => "success",
                                            "Suspended" => "warning",
                                            _           => "secondary"
                                        };
                                    }
                                    <StatusBadge Text="@member.Status.ToString()" Type="@statusType" />
                                </td>
                                <td class="text-muted small">@member.JoiningDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (member.IsInCoolingPeriod)
                                    {
                                        <StatusBadge Text="Cooling" Type="info" />
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>
                                    <a class="btn btn-sm btn-outline-primary" href="@($"/member-profile/{member.Id}")">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

<style>
    .fw-600 { font-weight: 600; }
</style>

@code {
    private Stokvel? stokvel;
    private List<Member> members = [];
    private bool isLoading = true;
    private bool canManageMembers;

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        canManageMembers = false;
        members = [];

        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);

        if (stokvel is null)
        {
            isLoading = false;
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            isLoading = false;
            return;
        }

        canManageMembers = await MemberAccessService.CanManageMembersAsync(userId, StokvelId);

        if (canManageMembers)
        {
            members = await MemberService.GetMembersByStokvelIdAsync(StokvelId);
        }

        isLoading = false;
    }

    private static string GetInitials(string fullName)
    {
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : fullName.Length > 0 ? fullName[0].ToString().ToUpperInvariant() : "?";
    }
}
