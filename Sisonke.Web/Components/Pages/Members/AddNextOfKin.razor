@page "/add-next-of-kin/{MemberId:guid}"
@rendermode InteractiveServer

@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject MemberService MemberService
@inject NavigationManager NavigationManager

<PageTitle>Add Next of Kin</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm text-secondary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading...
    </div>
}
else if (member is null)
{
    <AlertBanner Type="danger" Title="Member not found." Message="" Icon="bi bi-x-circle-fill" />
}
else
{
    <PageHeader
        Title="Add Next of Kin"
        Subtitle="@member.FullName"
        BackText="Back to Member Profile"
        BackHref="@($"/member-profile/{MemberId}")" />

    @if (saveFailed)
    {
        <AlertBanner Type="danger" Title="Unable to save next of kin record." Message="Please try again." Icon="bi bi-x-circle-fill" />
    }

    <div class="form-page">
        <div class="card">
            <div class="card-body p-4">
                <EditForm Model="@newNextOfKin" OnValidSubmit="@HandleValidSubmit" FormName="AddNextOfKinForm">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="alert alert-danger" />

                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="full-name">Full name</label>
                            <InputText id="full-name" class="form-control" @bind-Value="newNextOfKin.FullName" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" for="relationship">Relationship</label>
                            <InputSelect id="relationship" class="form-select" @bind-Value="newNextOfKin.Relationship">
                                @foreach (var relationship in relationshipOptions)
                                {
                                    <option value="@relationship">@relationship</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" for="cellphone-number">Cellphone number</label>
                            <InputText id="cellphone-number" class="form-control" @bind-Value="newNextOfKin.CellphoneNumber" />
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="address">Address</label>
                            <InputText id="address" class="form-control" @bind-Value="newNextOfKin.Address" />
                        </div>

                        <div class="col-12">
                            <div class="form-check">
                                <InputCheckbox id="is-primary" class="form-check-input" @bind-Value="newNextOfKin.IsPrimary" />
                                <label class="form-check-label" for="is-primary">Primary next of kin</label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-person-check me-2"></i>Save Next of Kin
                        </button>
                        <a class="btn btn-outline-secondary" href="@($"/member-profile/{MemberId}")">Cancel</a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private static readonly string[] relationshipOptions =
    [
        "Spouse",
        "Child",
        "Parent",
        "Sibling",
        "Grandparent",
        "Grandchild",
        "Aunt/Uncle",
        "Cousin",
        "Friend",
        "Other"
    ];

    private Member? member;
    private NextOfKin newNextOfKin = new()
    {
        Relationship = "Spouse"
    };
    private bool isLoading = true;
    private bool saveFailed;

    [Parameter]
    public Guid MemberId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        member = await MemberService.GetMemberByIdAsync(MemberId);
        isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        saveFailed = false;

        var savedNextOfKin = await MemberService.AddNextOfKinAsync(MemberId, newNextOfKin);

        if (savedNextOfKin is null)
        {
            saveFailed = true;
            return;
        }

        NavigationManager.NavigateTo($"/member-profile/{MemberId}");
    }
}
