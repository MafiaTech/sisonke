                }
                else
                {
                    <div class="table-responsive">
                        <table class="sisonke-table member-transparency-table">
                            <thead><tr><th>Member</th><th>Status</th><th>Amount</th><th>Paid On</th></tr></thead>
                            <tbody>
                            @foreach (var contribution in currentMonthStokvelContributions)
                            {
