    private static ContributionPaymentSummary MapRotationalPaymentToContributionSummary(
        RotationalContributionPayment payment,
        RotationalContributionCycle? fallbackCycle = null)
    {
        var cycle = payment.Cycle ?? fallbackCycle;
        var cycleDate = cycle?.CycleStartDate ?? DateTime.Today;

        return new ContributionPaymentSummary
        {
            Id = payment.Id,
            ContributionYear = cycleDate.Year,
            ContributionMonth = cycleDate.Month,
            MonthYearLabel = string.IsNullOrWhiteSpace(cycle?.CycleName)
                ? cycleDate.ToString("MMMM yyyy")
                : cycle.CycleName,
            ExpectedAmount = payment.ExpectedAmount,
            PaidAmount = payment.PaidAmount,
            Balance = GetRotationalPaymentBalance(payment),
            Status = MapRotationalPaymentStatus(payment.PaymentStatus),
            PaidDate = payment.PaymentDate,
            PaymentReference = payment.ReferenceNumber
        };
    }

    private static PaymentStatus MapRotationalPaymentStatus(ContributionPaymentStatus status)
    {
        return status switch
        {
            ContributionPaymentStatus.Paid => PaymentStatus.Paid,
            ContributionPaymentStatus.Waived => PaymentStatus.Exempted,
            ContributionPaymentStatus.PartiallyPaid => PaymentStatus.PartiallyPaid,
            ContributionPaymentStatus.Late => PaymentStatus.Late,
            _ => PaymentStatus.Unpaid
        };
    }

    private static decimal GetRotationalPaymentBalance(RotationalContributionPayment payment) =>
        Math.Max(0, payment.ExpectedAmount + payment.PenaltyAmount - payment.PaidAmount);

    private IReadOnlyList<ReportDatum> GetMemberContributionReportSegments()
    {
        var paid = currentMonthContribution?.PaidAmount ?? recentContributions.Sum(contribution => contribution.PaidAmount);
        var balance = currentMonthContribution?.Balance ?? recentContributions.Sum(contribution => contribution.Balance);

        return
        [
            new("Paid", paid, "#0F8A50", "Confirmed payments"),
            new("Outstanding", balance, "#D97706", "Balance still open")
        ];
    }

    private IReadOnlyList<ReportDatum> GetMemberContributionHistoryBars() =>
        recentContributions
            .Take(6)
            .Select(contribution => new ReportDatum(
                contribution.MonthYearLabel,
                contribution.PaidAmount,
                contribution.Balance <= 0 ? "#0F8A50" : "#D97706",
                $"{FormatCurrency(contribution.ExpectedAmount)} expected"))
            .ToList();

    private decimal GetMemberContributionHistoryMax() =>
        Math.Max(1, recentContributions.Count == 0 ? CurrentContributionTotal : recentContributions.Max(contribution => contribution.ExpectedAmount));

    private IReadOnlyList<ReportDatum> GetMemberFineReportSegments()
    {
        var paid = memberFines
            .Where(fine => fine.Status == FineStatus.Paid)
            .Sum(fine => fine.Amount);
        var open = memberFines
            .Where(fine => fine.Status == FineStatus.Unpaid)
            .Sum(fine => fine.Amount);
        var waived = memberFines
            .Where(fine => fine.Status == FineStatus.Waived)
            .Sum(fine => fine.Amount);

        return
        [
            new("Paid", paid, "#0F8A50", $"{PaidFinesCount} paid"),
            new("Open", open, "#B94242", $"{OpenFinesCount} unpaid"),
            new("Waived", waived, "#64746B", "Waived or cleared")
        ];
    }

    private string GetApologyType(Guid meetingId)
    {
        return meetingApologiesByMeetingId.TryGetValue(meetingId, out var apology) &&
            !string.IsNullOrWhiteSpace(apology.ApologyType)
                ? apology.ApologyType
                : "Not specified";
    }

    private static string FormatCurrency(decimal amount)
    {
        return amount.ToString("C", new System.Globalization.CultureInfo("en-ZA"));
    }
