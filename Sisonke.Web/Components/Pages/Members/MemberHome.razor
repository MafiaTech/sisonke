            @if (!stokvel.EnableRotation && (stokvel.EnableClaims || stokvel.EnableDependents))
            {
                <div class="mw-card mw-card-accent mw-ca-ochre">
                    <div class="mw-card-top">
                        <div class="mw-card-tl"><div class="mw-card-ico mw-ico-ochre"><i class="bi bi-shield-heart"></i></div><span class="mw-card-lbl">Burial Cover</span></div>
                        <span class="mw-badge mw-bg-info">Member cover</span>
