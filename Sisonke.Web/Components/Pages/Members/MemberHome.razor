@page "/member-home/{MemberId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject MemberService MemberService
@inject MemberAccessService MemberAccessService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject FineService FineService
@inject FuneralClaimService FuneralClaimService
@inject MeetingService MeetingService
@inject MeetingMinuteService MeetingMinuteService
@inject MeetingApologyService MeetingApologyService
@inject StokvelService StokvelService
@inject ContributionPaymentService ContributionPaymentService
@inject VotingService VotingService

<PageTitle>My Member Dashboard</PageTitle>
<link rel="stylesheet" href="/css/member-workspace.css" />

@if (isLoading)
{
    <div class="sisonke-alert sisonke-alert-blue">Loading your member dashboard...</div>
}
else if (member is null)
{
    <div class="sisonke-alert sisonke-alert-red">Member not found.</div>
}
else if (!isAllowed)
{
    <div class="sisonke-alert sisonke-alert-gold">You do not have access to this member view.</div>
    <a class="sisonke-btn sisonke-btn-outline" href="/my-workspace">
        <i class="bi bi-columns-gap me-1"></i>Back to My Workspace
    </a>
}
else if (stokvel is null)
{
    <div class="sisonke-alert sisonke-alert-red">Stokvel not found for this member.</div>
    <a class="sisonke-btn sisonke-btn-outline" href="/my-workspace">
        <i class="bi bi-columns-gap me-1"></i>Back to My Workspace
    </a>
}
else
{
    <div class="mw-member-workspace">
        <div class="mw-hero member-hero">
            <div class="mw-hero-ring"></div>
            <div class="mw-hero-ring2"></div>
            <div class="mw-hero-left">
                <div class="mw-hero-eyebrow" id="mw-greeting">Welcome back</div>
                <div class="mw-hero-name">@Display(member.FullName)</div>
                <div class="mw-hero-sub">
                    <span>@stokvel.Name</span>
                    <span class="mw-hero-sub-dot"></span>
                    <span>@member.DefaultRole</span>
                </div>
                <div class="mw-hero-chips">
                    <span class="mw-hchip mw-hchip--green">@member.Status</span>
                    <span class="mw-hchip mw-hchip--ochre">@Display(member.MemberNumber)</span>
                    <span class="mw-hchip mw-hchip--white">Joined @member.JoiningDate.ToString("dd MMM yyyy")</span>
                </div>
            </div>
            <div class="mw-hero-right">
                <div class="mw-hero-tiles member-hero-grid">
                    <div class="mw-htile">
                        <div class="mw-htile-label">Member No.</div>
                        <div class="mw-htile-val">@Display(member.MemberNumber)</div>
                    </div>
                    <div class="mw-htile">
                        <div class="mw-htile-label">Joining Date</div>
                        <div class="mw-htile-val mw-htile-val--mint">@member.JoiningDate.ToString("dd MMM yyyy")</div>
                    </div>
                    <div class="mw-htile">
                        <div class="mw-htile-label">ID Number</div>
                        <div class="mw-htile-val">@SensitiveDataMasker.MaskIdNumber(member.IdNumber)</div>
                    </div>
                    <div class="mw-htile">
                        <div class="mw-htile-label">Cellphone</div>
                        <div class="mw-htile-val mw-htile-val--ochre">@SensitiveDataMasker.MaskPhoneNumber(member.CellphoneNumber)</div>
                    </div>
                </div>
            </div>
        </div>

        <section class="sisonke-card upcoming-meetings-card">
            <div class="sisonke-card-head">
                <div>
                    <h2 class="h5 mb-1">Upcoming Meetings</h2>
                    <div class="text-muted">View your next meetings and send apologies where needed.</div>
                </div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="sisonke-badge sisonke-badge-blue">@upcomingMeetings.Count Scheduled</span>
                    <a class="sisonke-btn sisonke-btn-outline" href="/meetings/@stokvel.Id">View All</a>
                </div>
            </div>
            <div class="sisonke-card-body">
                @if (upcomingMeetings.Count == 0)
                {
                    <div class="sisonke-alert sisonke-alert-blue">
                        No upcoming meetings have been scheduled yet.
                    </div>
                }
                else
                {
                    <div class="member-meeting-grid">
                        @foreach (var meeting in upcomingMeetings.Take(2))
                        {
                            var hasApology = meetingApologiesByMeetingId.ContainsKey(meeting.Id);
                            var apologyType = GetApologyType(meeting.Id);
                            var isPastMeeting = meeting.MeetingDate.Date < DateTime.Today;

                            <article class="member-meeting-card">
                                <div class="meeting-date-block">
                                    <span class="meeting-date-day">@meeting.MeetingDate.Day.ToString("00")</span>
                                    <span class="meeting-date-month">@meeting.MeetingDate.ToString("MMM")</span>
                                    <span class="meeting-date-year">@meeting.MeetingDate.Year</span>
                                </div>

                                <div class="member-meeting-content">
                                    <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                        <div>
                                            <h3>@Display(meeting.Title)</h3>
                                            @if (!string.IsNullOrWhiteSpace(meeting.Purpose))
                                            {
                                                <p>@meeting.Purpose</p>
                                            }
                                        </div>
                                        @if (hasApology)
                                        {
                                            <span class="sisonke-badge sisonke-badge-green">Apology Submitted</span>
                                        }
                                        else if (isPastMeeting)
                                        {
                                            <span class="sisonke-badge sisonke-badge-gray">Closed</span>
                                        }
                                        else
                                        {
                                            <span class="sisonke-badge sisonke-badge-gold">RSVP Open</span>
                                        }
                                    </div>

                                    <div class="member-meeting-meta">
                                        <span><i class="bi bi-clock me-1"></i>@meeting.MeetingDate.ToString("HH:mm")</span>
                                        <span><i class="bi bi-geo-alt me-1"></i>@Display(meeting.Venue)</span>
                                        <span><i class="bi bi-calendar-check me-1"></i>Deadline @meeting.MeetingDate.ToString("dd MMM yyyy HH:mm")</span>
                                    </div>

                                    <div class="member-meeting-actions">
                                        <a class="sisonke-btn sisonke-btn-outline" href="/meeting/@meeting.Id">View</a>
                                        @if (approvedMinutesByMeetingId.ContainsKey(meeting.Id))
                                        {
                                            <a class="sisonke-btn sisonke-btn-primary" href="@($"/meeting-minutes/{meeting.Id}")">
                                                View Approved Minutes
                                            </a>
                                        }
                                        @if (hasApology)
                                        {
                                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                                <span class="sisonke-badge sisonke-badge-green">Apology Submitted</span>
                                                <span class="text-muted small">· @apologyType</span>
                                            </div>
                                        }
                                        else if (isPastMeeting)
                                        {
                                            <span class="sisonke-badge sisonke-badge-gray">Closed</span>
                                        }
                                        else
                                        {
                                            <a class="sisonke-btn sisonke-btn-gold send-apology-btn" href="@($"/submit-apology/{meeting.Id}/{MemberId}")">
                                                Send Apology
                                            </a>
                                        }
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                }
            </div>
        </section>

        <div class="member-quick-actions">
            <a class="member-quick-action-tile" href="/member-profile/@MemberId">
                <span class="member-quick-action-icon">👤</span>
                <span>My Profile</span>
            </a>
            @if (stokvel.EnableClaims)
            {
                <a class="member-quick-action-tile" href="/create-claim/@MemberId">
                    <span class="member-quick-action-icon">📋</span>
                    <span>Create Claim</span>
                </a>
            }
            <a class="member-quick-action-tile" href="#member-contributions">
                <span class="member-quick-action-icon">💰</span>
                <span>Contributions</span>
            </a>
            <a class="member-quick-action-tile" href="/constitution-builder/@stokvel.Id">
                <span class="member-quick-action-icon">📜</span>
                <span>Constitution</span>
            </a>
        </div>

        <div class="mw-sec-head">
            <span class="mw-sec-label">Member Details</span>
            <div class="mw-sec-line"></div>
        </div>
        <div class="mw-card mw-mb26" style="animation-delay:0.05s">
            <div class="mw-prof-banner">
                <div class="mw-prof-avi">
                    @(string.Join("", (member.FullName ?? string.Empty).Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(part => part[0])).ToUpperInvariant())
                </div>
                <div class="mw-prof-info">
                    <div class="mw-prof-name">@Display(member.FullName)</div>
                    <div class="mw-prof-org">@stokvel.Name</div>
                    <div class="mw-prof-chips">
                        <span class="mw-badge mw-bg-ok mw-bg-dot">@member.Status</span>
                        <span class="mw-badge mw-bg-info">@member.DefaultRole</span>
                        <span class="mw-badge mw-bg-warn">@Display(member.ResidentialArea)</span>
                    </div>
                </div>
            </div>
            <div class="mw-md-grid">
                <div class="mw-md-cell">
                    <div class="mw-md-lbl">Full Name</div>
                    <div class="mw-md-val">@Display(member.FullName)</div>
                </div>
                <div class="mw-md-cell">
                    <div class="mw-md-lbl">Stokvel</div>
                    <div class="mw-md-val">@stokvel.Name</div>
                </div>
                <div class="mw-md-cell">
                    <div class="mw-md-lbl">Role</div>
                    <div class="mw-md-val">@member.DefaultRole</div>
                </div>
                <div class="mw-md-cell">
                    <div class="mw-md-lbl">Member Number</div>
                    <div class="mw-md-val mw-md-val--mono">@Display(member.MemberNumber)</div>
                </div>
                <div class="mw-md-cell">
                    <div class="mw-md-lbl">Joining Date</div>
                    <div class="mw-md-val">@member.JoiningDate.ToString("dd MMM yyyy")</div>
                </div>
                <div class="mw-md-cell">
                    <div class="mw-md-lbl">ID Number</div>
                    <div class="mw-md-val mw-md-val--mono">@SensitiveDataMasker.MaskIdNumber(member.IdNumber)</div>
                </div>
                <div class="mw-md-cell">
                    <div class="mw-md-lbl">Telephone</div>
                    <div class="mw-md-val mw-md-val--mono">@SensitiveDataMasker.MaskPhoneNumber(member.CellphoneNumber)</div>
                </div>
                <div class="mw-md-cell">
                    <div class="mw-md-lbl">Email</div>
                    <div class="mw-md-val">@SensitiveDataMasker.MaskEmail(member.EmailAddress)</div>
                </div>
                <div class="mw-md-cell">
                    <div class="mw-md-lbl">Residential Area</div>
                    <div class="mw-md-val">@Display(member.ResidentialArea)</div>
                </div>
            </div>
        </div>

        <div class="mw-sec-head">
            <span class="mw-sec-label">Financial &amp; Membership</span>
            <div class="mw-sec-line"></div>
        </div>
        <div class="mw-g mw-g3 mw-mb26">
            <div class="mw-card mw-card-accent mw-ca-fern" id="member-contributions">
                <div class="mw-card-top">
                    <div class="mw-card-tl">
                        <div class="mw-card-ico mw-ico-fern">💰</div>
                        <span class="mw-card-lbl">My Contribution Status</span>
                    </div>
                    <a class="mw-btn mw-btn-outline mw-btn-xs" href="@($"/member-statement/{MemberId}/{stokvel.Id}")">View Statement</a>
                </div>
                <div class="mw-card-body">
                    @if (overdueContributions.Count > 0)
                    {
                        <div class="sisonke-alert sisonke-alert-red mb-3">
                            You have overdue contributions. Total outstanding: @FormatCurrency(MemberContributionOutstandingTotal)
                        </div>
                    }

                    @if (currentMonthContribution is null)
                    {
                        <div class="mw-alert mw-alert-info">
                            <div class="mw-alert-icon">ℹ</div>
                            <div>
                                <div class="mw-alert-title">No current record</div>
                                <div class="mw-alert-body">No contribution record has been generated for @CurrentMonthLabel yet.</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mw-smini">
                            <div class="mw-smini-block">
                                <span class="mw-smini-num">@FormatCurrency(currentMonthContribution.ExpectedAmount)</span>
                                <span class="mw-smini-lbl">Expected</span>
                            </div>
                            <div class="mw-smini-block">
                                <span class="mw-smini-num" style="color:var(--mw-ok)">@FormatCurrency(currentMonthContribution.PaidAmount)</span>
                                <span class="mw-smini-lbl">Paid</span>
                            </div>
                            <div class="mw-smini-block">
                                <span class="mw-smini-num" style="color:var(--mw-ochre)">@FormatCurrency(currentMonthContribution.Balance)</span>
                                <span class="mw-smini-lbl">Balance</span>
                            </div>
                        </div>
                        <div class="mw-div"></div>
                        <div class="mw-p-row">
                            <span class="mw-p-lbl">Month</span>
                            <span class="mw-p-val">@CurrentMonthLabel</span>
                        </div>
                        <div class="mw-p-row">
                            <span class="mw-p-lbl">Status</span>
                            <span class="@GetPaymentStatusBadgeClass(currentMonthContribution.Status)">@GetPaymentStatusText(currentMonthContribution.Status)</span>
                        </div>
                        <div class="mw-p-row">
                            <span class="mw-p-lbl">Paid Date</span>
                            <span class="mw-p-val">@(currentMonthContribution.PaidDate?.ToString("dd MMM yyyy") ?? "Not fully paid")</span>
                        </div>
                        <div class="mw-p-row">
                            <span class="mw-p-lbl">Reference</span>
                            <span class="mw-p-val">@(string.IsNullOrWhiteSpace(currentMonthContribution.PaymentReference) ? "Not captured" : currentMonthContribution.PaymentReference)</span>
                        </div>
                    }

                    <div class="mw-div"></div>
                    <div class="mw-card-lbl mb-2">Contribution History</div>
                    @if (recentContributions.Count == 0)
                    {
                        <div class="sisonke-alert sisonke-alert-blue mb-0">
                            No contribution history has been recorded yet.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="sisonke-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Month / Year</th>
                                        <th>Expected</th>
                                        <th>Paid</th>
                                        <th>Balance</th>
                                        <th>Status</th>
                                        <th>Paid Date</th>
                                        <th>Reference</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var contribution in recentContributions)
                                    {
                                        <tr>
                                            <td>@contribution.MonthYearLabel</td>
                                            <td>@FormatCurrency(contribution.ExpectedAmount)</td>
                                            <td>@FormatCurrency(contribution.PaidAmount)</td>
                                            <td>@FormatCurrency(contribution.Balance)</td>
                                            <td><span class="@GetPaymentStatusBadgeClass(contribution.Status)">@GetPaymentStatusText(contribution.Status)</span></td>
                                            <td>@(contribution.PaidDate?.ToString("dd MMM yyyy") ?? "-")</td>
                                            <td>@(string.IsNullOrWhiteSpace(contribution.PaymentReference) ? "-" : contribution.PaymentReference)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="mw-card mw-card-accent mw-ca-terra">
                <div class="mw-card-top">
                    <div class="mw-card-tl">
                        <div class="mw-card-ico mw-ico-terra">⚖</div>
                        <span class="mw-card-lbl">My Fines</span>
                    </div>
                    @if (OpenFinesCount == 0)
                    {
                        <span class="mw-badge mw-bg-ok">All Clear</span>
                    }
                    else
                    {
                        <span class="mw-badge mw-bg-danger">@OpenFinesCount Open</span>
                    }
                </div>
                <div class="mw-card-body">
                    @if (memberFines.Count == 0)
                    {
                        <div class="mw-alert mw-alert-info">
                            <div class="mw-alert-icon">ℹ</div>
                            <div>
                                <div class="mw-alert-title">No fines recorded</div>
                                <div class="mw-alert-body">No fines have been recorded against your membership.</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mw-smini">
                            <div class="mw-smini-block">
                                <span class="mw-smini-num" style="color:var(--mw-terra)">@FormatCurrency(OutstandingFineTotal)</span>
                                <span class="mw-smini-lbl">Outstanding</span>
                            </div>
                            <div class="mw-smini-block">
                                <span class="mw-smini-num">@OpenFinesCount</span>
                                <span class="mw-smini-lbl">Open</span>
                            </div>
                            <div class="mw-smini-block">
                                <span class="mw-smini-num" style="color:var(--mw-ok)">@PaidFinesCount</span>
                                <span class="mw-smini-lbl">Paid</span>
                            </div>
                        </div>
                        <div class="mw-div"></div>
                        @foreach (var fine in memberFines.OrderByDescending(fine => fine.FineDate).Take(4))
                        {
                            <div class="mw-lrow">
                                <div class="mw-lrow-ico mw-ico-terra">!</div>
                                <div class="mw-lrow-detail">
                                    <div class="mw-lrow-title">@Display(fine.FineType?.Name)</div>
                                    <div class="mw-lrow-sub">@fine.FineDate.ToString("dd MMM yyyy") · @Display(fine.Reason)</div>
                                </div>
                                <div class="text-end">
                                    <div class="mw-md-val mw-md-val--mono">@FormatCurrency(fine.Amount)</div>
                                    <span class="@GetFineStatusBadgeClass(fine.Status)">@fine.Status</span>
                                </div>
                            </div>
                        }
                    }
                    <div class="mw-div"></div>
                    <a class="mw-btn mw-btn-outline mw-btn-sm mw-btn-full" href="/member-profile/@MemberId">
                        View My Profile
                    </a>
                </div>
            </div>

            <div class="sisonke-card mw-card-accent mw-ca-blue">
                <div class="sisonke-card-head">
                    <div class="mw-card-tl">
                        <div class="mw-card-ico mw-ico-blue">📋</div>
                        <span class="mw-card-lbl">My Claims</span>
                    </div>
                    <a class="sisonke-btn sisonke-btn-primary" href="/create-claim/@MemberId">Create Claim</a>
                </div>
                <div class="sisonke-card-body">
                    <div class="mw-smini">
                        <div class="mw-smini-block">
                            <span class="mw-smini-num">@memberClaims.Count</span>
                            <span class="mw-smini-lbl">Total</span>
                        </div>
                        <div class="mw-smini-block">
                            <span class="mw-smini-num" style="color:var(--mw-dust)">@DraftClaimCount</span>
                            <span class="mw-smini-lbl">Draft</span>
                        </div>
                        <div class="mw-smini-block">
                            <span class="mw-smini-num" style="color:var(--mw-slate)">@SubmittedOrReviewClaimCount</span>
                            <span class="mw-smini-lbl">In Review</span>
                        </div>
                    </div>
                    <div class="mw-smini">
                        <div class="mw-smini-block">
                            <span class="mw-smini-num" style="color:var(--mw-ok)">@ApprovedClaimCount</span>
                            <span class="mw-smini-lbl">Approved</span>
                        </div>
                        <div class="mw-smini-block">
                            <span class="mw-smini-num" style="color:var(--mw-danger)">@RejectedClaimCount</span>
                            <span class="mw-smini-lbl">Rejected</span>
                        </div>
                        <div class="mw-smini-block">
                            <span class="mw-smini-num" style="color:var(--mw-ochre)">@(LatestClaim is null ? "None" : GetClaimStatusText(LatestClaim.Status))</span>
                            <span class="mw-smini-lbl">Latest</span>
                        </div>
                    </div>
                    <div class="mw-div"></div>
                    @if (memberClaims.Count == 0)
                    {
                        <div class="sisonke-alert sisonke-alert-blue">
                            <i class="bi bi-info-circle-fill mt-1"></i>
                            <div>
                                <strong>No claims have been submitted for this membership.</strong>
                                <div>Use the existing Create Claim flow for yourself or a covered dependent.</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="sisonke-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Reference</th>
                                        <th>Subject / Deceased</th>
                                        <th>Type</th>
                                        <th>Date of death</th>
                                        <th>Status</th>
                                        <th>Submitted</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var claim in memberClaims.OrderByDescending(claim => claim.CreatedAt))
                                    {
                                        <tr>
                                            <td class="mw-md-val--mono">@GetClaimReference(claim)</td>
                                            <td>@Display(claim.DeceasedFullName)</td>
                                            <td>@claim.SubjectType</td>
                                            <td>@(claim.DateOfDeath?.ToString("dd MMM yyyy") ?? "Not captured")</td>
                                            <td><span class="@GetClaimStatusBadgeClass(claim.Status)">@GetClaimStatusText(claim.Status)</span></td>
                                            <td>@(claim.SubmittedAt?.ToString("dd MMM yyyy") ?? "Not submitted")</td>
                                            <td class="text-end">
                                                <a class="sisonke-btn sisonke-btn-outline" href="/claim/@claim.Id">View Claim</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="mw-card mw-card-accent mw-ca-forest">
                <div class="mw-card-top">
                    <div class="mw-card-tl">
                        <div class="mw-card-ico mw-ico-fern">👨‍👩‍👧</div>
                        <span class="mw-card-lbl">My Dependents / Covered Lives</span>
                    </div>
                    <a class="mw-btn mw-btn-outline mw-btn-xs" href="/member-profile/@MemberId">View Profile</a>
                </div>
                <div class="mw-card-body">
                    <div class="mw-smini">
                        <div class="mw-smini-block">
                            <span class="mw-smini-num">@dependents.Count</span>
                            <span class="mw-smini-lbl">Total</span>
                        </div>
                        <div class="mw-smini-block">
                            <span class="mw-smini-num" style="color:var(--mw-fern)">@ActiveDependentCount</span>
                            <span class="mw-smini-lbl">Active</span>
                        </div>
                        <div class="mw-smini-block">
                            <span class="mw-smini-num" style="color:var(--mw-terra)">@DeceasedDependentCount</span>
                            <span class="mw-smini-lbl">Deceased</span>
                        </div>
                    </div>
                    <div class="mw-div"></div>
                    @if (dependents.Count == 0)
                    {
                        <div class="mw-alert mw-alert-info">
                            <div class="mw-alert-icon">ℹ</div>
                            <div>
                                <div class="mw-alert-title">No dependents captured</div>
                                <div class="mw-alert-body">No dependents / covered lives have been captured for this membership yet.</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        @foreach (var dependent in dependents.Take(4))
                        {
                            <div class="mw-lrow">
                                <div class="mw-lrow-ico mw-ico-fern">👤</div>
                                <div class="mw-lrow-detail">
                                    <div class="mw-lrow-title">@Display(dependent.FullName)</div>
                                    <div class="mw-lrow-sub">@dependent.Relationship · @(dependent.DateOfBirth?.ToString("dd MMM yyyy") ?? "Date of birth not captured")</div>
                                </div>
                                <span class="@GetDependentStatusBadgeClass(dependent)">@GetDependentStatusText(dependent)</span>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="mw-sec-head">
            <span class="mw-sec-label">Operations &amp; Meetings</span>
            <div class="mw-sec-line"></div>
        </div>
        <div class="mw-g mw-g3 mw-mb26">
            <div class="mw-card mw-card-accent mw-ca-blue">
                <div class="mw-card-top">
                    <div class="mw-card-tl">
                        <div class="mw-card-ico mw-ico-blue">✓</div>
                        <span class="mw-card-lbl">Open Votes</span>
                    </div>
                    <span class="sisonke-badge sisonke-badge-blue">@openVotes.Count Open</span>
                </div>
                <div class="mw-card-body">
                    @if (openVotes.Count == 0)
                    {
                        <div class="sisonke-alert sisonke-alert-blue mb-3">
                            No open votes are available right now.
                        </div>
                    }
                    else
                    {
                        @foreach (var vote in openVotes.Take(3))
                        {
                            <div class="mw-lrow">
                                <div class="mw-lrow-ico mw-ico-blue">✓</div>
                                <div class="mw-lrow-detail">
                                    <div class="mw-lrow-title">@Display(vote.Title)</div>
                                    <div class="mw-lrow-sub">@vote.OpensAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                                </div>
                                <span class="sisonke-badge sisonke-badge-green">@vote.Status</span>
                            </div>
                        }
                    }
                    <div class="mw-div"></div>
                    <a class="mw-btn mw-btn-outline mw-btn-sm mw-btn-full" href="@($"/votes/{stokvel.Id}")">
                        View Votes
                    </a>
                </div>
            </div>

            @if (stokvel.EnableRotation)
            {
                <div class="mw-card mw-card-accent mw-ca-ochre">
                    <div class="mw-card-top">
                        <div class="mw-card-tl">
                            <div class="mw-card-ico mw-ico-ochre">🏠</div>
                            <span class="mw-card-lbl">My Payout / Host Turn</span>
                        </div>
                    </div>
                    <div class="mw-card-body">
                        <div class="mw-alert mw-alert-warn">
                            <div class="mw-alert-icon">ℹ</div>
                            <div>
                                <div class="mw-alert-title">Coming Soon</div>
                                <div class="mw-alert-body">Payout and host rotation coming soon.</div>
                            </div>
                        </div>
                    </div>
                </div>
            }

        </div>

        <div class="mw-sec-head">
            <span class="mw-sec-label">Account &amp; Documents</span>
            <div class="mw-sec-line"></div>
        </div>
        <div class="mw-g mw-g3">
            <div class="mw-card mw-card-accent mw-ca-blue">
                <div class="mw-card-top">
                    <div class="mw-card-tl">
                        <div class="mw-card-ico mw-ico-blue">📁</div>
                        <span class="mw-card-lbl">My Documents</span>
                    </div>
                </div>
                <div class="mw-card-body">
                    <div class="mw-alert mw-alert-info">
                        <div class="mw-alert-icon">ℹ</div>
                        <div>
                            <div class="mw-alert-title">Coming Soon</div>
                            <div class="mw-alert-body">Your documents will appear here.</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mw-card mw-card-accent mw-ca-fern">
                <div class="mw-card-top">
                    <div class="mw-card-tl">
                        <div class="mw-card-ico mw-ico-fern">👤</div>
                        <span class="mw-card-lbl">My Profile</span>
                    </div>
                    <a class="mw-btn mw-btn-outline mw-btn-xs" href="/member-profile/@MemberId">View</a>
                </div>
                <div class="mw-card-body">
                    <div class="mw-p-row">
                        <span class="mw-p-lbl">Phone</span>
                        <span class="mw-p-val mw-p-val--mono">@SensitiveDataMasker.MaskPhoneNumber(member.CellphoneNumber)</span>
                    </div>
                    <div class="mw-p-row">
                        <span class="mw-p-lbl">Email</span>
                        <span class="mw-p-val">@SensitiveDataMasker.MaskEmail(member.EmailAddress)</span>
                    </div>
                    <div class="mw-p-row">
                        <span class="mw-p-lbl">ID Number</span>
                        <span class="mw-p-val mw-p-val--mono">@SensitiveDataMasker.MaskIdNumber(member.IdNumber)</span>
                    </div>
                    <div class="mw-p-row">
                        <span class="mw-p-lbl">Joined</span>
                        <span class="mw-p-val">@member.JoiningDate.ToString("dd MMM yyyy")</span>
                    </div>
                    <div class="mw-p-row">
                        <span class="mw-p-lbl">Area</span>
                        <span class="mw-p-val">@Display(member.ResidentialArea)</span>
                    </div>
                    <div class="mw-div"></div>
                    <a class="mw-btn mw-btn-forest mw-btn-sm mw-btn-full" href="/member-profile/@MemberId">
                        View Full Profile
                    </a>
                </div>
            </div>

            <div class="mw-card mw-card-accent mw-ca-forest">
                <div class="mw-card-top">
                    <div class="mw-card-tl">
                        <div class="mw-card-ico mw-ico-fern">📜</div>
                        <span class="mw-card-lbl">Constitution</span>
                    </div>
                    <span class="mw-badge mw-bg-info">Read Only</span>
                </div>
                <div class="mw-card-body">
                    <a class="mw-const-banner" href="/constitution-builder/@stokvel.Id">
                        <div class="mw-const-ico">📜</div>
                        <div>
                            <div class="mw-const-title">@stokvel.Name</div>
                            <div class="mw-const-sub">View the stokvel constitution · Read only</div>
                        </div>
                        <span class="mw-const-arrow">→</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
}

<script>
    (function () {
        var h = new Date().getHours();
        var g = h < 12 ? 'Good morning \uD83C\uDF3F'
            : h < 18 ? 'Good afternoon \u2600\uFE0F'
            : 'Good evening \uD83C\uDF19';
        var el = document.getElementById('mw-greeting');
        if (el) {
            el.textContent = g;
        }
    })();
</script>

@code {
    [Parameter]
    public Guid MemberId { get; set; }

    private Member? member;
    private Stokvel? stokvel;
    private List<MemberFine> memberFines = [];
    private List<FuneralClaim> memberClaims = [];
    private List<MemberDependent> dependents = [];
    private List<Meeting> upcomingMeetings = [];
    private List<VoteMotion> openVotes = [];
    private Dictionary<Guid, MeetingMinute> approvedMinutesByMeetingId = [];
    private Dictionary<Guid, MeetingApology> meetingApologiesByMeetingId = [];
    private List<ContributionPaymentSummary> memberContributions = [];
    private List<ContributionPaymentSummary> recentContributions = [];
    private List<MemberContribution> overdueContributions = [];
    private ContributionPaymentSummary? currentMonthContribution;
    private bool isLoading = true;
    private bool isAllowed;
    private string CurrentMonthLabel => DateTime.Today.ToString("MMMM yyyy");

    private FuneralClaim? LatestClaim => memberClaims
        .OrderByDescending(claim => claim.CreatedAt)
        .FirstOrDefault();

    private Meeting? NextMeeting => upcomingMeetings
        .OrderBy(meeting => meeting.MeetingDate)
        .FirstOrDefault();

    private int DraftClaimCount => memberClaims.Count(claim => claim.Status == FuneralClaimStatus.Draft);
    private int SubmittedOrReviewClaimCount => memberClaims.Count(claim =>
        claim.Status is FuneralClaimStatus.Submitted or FuneralClaimStatus.UnderReview or FuneralClaimStatus.OnHold);
    private int ApprovedClaimCount => memberClaims.Count(claim =>
        claim.Status is FuneralClaimStatus.Approved or FuneralClaimStatus.Paid);
    private int RejectedClaimCount => memberClaims.Count(claim => claim.Status == FuneralClaimStatus.Rejected);

    private int ActiveDependentCount => dependents.Count(dependent => dependent.IsActive);
    private int DeceasedDependentCount => dependents.Count(dependent => dependent.IsDeceased);
    private int InactiveDependentCount => dependents.Count(dependent => !dependent.IsActive && !dependent.IsDeceased);

    private decimal OutstandingFineTotal => memberFines
        .Where(fine => fine.Status == FineStatus.Unpaid)
        .Sum(fine => fine.Amount);

    private int OpenFinesCount => memberFines.Count(fine => fine.Status == FineStatus.Unpaid);
    private int PaidFinesCount => memberFines.Count(fine => fine.Status == FineStatus.Paid);
    private int ApologiesSubmittedCount => meetingApologiesByMeetingId.Count;
    private int PendingApologyCount => Math.Max(0, upcomingMeetings.Count - meetingApologiesByMeetingId.Count);
    private decimal MemberContributionOutstandingTotal => memberContributions
        .Where(contribution =>
            contribution.Status != PaymentStatus.Paid &&
            contribution.Status != PaymentStatus.Exempted &&
            contribution.Status != PaymentStatus.WrittenOff)
        .Sum(contribution => contribution.Balance);

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        isAllowed = false;
        member = null;
        stokvel = null;
        memberFines = [];
        memberClaims = [];
        dependents = [];
        upcomingMeetings = [];
        openVotes = [];
        approvedMinutesByMeetingId = [];
        meetingApologiesByMeetingId = [];
        memberContributions = [];
        recentContributions = [];
        overdueContributions = [];
        currentMonthContribution = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        member = await MemberService.GetMemberByIdAsync(MemberId);

        if (member is null)
        {
            isLoading = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(userId))
        {
            isLoading = false;
            return;
        }

        isAllowed = await MemberAccessService.CanAccessMemberHomeAsync(userId, MemberId);

        if (!isAllowed)
        {
            isLoading = false;
            return;
        }

        stokvel = await StokvelService.GetStokvelByTenantIdAsync(member.TenantId);

        if (stokvel is null)
        {
            isLoading = false;
            return;
        }

        memberFines = await FineService.GetMemberFinesAsync(MemberId);
        memberClaims = stokvel.EnableClaims ? await FuneralClaimService.GetClaimsByMemberIdAsync(MemberId) : [];
        dependents = stokvel.EnableDependents ? await MemberService.GetDependentsByMemberIdAsync(MemberId) : [];
        memberContributions = await ContributionPaymentService.GetContributionsByMemberIdAsync(MemberId);
        overdueContributions = await ContributionPaymentService.GetOverdueContributionsByMemberIdAsync(MemberId);
        currentMonthContribution = memberContributions.FirstOrDefault(contribution =>
            contribution.ContributionYear == DateTime.Today.Year &&
            contribution.ContributionMonth == DateTime.Today.Month);
        recentContributions = memberContributions.Take(6).ToList();

        var meetings = await MeetingService.GetMeetingsByStokvelIdAsync(stokvel.Id);
        upcomingMeetings = meetings
            .Where(meeting =>
                meeting.MeetingDate >= DateTime.Today &&
                (meeting.Status == MeetingStatus.Planned || meeting.Status == MeetingStatus.InProgress))
            .OrderBy(meeting => meeting.MeetingDate)
            .ToList();

        approvedMinutesByMeetingId = (await MeetingMinuteService.GetMinutesByStokvelIdAsync(stokvel.Id))
            .Where(minutes => minutes.Status is "Approved" or "Published")
            .GroupBy(minutes => minutes.MeetingId)
            .ToDictionary(group => group.Key, group => group.First());
        openVotes = await VotingService.GetOpenVotesForMemberAsync(MemberId, stokvel.Id);

        foreach (var meeting in upcomingMeetings)
        {
            var meetingApology = await MeetingApologyService.GetApologyAsync(meeting.Id, MemberId);

            if (meetingApology is not null)
            {
                meetingApologiesByMeetingId[meeting.Id] = meetingApology;
            }
        }

        isLoading = false;
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not captured" : value;
    }

    private static string GetMemberStatusVariant(MemberStatus status)
    {
        return status switch
        {
            MemberStatus.Active => "success",
            MemberStatus.Pending => "warning",
            MemberStatus.CoolingPeriod => "warning",
            MemberStatus.Suspended => "warning",
            MemberStatus.Deceased => "danger",
            MemberStatus.Resigned => "secondary",
            MemberStatus.Removed => "secondary",
            _ => "secondary"
        };
    }

    private static string GetMemberStatusBadgeClass(MemberStatus status)
    {
        return status switch
        {
            MemberStatus.Active => "sisonke-badge sisonke-badge-green",
            MemberStatus.Pending => "sisonke-badge sisonke-badge-gold",
            MemberStatus.CoolingPeriod => "sisonke-badge sisonke-badge-gold",
            MemberStatus.Suspended => "sisonke-badge sisonke-badge-red",
            MemberStatus.Deceased => "sisonke-badge sisonke-badge-red",
            MemberStatus.Resigned => "sisonke-badge sisonke-badge-gray",
            MemberStatus.Removed => "sisonke-badge sisonke-badge-gray",
            _ => "sisonke-badge sisonke-badge-gray"
        };
    }

    private static string GetPaymentStatusText(PaymentStatus status)
    {
        return status == PaymentStatus.Late ? "Overdue" : status.ToString();
    }

    private static string GetClaimStatusBadgeClass(FuneralClaimStatus status)
    {
        return status switch
        {
            FuneralClaimStatus.Draft => "sisonke-badge sisonke-badge-gray",
            FuneralClaimStatus.Submitted => "sisonke-badge sisonke-badge-blue",
            FuneralClaimStatus.UnderReview => "sisonke-badge sisonke-badge-teal",
            FuneralClaimStatus.OnHold => "sisonke-badge sisonke-badge-gold",
            FuneralClaimStatus.Approved => "sisonke-badge sisonke-badge-green",
            FuneralClaimStatus.Rejected => "sisonke-badge sisonke-badge-red",
            FuneralClaimStatus.Paid => "sisonke-badge sisonke-badge-green",
            FuneralClaimStatus.Cancelled => "sisonke-badge sisonke-badge-gray",
            _ => "sisonke-badge sisonke-badge-gray"
        };
    }

    private static string GetClaimStatusText(FuneralClaimStatus status)
    {
        return status switch
        {
            FuneralClaimStatus.Approved => "Approved / Awaiting Payout",
            FuneralClaimStatus.Paid => "Paid / Closed",
            _ => status.ToString()
        };
    }

    private static string GetClaimReference(FuneralClaim claim)
    {
        return string.IsNullOrWhiteSpace(claim.ClaimReference)
            ? $"CLM-{claim.Id.ToString("N")[..8].ToUpperInvariant()}"
            : claim.ClaimReference;
    }

    private static string GetMeetingStatusBadgeClass(MeetingStatus status)
    {
        return status switch
        {
            MeetingStatus.Planned => "sisonke-badge sisonke-badge-blue",
            MeetingStatus.Scheduled => "sisonke-badge sisonke-badge-gold",
            MeetingStatus.InProgress => "sisonke-badge sisonke-badge-teal",
            MeetingStatus.Completed => "sisonke-badge sisonke-badge-green",
            MeetingStatus.Cancelled => "sisonke-badge sisonke-badge-gray",
            _ => "sisonke-badge sisonke-badge-gray"
        };
    }

    private static string GetDependentStatusBadgeClass(MemberDependent dependent)
    {
        if (dependent.IsDeceased)
        {
            return "sisonke-badge sisonke-badge-red";
        }

        return dependent.IsActive
            ? "sisonke-badge sisonke-badge-green"
            : "sisonke-badge sisonke-badge-gray";
    }

    private static string GetDependentStatusText(MemberDependent dependent)
    {
        if (dependent.IsDeceased)
        {
            return "Deceased";
        }

        return dependent.IsActive ? "Active" : "Inactive";
    }

    private static string GetFineStatusBadgeClass(FineStatus status)
    {
        return status switch
        {
            FineStatus.Unpaid => "sisonke-badge sisonke-badge-red",
            FineStatus.Paid => "sisonke-badge sisonke-badge-green",
            FineStatus.Waived => "sisonke-badge sisonke-badge-gold",
            FineStatus.Cancelled => "sisonke-badge sisonke-badge-gray",
            _ => "sisonke-badge sisonke-badge-gray"
        };
    }

    private static string GetPaymentStatusBadgeClass(PaymentStatus status)
    {
        return status switch
        {
            PaymentStatus.Paid => "sisonke-badge sisonke-badge-green",
            PaymentStatus.PartiallyPaid => "sisonke-badge sisonke-badge-gold",
            PaymentStatus.Late => "sisonke-badge sisonke-badge-red",
            PaymentStatus.Unpaid => "sisonke-badge sisonke-badge-gray",
            PaymentStatus.Exempted => "sisonke-badge sisonke-badge-gray",
            PaymentStatus.WrittenOff => "sisonke-badge sisonke-badge-gray",
            _ => "sisonke-badge sisonke-badge-gray"
        };
    }

    private string GetApologyType(Guid meetingId)
    {
        return meetingApologiesByMeetingId.TryGetValue(meetingId, out var apology) &&
            !string.IsNullOrWhiteSpace(apology.ApologyType)
                ? apology.ApologyType
                : "Not specified";
    }

    private static string FormatCurrency(decimal amount)
    {
        return amount.ToString("C", new System.Globalization.CultureInfo("en-ZA"));
    }
}
