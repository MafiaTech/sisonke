        <section class="mw-card dashboard-panel recent-activity-panel">
            <div class="dashboard-panel-head">
                <div><span class="dashboard-panel-eyebrow">Latest updates</span><h2>Recent Activity</h2></div>
                <span class="dashboard-panel-icon"><i class="bi bi-activity"></i></span>
            </div>
            @if (recentContributions.Count == 0 && memberFines.Count == 0 && approvedMinutesByMeetingId.Count == 0)
            {
                <div class="dashboard-empty"><i class="bi bi-inbox"></i><span>No recent activity yet.</span></div>
            }
            else
            {
                <div class="activity-list">
                    @if (recentContributions.FirstOrDefault() is { } recentContribution)
                    {
                        <div class="activity-item"><i class="bi bi-cash-coin"></i><span><strong>Contribution update</strong><small>@recentContribution.MonthYearLabel · @GetPaymentStatusText(recentContribution.Status)</small></span></div>
                    }
                    @if (memberFines.FirstOrDefault() is { } recentFine)
                    {
                        <div class="activity-item"><i class="bi bi-receipt"></i><span><strong>Fine update</strong><small>@Display(recentFine.Reason) · @recentFine.FineDate.ToString("dd MMM yyyy")</small></span></div>
                    }
                    @if (approvedMinutesByMeetingId.Values.OrderByDescending(item => item.ApprovedAt ?? item.CreatedAt).FirstOrDefault() is { } recentMinutes)
                    {
                        <a class="activity-item" href="/meeting-minutes/@recentMinutes.MeetingId"><i class="bi bi-file-earmark-check"></i><span><strong>Minutes published</strong><small>@Display(recentMinutes.Title)</small></span></a>
                    }
                </div>
            }
        </section>

        <section class="member-community-footer">
            <i class="bi bi-people-fill"></i>
            <div><strong>Stronger together</strong><span>Thank you for your commitment. Transparency builds trust and keeps our stokvel strong.</span></div>
        </section>
    </div>
}

<script>
    (function () {
        var h = new Date().getHours();
        var g = h < 12 ? 'Good morning \uD83C\uDF3F'
            : h < 18 ? 'Good afternoon \u2600\uFE0F'
            : 'Good evening \uD83C\uDF19';
        var el = document.getElementById('mw-greeting');
        if (el) {
            el.textContent = g;
        }
    })();
</script>

@code {
    [Parameter]
    public Guid MemberId { get; set; }

    private Member? member;
    private Stokvel? stokvel;
    private RotationalPayoutOrderSummary rotationOrderSummary = new(false, 0, null, null, null);
    private List<MemberFine> memberFines = [];
    private List<FuneralClaim> memberClaims = [];
    private List<MemberDependent> dependents = [];
    private List<Meeting> upcomingMeetings = [];
    private List<VoteMotion> openVotes = [];
    private Dictionary<Guid, MeetingMinute> approvedMinutesByMeetingId = [];
    private Dictionary<Guid, MeetingApology> meetingApologiesByMeetingId = [];
    private List<ContributionPaymentSummary> memberContributions = [];
    private List<ContributionPaymentSummary> recentContributions = [];
    private List<MemberContribution> overdueContributions = [];
    private List<MemberContribution> currentMonthStokvelContributions = [];
    private List<RotationalContributionPayment> currentCycleRotationalContributions = [];
    private List<MemberFine> stokvelOutstandingFines = [];
    private ContributionPaymentSummary? currentMonthContribution;
    private MemberRotationalView? rotationalMemberView;
    private bool isLoading = true;
    private bool isAllowed;
    private string CurrentMonthLabel => DateTime.Today.ToString("MMMM yyyy");
    private string CurrentContributionLabel => stokvel?.EnableRotation == true && rotationalMemberView?.CurrentCycle is not null
        ? rotationalMemberView.CurrentCycle.CycleName
        : CurrentMonthLabel;

    private FuneralClaim? LatestClaim => memberClaims
        .OrderByDescending(claim => claim.CreatedAt)
        .FirstOrDefault();

    private Meeting? NextMeeting => upcomingMeetings
        .OrderBy(meeting => meeting.MeetingDate)
        .FirstOrDefault();

    private int DraftClaimCount => memberClaims.Count(claim => claim.Status == FuneralClaimStatus.Draft);
    private int SubmittedOrReviewClaimCount => memberClaims.Count(claim =>
        claim.Status is FuneralClaimStatus.Submitted or FuneralClaimStatus.UnderReview or FuneralClaimStatus.OnHold);
    private int ApprovedClaimCount => memberClaims.Count(claim =>
        claim.Status is FuneralClaimStatus.Approved or FuneralClaimStatus.Paid);
    private int RejectedClaimCount => memberClaims.Count(claim => claim.Status == FuneralClaimStatus.Rejected);

    private int ActiveDependentCount => dependents.Count(dependent => dependent.IsActive);
    private int DeceasedDependentCount => dependents.Count(dependent => dependent.IsDeceased);
    private int InactiveDependentCount => dependents.Count(dependent => !dependent.IsActive && !dependent.IsDeceased);

    private decimal OutstandingFineTotal => memberFines
        .Where(fine => fine.Status == FineStatus.Unpaid)
        .Sum(fine => fine.Amount);

    private int OpenFinesCount => memberFines.Count(fine => fine.Status == FineStatus.Unpaid);
    private int PaidFinesCount => memberFines.Count(fine => fine.Status == FineStatus.Paid);
    private int ApologiesSubmittedCount => meetingApologiesByMeetingId.Count;
    private int PendingApologyCount => Math.Max(0, upcomingMeetings.Count - meetingApologiesByMeetingId.Count);
    private decimal CurrentContributionTotal => currentMonthContribution?.ExpectedAmount ??
        recentContributions.FirstOrDefault()?.ExpectedAmount ??
        0;
    private decimal MemberContributionOutstandingTotal => memberContributions
        .Where(contribution =>
            contribution.Status != PaymentStatus.Paid &&
            contribution.Status != PaymentStatus.Exempted &&
            contribution.Status != PaymentStatus.WrittenOff)
        .Sum(contribution => contribution.Balance);

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        isAllowed = false;
        member = null;
        stokvel = null;
        rotationOrderSummary = new(false, 0, null, null, null);
        memberFines = [];
        memberClaims = [];
        dependents = [];
        upcomingMeetings = [];
        openVotes = [];
        approvedMinutesByMeetingId = [];
        meetingApologiesByMeetingId = [];
        memberContributions = [];
        recentContributions = [];
        overdueContributions = [];
        currentMonthStokvelContributions = [];
        currentCycleRotationalContributions = [];
        stokvelOutstandingFines = [];
        currentMonthContribution = null;
        rotationalMemberView = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        member = await MemberService.GetMemberByIdAsync(MemberId);

        if (member is null)
        {
            isLoading = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(userId))
        {
            isLoading = false;
            return;
        }

        isAllowed = await MemberAccessService.CanAccessMemberHomeAsync(userId, MemberId);

        if (!isAllowed)
        {
            isLoading = false;
            return;
        }

        stokvel = await StokvelService.GetStokvelByTenantIdAsync(member.TenantId);

        if (stokvel is null)
        {
            isLoading = false;
            return;
        }

        memberFines = await FineService.GetMemberFinesAsync(MemberId);
        memberClaims = stokvel.EnableClaims ? await FuneralClaimService.GetClaimsByMemberIdAsync(MemberId) : [];
        dependents = stokvel.EnableDependents ? await MemberService.GetDependentsByMemberIdAsync(MemberId) : [];
        if (stokvel.EnableRotation)
        {
            rotationalMemberView = await RotationalTaskService.GetMemberRotationalViewAsync(stokvel.Id, MemberId);
            var rotationalMemberPayments = await RotationalContributionPaymentService.GetPaymentsForMemberAsync(stokvel.Id, MemberId);
            memberContributions = rotationalMemberPayments
                .Select(payment => MapRotationalPaymentToContributionSummary(payment))
                .ToList();
            recentContributions = memberContributions.Take(6).ToList();

            if (rotationalMemberView.CurrentCycle is not null)
            {
                currentCycleRotationalContributions = await RotationalContributionPaymentService.GetPaymentsForCycleAsync(rotationalMemberView.CurrentCycle.Id);
                currentMonthContribution = rotationalMemberView.MyPayment is not null
                    ? MapRotationalPaymentToContributionSummary(rotationalMemberView.MyPayment, rotationalMemberView.CurrentCycle)
                    : null;
            }
        }
        else
        {
            memberContributions = await ContributionPaymentService.GetContributionsByMemberIdAsync(MemberId);
            overdueContributions = await ContributionPaymentService.GetOverdueContributionsByMemberIdAsync(MemberId);
            currentMonthStokvelContributions = await ContributionPaymentService.GetMonthlyContributionsAsync(
                stokvel.Id,
                DateTime.Today.Year,
                DateTime.Today.Month);
            currentMonthContribution = memberContributions.FirstOrDefault(contribution =>
                contribution.ContributionYear == DateTime.Today.Year &&
                contribution.ContributionMonth == DateTime.Today.Month);
            recentContributions = memberContributions.Take(6).ToList();
        }
        stokvelOutstandingFines = await FineService.GetOutstandingFinesByStokvelIdAsync(stokvel.Id);

        var meetings = await MeetingService.GetMeetingsByStokvelIdAsync(stokvel.Id);
        upcomingMeetings = meetings
            .Where(meeting =>
                meeting.MeetingDate >= DateTime.Today &&
                (meeting.Status == MeetingStatus.Planned || meeting.Status == MeetingStatus.InProgress))
            .OrderBy(meeting => meeting.MeetingDate)
            .ToList();

        approvedMinutesByMeetingId = (await MeetingMinuteService.GetMinutesByStokvelIdAsync(stokvel.Id))
            .Where(minutes => minutes.Status is "Approved" or "Published")
            .GroupBy(minutes => minutes.MeetingId)
            .ToDictionary(group => group.Key, group => group.First());
        openVotes = await VotingService.GetOpenVotesForMemberAsync(MemberId, stokvel.Id);
        if (stokvel.EnableRotation)
        {
            rotationOrderSummary = await RotationalPayoutOrderService.GetSummaryAsync(stokvel.Id, MemberId);
        }

        foreach (var meeting in upcomingMeetings)
        {
            var meetingApology = await MeetingApologyService.GetApologyAsync(meeting.Id, MemberId);

            if (meetingApology is not null)
            {
                meetingApologiesByMeetingId[meeting.Id] = meetingApology;
            }
        }

        isLoading = false;
    }

