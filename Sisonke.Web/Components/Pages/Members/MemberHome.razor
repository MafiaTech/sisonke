                                {
                                    <tr class="@(contribution.MemberId == MemberId ? "member-current-row" : null)">
                                        <td>@Display(contribution.Member?.FullName) @(contribution.MemberId == MemberId ? "(You)" : null)</td>
                                        <td><span class="@GetRotationalPaymentStatusBadgeClass(contribution.PaymentStatus)">@GetRotationalPaymentStatusText(contribution.PaymentStatus)</span></td>
                                        <td>@FormatCurrency(contribution.ExpectedAmount)</td>
                                        <td>@FormatCurrency(contribution.PaidAmount)</td>
                                        <td>@FormatCurrency(GetRotationalPaymentBalance(contribution))</td>
                                        <td>@(contribution.PaymentDate?.ToString("dd MMM yyyy") ?? "Pending")</td>
                                    </tr>
                                }
                                </tbody>
