                        <div class="mw-p-row"><span class="mw-p-lbl">Benefit amount</span><span class="mw-p-val">Not configured</span></div>
                        <div class="mw-p-row"><span class="mw-p-lbl">Dependents covered</span><span class="mw-p-val">@(stokvel.EnableDependents ? ActiveDependentCount.ToString() : "Not available")</span></div>
                        <div class="mw-p-row"><span class="mw-p-lbl">Latest claim</span><span class="mw-p-val">@(LatestClaim is null ? "No claim submitted yet" : GetClaimStatusText(LatestClaim.Status))</span></div>
                    </div>
                </div>
