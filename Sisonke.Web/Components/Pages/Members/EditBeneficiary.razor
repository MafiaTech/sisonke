@page "/edit-beneficiary/{BeneficiaryId:guid}"
@rendermode InteractiveServer

@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject MemberService MemberService
@inject NavigationManager NavigationManager

<PageTitle>Edit Beneficiary</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading…
    </div>
}
else if (editBeneficiary is null)
{
    <AlertBanner Type="danger" Title="Beneficiary record not found." Message="" Icon="bi bi-x-circle-fill" />
}
else
{
    <PageHeader
        Title="Edit Beneficiary"
        Subtitle="@editBeneficiary.Member.FullName"
        BackText="Back to Member Profile"
        BackHref="@($"/member-profile/{editBeneficiary.MemberId}")" />

    @if (saveFailed)
    {
        <AlertBanner Type="danger" Title="Unable to update beneficiary record." Message="Please try again." Icon="bi bi-x-circle-fill" />
    }

    <EditForm Model="@editBeneficiary" OnValidSubmit="@HandleValidSubmit" FormName="EditBeneficiaryForm">
        <DataAnnotationsValidator />
        <ValidationSummary class="alert alert-danger" />

        <div class="form-page">
            <div class="card mb-4">
                <div class="card-body p-4">
                    <p class="form-section-title">Beneficiary Details</p>
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="full-name">Full name</label>
                            <InputText id="full-name" class="form-control" placeholder="e.g. Lindiwe Dlamini" @bind-Value="editBeneficiary.FullName" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="relationship">Relationship</label>
                            <InputSelect id="relationship" class="form-select" @bind-Value="editBeneficiary.Relationship">
                                @foreach (var relationship in relationshipOptions)
                                {
                                    <option value="@relationship">@relationship</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="id-number">ID number</label>
                            <InputText id="id-number" class="form-control" placeholder="13-digit SA ID number" @bind-Value="editBeneficiary.IdNumber" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="cellphone-number">Cellphone number</label>
                            <InputText id="cellphone-number" class="form-control" placeholder="e.g. 0821234567" @bind-Value="editBeneficiary.CellphoneNumber" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="date-of-birth">Date of birth</label>
                            <InputDate id="date-of-birth" class="form-control" @bind-Value="editBeneficiary.DateOfBirth" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <InputCheckbox id="is-active" class="form-check-input" @bind-Value="editBeneficiary.IsActive" />
                                <label class="form-check-label fw-semibold" for="is-active">Active beneficiary</label>
                            </div>
                            <div class="form-text">Inactive beneficiaries are excluded from payout distributions.</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-floppy me-2"></i>Save Changes
                </button>
                <a class="btn btn-outline-secondary" href="@($"/member-profile/{editBeneficiary.MemberId}")">Cancel</a>
            </div>
        </div>
    </EditForm>
}

@code {
    private static readonly string[] relationshipOptions =
    [
        "Spouse",
        "Child",
        "Parent",
        "Sibling",
        "Grandparent",
        "Grandchild",
        "Aunt/Uncle",
        "Cousin",
        "Friend",
        "Other"
    ];

    private Beneficiary? editBeneficiary;
    private bool isLoading = true;
    private bool saveFailed;

    [Parameter]
    public Guid BeneficiaryId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        editBeneficiary = await MemberService.GetBeneficiaryByIdAsync(BeneficiaryId);
        isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        if (editBeneficiary is null)
        {
            return;
        }

        saveFailed = false;

        var updatedBeneficiary = await MemberService.UpdateBeneficiaryAsync(editBeneficiary);

        if (updatedBeneficiary is null)
        {
            saveFailed = true;
            return;
        }

        NavigationManager.NavigateTo($"/member-profile/{editBeneficiary.MemberId}");
    }
}
