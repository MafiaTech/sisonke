@page "/edit-next-of-kin/{NextOfKinId:guid}"
@rendermode InteractiveServer

@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject MemberService MemberService
@inject NavigationManager NavigationManager

<PageTitle>Edit Next of Kin</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading…
    </div>
}
else if (editNextOfKin is null)
{
    <AlertBanner Type="danger" Title="Next of kin record not found." Message="" Icon="bi bi-x-circle-fill" />
}
else
{
    <PageHeader
        Title="Edit Next of Kin"
        Subtitle="@editNextOfKin.Member.FullName"
        BackText="Back to Member Profile"
        BackHref="@($"/member-profile/{editNextOfKin.MemberId}")" />

    @if (saveFailed)
    {
        <AlertBanner Type="danger" Title="Unable to update next of kin record." Message="Please try again." Icon="bi bi-x-circle-fill" />
    }

    <EditForm Model="@editNextOfKin" OnValidSubmit="@HandleValidSubmit" FormName="EditNextOfKinForm">
        <DataAnnotationsValidator />
        <ValidationSummary class="alert alert-danger" />

        <div class="form-page">
            <div class="card mb-4">
                <div class="card-body p-4">
                    <p class="form-section-title">Next of Kin Details</p>
                    <div class="row g-3">
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="full-name">Full name</label>
                            <InputText id="full-name" class="form-control" placeholder="e.g. Sipho Nkosi" @bind-Value="editNextOfKin.FullName" />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="relationship">Relationship</label>
                            <InputSelect id="relationship" class="form-select" @bind-Value="editNextOfKin.Relationship">
                                @foreach (var relationship in relationshipOptions)
                                {
                                    <option value="@relationship">@relationship</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="cellphone-number">Cellphone number</label>
                            <InputText id="cellphone-number" class="form-control" placeholder="e.g. 0821234567" @bind-Value="editNextOfKin.CellphoneNumber" />
                        </div>
                        <div class="col-12">
                            <label class="form-label" for="address">Address</label>
                            <InputText id="address" class="form-control" placeholder="e.g. 12 Main St, Soweto" @bind-Value="editNextOfKin.Address" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <InputCheckbox id="is-primary" class="form-check-input" @bind-Value="editNextOfKin.IsPrimary" />
                                <label class="form-check-label fw-semibold" for="is-primary">Primary next of kin</label>
                            </div>
                            <div class="form-text">The primary next of kin is the first contact in case of an emergency.</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary" type="submit">
                    <i class="bi bi-floppy me-2"></i>Save Changes
                </button>
                <a class="btn btn-outline-secondary" href="@($"/member-profile/{editNextOfKin.MemberId}")">Cancel</a>
            </div>
        </div>
    </EditForm>
}

@code {
    private static readonly string[] relationshipOptions =
    [
        "Spouse",
        "Child",
        "Parent",
        "Sibling",
        "Grandparent",
        "Grandchild",
        "Aunt/Uncle",
        "Cousin",
        "Friend",
        "Other"
    ];

    private NextOfKin? editNextOfKin;
    private bool isLoading = true;
    private bool saveFailed;

    [Parameter]
    public Guid NextOfKinId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        editNextOfKin = await MemberService.GetNextOfKinByIdAsync(NextOfKinId);
        isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        if (editNextOfKin is null)
        {
            return;
        }

        saveFailed = false;

        var updatedNextOfKin = await MemberService.UpdateNextOfKinAsync(editNextOfKin);

        if (updatedNextOfKin is null)
        {
            saveFailed = true;
            return;
        }

        NavigationManager.NavigateTo($"/member-profile/{editNextOfKin.MemberId}");
    }
}
