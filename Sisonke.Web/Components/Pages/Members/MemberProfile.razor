@code {
    private Member? member;
    private List<MemberDependent> dependents = [];
    private List<MemberFine> memberFines = [];
    private List<FuneralClaim> funeralClaims = [];
    private List<MemberWarning> memberWarnings = [];
    private List<MemberGovernanceTimelineItemDto> timelineItems = [];
    private List<MemberGovernanceTimelineItemDto> visibleTimelineItems = [];
    private Dictionary<Guid, FuneralClaim> activeDependentClaims = new();
    private Stokvel? stokvel;
    private int maxNextOfKin;
    private int maxBeneficiaries;
    private int maxDependents;
    private bool isLoading = true;
    private bool showGovernanceStatusConfirmation;
    private MemberGovernanceStatus selectedGovernanceStatus = MemberGovernanceStatus.Active;
    private string? governanceStatusReason;
    private string? successMessage;
    private string? warningMessage;
    private bool canManageStokvel;
    private bool canManagePayments;
    private bool canManageMemberStatus;
    private bool isOwnMemberProfile;
    private bool canViewFines;
    private bool canViewFinancials;

    private int OpenMemberWarningCount => memberWarnings.Count(warning => warning.Status == "Open");

    [Parameter]
    public Guid MemberId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        canManageStokvel = false;
        canManagePayments = false;
        canManageMemberStatus = false;
        isOwnMemberProfile = false;
        canViewFines = false;
        canViewFinancials = false;
        successMessage = null;
        warningMessage = null;
        memberWarnings = [];
        timelineItems = [];
        visibleTimelineItems = [];
        member = await MemberService.GetMemberByIdAsync(MemberId);
        stokvel = member is null ? null : await StokvelService.GetStokvelByTenantIdAsync(member.TenantId);

        if (member is not null && stokvel is not null)
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

            if (!string.IsNullOrWhiteSpace(userId))
            {
                canManageStokvel = await MemberAccessService.CanManageStokvelAsync(userId, stokvel.Id);
                canManagePayments = await MemberAccessService.CanManagePaymentsAsync(userId, stokvel.Id);
                canManageMemberStatus = await MemberAccessService.CanManageMemberStatusAsync(userId, stokvel.Id);
                isOwnMemberProfile = await MemberAccessService.CanViewOwnMemberProfileAsync(userId, MemberId);
                canViewFinancials = await MemberAccessService.CanViewFinancialsAsync(userId, stokvel.Id);
                canViewFines = canManageStokvel || isOwnMemberProfile;
            }
        }

        maxNextOfKin = stokvel is null ? 0 : await OperatingRuleService.GetMaxNextOfKinAsync(stokvel.Id);
        maxBeneficiaries = stokvel is null ? 0 : await OperatingRuleService.GetMaxBeneficiariesAsync(stokvel.Id);
        maxDependents = stokvel is null ? 0 : await OperatingRuleService.GetMaxDependentsAsync(stokvel.Id);
        dependents = member is null || stokvel?.EnableDependents != true ? [] : await MemberService.GetDependentsByMemberIdAsync(MemberId);
        activeDependentClaims = member is null || stokvel?.EnableClaims != true ? new() : await FuneralClaimService.GetActiveDependentClaimsByMemberIdAsync(MemberId);
        memberFines = member is null || !canViewFines ? [] : await FineService.GetMemberFinesAsync(MemberId);
        funeralClaims = member is null || stokvel?.EnableClaims != true ? [] : await FuneralClaimService.GetClaimsByMemberIdAsync(MemberId);
        memberWarnings = member is null || (!canManageMemberStatus && !isOwnMemberProfile) ? [] : await MemberWarningService.GetWarningsByMemberIdAsync(MemberId);
        timelineItems = member is null || stokvel is null ? [] : await MemberGovernanceTimelineService.GetTimelineByMemberIdAsync(MemberId, stokvel.Id);
        visibleTimelineItems = GetVisibleTimelineItems();

        if (member is not null)
        {
            selectedGovernanceStatus = member.GovernanceStatus;
            governanceStatusReason = member.GovernanceStatusReason;
        }

        isLoading = false;
    }

    private static string GetInitials(string fullName)
    {
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : parts.Length == 1 ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant() : "M";
    }

    private string GetStokvelDisplayName()
    {
        return stokvel?.Name ?? member?.Tenant.Name ?? "Stokvel";
    }

    private string GetAccountLinkStatusText()
    {
        return string.IsNullOrWhiteSpace(member?.ApplicationUserId)
            ? "No Login Account"
            : "Account Linked";
    }

    private string GetAccountLinkStatusBadgeType()
    {
        return string.IsNullOrWhiteSpace(member?.ApplicationUserId)
            ? "secondary"
            : "success";
    }

    private void ShowGovernanceStatusConfirmation()
    {
        successMessage = null;
        warningMessage = null;

        if (!canManageMemberStatus)
        {
            warningMessage = "You are not authorised to update this member's status.";
            return;
        }

        showGovernanceStatusConfirmation = true;
    }

    private void CancelGovernanceStatusUpdate()
    {
        showGovernanceStatusConfirmation = false;
    }

    private async Task ConfirmGovernanceStatusUpdateAsync()
    {
        showGovernanceStatusConfirmation = false;
        successMessage = null;
        warningMessage = null;

        if (!canManageMemberStatus)
        {
            warningMessage = "You are not authorised to update this member's status.";
            return;
        }

        var updatedMember = await MemberService.UpdateMemberGovernanceStatusAsync(
            MemberId,
            selectedGovernanceStatus,
            governanceStatusReason);

        if (updatedMember is null)
        {
            return;
        }

        member = await MemberService.GetMemberByIdAsync(MemberId);
        stokvel = member is null ? null : await StokvelService.GetStokvelByTenantIdAsync(member.TenantId);

        if (member is not null)
        {
            selectedGovernanceStatus = member.GovernanceStatus;
            governanceStatusReason = member.GovernanceStatusReason;
        }

        successMessage = "Member governance status updated.";
    }

    private static string GetGovernanceStatusBadgeType(MemberGovernanceStatus governanceStatus) =>
        governanceStatus switch
        {
            MemberGovernanceStatus.Active => "success",
            MemberGovernanceStatus.Warning => "warning",
            MemberGovernanceStatus.Suspended => "danger",
            MemberGovernanceStatus.Expelled => "secondary",
            MemberGovernanceStatus.Deceased => "danger",
            _ => "secondary"
        };

    private string GetMemberStandingText()
    {
        if (member is null)
        {
            return "Unknown";
        }

        return member.GovernanceStatus switch
        {
            MemberGovernanceStatus.Suspended => "Suspended",
            MemberGovernanceStatus.Active => "Active",
            _ => member.GovernanceStatus.ToString()
        };
    }

    private static string GetGovernanceStatusBadgeClass(MemberGovernanceStatus governanceStatus)
    {
        return governanceStatus switch
        {
            MemberGovernanceStatus.Active => "sisonke-badge sisonke-badge-green",
            MemberGovernanceStatus.Warning => "sisonke-badge sisonke-badge-gold",
            MemberGovernanceStatus.Suspended => "sisonke-badge sisonke-badge-red",
            MemberGovernanceStatus.Expelled => "sisonke-badge sisonke-badge-gray",
            MemberGovernanceStatus.Deceased => "sisonke-badge sisonke-badge-red",
            _ => "sisonke-badge sisonke-badge-gray"
        };
    }

    private static string GetDependentStatusText(MemberDependent dependent, bool hasActiveClaim)
    {
        if (hasActiveClaim)
        {
            return "Claim Logged";
        }

        if (dependent.IsDeceased)
        {
            return "Deceased";
        }

        return dependent.IsActive ? "Active" : "Inactive";
    }

    private static string GetDependentStatusBadgeType(MemberDependent dependent, bool hasActiveClaim)
    {
        if (hasActiveClaim)
        {
            return "warning";
        }

        if (dependent.IsDeceased)
        {
            return "danger";
        }

        return dependent.IsActive ? "success" : "secondary";
    }

    private static string GetClaimStatusBadgeType(FuneralClaimStatus status) =>
        status switch
        {
            FuneralClaimStatus.Draft => "secondary",
            FuneralClaimStatus.Submitted => "info",
            FuneralClaimStatus.UnderReview => "info",
            FuneralClaimStatus.OnHold => "warning",
            FuneralClaimStatus.Approved => "success",
            FuneralClaimStatus.Rejected => "danger",
            FuneralClaimStatus.Paid => "success",
            FuneralClaimStatus.Cancelled => "secondary",
            _ => "secondary"
        };

    private static string GetWarningBadgeClass(string warningType)
    {
        return warningType switch
        {
            "ExecutiveReviewRequired" => "sisonke-badge sisonke-badge-red",
            "FormalWarning" => "sisonke-badge sisonke-badge-gold",
            "Reminder" => "sisonke-badge sisonke-badge-blue",
            _ => "sisonke-badge sisonke-badge-gray"
        };
    }

    private static string GetWarningTypeLabel(string warningType) =>
        warningType switch
        {
            "ExecutiveReviewRequired" => "Executive Review Required",
            "FormalWarning" => "Formal Warning",
            "Reminder" => "Reminder",
            _ => warningType
        };

    private static string GetWarningStatusBadgeClass(string status) =>
        status switch
        {
            "Open" => "sisonke-badge sisonke-badge-gold",
            "Acknowledged" => "sisonke-badge sisonke-badge-blue",
            "Resolved" => "sisonke-badge sisonke-badge-green",
            _ => "sisonke-badge sisonke-badge-gray"
        };

    private static string DisplayOrDash(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private List<MemberGovernanceTimelineItemDto> GetVisibleTimelineItems()
    {
        if (canManageStokvel || canManageMemberStatus || canViewFinancials)
        {
            return timelineItems;
        }

        if (!isOwnMemberProfile)
        {
            return [];
        }

        return timelineItems
            .Where(item => SafePersonalTimelineTypes.Contains(item.EventType))
            .ToList();
    }

    private static readonly HashSet<string> SafePersonalTimelineTypes = new(StringComparer.OrdinalIgnoreCase)
    {
        "Membership",
        "Covered Life",
        "Apology",
        "Claim",
        "Payout",
        "Contribution"
    };

    private static string FormatTimelineDate(DateTime eventDate)
    {
        return eventDate == default || eventDate == DateTime.MinValue
            ? "Date not recorded"
            : eventDate.ToLocalTime().ToString("dd MMM yyyy HH:mm");
    }

    private static string GetTimelineEventBadgeClass(string badgeStyle)
    {
        return badgeStyle switch
        {
            "green" => "sisonke-badge sisonke-badge-green",
            "red" => "sisonke-badge sisonke-badge-red",
            "gold" => "sisonke-badge sisonke-badge-gold",
            "blue" => "sisonke-badge sisonke-badge-blue",
            _ => "sisonke-badge sisonke-badge-gray"
        };
    }

    private static string GetTimelineStatusBadgeClass(string status)
    {
        return status switch
        {
            "Approved" or "Paid" or "Active" or "Present" or "Resolved" => "sisonke-badge sisonke-badge-green",
            "Rejected" or "Suspended" or "Expelled" or "Absent" or "Unpaid" => "sisonke-badge sisonke-badge-red",
            "Warning" or "OnHold" or "PartiallyPaid" or "Late" or "Open" => "sisonke-badge sisonke-badge-gold",
            "Reviewed" or "Submitted" or "Voted" => "sisonke-badge sisonke-badge-blue",
            _ => "sisonke-badge sisonke-badge-gray"
        };
    }
}
