@page "/member-profile/{MemberId:guid}"
@rendermode InteractiveServer

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services
@using Sisonke.Web.Services.Dto

@inject FineService FineService
@inject FuneralClaimService FuneralClaimService
@inject MemberService MemberService
@inject MemberWarningService MemberWarningService
@inject MemberGovernanceTimelineService MemberGovernanceTimelineService
@inject OperatingRuleService OperatingRuleService
@inject StokvelService StokvelService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccessService MemberAccessService

<PageTitle>Member Profile</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading member profile…
    </div>
}
else if (member is null)
{
    <AlertBanner Type="danger" Title="Member not found." Message="" Icon="bi bi-x-circle-fill" />
}
else
{
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <AlertBanner Type="success" Title="@successMessage" Message="" Icon="bi bi-check-circle-fill" />
    }

    @if (!string.IsNullOrWhiteSpace(warningMessage))
    {
        <AlertBanner Type="warning" Title="@warningMessage" Message="" Icon="bi bi-exclamation-triangle-fill" />
    }

    <!-- ── Back nav + action bar ── -->
    <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
        <div>
            @if (stokvel is not null)
            {
                <a class="btn btn-outline-secondary btn-sm" href="@($"/members/{stokvel.Id}")">
                    <i class="bi bi-chevron-left me-1"></i>Members
                </a>
            }
            else
            {
                <a class="btn btn-outline-secondary btn-sm" href="/my-stokvels">
                    <i class="bi bi-chevron-left me-1"></i>My Stokvels
                </a>
            }
        </div>
        <div class="d-flex flex-wrap gap-2">
            @if (stokvel is not null && (isOwnMemberProfile || canViewFinancials))
            {
                <a class="btn btn-outline-primary btn-sm" href="@($"/member-statement/{MemberId}/{stokvel.Id}")">
                    <i class="bi bi-receipt me-1"></i>View Financial Statement
                </a>
            }
            <a class="btn btn-primary btn-sm" href="@($"/edit-member/{MemberId}")">
                <i class="bi bi-pencil me-1"></i>Edit Member
            </a>
        </div>
    </div>

    <!-- ── Modern profile header ── -->
    <section class="member-profile-hero">
        <div class="member-profile-hero-main">
            <div class="member-profile-avatar" aria-hidden="true">
                @GetInitials(member.FullName)
            </div>
            <div class="member-profile-identity">
                <h1>@member.FullName</h1>
                <div class="member-profile-contact">
                    <span><i class="bi bi-phone me-1"></i>@SensitiveDataMasker.MaskPhoneNumber(member.CellphoneNumber)</span>
                    <span><i class="bi bi-envelope me-1"></i>@SensitiveDataMasker.MaskEmail(member.EmailAddress)</span>
                    <span><i class="bi bi-geo-alt me-1"></i>@(member.ResidentialArea ?? "No area captured")</span>
                </div>
                <div class="member-profile-badges">
                    <span class="profile-chip">@member.MemberNumber</span>
                    <StatusBadge Text="@member.DefaultRole.ToString()" Type="secondary" />
                    <span class="profile-chip">@GetStokvelDisplayName()</span>
                    <StatusBadge Text="@member.GovernanceStatus.ToString()" Type="@GetGovernanceStatusBadgeType(member.GovernanceStatus)" />
                    <StatusBadge Text="@GetAccountLinkStatusText()" Type="@GetAccountLinkStatusBadgeType()" />
                </div>
            </div>
        </div>
        <div class="member-profile-since">
            <div class="member-profile-since-label">Member since</div>
            <div class="member-profile-since-date">@member.JoiningDate.ToString("dd MMM yyyy")</div>
        </div>
    </section>

    @if (member.GovernanceStatus == MemberGovernanceStatus.Suspended)
    {
        @* TODO: Later decide how suspended members affect claim eligibility. *@
        <AlertBanner
            Type="warning"
            Title="This member is currently suspended."
            Message="This status was set by a manual governance decision."
            Icon="bi bi-exclamation-triangle-fill" />
    }
    else if (member.GovernanceStatus == MemberGovernanceStatus.Expelled)
    {
        <AlertBanner
            Type="danger"
            Title="This member is expelled."
            Message="Claims linked to this member or their dependents may be placed on hold unless reversed by a disciplinary decision."
            Icon="bi bi-x-circle-fill" />
    }
    else if (member.GovernanceStatus == MemberGovernanceStatus.Warning)
    {
        <AlertBanner
            Type="warning"
            Title="This member is under warning."
            Message="Monitor attendance and conduct before approving sensitive actions."
            Icon="bi bi-exclamation-triangle-fill" />
    }

    <section class="sisonke-card mb-3">
        <div class="sisonke-card-head">
            <div>
                <h2>Governance Status</h2>
                <p>Current member standing and attendance warning summary.</p>
            </div>
            <span class="@GetGovernanceStatusBadgeClass(member.GovernanceStatus)">
                @member.GovernanceStatus
            </span>
        </div>
        <div class="sisonke-card-body">
            <div class="member-governance-summary">
                <div>
                    <div class="member-governance-label">Status</div>
                    <div class="member-governance-value">@GetMemberStandingText()</div>
                </div>
                <div>
                    <div class="member-governance-label">Warning count</div>
                    <div class="member-governance-value">@memberWarnings.Count</div>
                </div>
                <div>
                    <div class="member-governance-label">Open warnings</div>
                    <div class="member-governance-value">@OpenMemberWarningCount</div>
                </div>
                <div>
                    <div class="member-governance-label">Last status update</div>
                    <div class="member-governance-value">@(member.GovernanceStatusChangedAt?.ToString("dd MMM yyyy") ?? "—")</div>
                </div>
            </div>
        </div>
    </section>

    <section class="sisonke-card mb-3">
        <div class="sisonke-card-head">
            <div>
                <h2>Member Governance Timeline</h2>
                <p>This timeline brings together member activity from claims, contributions, attendance, apologies, voting and governance records.</p>
            </div>
            <span class="sisonke-badge sisonke-badge-gray">@visibleTimelineItems.Count event(s)</span>
        </div>
        <div class="sisonke-card-body">
            @if (visibleTimelineItems.Count == 0)
            {
                <div class="sisonke-alert sisonke-alert-info mb-0">
                    No governance timeline activity has been recorded for this member yet.
                </div>
            }
            else
            {
                <div class="governance-timeline">
                    @foreach (var item in visibleTimelineItems)
                    {
                        <article class="governance-timeline-item">
                            <div class="governance-timeline-date">
                                <span>@FormatTimelineDate(item.EventDate)</span>
                            </div>
                            <div class="governance-timeline-content">
                                <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                    <div>
                                        <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                            <span class="@GetTimelineEventBadgeClass(item.BadgeStyle)">@item.EventType</span>
                                            <span class="@GetTimelineStatusBadgeClass(item.Status)">@item.Status</span>
                                        </div>
                                        <h3 class="governance-timeline-title">@item.Title</h3>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(item.LinkUrl))
                                    {
                                        <a class="sisonke-btn sisonke-btn-outline btn-sm" href="@item.LinkUrl">Open</a>
                                    }
                                </div>
                                <p class="governance-timeline-description">@item.Description</p>
                                @if (!string.IsNullOrWhiteSpace(item.Reference))
                                {
                                    <div class="text-muted small">Reference: @item.Reference</div>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </div>
    </section>

    <!-- ── Detail cards ── -->
    <div class="row g-3">

        <!-- Personal details -->
        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-body p-4">
                    <div class="card-section-title">Personal Details</div>
                    <dl class="profile-dl">
                        <div class="pdl-row"><dt>Full name</dt><dd>@member.FullName</dd></div>
                        <div class="pdl-row"><dt>Cellphone</dt><dd>@SensitiveDataMasker.MaskPhoneNumber(member.CellphoneNumber)</dd></div>
                        <div class="pdl-row"><dt>Email</dt><dd>@SensitiveDataMasker.MaskEmail(member.EmailAddress)</dd></div>
                        <div class="pdl-row"><dt>ID number</dt><dd>@SensitiveDataMasker.MaskIdNumber(member.IdNumber)</dd></div>
                        <div class="pdl-row"><dt>Residential area</dt><dd>@(member.ResidentialArea ?? "—")</dd></div>
                        <div class="pdl-row">
                            <dt>Deceased</dt>
                            <dd>
                                <StatusBadge Text="@(member.IsDeceased ? "Yes" : "No")" Type="@(member.IsDeceased ? "danger" : "secondary")" />
                            </dd>
                        </div>
                        @if (member.IsDeceased)
                        {
                            <div class="pdl-row"><dt>Deceased date</dt><dd>@(member.DeceasedDate?.ToString("dd MMM yyyy") ?? "—")</dd></div>
                            <div class="pdl-row"><dt>Death reported at</dt><dd>@(member.DeathReportedAt?.ToString("dd MMM yyyy") ?? "—")</dd></div>
                        }
                    </dl>

                    @if (canManageMemberStatus)
                    {
                        <div class="member-status-control">
                            <div class="card-section-title">Member Status Control</div>

                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label" for="governance-status">Member Status</label>
                                    <InputSelect id="governance-status" class="form-select" @bind-Value="selectedGovernanceStatus">
                                        @foreach (var governanceStatus in Enum.GetValues<MemberGovernanceStatus>())
                                        {
                                            <option value="@governanceStatus">@governanceStatus</option>
                                        }
                                    </InputSelect>
                                </div>
                                <div class="col-12">
                                    <label class="form-label" for="governance-reason">Reason</label>
                                    <InputTextArea id="governance-reason" class="form-control" rows="3" @bind-Value="governanceStatusReason" />
                                </div>
                            </div>

                            <div class="mt-4">
                                <button class="btn btn-primary" type="button" @onclick="ShowGovernanceStatusConfirmation">
                                    <i class="bi bi-shield-check me-2"></i>Update Status
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Membership details -->
        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-body p-4">
                    <div class="card-section-title">Membership Details</div>
                    <dl class="profile-dl">
                        <div class="pdl-row"><dt>Member number</dt><dd>@member.MemberNumber</dd></div>
                        <div class="pdl-row"><dt>Joining date</dt><dd>@member.JoiningDate.ToString("dd MMM yyyy")</dd></div>
                        <div class="pdl-row"><dt>Default role</dt><dd>@member.DefaultRole</dd></div>
                        <div class="pdl-row"><dt>Tenant</dt><dd>@member.Tenant.Name</dd></div>
                        <div class="pdl-row">
                            <dt>Account Linked</dt>
                            <dd>
                                <StatusBadge Text="@GetAccountLinkStatusText()" Type="@GetAccountLinkStatusBadgeType()" />
                            </dd>
                        </div>
                        <div class="pdl-row">
                            <dt>Member Status</dt>
                            <dd>
                                <StatusBadge Text="@member.GovernanceStatus.ToString()" Type="@GetGovernanceStatusBadgeType(member.GovernanceStatus)" />
                            </dd>
                        </div>
                        <div class="pdl-row"><dt>Member Status Reason</dt><dd>@(member.GovernanceStatusReason ?? "—")</dd></div>
                        <div class="pdl-row"><dt>Member Status Changed At</dt><dd>@(member.GovernanceStatusChangedAt?.ToString("dd MMM yyyy") ?? "—")</dd></div>
                        <div class="pdl-row"><dt>Last Warning Issued At</dt><dd>@(member.LastWarningIssuedAt?.ToString("dd MMM yyyy") ?? "—")</dd></div>
                        <div class="pdl-row"><dt>Suspended At</dt><dd>@(member.SuspendedAt?.ToString("dd MMM yyyy") ?? "—")</dd></div>
                        <div class="pdl-row"><dt>Expelled At</dt><dd>@(member.ExpelledAt?.ToString("dd MMM yyyy") ?? "—")</dd></div>
                        <div class="pdl-row last">
                            <dt>Cooling period</dt>
                            <dd>
                                @if (member.IsInCoolingPeriod)
                                {
                                    <StatusBadge Text="Active" Type="info" />
                                    @if (member.CoolingPeriodEndDate is not null)
                                    {
                                        <span class="ms-2 small text-muted">until @member.CoolingPeriodEndDate.Value.ToString("dd MMM yyyy")</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>

        <!-- Next of kin -->
        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex align-items-center gap-2">
                            <div class="card-section-title mb-0">Next of Kin</div>
                            <StatusBadge Text="@($"{member.NextOfKinRecords.Count}/{maxNextOfKin}")" Type="secondary" />
                        </div>
                        @if (member.NextOfKinRecords.Count < maxNextOfKin)
                        {
                            <a class="btn btn-sm btn-primary" href="@($"/add-next-of-kin/{MemberId}")">
                                <i class="bi bi-plus me-1"></i>Add
                            </a>
                        }
                    </div>

                    @if (member.NextOfKinRecords.Count == 0)
                    {
                        <p class="text-muted small mb-0">No next of kin records captured yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead><tr><th>Name</th><th>Relationship</th><th>Cellphone</th><th></th><th></th></tr></thead>
                                <tbody>
                                    @foreach (var nok in member.NextOfKinRecords)
                                    {
                                        <tr>
                                            <td class="fw-500">@nok.FullName</td>
                                            <td class="text-muted small">@nok.Relationship</td>
                                            <td class="text-muted small">@SensitiveDataMasker.MaskPhoneNumber(nok.CellphoneNumber)</td>
                                            <td>@if (nok.IsPrimary) { <StatusBadge Text="Primary" Type="info" /> }</td>
                                            <td><a class="btn btn-sm btn-outline-secondary" href="@($"/edit-next-of-kin/{nok.Id}")">Edit</a></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Beneficiaries -->
        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="d-flex align-items-center gap-2">
                            <div class="card-section-title mb-0">Beneficiaries</div>
                            <StatusBadge Text="@($"{member.Beneficiaries.Count}/{maxBeneficiaries}")" Type="secondary" />
                        </div>
                        @if (member.Beneficiaries.Count < maxBeneficiaries)
                        {
                            <a class="btn btn-sm btn-primary" href="@($"/add-beneficiary/{MemberId}")">
                                <i class="bi bi-plus me-1"></i>Add
                            </a>
                        }
                    </div>

                    @if (member.Beneficiaries.Count == 0)
                    {
                        <p class="text-muted small mb-0">No beneficiaries captured yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead><tr><th>Name</th><th>Relationship</th><th>Cellphone</th><th>Status</th><th></th></tr></thead>
                                <tbody>
                                    @foreach (var ben in member.Beneficiaries)
                                    {
                                        <tr>
                                            <td class="fw-500">@ben.FullName</td>
                                            <td class="text-muted small">@ben.Relationship</td>
                                            <td class="text-muted small">@SensitiveDataMasker.MaskPhoneNumber(ben.CellphoneNumber)</td>
                                            <td>
                                                <StatusBadge Text="@(ben.IsActive ? "Active" : "Inactive")" Type="@(ben.IsActive ? "success" : "secondary")" />
                                            </td>
                                            <td><a class="btn btn-sm btn-outline-secondary" href="@($"/edit-beneficiary/{ben.Id}")">Edit</a></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Dependents / covered lives -->
        <div class="col-12">
            <div class="card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <div class="card-section-title mb-1">Dependents / Covered Lives</div>
                            <div class="text-muted small">Dependents captured: @dependents.Count of @maxDependents</div>
                        </div>
                        @if (maxDependents > 0 && dependents.Count < maxDependents)
                        {
                            <a class="btn btn-sm btn-primary" href="@($"/add-dependent/{MemberId}")">
                                <i class="bi bi-plus me-1"></i>Add Dependent
                            </a>
                        }
                    </div>

                    @if (maxDependents <= 0)
                    {
                        <div class="alert alert-info mb-0" role="alert">
                            Dependents are not enabled for this stokvel. Update the stokvel setup rules if dependents should be allowed.
                        </div>
                    }
                    else if (dependents.Count >= maxDependents)
                    {
                        <div class="alert alert-warning" role="alert">
                            Maximum number of dependents reached.
                        </div>
                    }

                    @if (dependents.Count == 0)
                    {
                        <p class="text-muted small mb-0">No dependents captured yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th>Full name</th>
                                        <th>Relationship</th>
                                        <th>Date of birth</th>
                                        <th>ID number</th>
                                        <th>Cellphone</th>
                                        <th>Status</th>
                                        <th>Deceased date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var dependent in dependents)
                                    {
                                        var hasActiveClaim = activeDependentClaims.ContainsKey(dependent.Id);
                                        var activeClaim = hasActiveClaim ? activeDependentClaims[dependent.Id] : null;
                                        <tr>
                                            <td class="fw-500">@dependent.FullName</td>
                                            <td class="text-muted small">@dependent.Relationship</td>
                                            <td class="text-muted small">@(dependent.DateOfBirth?.ToString("dd MMM yyyy") ?? "—")</td>
                                            <td class="text-muted small">@SensitiveDataMasker.MaskIdNumber(dependent.IdNumber)</td>
                                            <td class="text-muted small">@SensitiveDataMasker.MaskPhoneNumber(dependent.CellphoneNumber)</td>
                                            <td>
                                                <div class="d-flex flex-column gap-1 align-items-start">
                                                    <StatusBadge Text="@GetDependentStatusText(dependent, hasActiveClaim)" Type="@GetDependentStatusBadgeType(dependent, hasActiveClaim)" />
                                                    @if (activeClaim is not null)
                                                    {
                                                        <span class="small text-muted">Claim: @activeClaim.Status</span>
                                                    }
                                                </div>
                                            </td>
                                            <td class="text-muted small">
                                                @(dependent.IsDeceased ? dependent.DeceasedDate?.ToString("dd MMM yyyy") ?? "-" : "-")
                                            </td>
                                            <td>
                                                <div class="d-flex gap-2 flex-wrap">
                                                    @if (activeClaim is not null)
                                                    {
                                                        <button
                                                            class="btn btn-sm btn-outline-secondary"
                                                            type="button"
                                                            title="Dependent cannot be edited while a claim is active."
                                                            disabled>
                                                            Edit locked
                                                        </button>
                                                        <a class="btn btn-sm btn-primary" href="@($"/claim/{activeClaim.Id}")">View Claim</a>
                                                    }
                                                    else
                                                    {
                                                        <a class="btn btn-sm btn-outline-secondary" href="@($"/edit-dependent/{dependent.Id}")">Edit</a>
                                                        <a class="btn btn-sm btn-primary" href="@($"/create-claim/{MemberId}?dependentId={dependent.Id}")">Create Claim</a>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Claims -->
        <div class="col-12">
            <div class="card">
                <div class="card-body p-4">
                    @if (stokvel?.EnableClaims == true)
                    {
                        <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-3">
                            <div class="card-section-title mb-0">Claims</div>
                            <a class="btn btn-sm btn-primary" href="@($"/create-claim/{MemberId}")">
                                <i class="bi bi-plus me-1"></i>Create Member Claim
                            </a>
                        </div>

                        @if (member.GovernanceStatus is MemberGovernanceStatus.Suspended or MemberGovernanceStatus.Expelled)
                        {
                            <div class="alert alert-warning" role="alert">
                                This member's governance status means new claims may be placed on hold.
                            </div>
                        }

                        @if (funeralClaims.Count == 0)
                        {
                            <p class="text-muted small mb-0">No funeral claims captured yet.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm mb-0">
                                    <thead>
                                        <tr>
                                            <th>Deceased</th>
                                            <th>Subject</th>
                                            <th>Date of death</th>
                                            <th>Status</th>
                                            <th>Waiting period</th>
                                            <th>Member eligible</th>
                                            <th>Documents</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var claim in funeralClaims)
                                        {
                                            <tr>
                                                <td class="fw-500">@claim.DeceasedFullName</td>
                                                <td class="text-muted small">@claim.SubjectType</td>
                                                <td class="text-muted small">@(claim.DateOfDeath?.ToString("dd MMM yyyy") ?? "—")</td>
                                                <td>
                                                    <StatusBadge Text="@claim.Status.ToString()" Type="@GetClaimStatusBadgeType(claim.Status)" />
                                                </td>
                                                <td>
                                                    <StatusBadge Text="@(claim.IsWaitingPeriodSatisfied ? "Yes" : "No")" Type="@(claim.IsWaitingPeriodSatisfied ? "success" : "warning")" />
                                                </td>
                                                <td>
                                                    <StatusBadge Text="@(claim.IsMemberStatusEligible ? "Yes" : "No")" Type="@(claim.IsMemberStatusEligible ? "success" : "warning")" />
                                                </td>
                                                <td class="text-muted small">@claim.Documents.Count</td>
                                                <td>
                                                    <a class="btn btn-sm btn-outline-secondary" href="@($"/claim/{claim.Id}")">View</a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="card-section-title mb-2">Claims</div>
                        <AlertBanner
                            Type="warning"
                            Title="Claims are not enabled for this stokvel type."
                            Message="This group can still use the enabled member, contribution, fine and meeting features."
                            Icon="bi bi-exclamation-triangle-fill" />
                    }
                </div>
            </div>
        </div>

        @if (canManageMemberStatus)
        {
            <div class="col-12">
                <div class="sisonke-card">
                    <div class="sisonke-card-head">
                        <div>
                            <h2>Attendance Warnings</h2>
                            <p>Attendance warnings visible to office bearers.</p>
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                            <span class="sisonke-badge sisonke-badge-gold">@memberWarnings.Count</span>
                            @if (stokvel is not null)
                            {
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/member-warnings/{stokvel.Id}")">View All Warnings</a>
                            }
                        </div>
                    </div>
                    <div class="sisonke-card-body">
                        @if (memberWarnings.Count == 0)
                        {
                            <div class="sisonke-alert sisonke-alert-green mb-0">No member warnings recorded.</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="sisonke-table mb-0">
                                    <thead>
                                        <tr>
                                            <th>Warning type</th>
                                            <th>Reason</th>
                                            <th>Status</th>
                                            <th>Created date</th>
                                            <th>Absence count</th>
                                            <th>Related meeting</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var warning in memberWarnings)
                                        {
                                            <tr>
                                                <td><span class="@GetWarningBadgeClass(warning.WarningType)">@GetWarningTypeLabel(warning.WarningType)</span></td>
                                                <td>@DisplayOrDash(warning.Reason)</td>
                                                <td><span class="@GetWarningStatusBadgeClass(warning.Status)">@warning.Status</span></td>
                                                <td>@warning.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                                <td>@warning.AbsenceCount</td>
                                                <td>
                                                    <div>@DisplayOrDash(warning.Meeting?.Title)</div>
                                                    <div class="text-muted small">@(warning.Meeting?.MeetingDate.ToString("dd MMM yyyy") ?? "-")</div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Fines -->
        <div class="col-12">
            <div class="card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="card-section-title mb-0">Fines</div>
                        @if (canManageStokvel)
                        {
                            <a class="btn btn-sm btn-primary" href="@($"/add-fine/{MemberId}")">
                                <i class="bi bi-plus me-1"></i>Add Fine
                            </a>
                        }
                    </div>

                    @if (!canViewFines)
                    {
                        <AlertBanner Type="warning" Title="Access restricted." Message="You do not have access to view these fines." Icon="bi bi-exclamation-triangle-fill" />
                    }
                    else if (memberFines.Count == 0)
                    {
                        <p class="text-muted small mb-0">No fines captured yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th>Fine type</th>
                                        <th>Amount</th>
                                        <th>Reason</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                        <th>Paid date</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var fine in memberFines)
                                    {
                                        <tr>
                                            <td class="fw-500">@fine.FineType.Name</td>
                                            <td class="fw-600">@fine.Amount.ToString("C0", new System.Globalization.CultureInfo("en-ZA"))</td>
                                            <td class="text-muted small">@fine.Reason</td>
                                            <td class="text-muted small">@fine.FineDate.ToString("dd MMM yyyy")</td>
                                            <td>
                                                <StatusBadge Text="@fine.Status.ToString()" Type="@(fine.Status == FineStatus.Paid ? "success" : "danger")" />
                                            </td>
                                            <td class="text-muted small">@(fine.PaidDate?.ToString("dd MMM yyyy") ?? "—")</td>
                                            <td>
                                                @if (canManagePayments && fine.Status == FineStatus.Unpaid)
                                                {
                                                    <a class="btn btn-sm btn-success" href="@($"/mark-fine-paid/{fine.Id}")">Mark Paid</a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>

    <ConfirmationModal
        IsVisible="@showGovernanceStatusConfirmation"
        Title="Update Member Status"
        Message="Are you sure you want to update this member's status?"
        ConfirmButtonText="Update Status"
        CancelButtonText="Cancel"
        ModalType="warning"
        OnConfirm="@ConfirmGovernanceStatusUpdateAsync"
        OnCancel="@CancelGovernanceStatusUpdate" />
}

