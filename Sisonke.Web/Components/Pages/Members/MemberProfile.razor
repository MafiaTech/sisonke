@page "/member-profile/{MemberId:guid}"
@rendermode InteractiveServer

@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject FineService FineService
@inject MemberService MemberService
@inject OperatingRuleService OperatingRuleService
@inject StokvelService StokvelService

<PageTitle>Member Profile</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm text-secondary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading member profile...
    </div>
}
else if (member is null)
{
    <AlertBanner Type="danger" Title="Member not found." Message="" Icon="bi bi-x-circle-fill" />
}
else
{
    <div class="page-header">
        <div class="d-flex align-items-center gap-3">
            <div class="member-avatar" aria-hidden="true">@GetInitials(member.FullName)</div>
            <div class="page-header-text">
                <h1>@member.FullName</h1>
                <p class="page-subtitle">
                    <StatusBadge Text="@member.DefaultRole.ToString()" Type="secondary" />
                    @if (member.Status.ToString() == "Active")
                    {
                        <StatusBadge Text="Active" Type="success" />
                    }
                    else if (member.Status.ToString() == "Suspended")
                    {
                        <StatusBadge Text="@member.Status.ToString()" Type="warning" />
                    }
                    else
                    {
                        <StatusBadge Text="@member.Status.ToString()" Type="secondary" />
                    }
                </p>
            </div>
        </div>
        <div class="d-flex gap-2 align-items-start flex-wrap">
            @if (stokvel is not null)
            {
                <a class="btn btn-outline-secondary btn-sm" href="@($"/members/{stokvel.Id}")">
                    <i class="bi bi-chevron-left me-1"></i>Members
                </a>
            }
            else
            {
                <a class="btn btn-outline-secondary btn-sm" href="/my-stokvels">
                    <i class="bi bi-chevron-left me-1"></i>My Stokvels
                </a>
            }
            <a class="btn btn-primary btn-sm" href="@($"/edit-member/{MemberId}")">
                <i class="bi bi-pencil me-1"></i>Edit Member
            </a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-body">
                    <h3 class="h6 card-title text-muted text-uppercase" style="letter-spacing: .05em; font-size: .7rem;">Personal Details</h3>
                    <dl class="row mb-0 mt-2">
                        <dt class="col-sm-5 fw-normal text-muted small">Full name</dt>
                        <dd class="col-sm-7">@member.FullName</dd>

                        <dt class="col-sm-5 fw-normal text-muted small">Cellphone</dt>
                        <dd class="col-sm-7">@member.CellphoneNumber</dd>

                        <dt class="col-sm-5 fw-normal text-muted small">Email</dt>
                        <dd class="col-sm-7">@(member.EmailAddress ?? "—")</dd>

                        <dt class="col-sm-5 fw-normal text-muted small">ID number</dt>
                        <dd class="col-sm-7">@(member.IdNumber ?? "—")</dd>

                        <dt class="col-sm-5 fw-normal text-muted small">Residential area</dt>
                        <dd class="col-sm-7">@(member.ResidentialArea ?? "—")</dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-body">
                    <h3 class="h6 card-title text-muted text-uppercase" style="letter-spacing: .05em; font-size: .7rem;">Membership Details</h3>
                    <dl class="row mb-0 mt-2">
                        <dt class="col-sm-5 fw-normal text-muted small">Member number</dt>
                        <dd class="col-sm-7">@member.MemberNumber</dd>

                        <dt class="col-sm-5 fw-normal text-muted small">Joining date</dt>
                        <dd class="col-sm-7">@member.JoiningDate.ToString("dd MMM yyyy")</dd>

                        <dt class="col-sm-5 fw-normal text-muted small">Default role</dt>
                        <dd class="col-sm-7">@member.DefaultRole</dd>

                        <dt class="col-sm-5 fw-normal text-muted small">Tenant</dt>
                        <dd class="col-sm-7">@member.Tenant.Name</dd>

                        <dt class="col-sm-5 fw-normal text-muted small">Cooling period</dt>
                        <dd class="col-sm-7">
                            @if (member.IsInCoolingPeriod)
                            {
                                <StatusBadge Text="Active" Type="info" />
                                @if (member.CoolingPeriodEndDate is not null)
                                {
                                    <span class="ms-2 small text-muted">until @member.CoolingPeriodEndDate.Value.ToString("dd MMM yyyy")</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="h6 card-title mb-0 text-muted text-uppercase" style="letter-spacing: .05em; font-size: .7rem;">
                            Next of Kin
                            <StatusBadge Text="@($"{member.NextOfKinRecords.Count} / {maxNextOfKin}")" Type="secondary" />
                        </h3>
                        @if (member.NextOfKinRecords.Count < maxNextOfKin)
                        {
                            <a class="btn btn-sm btn-primary" href="@($"/add-next-of-kin/{MemberId}")">
                                <i class="bi bi-plus me-1"></i>Add
                            </a>
                        }
                    </div>

                    @if (member.NextOfKinRecords.Count == 0)
                    {
                        <p class="text-muted small mb-0">No next of kin records captured yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Full name</th>
                                        <th>Relationship</th>
                                        <th>Cellphone</th>
                                        <th>Primary</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var nextOfKin in member.NextOfKinRecords)
                                    {
                                        <tr>
                                            <td>@nextOfKin.FullName</td>
                                            <td class="text-muted small">@nextOfKin.Relationship</td>
                                            <td class="text-muted small">@nextOfKin.CellphoneNumber</td>
                                            <td>
                                                @if (nextOfKin.IsPrimary)
                                                {
                                                    <StatusBadge Text="Primary" Type="info" />
                                                }
                                            </td>
                                            <td>
                                                <a class="btn btn-sm btn-outline-secondary" href="@($"/edit-next-of-kin/{nextOfKin.Id}")">Edit</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="h6 card-title mb-0 text-muted text-uppercase" style="letter-spacing: .05em; font-size: .7rem;">
                            Beneficiaries
                            <StatusBadge Text="@($"{member.Beneficiaries.Count} / {maxBeneficiaries}")" Type="secondary" />
                        </h3>
                        @if (member.Beneficiaries.Count < maxBeneficiaries)
                        {
                            <a class="btn btn-sm btn-primary" href="@($"/add-beneficiary/{MemberId}")">
                                <i class="bi bi-plus me-1"></i>Add
                            </a>
                        }
                    </div>

                    @if (member.Beneficiaries.Count == 0)
                    {
                        <p class="text-muted small mb-0">No beneficiaries captured yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Full name</th>
                                        <th>Relationship</th>
                                        <th>Cellphone</th>
                                        <th>Status</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var beneficiary in member.Beneficiaries)
                                    {
                                        <tr>
                                            <td>@beneficiary.FullName</td>
                                            <td class="text-muted small">@beneficiary.Relationship</td>
                                            <td class="text-muted small">@(beneficiary.CellphoneNumber ?? "—")</td>
                                            <td>
                                                @if (beneficiary.IsActive)
                                                {
                                                    <span class="badge text-bg-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge text-bg-secondary">Inactive</span>
                                                }
                                            </td>
                                            <td>
                                                <a class="btn btn-sm btn-outline-secondary" href="@($"/edit-beneficiary/{beneficiary.Id}")">Edit</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h3 class="h6 card-title mb-0 text-muted text-uppercase" style="letter-spacing: .05em; font-size: .7rem;">Fines</h3>
                        <a class="btn btn-sm btn-primary" href="@($"/add-fine/{MemberId}")">
                            <i class="bi bi-plus me-1"></i>Add Fine
                        </a>
                    </div>

                    @if (memberFines.Count == 0)
                    {
                        <p class="text-muted small mb-0">No fines captured yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Fine type</th>
                                        <th>Amount</th>
                                        <th>Reason</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                        <th>Paid date</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var fine in memberFines)
                                    {
                                        <tr>
                                            <td>@fine.FineType.Name</td>
                                            <td>@fine.Amount.ToString("C0", new System.Globalization.CultureInfo("en-ZA"))</td>
                                            <td class="text-muted small">@fine.Reason</td>
                                            <td class="text-muted small">@fine.FineDate.ToString("dd MMM yyyy")</td>
                                            <td>
                                                @if (fine.Status == FineStatus.Paid)
                                                {
                                                    <span class="badge text-bg-success">Paid</span>
                                                }
                                                else
                                                {
                                                    <span class="badge text-bg-danger">Unpaid</span>
                                                }
                                            </td>
                                            <td class="text-muted small">@(fine.PaidDate?.ToString("dd MMM yyyy") ?? "—")</td>
                                            <td>
                                                @if (fine.Status == FineStatus.Unpaid)
                                                {
                                                    <a class="btn btn-sm btn-success" href="@($"/mark-fine-paid/{fine.Id}")">Mark Paid</a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private Member? member;
    private List<MemberFine> memberFines = [];
    private Stokvel? stokvel;
    private int maxNextOfKin;
    private int maxBeneficiaries;
    private bool isLoading = true;

    [Parameter]
    public Guid MemberId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;

        member = await MemberService.GetMemberByIdAsync(MemberId);
        stokvel = member is null
            ? null
            : await StokvelService.GetStokvelByTenantIdAsync(member.TenantId);
        maxNextOfKin = stokvel is null
            ? 0
            : await OperatingRuleService.GetMaxNextOfKinAsync(stokvel.Id);
        maxBeneficiaries = stokvel is null
            ? 0
            : await OperatingRuleService.GetMaxBeneficiariesAsync(stokvel.Id);
        memberFines = member is null
            ? []
            : await FineService.GetMemberFinesAsync(MemberId);

        isLoading = false;
    }

    private static string GetInitials(string fullName)
    {
        var parts = fullName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant()
            : fullName.Length > 0 ? fullName[0].ToString().ToUpperInvariant() : "?";
    }
}
