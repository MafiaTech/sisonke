@page "/add-member/{StokvelId:guid}"
@rendermode InteractiveServer

@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject MemberService MemberService
@inject StokvelService StokvelService
@inject NavigationManager NavigationManager

<PageTitle>Register Member</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading…
    </div>
}
else if (stokvel is null)
{
    <AlertBanner Type="danger" Title="Stokvel not found." Message="" Icon="bi bi-x-circle-fill" />
}
else
{
    <section class="sisonke-hero-card mb-4">
        <div>
            <span class="sisonke-badge sisonke-badge-gold">Registering under: @stokvel.Name</span>
            <h1>Register Member</h1>
            <p>Add a new member to this stokvel.</p>
        </div>
        <div class="member-register-meta">
            <div><span>Stokvel</span><strong>@stokvel.Name</strong></div>
            <div><span>Type</span><strong>@stokvel.Type</strong></div>
            <div><span>Package</span><strong>@GetSubscriptionPackageText()</strong></div>
            <div><span>Members</span><strong>@GetMemberCountText()</strong></div>
        </div>
    </section>

    <div class="sisonke-card mb-3">
        <div class="sisonke-card-body">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                <div>
                    <span class="sisonke-badge sisonke-badge-green">Registering under: @stokvel.Name</span>
                    <h2 class="stokvel-context-title">@stokvel.Name</h2>
                    <div class="stokvel-context-meta">
                        <span><i class="bi bi-collection me-1"></i>@stokvel.Type</span>
                        <span><i class="bi bi-box-seam me-1"></i>@GetSubscriptionPackageText()</span>
                        <span><i class="bi bi-people me-1"></i>@GetMemberCountText()</span>
                    </div>
                </div>
                <span class="sisonke-badge sisonke-badge-blue">New Member Registration</span>
            </div>
        </div>
    </div>

    @if (saveFailed)
    {
        <AlertBanner Type="danger" Title="Member could not be added." Message="The subscription limit may have been reached." Icon="bi bi-x-circle-fill" />
    }

    @if (!canAddMember)
    {
        <div class="member-limit-warning">
            <div class="mlw-icon"><i class="bi bi-shield-exclamation"></i></div>
            <div class="mlw-content">
                <h2 class="mlw-title">Member Limit Reached</h2>
                @if (!string.IsNullOrWhiteSpace(memberLimitMessage))
                {
                    <p class="mlw-stat">@memberLimitMessage</p>
                }
                <p class="mlw-hint">Upgrade your subscription package to add more members to this stokvel.</p>
                <div class="mlw-actions">
                    <a class="sisonke-btn sisonke-btn-gold" href="@($"/stokvel-dashboard/{StokvelId}")">
                        <i class="bi bi-arrow-up-circle me-2"></i>View Subscription Package
                    </a>
                    <a class="sisonke-btn sisonke-btn-outline" href="@($"/members/{StokvelId}")">
                        <i class="bi bi-chevron-left me-1"></i>Back to Members
                    </a>
                </div>
            </div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(memberLimitMessage))
    {
        <AlertBanner Type="info" Title="Member package limit" Message="@memberLimitMessage" Icon="bi bi-info-circle-fill" />
    }

    <div class="form-page @(!canAddMember ? "form-faded" : "")">
        <EditForm FormName="AddMemberForm" Model="@newMember" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />

            <!-- Personal details -->
            <div class="sisonke-card mb-3 member-registration-card">
                <div class="sisonke-card-body">
                    <div class="form-section-title text-uppercase">Personal Details</div>
                    <div class="sisonke-grid sisonke-grid-2">
                        <div class="member-form-field">
                            <label class="form-label" for="full-name">Full name <span class="text-danger">*</span></label>
                            <InputText id="full-name" class="form-control" placeholder="e.g. Thabo Nkosi" @bind-Value="newMember.FullName" />
                        </div>

                        <div class="member-form-field">
                            <label class="form-label" for="cellphone-number">Cellphone number <span class="text-danger">*</span></label>
                            <InputText id="cellphone-number" class="form-control" placeholder="e.g. 0821234567" @bind-Value="newMember.CellphoneNumber" />
                        </div>

                        <div class="member-form-field">
                            <label class="form-label" for="email-address">Email address</label>
                            <InputText id="email-address" class="form-control" type="email" placeholder="optional" @bind-Value="newMember.EmailAddress" />
                        </div>

                        <div class="member-form-field">
                            <label class="form-label" for="id-number">SA ID number</label>
                            <InputText id="id-number" class="form-control" placeholder="13-digit SA ID" @bind-Value="newMember.IdNumber" />
                            <div class="form-text">Used later to link this member to a login account and other stokvel memberships.</div>
                        </div>

                        <div class="member-form-field">
                            <label class="form-label" for="residential-area">Residential area</label>
                            <InputText id="residential-area" class="form-control" placeholder="e.g. Soweto, Gauteng" @bind-Value="newMember.ResidentialArea" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Membership details -->
            <div class="sisonke-card mb-3">
                <div class="sisonke-card-body">
                    <div class="form-section-title">Membership Details</div>
                    <div class="sisonke-grid sisonke-grid-2">
                        <div class="member-form-field">
                            <label class="form-label" for="joining-date">Joining date</label>
                            <InputDate id="joining-date" class="form-control" @bind-Value="newMember.JoiningDate" />
                        </div>

                        <div class="member-form-field">
                            <label class="form-label" for="default-role">Default role</label>
                            <InputSelect id="default-role" class="form-select" @bind-Value="newMember.DefaultRole">
                                @foreach (var role in Enum.GetValues<SisonkeRole>())
                                {
                                    <option value="@role">@role</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="member-form-field">
                            <label class="form-label" for="status">Member status</label>
                            <InputSelect id="status" class="form-select" @bind-Value="newMember.Status">
                                @foreach (var status in Enum.GetValues<MemberStatus>())
                                {
                                    <option value="@status">@status</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Cooling period -->
            <div class="sisonke-card mb-3">
                <div class="sisonke-card-body">
                    <div class="form-section-title">Cooling Period</div>
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <InputCheckbox id="cooling-period" class="form-check-input" @bind-Value="newMember.IsInCoolingPeriod" />
                                <label class="form-check-label fw-600" for="cooling-period">Member is in a cooling period</label>
                            </div>
                            <div class="form-text">A cooling period temporarily restricts the member from receiving payouts.</div>
                        </div>

                        @if (newMember.IsInCoolingPeriod)
                        {
                            <div class="member-form-field mt-3">
                                <label class="form-label" for="cooling-period-end-date">Cooling period end date</label>
                                <InputDate id="cooling-period-end-date" class="form-control" @bind-Value="newMember.CoolingPeriodEndDate" />
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                @if (canAddMember)
                {
                    <button class="sisonke-btn sisonke-btn-primary" type="submit">
                        <i class="bi bi-person-check me-2"></i>Save Member
                    </button>
                }
                <a class="sisonke-btn sisonke-btn-outline" href="@($"/members/{StokvelId}")">Cancel / Back to Members</a>
            </div>
        </EditForm>
    </div>
}

<style>
    .member-register-meta {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .75rem;
        min-width: min(28rem, 100%);
        padding: 1rem;
        border: 1px solid rgb(255 255 255 / .28);
        border-radius: var(--r-md);
        background: rgb(255 255 255 / .12);
    }

    .member-register-meta div {
        display: grid;
        gap: .15rem;
    }

    .member-register-meta span {
        color: rgb(255 255 255 / .78);
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .member-register-meta strong {
        color: #fff;
        font-size: .92rem;
    }

    .fw-600 { font-weight: 600; }
    .context-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: .25rem .65rem;
        background: rgba(45, 90, 61, .1);
        color: var(--sk-green-700);
        font-size: .75rem;
        font-weight: 700;
        margin-bottom: .75rem;
    }
    .stokvel-context-title {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--text);
    }
    .stokvel-context-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem 1rem;
        color: var(--muted);
        font-size: .875rem;
        margin-top: .5rem;
    }

    @@media (max-width: 768px) {
        .member-register-meta {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private Stokvel? stokvel;
    private TenantSubscription? activeSubscription;
    private Member newMember = new()
    {
        JoiningDate = DateTime.Today,
        Status = MemberStatus.Active,
        DefaultRole = SisonkeRole.Member
    };
    private bool isLoading = true;
    private bool canAddMember = true;
    private int currentMemberCount;
    private string memberLimitMessage = string.Empty;
    private bool saveFailed;

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);

        if (stokvel is not null)
        {
            activeSubscription = await StokvelService.GetActiveSubscriptionByStokvelIdAsync(StokvelId);
            currentMemberCount = await MemberService.GetMemberCountByStokvelIdAsync(StokvelId);
            canAddMember = await StokvelService.CanAddMemberAsync(StokvelId);
            memberLimitMessage = await StokvelService.GetMemberLimitMessageAsync(StokvelId);
        }
        else
        {
            canAddMember = false;
        }

        isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        if (stokvel is null)
        {
            saveFailed = true;
            return;
        }

        saveFailed = false;
        var savedMember = await MemberService.AddMemberAsync(StokvelId, newMember);
        if (savedMember is null) { saveFailed = true; return; }
        NavigationManager.NavigateTo($"/members/{StokvelId}");
    }

    private string GetSubscriptionPackageText()
    {
        return activeSubscription?.SubscriptionPlan.Name ?? "Subscription package unavailable";
    }

    private string GetMemberCountText()
    {
        var maxMembers = activeSubscription?.SubscriptionPlan.MaxMembers;

        return maxMembers is null
            ? $"{currentMemberCount} members captured"
            : $"{currentMemberCount} of {maxMembers} members captured";
    }
}
