</style>

@code {
    private static readonly string[] stepTitles = ["Basics", "Money", "Rules", "Sign-off"];
    private static readonly string[] GroupPurposeOptions =
    [
        "General Rotational Payouts",
        "Long-term Savings Fund",
        "Burial Society",
        "Investment / Property Club",
        "Grocery / Bulk Buying"
    ];
    private static readonly string[] ContributionFrequencyOptions = ["Weekly", "Fortnightly", "Monthly"];
    private static readonly string[] ContributionDueDayOptions =
    [
        "Monday",
        "Friday",
        "Saturday",
        "Sunday",
        "1st of the month",
        "25th of the month",
        "Last day of the month"
    ];

    private Stokvel? stokvel;
    private ConstitutionDocument? latestConstitution;
    private IBrowserFile? selectedConstitutionFile;
    private Dictionary<string, string> wizardAnswers = new(StringComparer.OrdinalIgnoreCase);
    private string constitutionStatus = string.Empty;
    private string? previewContent;
    private int currentStep = 1;
    private bool isLoading = true;
    private bool showApprovalConfirmation;
    private string? successMessage;
    private string? errorMessage;
    private bool canViewStokvel;
    private bool canManageConstitution;
    private bool canApproveConstitution;

    private bool IsApproved => string.Equals(constitutionStatus, "Approved", StringComparison.OrdinalIgnoreCase);
    private bool HasUploadedConstitution => latestConstitution?.IsUploadedDocument == true;

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        successMessage = null;
        errorMessage = null;
        showApprovalConfirmation = false;
        canViewStokvel = false;
        canManageConstitution = false;
        canApproveConstitution = false;

        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);

        if (stokvel is null)
        {
            isLoading = false;
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            isLoading = false;
            return;
        }

        canViewStokvel = await MemberAccessService.CanViewStokvelAsync(userId, StokvelId);

        if (!canViewStokvel)
        {
            isLoading = false;
            return;
        }

        canManageConstitution = await MemberAccessService.CanManageConstitutionAsync(userId, StokvelId);
        var linkedMember = await MemberAccessService.GetLinkedMemberForUserAsync(userId, StokvelId);
        canApproveConstitution = CanApproveConstitutionRole(linkedMember?.DefaultRole.ToString());
        constitutionStatus = await ConstitutionService.GetConstitutionStatusAsync(StokvelId);
        wizardAnswers = await ConstitutionService.GetWizardAnswersAsync(StokvelId);
        latestConstitution = await ConstitutionService.GetLatestConstitutionAsync(StokvelId);
        previewContent = latestConstitution?.IsUploadedDocument == true ? null : latestConstitution?.Content;

        isLoading = false;
    }

    private string GetAnswer(string key)
    {
        return wizardAnswers.TryGetValue(key, out var answer)
            ? answer
            : string.Empty;
    }

    private void SetAnswer(string key, string? value)
    {
        if (!canManageConstitution)
        {
            return;
        }

        wizardAnswers[key] = value ?? string.Empty;
        successMessage = null;
        errorMessage = null;
    }

    private void SetLegalDisclosure(ChangeEventArgs args)
    {
        SetAnswer("legalDisclosureAccepted", args.Value is true ? "Yes" : "No");
    }

    private void GoToStep(int step)
    {
        if (!canManageConstitution)
        {
            return;
        }

        currentStep = Math.Clamp(step, 1, 4);
    }

    private void PreviousStep()
    {
        GoToStep(currentStep - 1);
    }

    private void NextStep()
    {
        GoToStep(currentStep + 1);
    }

    private async Task SaveProgressAsync()
    {
        if (!canManageConstitution)
        {
            return;
        }

        successMessage = null;
        errorMessage = null;

        var saved = await ConstitutionService.SaveWizardAnswersAsync(StokvelId, wizardAnswers);

        if (!saved)
        {
            errorMessage = "Progress could not be saved.";
            return;
        }

        successMessage = "Progress saved successfully.";
    }

    private async Task GeneratePreviewAsync()
    {
        if (!canManageConstitution)
        {
            return;
        }

        successMessage = null;
        errorMessage = null;

        if (!await ConstitutionService.SaveWizardAnswersAsync(StokvelId, wizardAnswers))
        {
            errorMessage = "Progress could not be saved before generating the preview.";
            return;
        }

        previewContent = await ConstitutionService.GenerateConstitutionFromWizardAsync(StokvelId);

        if (string.IsNullOrWhiteSpace(previewContent))
        {
            errorMessage = "Constitution preview could not be generated.";
            return;
        }

        successMessage = "Constitution preview generated successfully.";
    }

    private async Task SaveDraftAsync()
    {
        if (!canManageConstitution)
        {
            return;
        }

        successMessage = null;
        errorMessage = null;

        var generatedContent = await SaveAndGenerateContentAsync();

        if (string.IsNullOrWhiteSpace(generatedContent))
        {
            return;
        }

        var savedConstitution = await ConstitutionService.SaveDraftAsync(StokvelId, generatedContent);

        if (savedConstitution is null)
        {
            errorMessage = "Constitution draft could not be saved.";
            return;
        }

        await ReloadStatusAsync();
        previewContent = savedConstitution.Content;
        successMessage = "Constitution draft saved successfully.";
    }

    private void OnExistingConstitutionSelected(InputFileChangeEventArgs args)
    {
        if (!canManageConstitution)
        {
            return;
        }

        selectedConstitutionFile = args.File;
        successMessage = null;
        errorMessage = null;
    }

    private async Task UploadExistingConstitutionAsync()
    {
        if (!canManageConstitution)
        {
            return;
        }

        successMessage = null;
        errorMessage = null;

        if (selectedConstitutionFile is null)
        {
            errorMessage = "Please select a constitution document to upload.";
            return;
        }

        latestConstitution = await ConstitutionService.UploadExistingConstitutionAsync(StokvelId, selectedConstitutionFile);

        if (latestConstitution is null)
        {
            errorMessage = "Existing constitution could not be uploaded. Use a PDF, DOC or DOCX file up to 10MB.";
            return;
        }

        selectedConstitutionFile = null;
        previewContent = null;
        await ReloadStatusAsync();
        successMessage = "Existing constitution uploaded successfully.";
    }

    private void ShowApprovalConfirmation()
    {
        if (!canApproveConstitution)
        {
            return;
        }

        successMessage = null;
        errorMessage = null;
        showApprovalConfirmation = true;
    }

    private void CancelApproval() => showApprovalConfirmation = false;

    private async Task ConfirmApprovalAsync()
    {
        if (!canApproveConstitution)
        {
            return;
        }

        successMessage = null;
        errorMessage = null;
        showApprovalConfirmation = false;

        if (HasUploadedConstitution)
        {
            latestConstitution = await ConstitutionService.ApproveUploadedConstitutionAsync(StokvelId);

            if (latestConstitution is null)
            {
                errorMessage = "Constitution could not be approved.";
                return;
            }

            await ReloadStatusAsync();
            previewContent = null;
            successMessage = "Constitution approved successfully.";
            return;
        }

        var generatedContent = await SaveAndGenerateContentAsync();

        if (string.IsNullOrWhiteSpace(generatedContent))
        {
            return;
        }

        var savedDraft = await ConstitutionService.SaveDraftAsync(StokvelId, generatedContent);

        if (savedDraft is null)
        {
            errorMessage = "Constitution draft could not be saved before approval.";
            return;
        }

        latestConstitution = await ConstitutionService.ApproveLatestAsync(StokvelId);

        if (latestConstitution is null)
        {
            errorMessage = "Constitution could not be approved.";
            return;
        }

        await ReloadStatusAsync();
        previewContent = latestConstitution.Content;
        successMessage = "Constitution approved successfully.";
    }

    private async Task<string?> SaveAndGenerateContentAsync()
    {
        if (!await ConstitutionService.SaveWizardAnswersAsync(StokvelId, wizardAnswers))
        {
            errorMessage = "Progress could not be saved.";
            return null;
        }

        var generatedContent = await ConstitutionService.GenerateConstitutionFromWizardAsync(StokvelId);

        if (string.IsNullOrWhiteSpace(generatedContent))
        {
            errorMessage = "Constitution preview could not be generated.";
            return null;
        }

        previewContent = generatedContent;
        return generatedContent;
    }

    private async Task ReloadStatusAsync()
    {
        constitutionStatus = await ConstitutionService.GetConstitutionStatusAsync(StokvelId);
        latestConstitution = await ConstitutionService.GetLatestConstitutionAsync(StokvelId);
    }

    private static string FormatFileSize(long? bytes)
    {
        if (bytes is null)
        {
            return "—";
        }

        const decimal oneMegabyte = 1024 * 1024;

        return bytes >= oneMegabyte
            ? $"{bytes.Value / oneMegabyte:0.##} MB"
            : $"{bytes.Value / 1024m:0.##} KB";
    }

    private static string GetStatusBadgeType(string status) =>
        status switch { "Approved" => "success", "Draft" => "warning", "Not Created" => "secondary", _ => "info" };

    private static string GetStatusBadgeClass(string status) =>
        status switch
        {
            "Approved" => "sisonke-badge sisonke-badge-green",
            "Draft" => "sisonke-badge sisonke-badge-gold",
            "Uploaded" => "sisonke-badge sisonke-badge-blue",
            "Not Created" => "sisonke-badge sisonke-badge-gray",
            _ => "sisonke-badge sisonke-badge-teal"
        };

    private static bool CanApproveConstitutionRole(string? role)
    {
        var normalizedRole = role?.Trim();

        return normalizedRole?.Equals("Chairperson", StringComparison.OrdinalIgnoreCase) == true ||
            normalizedRole?.Equals("Creator", StringComparison.OrdinalIgnoreCase) == true ||
            normalizedRole?.Equals("Admin", StringComparison.OrdinalIgnoreCase) == true ||
            normalizedRole?.Equals("StokvelAdmin", StringComparison.OrdinalIgnoreCase) == true;
    }

    private static string FormatConstitutionDate(ConstitutionDocument? document)
    {
        if (document is null)
        {
            return "Not updated yet";
        }

        var date = document.ApprovedAt ?? document.CreatedAt;
        return date.ToString("dd MMM yyyy");
    }
}
