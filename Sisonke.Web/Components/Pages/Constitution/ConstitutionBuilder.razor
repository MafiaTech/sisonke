@page "/constitution-builder/{StokvelId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject StokvelService StokvelService
@inject ConstitutionService ConstitutionService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccessService MemberAccessService

<PageTitle>Constitution Builder</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading constitution builder...
    </div>
}
else if (stokvel is null)
{
    <AlertBanner Type="danger" Title="Stokvel not found." Message="" Icon="bi bi-x-circle-fill" />
}
else if (!canViewStokvel)
{
    <AlertBanner Type="warning" Title="Access restricted." Message="You do not have access to this constitution." Icon="bi bi-exclamation-triangle-fill" />
}
else
{
    <section class="sisonke-hero-card mb-4">
        <div>
            <span class="sisonke-badge sisonke-badge-gold">Governance</span>
            <h1>Constitution</h1>
            <p>Build, review and approve the stokvel constitution.</p>
            <div class="constitution-hero-badges">
                <span class="@GetStatusBadgeClass(constitutionStatus)">@constitutionStatus</span>
                @if (IsApproved)
                {
                    <span class="sisonke-badge sisonke-badge-green">
                        <i class="bi bi-shield-check me-1"></i>Approved
                    </span>
                }
            </div>
        </div>
        <div class="constitution-hero-meta">
            <div>
                <span>Stokvel</span>
                <strong>@stokvel.Name</strong>
            </div>
            <div>
                <span>Type</span>
                <strong>@stokvel.Type</strong>
            </div>
            <div>
                <span>Last Updated</span>
                <strong>@FormatConstitutionDate(latestConstitution)</strong>
            </div>
        </div>
    </section>

    <div class="mb-4">
        <a class="sisonke-btn sisonke-btn-outline" href="@($"/stokvel-dashboard/{StokvelId}")">
            <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
        </a>
    </div>

    @if (canManageConstitution && !canApproveConstitution)
    {
        <div class="sisonke-alert sisonke-alert-gold">
            Only the Chairperson, Creator or Admin can approve the constitution.
        </div>
    }

    @if (!canManageConstitution)
    {
        <div class="sisonke-alert sisonke-alert-blue">
            You are viewing the constitution in read-only mode.
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <AlertBanner Type="success" Title="@successMessage" Message="" Icon="bi bi-check-circle-fill" />
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <AlertBanner Type="danger" Title="@errorMessage" Message="" Icon="bi bi-x-circle-fill" />
    }

    @if (!canManageConstitution)
    {
        <div class="sisonke-card mb-4">
            <div class="sisonke-card-body">
                @if (HasUploadedConstitution)
                {
                    <div class="sisonke-card-head">
                        <div class="d-flex align-items-center gap-2">
                        <div class="sisonke-card-icon">
                            <i class="bi bi-file-earmark-arrow-up-fill"></i>
                        </div>
                        <div>
                            <h2>Uploaded Constitution</h2>
                            <p>View the uploaded constitution document.</p>
                        </div>
                        </div>
                    </div>

                    <div class="sisonke-grid sisonke-grid-2 mb-4">
                        <div>
                            <div class="detail-mini-label">Original file name</div>
                            <div class="fw-600">@latestConstitution?.OriginalFileName</div>
                        </div>
                        <div>
                            <div class="detail-mini-label">File size</div>
                            <div class="text-muted small">@FormatFileSize(latestConstitution?.FileSizeBytes)</div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(latestConstitution?.StoredFilePath))
                    {
                        <a class="sisonke-btn sisonke-btn-primary" href="@latestConstitution.StoredFilePath" target="_blank" rel="noopener noreferrer">
                            <i class="bi bi-box-arrow-up-right me-2"></i>Open Uploaded Document
                        </a>
                    }
                }
                else if (!string.IsNullOrWhiteSpace(previewContent))
                {
                    @if (IsApproved)
                    {
                        <div class="approved-watermark-banner mb-4">
                            <i class="bi bi-shield-fill-check me-2"></i>
                            This constitution has been approved and is binding on all members.
                        </div>
                    }
                    <div class="constitution-preview">
                        @((MarkupString)previewContent)
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No constitution content is available yet.</p>
                }
            </div>
        </div>
    }
    else if (HasUploadedConstitution)
    {
        <div class="sisonke-card mb-4">
            <div class="sisonke-card-body">
                <div class="sisonke-card-head">
                    <div class="d-flex align-items-center gap-2">
                    <div class="sisonke-card-icon">
                        <i class="bi bi-file-earmark-arrow-up-fill"></i>
                    </div>
                    <div>
                        <h2>Uploaded Constitution</h2>
                        <p>Review and approve the uploaded constitution document.</p>
                    </div>
                    </div>
                </div>

                <div class="sisonke-grid sisonke-grid-2 mb-4">
                    <div>
                        <div class="detail-mini-label">Original file name</div>
                        <div class="fw-600">@latestConstitution?.OriginalFileName</div>
                    </div>
                    <div>
                        <div class="detail-mini-label">File size</div>
                        <div class="text-muted small">@FormatFileSize(latestConstitution?.FileSizeBytes)</div>
                    </div>
                    <div>
                        <div class="detail-mini-label">Uploaded status</div>
                        <span class="sisonke-badge sisonke-badge-blue">Uploaded</span>
                    </div>
                    <div>
                        <div class="detail-mini-label">Approved status</div>
                        <span class="@(IsApproved ? "sisonke-badge sisonke-badge-green" : "sisonke-badge sisonke-badge-gold")">@(IsApproved ? "Approved" : "Not Approved")</span>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    @if (!string.IsNullOrWhiteSpace(latestConstitution?.StoredFilePath))
                    {
                        <a class="sisonke-btn sisonke-btn-primary" href="@latestConstitution.StoredFilePath" target="_blank" rel="noopener noreferrer">
                            <i class="bi bi-box-arrow-up-right me-2"></i>Open Uploaded Document
                        </a>
                    }
                    @if (!IsApproved && canApproveConstitution)
                    {
                        <button type="button" class="sisonke-btn sisonke-btn-gold" @onclick="ShowApprovalConfirmation">
                            <i class="bi bi-check-circle me-2"></i>Approve Constitution
                        </button>
                    }
                </div>
            </div>
        </div>

        @if (!IsApproved && canApproveConstitution)
        {
            <ConfirmationModal
                IsVisible="@showApprovalConfirmation"
                Title="Approve Constitution"
                Message="You are about to approve this uploaded constitution. Please confirm that the uploaded document has been reviewed and accepted by the stokvel members."
                ConfirmButtonText="Confirm Approval"
                CancelButtonText="Cancel"
                ModalType="warning"
                OnConfirm="@ConfirmApprovalAsync"
                OnCancel="@CancelApproval" />
        }
    }
    else
    {
        <div class="sisonke-card mb-4">
            <div class="sisonke-card-body">
                <div class="sisonke-card-head">
                    <div>
                        <h2>Questionnaire Wizard</h2>
                        <p>Complete the Basics, Money, Rules and Sign-off steps to generate a constitution preview.</p>
                    </div>
                </div>

                <div class="wizard-steps mb-4">
                    @for (var step = 1; step <= stepTitles.Length; step++)
                    {
                        var localStep = step;
                        <button type="button"
                                class="wizard-step @(currentStep == localStep ? "active" : string.Empty)"
                                @onclick="() => GoToStep(localStep)">
                            <span>@localStep</span>
                            @stepTitles[localStep - 1]
                        </button>
                    }
                </div>

                @if (currentStep == 1)
                {
                    <div class="constitution-step-card">
                    <div class="form-section-title">Basics</div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label" for="group-purpose">What is the primary purpose of this group?</label>
                            <select id="group-purpose" class="form-select" value="@GetAnswer("groupPurpose")" @onchange='e => SetAnswer("groupPurpose", e.Value?.ToString())'>
                                <option value="">Select purpose</option>
                                @foreach (var option in GroupPurposeOptions)
                                {
                                    <option value="@option">@option</option>
                                }
                            </select>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label" for="chairperson">Chairperson Name</label>
                            <input id="chairperson" class="form-control" value="@GetAnswer("executiveChairperson")" @oninput='e => SetAnswer("executiveChairperson", e.Value?.ToString())' />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label" for="secretary">Secretary Name</label>
                            <input id="secretary" class="form-control" value="@GetAnswer("executiveSecretary")" @oninput='e => SetAnswer("executiveSecretary", e.Value?.ToString())' />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label" for="treasurer">Treasurer Name</label>
                            <input id="treasurer" class="form-control" value="@GetAnswer("executiveTreasurer")" @oninput='e => SetAnswer("executiveTreasurer", e.Value?.ToString())' />
                        </div>
                    </div>
                    </div>
                }
            else if (currentStep == 2)
            {
                <div class="constitution-step-card">
                <div class="form-section-title">Money</div>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="contribution-amount">Mandatory contribution amount per member</label>
                        <div class="input-group">
                            <span class="input-group-text">R</span>
                            <input id="contribution-amount" type="number" min="0" step="0.01" class="form-control" value="@GetAnswer("mandatoryContributionAmount")" @oninput='e => SetAnswer("mandatoryContributionAmount", e.Value?.ToString())' />
                        </div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="frequency">Contribution frequency</label>
                        <select id="frequency" class="form-select" value="@GetAnswer("contributionFrequency")" @onchange='e => SetAnswer("contributionFrequency", e.Value?.ToString())'>
                            <option value="">Select frequency</option>
                            @foreach (var option in ContributionFrequencyOptions)
                            {
                                <option value="@option">@option</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="due-day">Contribution due day</label>
                        <select id="due-day" class="form-select" value="@GetAnswer("contributionDueDay")" @onchange='e => SetAnswer("contributionDueDay", e.Value?.ToString())'>
                            <option value="">Select due day</option>
                            @foreach (var option in ContributionDueDayOptions)
                            {
                                <option value="@option">@option</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="joining-fee">Is there a non-refundable joining fee?</label>
                        <select id="joining-fee" class="form-select" value="@GetAnswer("hasJoiningFee")" @onchange='e => SetAnswer("hasJoiningFee", e.Value?.ToString())'>
                            <option value="">Select answer</option>
                            <option value="Yes">Yes</option>
                            <option value="No">No</option>
                        </select>
                    </div>
                    @if (GetAnswer("hasJoiningFee") == "Yes")
                    {
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="joining-amount">Joining fee amount</label>
                            <div class="input-group">
                                <span class="input-group-text">R</span>
                                <input id="joining-amount" type="number" min="0" step="0.01" class="form-control" value="@GetAnswer("joiningFeeAmount")" @oninput='e => SetAnswer("joiningFeeAmount", e.Value?.ToString())' />
                            </div>
                        </div>
                    }
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="approval-mandate">How many executive confirmations are required to approve payout or transfer?</label>
                        <select id="approval-mandate" class="form-select" value="@GetAnswer("withdrawalApprovalMandate")" @onchange='e => SetAnswer("withdrawalApprovalMandate", e.Value?.ToString())'>
                            <option value="">Select mandate</option>
                            <option value="2 out of 3 Executives">2 out of 3 Executives</option>
                            <option value="All 3 Executives">All 3 Executives</option>
                        </select>
                    </div>
                </div>
                </div>
            }
            else if (currentStep == 3)
            {
                <div class="constitution-step-card">
                <div class="form-section-title">Rules</div>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="voting-majority">What voting majority is required to change this constitution?</label>
                        <select id="voting-majority" class="form-select" value="@GetAnswer("constitutionChangeVotingMajority")" @onchange='e => SetAnswer("constitutionChangeVotingMajority", e.Value?.ToString())'>
                            <option value="">Select majority</option>
                            <option value="Simple Majority">Simple Majority</option>
                            <option value="Two-Thirds Majority">Two-Thirds Majority</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label" for="suspension-rule">After how many consecutive missed payments will a member be suspended or expelled?</label>
                        <select id="suspension-rule" class="form-select" value="@GetAnswer("missedPaymentSuspensionRule")" @onchange='e => SetAnswer("missedPaymentSuspensionRule", e.Value?.ToString())'>
                            <option value="">Select rule</option>
                            <option value="1 Month">1 Month</option>
                            <option value="2 Consecutive Months">2 Consecutive Months</option>
                            <option value="3 Consecutive Months">3 Consecutive Months</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="exit-handling">If a member exits before the cycle ends, how are past contributions handled?</label>
                        <select id="exit-handling" class="form-select" value="@GetAnswer("memberExitContributionHandling")" @onchange='e => SetAnswer("memberExitContributionHandling", e.Value?.ToString())'>
                            <option value="">Select handling</option>
                            <option value="Refund minus 10% admin fee within 30 days">Refund minus 10% admin fee within 30 days</option>
                            <option value="Refund at end of annual cycle">Refund at end of annual cycle</option>
                            <option value="Forfeit contributions to group pool">Forfeit contributions to group pool</option>
                        </select>
                    </div>
                    @if (GetAnswer("groupPurpose") == "Burial Society")
                    {
                        <div class="col-12 col-md-4">
                            <label class="form-label" for="burial-waiting">Burial waiting period</label>
                            <input id="burial-waiting" class="form-control" value="@GetAnswer("burialWaitingPeriod")" @oninput='e => SetAnswer("burialWaitingPeriod", e.Value?.ToString())' />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label" for="burial-turnaround">Burial claim turnaround</label>
                            <input id="burial-turnaround" class="form-control" value="@GetAnswer("burialClaimTurnaround")" @oninput='e => SetAnswer("burialClaimTurnaround", e.Value?.ToString())' />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label" for="burial-coverage">Burial family coverage</label>
                            <input id="burial-coverage" class="form-control" value="@GetAnswer("burialFamilyCoverage")" @oninput='e => SetAnswer("burialFamilyCoverage", e.Value?.ToString())' />
                        </div>
                    }
                    else if (GetAnswer("groupPurpose") == "Investment / Property Club")
                    {
                        <div class="col-12 col-md-4">
                            <label class="form-label" for="investment-voting">Investment voting power</label>
                            <input id="investment-voting" class="form-control" value="@GetAnswer("investmentVotingPower")" @oninput='e => SetAnswer("investmentVotingPower", e.Value?.ToString())' />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label" for="investment-lock">Investment lock-in period</label>
                            <input id="investment-lock" class="form-control" value="@GetAnswer("investmentLockInPeriod")" @oninput='e => SetAnswer("investmentLockInPeriod", e.Value?.ToString())' />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label" for="investment-exit">Investment early exit rule</label>
                            <input id="investment-exit" class="form-control" value="@GetAnswer("investmentEarlyExitRule")" @oninput='e => SetAnswer("investmentEarlyExitRule", e.Value?.ToString())' />
                        </div>
                    }
                    else if (GetAnswer("groupPurpose") == "Grocery / Bulk Buying")
                    {
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="grocery-split">Grocery split method</label>
                            <input id="grocery-split" class="form-control" value="@GetAnswer("grocerySplitMethod")" @oninput='e => SetAnswer("grocerySplitMethod", e.Value?.ToString())' />
                        </div>
                        <div class="col-12 col-md-6">
                            <label class="form-label" for="grocery-transport">Grocery transport cost rule</label>
                            <input id="grocery-transport" class="form-control" value="@GetAnswer("groceryTransportCostRule")" @oninput='e => SetAnswer("groceryTransportCostRule", e.Value?.ToString())' />
                        </div>
                    }
                </div>
                </div>
            }
            else
            {
                <div class="constitution-step-card">
                <div class="form-section-title">Sign-off</div>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label" for="death-benefit">In the event of a member's death, who inherits their financial standing or payout?</label>
                        <select id="death-benefit" class="form-select" value="@GetAnswer("deathBenefitHandling")" @onchange='e => SetAnswer("deathBenefitHandling", e.Value?.ToString())'>
                            <option value="">Select handling</option>
                            <option value="Paid to designated next of kin / beneficiary">Paid to designated next of kin / beneficiary</option>
                            <option value="Beneficiary steps into member slot">Beneficiary steps into member slot</option>
                            <option value="Paid to executor of estate">Paid to executor of estate</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <div class="form-check">
                            <input id="legal-disclosure" class="form-check-input" type="checkbox" checked="@(GetAnswer("legalDisclosureAccepted") == "Yes")" @onchange="SetLegalDisclosure" />
                            <label class="form-check-label" for="legal-disclosure">
                                I confirm that the group is a voluntary association and that personal data will be used for stokvel administration purposes.
                            </label>
                        </div>
                    </div>
                </div>
                </div>
            }

            <div class="wizard-actions mt-4">
                @if (currentStep > 1)
                {
                    <button type="button" class="sisonke-btn sisonke-btn-outline" @onclick="PreviousStep">
                        <i class="bi bi-arrow-left me-2"></i>Previous
                    </button>
                }
                @if (currentStep < 4)
                {
                    <button type="button" class="sisonke-btn sisonke-btn-primary" @onclick="NextStep">
                        Next<i class="bi bi-arrow-right ms-2"></i>
                    </button>
                }
                <button type="button" class="sisonke-btn sisonke-btn-outline" @onclick="SaveProgressAsync">
                    <i class="bi bi-save me-2"></i>Save Progress
                </button>
                <a class="sisonke-btn sisonke-btn-outline ms-auto" href="@($"/stokvel-dashboard/{StokvelId}")">
                    <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                </a>
            </div>
        </div>
    </div>

    <div class="sisonke-card mb-4">
        <div class="sisonke-card-body">
            <div class="sisonke-card-head">
                <div>
                    <h2>Build Actions</h2>
                    <p>Generate a preview, save a draft, upload an existing document or approve the final constitution.</p>
                </div>
            </div>

            <div class="constitution-toolbar">
                <button type="button" class="sisonke-btn sisonke-btn-primary" @onclick="GeneratePreviewAsync">
                    <i class="bi bi-file-earmark-text me-2"></i>Generate Preview
                </button>
                <button type="button" class="sisonke-btn sisonke-btn-outline" @onclick="SaveDraftAsync">
                    <i class="bi bi-floppy me-2"></i>Save Draft
                </button>
                <label class="sisonke-btn sisonke-btn-outline mb-0" for="existing-constitution">
                    <i class="bi bi-upload me-2"></i>Upload Existing
                </label>
                <InputFile id="existing-constitution" class="constitution-file-input" OnChange="@OnExistingConstitutionSelected" />
                @if (selectedConstitutionFile is not null)
                {
                    <button type="button" class="sisonke-btn sisonke-btn-outline" @onclick="UploadExistingConstitutionAsync">
                        Upload @selectedConstitutionFile.Name
                    </button>
                }
                @if (!IsApproved && canApproveConstitution)
                {
                    <button type="button" class="sisonke-btn sisonke-btn-gold" @onclick="ShowApprovalConfirmation">
                        <i class="bi bi-check-circle me-2"></i>Approve Constitution
                    </button>
                }
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(previewContent))
    {
        <div class="sisonke-card mb-4">
            <div class="sisonke-card-body constitution-preview-card">
                <div class="sisonke-card-head">
                    <div>
                        <h2>Constitution Preview</h2>
                        <p>Review the generated constitution content before saving or approval.</p>
                    </div>
                </div>
                @if (IsApproved)
                {
                    <div class="approved-watermark-banner mb-4">
                        <i class="bi bi-shield-fill-check me-2"></i>
                        This constitution has been approved and is binding on all members.
                    </div>
                }
                <div class="constitution-preview">
                    @((MarkupString)previewContent)
                </div>
            </div>
        </div>
    }

    @if (!IsApproved && canApproveConstitution)
    {
        <ConfirmationModal
            IsVisible="@showApprovalConfirmation"
            Title="Approve Constitution"
            Message="You are about to approve this constitution. Please confirm that all wizard answers and generated content have been reviewed and accepted by the stokvel members."
            ConfirmButtonText="Confirm Approval"
            CancelButtonText="Cancel"
            ModalType="warning"
            OnConfirm="@ConfirmApprovalAsync"
            OnCancel="@CancelApproval" />
    }
    }
}

<style>
    .constitution-hero-badges {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
        margin-top: .5rem;
    }

    .constitution-hero-meta {
        display: grid;
        gap: .75rem;
        min-width: min(18rem, 100%);
        padding: 1rem;
        border: 1px solid rgb(255 255 255 / .28);
        border-radius: var(--r-md);
        background: rgb(255 255 255 / .12);
    }

    .constitution-hero-meta div {
        display: grid;
        gap: .15rem;
    }

    .constitution-hero-meta span {
        color: rgb(255 255 255 / .78);
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .constitution-hero-meta strong {
        color: #fff;
        font-size: .98rem;
    }

    .fw-600 { font-weight: 600; }
    .fw-700 { font-weight: 700; }
    .dash-card-icon-sm {
        width: 2rem;
        height: 2rem;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .875rem;
        flex-shrink: 0;
    }
    .detail-mini-label {
        font-size: .6875rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--muted);
        font-weight: 600;
        margin-bottom: .15rem;
    }
    .wizard-steps {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: .75rem;
    }
    .wizard-step {
        border: 1px solid var(--border);
        border-radius: var(--r-md);
        background: #fff;
        color: var(--text);
        box-shadow: var(--shadow-sm);
        font-weight: 600;
        padding: .75rem;
        text-align: left;
