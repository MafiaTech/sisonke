@page "/contribution-rules/{StokvelId:guid}"
@rendermode InteractiveServer

@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject ContributionService ContributionService
@inject NavigationManager NavigationManager
@inject StokvelService StokvelService

<PageTitle>Contribution Rules</PageTitle>

@if (isLoading)
{
    <p>Loading contribution rules...</p>
}
else if (stokvel is null)
{
    <div class="alert alert-danger" role="alert">
        Stokvel not found.
    </div>
}
else
{
    <div class="mb-4">
        <h1>Contribution Rules</h1>
        <p class="text-muted mb-1">@stokvel.Name</p>
        <a href="@($"/stokvel-dashboard/{StokvelId}")">Back to Dashboard</a>
    </div>

    @if (savedSuccessfully)
    {
        <div class="alert alert-success" role="alert">
            Contribution rule saved successfully.
        </div>
    }

    @if (saveFailed)
    {
        <div class="alert alert-danger" role="alert">
            Unable to save contribution rule.
        </div>
    }

    <EditForm Model="@rule" OnValidSubmit="@HandleValidSubmit" FormName="ContributionRuleForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label class="form-label" for="amount">Amount</label>
                <InputNumber id="amount" class="form-control" @bind-Value="rule.Amount" />
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label" for="frequency">Frequency</label>
                <InputSelect id="frequency" class="form-select" @bind-Value="rule.Frequency">
                    @foreach (var frequency in Enum.GetValues<ContributionFrequency>())
                    {
                        <option value="@frequency">@frequency</option>
                    }
                </InputSelect>
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label" for="due-day">Due day of month</label>
                <InputNumber id="due-day" class="form-control" @bind-Value="rule.DueDayOfMonth" />
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label" for="late-payment-fine">Late payment fine amount</label>
                <InputNumber id="late-payment-fine" class="form-control" @bind-Value="rule.LatePaymentFineAmount" />
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label" for="grace-period">Grace period days</label>
                <InputNumber id="grace-period" class="form-control" @bind-Value="rule.GracePeriodDays" />
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label" for="effective-from">Effective from</label>
                <InputDate id="effective-from" class="form-control" @bind-Value="rule.EffectiveFrom" />
            </div>

            <div class="col-12">
                <div class="form-check">
                    <InputCheckbox id="allow-partial-payments" class="form-check-input" @bind-Value="rule.AllowPartialPayments" />
                    <label class="form-check-label" for="allow-partial-payments">Allow partial payments</label>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <button class="btn btn-primary" type="submit">Save Contribution Rule</button>
        </div>
    </EditForm>
}

@code {
    private Stokvel? stokvel;
    private ContributionRule rule = CreateDefaultRule();
    private bool isLoading = true;
    private bool savedSuccessfully;
    private bool saveFailed;

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);

        var activeRule = await ContributionService.GetActiveContributionRuleByStokvelIdAsync(StokvelId);
        rule = activeRule is null
            ? CreateDefaultRule()
            : new ContributionRule
            {
                Amount = activeRule.Amount,
                Frequency = activeRule.Frequency,
                DueDayOfMonth = activeRule.DueDayOfMonth,
                AllowPartialPayments = activeRule.AllowPartialPayments,
                LatePaymentFineAmount = activeRule.LatePaymentFineAmount,
                GracePeriodDays = activeRule.GracePeriodDays,
                EffectiveFrom = activeRule.EffectiveFrom
            };

        isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        savedSuccessfully = false;
        saveFailed = false;

        var savedRule = await ContributionService.SaveContributionRuleAsync(StokvelId, rule);

        if (savedRule is null)
        {
            saveFailed = true;
            return;
        }

        savedSuccessfully = true;
        rule = new ContributionRule
        {
            Amount = savedRule.Amount,
            Frequency = savedRule.Frequency,
            DueDayOfMonth = savedRule.DueDayOfMonth,
            AllowPartialPayments = savedRule.AllowPartialPayments,
            LatePaymentFineAmount = savedRule.LatePaymentFineAmount,
            GracePeriodDays = savedRule.GracePeriodDays,
            EffectiveFrom = savedRule.EffectiveFrom
        };
    }

    private static ContributionRule CreateDefaultRule()
    {
        return new ContributionRule
        {
            Amount = 0,
            Frequency = ContributionFrequency.Monthly,
            DueDayOfMonth = 5,
            AllowPartialPayments = true,
            LatePaymentFineAmount = 0,
            GracePeriodDays = 0,
            EffectiveFrom = DateTime.Today
        };
    }
}
