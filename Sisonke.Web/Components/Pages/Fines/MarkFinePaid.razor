@page "/mark-fine-paid/{MemberFineId:guid}"
@rendermode InteractiveServer

@using Sisonke.Web.Components.Shared
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject FineService FineService
@inject NavigationManager NavigationManager

<PageTitle>Mark Fine Paid</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading fine details…
    </div>
}
else if (memberFine is null)
{
    <AlertBanner Type="danger" Title="Fine not found." Message="" Icon="bi bi-x-circle-fill" />
}
else
{
    <PageHeader
        Title="Mark Fine Paid"
        Subtitle="@memberFine.Member.FullName"
        BackText="Back to Member Profile"
        BackHref="@($"/member-profile/{memberFine.MemberId}")" />

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <AlertBanner Type="success" Title="Payment confirmed" Message="@successMessage" Icon="bi bi-check-circle-fill" />
    }
    else if (memberFine.Status == FineStatus.Paid)
    {
        <AlertBanner Type="info" Title="Already paid" Message="This fine has already been marked as paid." Icon="bi bi-info-circle-fill" />
    }

    @if (updateFailed)
    {
        <AlertBanner Type="danger" Title="Could not mark fine as paid." Message="Please try again." Icon="bi bi-x-circle-fill" />
    }

    <div class="form-page form-page-sm">
        <div class="card">
            <div class="card-body p-4">
                <div class="form-section-title">Fine Details</div>
                <dl class="profile-dl">
                    <div class="pdl-row"><dt>Member</dt><dd class="fw-600">@memberFine.Member.FullName</dd></div>
                    <div class="pdl-row"><dt>Fine type</dt><dd>@memberFine.FineType.Name</dd></div>
                    <div class="pdl-row">
                        <dt>Amount</dt>
                        <dd class="fw-600" style="font-size:1.125rem">@memberFine.Amount.ToString("C0", new System.Globalization.CultureInfo("en-ZA"))</dd>
                    </div>
                    <div class="pdl-row"><dt>Reason</dt><dd>@memberFine.Reason</dd></div>
                    <div class="pdl-row"><dt>Fine date</dt><dd>@memberFine.FineDate.ToString("dd MMM yyyy")</dd></div>
                    <div class="pdl-row last">
                        <dt>Current status</dt>
                        <dd>
                            <StatusBadge Text="@memberFine.Status.ToString()" Type="@(memberFine.Status == FineStatus.Paid ? "success" : "danger")" />
                        </dd>
                    </div>
                </dl>
            </div>
        </div>
    </div>

    <ConfirmationModal
        IsVisible="@showPaymentConfirmation"
        Title="Confirm Fine Payment"
        Message="You are about to mark this fine as paid. Please confirm that payment was received before continuing."
        ConfirmButtonText="Confirm Payment"
        CancelButtonText="Cancel"
        ModalType="warning"
        OnConfirm="@ConfirmPaymentAsync"
        OnCancel="@CancelPayment" />
}

<style>
    .fw-600 { font-weight: 600; }
    .profile-dl { margin: 0; }
    .pdl-row {
        display: flex;
        padding: .625rem 0;
        border-bottom: 1px solid var(--sk-border);
        gap: 1rem;
        font-size: .9rem;
    }
    .pdl-row.last { border-bottom: none; }
    .pdl-row dt { flex: 0 0 40%; font-weight: 400; color: var(--sk-text-muted); font-size: .875rem; }
    .pdl-row dd { flex: 1; margin: 0; font-weight: 500; color: var(--sk-text); }
</style>

@code {
    private MemberFine? memberFine;
    private bool isLoading = true;
    private bool showPaymentConfirmation = true;
    private bool updateFailed;
    private string? successMessage;

    [Parameter]
    public Guid MemberFineId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        memberFine = await FineService.GetMemberFineByIdAsync(MemberFineId);
        showPaymentConfirmation = memberFine?.Status == FineStatus.Unpaid;
        isLoading = false;
    }

    private async Task ConfirmPaymentAsync()
    {
        updateFailed = false;
        var updatedFine = await FineService.MarkFineAsPaidAsync(MemberFineId);

        if (updatedFine is null)
        {
            updateFailed = true;
            showPaymentConfirmation = false;
            return;
        }

        memberFine = await FineService.GetMemberFineByIdAsync(MemberFineId) ?? updatedFine;
        successMessage = "Fine has been marked as paid successfully.";
        showPaymentConfirmation = false;
    }

    private void CancelPayment()
    {
        showPaymentConfirmation = false;
        if (memberFine is not null)
            NavigationManager.NavigateTo($"/member-profile/{memberFine.MemberId}");
    }
}
