@page "/add-fine/{MemberId:guid}"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject FineService FineService
@inject MemberService MemberService
@inject NavigationManager NavigationManager
@inject StokvelService StokvelService

<PageTitle>Add Fine</PageTitle>

@if (isLoading)
{
    <p>Loading fine form...</p>
}
else if (member is null)
{
    <div class="alert alert-danger" role="alert">
        Member not found.
    </div>
}
else
{
    <div class="mb-4">
        <h1>Add Fine</h1>
        <p class="text-muted mb-1">@member.FullName</p>
        <a href="@($"/member-profile/{MemberId}")">Back to Member Profile</a>
    </div>

    @if (saveFailed)
    {
        <div class="alert alert-danger" role="alert">
            Unable to save fine.
        </div>
    }

    @if (fineTypes.Count == 0)
    {
        <div class="alert alert-info" role="alert">
            No fine types configured for this stokvel.
        </div>
    }
    else
    {
        <EditForm Model="@model" OnValidSubmit="@HandleValidSubmit" FormName="AddFineForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label" for="fine-type">Fine type</label>
                    <InputSelect id="fine-type" class="form-select" @bind-Value="model.FineTypeId">
                        <option value="@Guid.Empty">Select fine type</option>
                        @foreach (var fineType in fineTypes)
                        {
                            <option value="@fineType.Id">@fineType.Name - default @fineType.DefaultAmount.ToString("C")</option>
                        }
                    </InputSelect>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label" for="amount">Amount</label>
                    <InputNumber id="amount" class="form-control" @bind-Value="model.Amount" />
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label" for="fine-date">Fine date</label>
                    <InputDate id="fine-date" class="form-control" @bind-Value="model.FineDate" />
                </div>

                <div class="col-12">
                    <label class="form-label" for="reason">Reason</label>
                    <InputTextArea id="reason" class="form-control" @bind-Value="model.Reason" />
                </div>
            </div>

            <div class="mt-4">
                <button class="btn btn-primary" type="submit">Save Fine</button>
            </div>
        </EditForm>
    }
}

@code {
    private Member? member;
    private List<FineType> fineTypes = [];
    private AddFineModel model = new();
    private bool isLoading = true;
    private bool saveFailed;

    [Parameter]
    public Guid MemberId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        member = await MemberService.GetMemberByIdAsync(MemberId);

        if (member is not null)
        {
            var stokvel = await StokvelService.GetStokvelByTenantIdAsync(member.TenantId);

            if (stokvel is not null)
            {
                fineTypes = await FineService.GetFineTypesByStokvelIdAsync(stokvel.Id);
            }
        }

        isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        saveFailed = false;

        var savedFine = await FineService.AddMemberFineAsync(
            MemberId,
            model.FineTypeId,
            model.Amount,
            model.Reason,
            model.FineDate);

        if (savedFine is null)
        {
            saveFailed = true;
            return;
        }

        NavigationManager.NavigateTo($"/member-profile/{MemberId}");
    }

    private class AddFineModel
    {
        [Required]
        public Guid FineTypeId { get; set; }

        [Range(0.01, 100000)]
        public decimal Amount { get; set; }

        [Required]
        [MaxLength(250)]
        public string Reason { get; set; } = string.Empty;

        public DateTime FineDate { get; set; } = DateTime.Today;
    }
}
