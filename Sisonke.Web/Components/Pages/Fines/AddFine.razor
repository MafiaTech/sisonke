@page "/add-fine/{MemberId:guid}"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject FineService FineService
@inject MemberService MemberService
@inject NavigationManager NavigationManager
@inject StokvelService StokvelService

<PageTitle>Add Fine</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading fine form…
    </div>
}
else if (member is null)
{
    <AlertBanner Type="danger" Title="Member not found." Message="" Icon="bi bi-x-circle-fill" />
}
else
{
    <PageHeader
        Title="Add Fine"
        Subtitle="@member.FullName"
        BackText="Back to Member Profile"
        BackHref="@($"/member-profile/{MemberId}")" />

    @if (saveFailed)
    {
        <AlertBanner Type="danger" Title="Unable to save fine." Message="Please try again." Icon="bi bi-x-circle-fill" />
    }

    @if (fineTypes.Count == 0)
    {
        <AlertBanner Type="info" Title="No fine types configured." Message="Configure fine types for this stokvel before adding fines." Icon="bi bi-info-circle-fill" />
    }
    else
    {
        <div class="form-page form-page-sm">
            <div class="card">
                <div class="card-body p-4">
                    <EditForm Model="@model" OnValidSubmit="@HandleValidSubmit" FormName="AddFineForm">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="alert alert-danger" />

                        <div class="form-section-title">Fine Details</div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label" for="fine-type">Fine type <span class="text-danger">*</span></label>
                                <InputSelect id="fine-type" class="form-select" @bind-Value="model.FineTypeId">
                                    <option value="@Guid.Empty">— Select fine type —</option>
                                    @foreach (var fineType in fineTypes)
                                    {
                                        <option value="@fineType.Id">@fineType.Name — default @fineType.DefaultAmount.ToString("C0")</option>
                                    }
                                </InputSelect>
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label" for="amount">Amount (R) <span class="text-danger">*</span></label>
                                <div class="input-group">
                                    <span class="input-group-text">R</span>
                                    <InputNumber id="amount" class="form-control" @bind-Value="model.Amount" />
                                </div>
                                <div class="form-text">Override the default fine amount if needed.</div>
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label" for="fine-date">Fine date</label>
                                <InputDate id="fine-date" class="form-control" @bind-Value="model.FineDate" />
                            </div>

                            <div class="col-12">
                                <label class="form-label" for="reason">Reason <span class="text-danger">*</span></label>
                                <InputTextArea id="reason" class="form-control" rows="3" placeholder="Briefly describe the reason for this fine." @bind-Value="model.Reason" />
                            </div>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <button class="btn btn-primary" type="submit">
                                <i class="bi bi-check-circle me-2"></i>Save Fine
                            </button>
                            <a class="btn btn-outline-secondary" href="@($"/member-profile/{MemberId}")">Cancel</a>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    }
}

@code {
    private Member? member;
    private List<FineType> fineTypes = [];
    private AddFineModel model = new();
    private bool isLoading = true;
    private bool saveFailed;

    [Parameter]
    public Guid MemberId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        member = await MemberService.GetMemberByIdAsync(MemberId);

        if (member is not null)
        {
            var stokvel = await StokvelService.GetStokvelByTenantIdAsync(member.TenantId);
            if (stokvel is not null)
            {
                fineTypes = await FineService.GetFineTypesByStokvelIdAsync(stokvel.Id);

                if (fineTypes.Count == 0)
                {
                    await FineService.EnsureDefaultFineTypesForStokvelAsync(stokvel.Id);
                    fineTypes = await FineService.GetFineTypesByStokvelIdAsync(stokvel.Id);
                }
            }
        }

        isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        saveFailed = false;
        var savedFine = await FineService.AddMemberFineAsync(MemberId, model.FineTypeId, model.Amount, model.Reason, model.FineDate);
        if (savedFine is null) { saveFailed = true; return; }
        NavigationManager.NavigateTo($"/member-profile/{MemberId}");
    }

    private class AddFineModel
    {
        [Required]
        public Guid FineTypeId { get; set; }

        [Range(0.01, 100000)]
        public decimal Amount { get; set; }

        [Required][MaxLength(250)]
        public string Reason { get; set; } = string.Empty;

        public DateTime FineDate { get; set; } = DateTime.Today;
    }
}
