@page "/rotation-schedule/{StokvelId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using Microsoft.AspNetCore.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject StokvelService StokvelService
@inject NavigationManager NavigationManager

<PageTitle>Rotation Schedule</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading rotation schedule…
    </div>
}
else if (stokvel is null)
{
    <AlertBanner Type="warning" Title="Stokvel not found." Message="" Icon="bi bi-exclamation-triangle-fill" />
    <a class="sisonke-btn sisonke-btn-outline mt-3" href="/my-workspace">
        <i class="bi bi-arrow-left me-2"></i>Back to Workspace
    </a>
}
else if (!stokvel.EnableRotation)
{
    <AlertBanner
        Type="warning"
        Title="Rotation is not enabled for this stokvel type."
        Message="Only Rotational Stokvel archetypes use the rotation schedule feature."
        Icon="bi bi-exclamation-triangle-fill" />
    <a class="sisonke-btn sisonke-btn-outline mt-3" href="@($"/stokvel-dashboard/{StokvelId}")">
        <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
    </a>
}
else
{
    <section class="sisonke-hero-card mb-4">
        <div>
            <span class="sisonke-badge sisonke-badge-gold">Rotational Stokvel</span>
            <h1>Rotation Schedule</h1>
            <p>@stokvel.Name</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="sisonke-btn sisonke-btn-outline" href="@($"/stokvel-dashboard/{StokvelId}")">
                <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
            </a>
        </div>
    </section>

    <div class="sisonke-card mb-3">
        <div class="sisonke-card-body">
            <div class="sisonke-card-head">
                <div>
                    <h2>Payout Order</h2>
                    <p>The sequence in which members receive the rotating lump-sum payout.</p>
                </div>
                <span class="sisonke-badge sisonke-badge-gray">Coming Soon</span>
            </div>

            <div class="sisonke-alert sisonke-alert-blue mb-0">
                <i class="bi bi-info-circle me-2"></i>
                The rotation schedule will show payout order, next recipient and contribution cycle once member order has been configured.
                This feature is in active development for the next release.
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-md-4">
            <div class="card h-100">
                <div class="card-body p-4">
                    <div class="detail-mini-label mb-2">Next Recipient</div>
                    <div class="placeholder-coming-soon">
                        <i class="bi bi-person-circle" style="font-size:2rem;color:var(--sk-text-muted);"></i>
                        <div class="text-muted small mt-2">To be configured</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100">
                <div class="card-body p-4">
                    <div class="detail-mini-label mb-2">Payout Amount</div>
                    <div class="placeholder-coming-soon">
                        <i class="bi bi-cash-coin" style="font-size:2rem;color:var(--sk-text-muted);"></i>
                        <div class="text-muted small mt-2">Based on contribution rules</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card h-100">
                <div class="card-body p-4">
                    <div class="detail-mini-label mb-2">Contribution Cycle</div>
                    <div class="placeholder-coming-soon">
                        <i class="bi bi-calendar-event" style="font-size:2rem;color:var(--sk-text-muted);"></i>
                        <div class="text-muted small mt-2">Cycle dates not yet set</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="sisonke-card mt-3">
        <div class="sisonke-card-body">
            <div class="sisonke-card-head mb-3">
                <div>
                    <h2>Member Rotation Order</h2>
                    <p>Define which member receives the lump sum in each round.</p>
                </div>
                <button class="sisonke-btn sisonke-btn-outline" type="button" disabled>
                    <i class="bi bi-pencil me-2"></i>Configure Order (Coming Soon)
                </button>
            </div>

            <div class="sisonke-alert sisonke-alert-info mb-0">
                Member rotation order, payout tracking and cycle management will be available in the next release.
                For now, use the <strong>Members</strong> and <strong>Contributions</strong> sections to manage this stokvel.
            </div>
        </div>
    </div>
}

<style>
    .placeholder-coming-soon {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 5rem;
        color: var(--sk-text-muted);
        text-align: center;
    }
</style>

@code {
    private Stokvel? stokvel;
    private bool isLoading = true;

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);
        isLoading = false;
    }
}
