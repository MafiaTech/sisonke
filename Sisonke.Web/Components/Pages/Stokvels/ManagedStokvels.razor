@page "/managed-stokvels"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccountLinkingService MemberAccountLinkingService
@inject MemberAccessService MemberAccessService
@inject StokvelService StokvelService

<PageTitle>Stokvels I Manage</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading managed stokvels...
    </div>
}
else
{
    <PageHeader
        Title="Stokvels I Manage"
        Subtitle="Office bearer access linked to your account."
        BackText="Back to Workspace"
        BackHref="/my-workspace" />

    <div class="d-flex justify-content-end mb-3">
        <a class="btn btn-primary btn-sm" href="/register-stokvel">
            <i class="bi bi-plus-circle me-1"></i>Register New Stokvel
        </a>
    </div>

    @if (managedMemberships.Count == 0)
    {
        <div class="ms-empty-state">
            <div class="ms-empty-icon-ring">
                <i class="bi bi-grid" aria-hidden="true"></i>
            </div>
            <h2 class="ms-empty-title">You are not currently an office bearer for any stokvel.</h2>
            <p class="ms-empty-text">Managed stokvels will appear here when your linked member role is Chairperson, Secretary, Treasurer or another office bearer role.</p>
            <a class="btn btn-outline-secondary" href="/my-workspace">Back to My Workspace</a>
        </div>
    }
    else
    {
        <div class="managed-stokvel-grid">
            @foreach (var item in managedMemberships)
            {
                <section class="card border-0 shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between gap-3 align-items-start mb-3">
                            <div>
                                <div class="managed-detail-label">Stokvel</div>
                                <h2 class="managed-card-title">@item.Stokvel.Name</h2>
                            </div>
                            <StatusBadge Text="Office Bearer" Type="success" />
                        </div>

                        <div class="managed-card-details">
                            <div>
                                <div class="managed-detail-label">Member</div>
                                <div class="managed-detail-value">@Display(item.Member.FullName)</div>
                            </div>
                            <div>
                                <div class="managed-detail-label">Role</div>
                                <div class="managed-detail-value">@item.Member.DefaultRole</div>
                            </div>
                            <div>
                                <div class="managed-detail-label">Member Number</div>
                                <div class="managed-detail-value">@Display(item.Member.MemberNumber)</div>
                            </div>
                            <div>
                                <div class="managed-detail-label">Access Type</div>
                                <div class="managed-detail-value">Office Bearer</div>
                            </div>
                        </div>

                        <div class="managed-card-actions mt-4">
                            <a class="btn btn-sm btn-primary" href="@($"/stokvel-dashboard/{item.Stokvel.Id}")">
                                Open Management Dashboard
                            </a>
                            <a class="btn btn-sm btn-outline-primary" href="@($"/members/{item.Stokvel.Id}")">
                                Manage Members
                            </a>
                            <a class="btn btn-sm btn-outline-primary" href="@($"/meetings/{item.Stokvel.Id}")">
                                Meetings
                            </a>
                            <a class="btn btn-sm btn-outline-primary" href="@($"/constitution-builder/{item.Stokvel.Id}")">
                                Constitution
                            </a>
                        </div>
                    </div>
                </section>
            }
        </div>
    }
}

<style>
    .managed-stokvel-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    }

    .managed-card-title {
        color: var(--sk-text);
        font-size: 1.125rem;
        font-weight: 800;
        margin: .15rem 0 0;
    }

    .managed-card-details {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .managed-detail-label {
        color: var(--sk-text-muted);
        font-size: .7rem;
        font-weight: 800;
        letter-spacing: .07em;
        text-transform: uppercase;
    }

    .managed-detail-value {
        color: var(--sk-text);
        font-size: .925rem;
        font-weight: 650;
        margin-top: .2rem;
        overflow-wrap: anywhere;
    }

    .managed-card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
    }

    @@media (max-width: 640px) {
        .managed-card-details {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private readonly List<ManagedMembership> managedMemberships = [];
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            isLoading = false;
            return;
        }

        var memberships = await MemberAccountLinkingService.GetMembershipsForUserAsync(userId);

        foreach (var member in memberships)
        {
            var stokvel = await StokvelService.GetStokvelByTenantIdAsync(member.TenantId);

            if (stokvel is not null && await MemberAccessService.IsOfficeBearerAsync(userId, stokvel.Id))
            {
                managedMemberships.Add(new ManagedMembership(member, stokvel));
            }
        }

        isLoading = false;
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not captured" : value;
    }

    private sealed record ManagedMembership(Member Member, Stokvel Stokvel);
}
