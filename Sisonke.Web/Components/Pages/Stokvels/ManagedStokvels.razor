@page "/managed-stokvels"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccountLinkingService MemberAccountLinkingService
@inject MemberAccessService MemberAccessService
@inject StokvelService StokvelService

<PageTitle>My Managed Stokvels</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading managed stokvels...
    </div>
}
else
{
    <section class="sisonke-hero-card mb-4">
        <div>
            <span class="sisonke-badge sisonke-badge-gold">Office Bearer</span>
            <h1>My Managed Stokvels</h1>
            <p>Your office bearer access and role-based shortcuts.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="sisonke-btn sisonke-btn-outline" href="/my-workspace">My Workspace</a>
            <a class="sisonke-btn sisonke-btn-primary" href="/register-stokvel">Register New Stokvel</a>
        </div>
    </section>

    @if (managedMemberships.Count == 0)
    {
        <div class="ms-empty-state">
            <div class="ms-empty-icon-ring">
                <i class="bi bi-grid" aria-hidden="true"></i>
            </div>
            <h2 class="ms-empty-title">You are not currently an office bearer for any stokvel.</h2>
            <p class="ms-empty-text">Managed stokvels will appear here when your linked member role is Chairperson, Secretary, Treasurer or another office bearer role.</p>
            <a class="sisonke-btn sisonke-btn-outline" href="/my-workspace">Back to My Workspace</a>
        </div>
    }
    else
    {
        @if (managedMemberships.Count == 1)
        {
            <div class="sisonke-alert sisonke-alert-blue mb-4">
                You currently manage one stokvel. Open the dashboard to continue.
            </div>
        }

        <div class="managed-stokvel-grid">
            @foreach (var item in managedMemberships)
            {
                var role = item.Member.DefaultRole.ToString();
                <section class="sisonke-card">
                    <div class="sisonke-card-head">
                        <div>
                            <span class="@GetRoleBadgeClass(role)">@GetRoleLabel(role)</span>
                            <h2 class="managed-card-title mt-1">@item.Stokvel.Name</h2>
                            <p class="text-muted small mb-0">@Display(item.Member.FullName) &middot; @Display(item.Member.MemberNumber)</p>
                        </div>
                        <div class="d-flex flex-column align-items-end gap-2">
                            <StatusBadge
                                Text="@(item.Stokvel.IsActive ? "Active" : "Inactive")"
                                Type="@(item.Stokvel.IsActive ? "success" : "secondary")" />
                            @if (item.Subscription is not null)
                            {
                                <span class="sisonke-badge sisonke-badge-blue">@item.Subscription.SubscriptionPlan.Name</span>
                            }
                        </div>
                    </div>
                    <div class="sisonke-card-body">

                        <div class="managed-card-details mb-4">
                            <div>
                                <div class="managed-detail-label">Member</div>
                                <div class="managed-detail-value">@Display(item.Member.FullName)</div>
                            </div>
                            <div>
                                <div class="managed-detail-label">Member Number</div>
                                <div class="managed-detail-value">@Display(item.Member.MemberNumber)</div>
                            </div>
                            <div>
                                <div class="managed-detail-label">Role</div>
                                <div class="managed-detail-value">@GetRoleLabel(role)</div>
                            </div>
                            <div>
                                <div class="managed-detail-label">Access Type</div>
                                <div class="managed-detail-value">Office Bearer</div>
                            </div>
                            <div>
                                <div class="managed-detail-label">Status</div>
                                <div class="managed-detail-value">@(item.Stokvel.IsActive ? "Active" : "Inactive")</div>
                            </div>
                            <div>
                                <div class="managed-detail-label">Package</div>
                                <div class="managed-detail-value">@(item.Subscription?.SubscriptionPlan.Name ?? "—")</div>
                            </div>
                        </div>

                        <div class="managed-detail-label mb-2">Quick Access</div>
                        <div class="managed-card-actions">
                            <a class="sisonke-btn sisonke-btn-primary" href="@($"/stokvel-dashboard/{item.Stokvel.Id}")">
                                Open Management Dashboard
                            </a>

                            @if (IsSecretaryRole(role))
                            {
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/secretary-tasks/{item.Stokvel.Id}")">Secretary Tasks</a>
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/members/{item.Stokvel.Id}")">Members</a>
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/meetings/{item.Stokvel.Id}")">Meetings</a>
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/member-warnings/{item.Stokvel.Id}")">Warnings</a>
                            }
                            else if (IsChairpersonRole(role))
                            {
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/chairperson-tasks/{item.Stokvel.Id}")">Approval Tasks</a>
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/secretary-tasks/{item.Stokvel.Id}")">Claims</a>
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/constitution-builder/{item.Stokvel.Id}")">Constitution</a>
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/member-warnings/{item.Stokvel.Id}")">Warnings</a>
                            }
                            else if (IsTreasurerRole(role))
                            {
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/treasurer-tasks/{item.Stokvel.Id}")">Treasurer Tasks</a>
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/finance-summary/{item.Stokvel.Id}")">Finance Summary</a>
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/contribution-capture/{item.Stokvel.Id}")">Contribution Capture</a>
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/finance-summary/{item.Stokvel.Id}")">Member Arrears</a>
                            }
                            else if (IsCreatorOrAdminRole(role))
                            {
                                <a class="sisonke-btn sisonke-btn-gold" href="@($"/stokvel-dashboard/{item.Stokvel.Id}")">Executive Overview</a>
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/members/{item.Stokvel.Id}")">Manage Members</a>
                                <a class="sisonke-btn sisonke-btn-outline" href="@($"/stokvel-questionnaire/{item.Stokvel.Id}")">Configuration</a>
                            }
                        </div>
                    </div>
                </section>
            }
        </div>
    }
}

<style>
    .managed-stokvel-grid {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: repeat(auto-fit, minmax(24rem, 1fr));
    }

    .managed-card-title {
        color: var(--sk-text);
        font-size: 1.125rem;
        font-weight: 800;
        margin: .15rem 0 0;
    }

    .managed-card-details {
        display: grid;
        gap: .75rem 1rem;
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .managed-detail-label {
        color: var(--sk-text-muted);
        font-size: .7rem;
        font-weight: 800;
        letter-spacing: .07em;
        text-transform: uppercase;
    }

    .managed-detail-value {
        color: var(--sk-text);
        font-size: .925rem;
        font-weight: 650;
        margin-top: .2rem;
        overflow-wrap: anywhere;
    }

    .managed-card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
    }

    @@media (max-width: 768px) {
        .managed-card-details {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 480px) {
        .managed-card-details {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private readonly List<ManagedMembership> managedMemberships = [];
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            isLoading = false;
            return;
        }

        var memberships = await MemberAccountLinkingService.GetMembershipsForUserAsync(userId);

        foreach (var member in memberships)
        {
            var stokvel = await StokvelService.GetStokvelByTenantIdAsync(member.TenantId);

            if (stokvel is not null && await MemberAccessService.IsOfficeBearerAsync(userId, stokvel.Id))
            {
                var subscription = await StokvelService.GetActiveSubscriptionByStokvelIdAsync(stokvel.Id);
                managedMemberships.Add(new ManagedMembership(member, stokvel, subscription));
            }
        }

        isLoading = false;
    }

    private static string Display(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string GetRoleLabel(string? role) =>
        role?.Trim() switch
        {
            "Creator" or "Admin" or "StokvelAdmin" => "Creator / Admin",
            "Chairperson" => "Chairperson",
            "Secretary" => "Secretary",
            "Treasurer" => "Treasurer",
            _ => role ?? "Office Bearer"
        };

    private static string GetRoleBadgeClass(string? role) =>
        role?.Trim() switch
        {
            "Creator" or "Admin" or "StokvelAdmin" => "sisonke-badge sisonke-badge-red",
            "Chairperson" => "sisonke-badge sisonke-badge-gold",
            "Secretary" => "sisonke-badge sisonke-badge-blue",
            "Treasurer" => "sisonke-badge sisonke-badge-green",
            _ => "sisonke-badge sisonke-badge-gray"
        };

    private static bool IsCreatorOrAdminRole(string? role)
    {
        var normalizedRole = role?.Trim();
        return normalizedRole?.Equals("Creator", StringComparison.OrdinalIgnoreCase) == true ||
               normalizedRole?.Equals("Admin", StringComparison.OrdinalIgnoreCase) == true ||
               normalizedRole?.Equals("StokvelAdmin", StringComparison.OrdinalIgnoreCase) == true;
    }

    private static bool IsChairpersonRole(string? role) =>
        role?.Trim().Equals("Chairperson", StringComparison.OrdinalIgnoreCase) == true;

    private static bool IsSecretaryRole(string? role) =>
        role?.Trim().Equals("Secretary", StringComparison.OrdinalIgnoreCase) == true;

    private static bool IsTreasurerRole(string? role) =>
        role?.Trim().Equals("Treasurer", StringComparison.OrdinalIgnoreCase) == true;

    private sealed record ManagedMembership(Member Member, Stokvel Stokvel, TenantSubscription? Subscription);
}
