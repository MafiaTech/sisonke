@page "/stokvel/{StokvelId:guid}/loans"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject LoansWalletService Service
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Loans</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading loans…
    </div>
}
else if (state is null)
{
    <AlertBanner Type="warning" Title="Stokvel or linked membership not found." Message="" Icon="bi bi-exclamation-triangle-fill" />
    <a class="sisonke-btn sisonke-btn-outline mt-3" href="/my-workspace"><i class="bi bi-arrow-left me-2"></i>Back to Workspace</a>
}
else
{
    <StokvelSubNav StokvelId="@StokvelId" IsRotational="@(state.Stokvel.Archetype == StokvelArchetype.Rotational)" />

    @if (state.Stokvel.Archetype == StokvelArchetype.BurialSociety)
    {
        <div class="sisonke-card"><div class="sisonke-card-body">
            <div class="sisonke-alert sisonke-alert-blue mb-0">
                <strong>Loans not available.</strong> Loans are not available for Burial Societies.
            </div>
        </div></div>
    }
    else
    {
        <div class="page-header">
            <div class="page-header-text">
                <h1>Loans</h1>
                <p class="page-subtitle">@state.Stokvel.Name</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a class="sisonke-btn sisonke-btn-outline" href="@($"/stokvel/{StokvelId}/wallet")">
                    <i class="bi bi-wallet2 me-1"></i>Wallet
                </a>
                <a class="sisonke-btn sisonke-btn-outline" href="@($"/stokvel-dashboard/{StokvelId}")">
                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                </a>
            </div>
        </div>

        @if (errors.Count > 0)
        {
            <div class="sisonke-alert sisonke-alert-red mb-3">
                <ul class="mb-0 ps-3">@foreach (var e in errors) { <li>@e</li> }</ul>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(success))
        {
            <div class="sisonke-alert sisonke-alert-green mb-3">@success</div>
        }

        @* ── Summary strip ── *@
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="sisonke-card h-100"><div class="sisonke-card-body">
                    <div class="detail-mini-label">Loan Eligibility</div>
                    <div class="fw-semibold">@state.EligibilityMessage</div>
                </div></div>
            </div>
            <div class="col-md-4">
                <div class="sisonke-card h-100"><div class="sisonke-card-body">
                    <div class="detail-mini-label">Available Wallet</div>
                    <div class="fw-semibold">@Money(WalletBalance)</div>
                </div></div>
            </div>
            <div class="col-md-4">
                <div class="sisonke-card h-100"><div class="sisonke-card-body">
                    <div class="detail-mini-label">My Active Loan</div>
                    <div class="fw-semibold">@(MyActiveLoan is null ? "None" : $"{Money(MyActiveLoan.OutstandingBalance)} outstanding")</div>
                </div></div>
            </div>
            <div class="col-md-4">
                <div class="sisonke-card h-100"><div class="sisonke-card-body">
                    <div class="detail-mini-label">Loan Rules</div>
                    @if (state.Configuration is null)
                    {
                        <span class="sisonke-badge sisonke-badge-gold">Not Configured</span>
                    }
                    else if (!state.Configuration.LoansEnabled)
                    {
                        <span class="sisonke-badge sisonke-badge-gray">Loans Disabled</span>
                    }
                    else
                    {
                        <span class="sisonke-badge sisonke-badge-green">Loans Active</span>
                    }
                </div></div>
            </div>
        </div>

        @* ── Loan Configuration ── *@
        <section class="sisonke-card mb-3">
            <div class="sisonke-card-body">
                <div class="sisonke-card-head mb-3">
                    <div>
                        @if (state.Configuration is null)
                        {
                            <span class="sisonke-badge sisonke-badge-gold">Not Configured</span>
                        }
                        else
                        {
                            <span class="sisonke-badge @(state.Configuration.LoansEnabled ? "sisonke-badge-green" : "sisonke-badge-gray")">
                                Loans @(state.Configuration.LoansEnabled ? "Enabled" : "Disabled")
                            </span>
                        }
                        <h2 class="mt-2">Loan Rules</h2>
                    </div>
                    @if (state.CanConfigure)
                    {
                        <a class="sisonke-btn sisonke-btn-outline" href="@($"/stokvel/loans-wallet/{StokvelId}")">
                            <i class="bi bi-pencil me-1"></i>Edit Rules
                        </a>
                    }
                </div>
                @if (state.Configuration is null)
                {
                    <div class="sisonke-alert sisonke-alert-blue mb-0">
                        Loan rules have not been configured yet.
                        @if (state.CanConfigure)
                        {
                            <a href="@($"/stokvel/loans-wallet/{StokvelId}")" class="fw-semibold ms-1">Configure now →</a>
                        }
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        <div class="col-6 col-md-3">
                            <div class="detail-mini-label">Min Loan</div>
                            <div class="detail-mini-value">@Money(state.Configuration.MinLoanAmount)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="detail-mini-label">Max Loan</div>
                            <div class="detail-mini-value">@Money(state.Configuration.MaxLoanAmount)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="detail-mini-label">Max Repayment</div>
                            <div class="detail-mini-value">@state.Configuration.MaxRepaymentMonths months</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="detail-mini-label">Interest</div>
                            <div class="detail-mini-value">
                                @if (state.Configuration.LoanInterestType == LoanInterestType.None)
                                {
                                    <span>None</span>
                                }
                                else if (state.Configuration.LoanInterestType == LoanInterestType.Percentage)
                                {
                                    <span>@state.Configuration.LoanInterestRate% (@state.Configuration.LoanInterestType)</span>
                                }
                                else
                                {
                                    <span>@Money(state.Configuration.LoanInterestRate) (@state.Configuration.LoanInterestType)</span>
                                }
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="detail-mini-label">Grace Period</div>
                            <div class="detail-mini-value">@state.Configuration.GracePeriodDays days</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="detail-mini-label">Freeze After Repayment</div>
                            <div class="detail-mini-value">@state.Configuration.FreezePeriodAfterFullRepaymentDays days</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="detail-mini-label">Chairperson Approval</div>
                            <div class="detail-mini-value">@(state.Configuration.RequireChairpersonApproval ? "Required" : "Not required")</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="detail-mini-label">Treasurer Disbursement</div>
                            <div class="detail-mini-value">@(state.Configuration.RequireTreasurerDisbursementConfirmation ? "Required" : "Not required")</div>
                        </div>
                    </div>
                }
            </div>
        </section>

        @* ── Request a Loan ── *@
        @if (state.EligibilityMessage.StartsWith("Eligible", StringComparison.OrdinalIgnoreCase) && state.Configuration?.LoansEnabled == true)
        {
            <section class="sisonke-card mb-3">
                <div class="sisonke-card-body">
                    <h2>Request a Loan</h2>
                    <p class="text-muted mb-3">Your wallet balance is applied first as an early payout. Only the remaining amount becomes a loan.</p>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Amount needed</label>
                            <InputNumber class="form-control" @bind-Value="loanAmount" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Repayment Months</label>
                            <InputNumber class="form-control" @bind-Value="loanMonths" disabled="@(NetLoanAmount <= 0)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Reason</label>
                            <InputText class="form-control" @bind-Value="loanReason" />
                        </div>
                    </div>
                    @if (loanMonths > 0 && loanAmount > 0)
                    {
                        <div class="loan-estimate-grid mt-3">
                            <div>
                                <div class="detail-mini-label">Wallet early payout</div>
                                <div class="detail-mini-value">@Money(WalletEarlyPayoutAmount)</div>
                            </div>
                            <div>
                                <div class="detail-mini-label">Loan amount after wallet</div>
                                <div class="detail-mini-value">@Money(NetLoanAmount)</div>
                            </div>
                            <div>
                                <div class="detail-mini-label">Estimated monthly repayment</div>
                                <div class="detail-mini-value">@Money(EstimatedMonthly)</div>
                            </div>
                        </div>
                    }
                    <button class="sisonke-btn sisonke-btn-primary mt-3" @onclick="RequestLoanAsync">
                        <i class="bi bi-send me-1"></i>Submit Loan Request
                    </button>
                </div>
            </section>
        }

        @* ── Active Loans ── *@
        <section class="sisonke-card mb-3">
            <div class="sisonke-card-body">
                <h2>@(state.CanViewAll ? "Loan Requests &amp; Active Loans" : "My Loans")</h2>
                @if (state.Loans.Count == 0)
                {
                    <div class="text-muted">No loan records.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="sisonke-table">
                            <thead>
                                <tr>
                                    <th>Member</th>
                                    <th>Requested</th>
                                    <th>Approved</th>
                                    <th>Months</th>
                                    <th>Status</th>
                                    <th>Outstanding</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var loan in state.Loans)
                                {
                                    <tr>
                                        <td class="fw-semibold">@loan.Member.FullName</td>
                                        <td>
                                            <div>@Money(loan.RequestedAmount)</div>
                                            @if (!string.IsNullOrWhiteSpace(loan.Notes))
                                            {
                                                <div class="text-muted small">@loan.Notes</div>
                                            }
                                        </td>
                                        <td>@Money(loan.ApprovedAmount ?? 0)</td>
                                        <td>@loan.RepaymentMonths</td>
                                        <td><span class="sisonke-badge @LoanStatusBadge(loan.LoanStatus)">@loan.LoanStatus</span></td>
                                        <td>@Money(loan.OutstandingBalance)</td>
                                        <td class="text-end">
                                            @if (state.CanApprove && loan.LoanStatus == MemberLoanStatus.PendingApproval)
                                            {
                                                <button class="sisonke-btn sisonke-btn-primary sisonke-btn-sm me-1" @onclick="() => OpenLoanApproval(loan)">Approve</button>
                                                <button class="sisonke-btn sisonke-btn-outline sisonke-btn-sm" style="color:var(--sk-danger)" @onclick="() => OpenLoanRejection(loan)">Reject</button>
                                            }
                                            @if (state.CanConfirmMoney && loan.LoanStatus == MemberLoanStatus.DisbursementPending)
                                            {
                                                <button class="sisonke-btn sisonke-btn-primary sisonke-btn-sm" @onclick="() => OpenDisbursement(loan)">Confirm Disbursement</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>

        @* ── Repayment Schedule ── *@
        <section class="sisonke-card mb-3">
            <div class="sisonke-card-body">
                <h2>Loan Repayment Register</h2>
                @if (state.Repayments.Count == 0)
                {
                    <div class="text-muted">No repayment schedule yet.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="sisonke-table">
                            <thead>
                                <tr>
                                    <th>Due Date</th>
                                    <th>Expected</th>
                                    <th>Paid</th>
                                    <th>Fine</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var repayment in state.Repayments)
                                {
                                    var isOverdue = repayment.PaymentStatus == LoanRepaymentStatus.Pending && repayment.DueDate.Date < DateTime.Today;
                                    <tr>
                                        <td>@repayment.DueDate.ToString("dd MMM yyyy")</td>
                                        <td>@Money(repayment.ExpectedAmount)</td>
                                        <td>@Money(repayment.PaidAmount)</td>
                                        <td>@Money(repayment.FineAmount)</td>
                                        <td>
                                            <span class="sisonke-badge @(isOverdue ? "sisonke-badge-red" : RepaymentStatusBadge(repayment.PaymentStatus))">
                                                @(isOverdue ? "Overdue" : repayment.PaymentStatus.ToString())
                                            </span>
                                        </td>
                                        <td>
                                            @if (state.CanConfirmMoney && repayment.PaymentStatus is not (LoanRepaymentStatus.Paid or LoanRepaymentStatus.Waived))
                                            {
                                                <button class="sisonke-btn sisonke-btn-primary sisonke-btn-sm" @onclick="() => OpenRepayment(repayment)">Confirm</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>
    }
}

@* ── Action Dialogs ── *@
@if (dialogKind is not null)
{
    <div class="modal d-block" style="background:rgba(0,0,0,.45)" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@dialogTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseDialog"></button>
                </div>
                <div class="modal-body">
                    @if (dialogKind == "loan-approve")
                    {
                        <div class="mb-3">
                            <label class="form-label">Approved Amount (R)</label>
                            <InputNumber class="form-control" @bind-Value="actionAmount" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Repayment Months</label>
                            <InputNumber class="form-control" @bind-Value="actionMonths" />
                        </div>
                    }
                    else if (dialogKind == "loan-reject")
                    {
                        <div class="mb-3">
                            <label class="form-label">Rejection Reason</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="actionReason" />
                        </div>
                    }
                    else if (dialogKind is "disburse" or "repayment")
                    {
                        @if (dialogKind == "repayment")
                        {
                            <div class="mb-3">
                                <label class="form-label">Paid Amount (R)</label>
                                <InputNumber class="form-control" @bind-Value="actionAmount" />
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label">Payment Method</label>
                            <InputSelect class="form-select" @bind-Value="actionMethod">
                                <option value="@PaymentMethod.EFT">EFT</option>
                                <option value="@PaymentMethod.Cash">Cash</option>
                                <option value="@PaymentMethod.BankDeposit">Bank Deposit</option>
                                <option value="@PaymentMethod.Other">Other</option>
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Reference</label>
                            <InputText class="form-control" @bind-Value="actionReference" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Date</label>
                            <InputDate class="form-control" @bind-Value="actionDate" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <InputTextArea class="form-control" rows="2" @bind-Value="actionNotes" />
                        </div>
                        @if (dialogKind == "repayment")
                        {
                            <div class="form-check mb-2">
                                <InputCheckbox class="form-check-input" @bind-Value="actionApplyFine" id="chkFine" />
                                <label class="form-check-label" for="chkFine">Apply suggested late fine</label>
                            </div>
                            <div class="form-check">
                                <InputCheckbox class="form-check-input" @bind-Value="actionWaive" id="chkWaive" />
                                <label class="form-check-label" for="chkWaive">Waive this repayment</label>
                            </div>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button class="sisonke-btn sisonke-btn-outline" @onclick="CloseDialog">Cancel</button>
                    <button class="sisonke-btn sisonke-btn-primary" @onclick="SubmitDialogAsync">Confirm</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .loan-estimate-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
        border: 1px solid var(--sk-border);
        border-radius: var(--sk-radius-sm);
        background: #fff;
        padding: 1rem;
    }
</style>

@code {
    [Parameter] public Guid StokvelId { get; set; }
    private LoansWalletPageState? state;
    private bool isLoading = true;
    private string currentUserId = "";
    private List<string> errors = [];
    private string? success;
    private decimal loanAmount;
    private int loanMonths = 1;
    private string loanReason = "";
    private string? dialogKind;
    private string dialogTitle = "";
    private Guid actionId;
    private decimal actionAmount;
    private int actionMonths;
    private string actionReason = "";
    private PaymentMethod? actionMethod = PaymentMethod.EFT;
    private string actionReference = "";
    private DateTime? actionDate = DateTime.Today;
    private string actionNotes = "";
    private bool actionApplyFine;
    private bool actionWaive;
    private decimal WalletBalance => state?.Wallet?.AvailableBalance ?? 0;
    private decimal WalletEarlyPayoutAmount => loanAmount <= 0 ? 0 : Math.Min(loanAmount, WalletBalance);
    private decimal NetLoanAmount => loanAmount <= 0 ? 0 : Math.Max(0, loanAmount - WalletEarlyPayoutAmount);

    private MemberLoan? MyActiveLoan => state?.Loans.FirstOrDefault(x =>
        x.MemberId == state.CurrentMember?.Id &&
        x.LoanStatus is MemberLoanStatus.Active or MemberLoanStatus.Overdue);

    private decimal EstimatedMonthly => loanMonths <= 0 || NetLoanAmount <= 0 ? 0 : Math.Round(NetLoanAmount / loanMonths, 2);

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errors = [];
        success = null;
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "";
        state = await Service.GetPageStateAsync(StokvelId, currentUserId);
        loanMonths = state?.Configuration?.DefaultRepaymentMonths ?? 1;
        isLoading = false;
    }

    private async Task RunAsync(Task<FinanceOperationResult> task, string message)
    {
        errors = [];
        success = null;
        var result = await task;
        errors = result.Errors;
        if (result.Success) { success = result.Message ?? message; CloseDialog(); state = await Service.GetPageStateAsync(StokvelId, currentUserId); }
    }

    private Task RequestLoanAsync() => RunAsync(Service.RequestLoanAsync(StokvelId, currentUserId, loanAmount, loanMonths, loanReason), "Loan request submitted.");
    private void OpenLoanApproval(MemberLoan x) { dialogKind = "loan-approve"; dialogTitle = "Approve Loan"; actionId = x.Id; actionAmount = x.RequestedAmount; actionMonths = x.RepaymentMonths; }
    private void OpenLoanRejection(MemberLoan x) { dialogKind = "loan-reject"; dialogTitle = "Reject Loan"; actionId = x.Id; actionReason = ""; }
    private void OpenDisbursement(MemberLoan x) { dialogKind = "disburse"; dialogTitle = "Confirm Loan Disbursement"; actionId = x.Id; actionMethod = PaymentMethod.EFT; actionReference = ""; actionDate = DateTime.Today; actionNotes = ""; }
    private void OpenRepayment(MemberLoanRepayment x) { dialogKind = "repayment"; dialogTitle = "Confirm Loan Repayment"; actionId = x.Id; actionAmount = x.ExpectedAmount; actionMethod = PaymentMethod.EFT; actionReference = ""; actionDate = DateTime.Today; actionNotes = ""; actionApplyFine = false; actionWaive = false; }
    private void CloseDialog() => dialogKind = null;

    private async Task SubmitDialogAsync()
    {
        if (dialogKind == "loan-approve") await RunAsync(Service.ApproveLoanAsync(actionId, currentUserId, actionAmount, actionMonths), "Loan approved.");
        else if (dialogKind == "loan-reject") await RunAsync(Service.RejectLoanAsync(actionId, currentUserId, actionReason), "Loan rejected.");
        else if (dialogKind == "disburse") await RunAsync(Service.ConfirmDisbursementAsync(actionId, currentUserId, actionMethod, actionReference, actionDate, actionNotes), "Loan disbursed and repayment schedule generated.");
        else if (dialogKind == "repayment") await RunAsync(Service.ConfirmRepaymentAsync(actionId, currentUserId, actionAmount, actionDate, actionMethod, actionReference, actionWaive, actionApplyFine, actionNotes), "Repayment confirmed.");
    }

    private static string Money(decimal x) => x.ToString("C2", new System.Globalization.CultureInfo("en-ZA"));
    private static string LoanStatusBadge(MemberLoanStatus s) => s switch {
        MemberLoanStatus.Active or MemberLoanStatus.FullyRepaid => "sisonke-badge-green",
        MemberLoanStatus.PendingApproval or MemberLoanStatus.DisbursementPending => "sisonke-badge-gold",
        MemberLoanStatus.Overdue => "sisonke-badge-red",
        _ => "sisonke-badge-gray"
    };
    private static string RepaymentStatusBadge(LoanRepaymentStatus s) => s switch {
        LoanRepaymentStatus.Paid or LoanRepaymentStatus.Late => "sisonke-badge-green",
        LoanRepaymentStatus.PartiallyPaid => "sisonke-badge-gold",
        LoanRepaymentStatus.Waived => "sisonke-badge-blue",
        _ => "sisonke-badge-gray"
    };
}
