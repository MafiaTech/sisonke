@page "/stokvel/{StokvelId:guid}/wallet"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject LoansWalletService Service
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Surplus Wallet</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading wallet…
    </div>
}
else if (state is null)
{
    <AlertBanner Type="warning" Title="Stokvel or linked membership not found." Message="" Icon="bi bi-exclamation-triangle-fill" />
    <a class="sisonke-btn sisonke-btn-outline mt-3" href="/my-workspace"><i class="bi bi-arrow-left me-2"></i>Back to Workspace</a>
}
else
{
    <StokvelSubNav StokvelId="@StokvelId" IsRotational="@(state.Stokvel.Archetype == StokvelArchetype.Rotational)" />

    @if (state.Stokvel.Archetype == StokvelArchetype.BurialSociety)
    {
        <div class="sisonke-card"><div class="sisonke-card-body">
            <div class="sisonke-alert sisonke-alert-blue mb-0">
                <strong>Wallet not available.</strong> Surplus wallets are not available for Burial Societies.
            </div>
        </div></div>
    }
    else
    {
        <div class="page-header">
            <div class="page-header-text">
                <h1>Surplus Wallet</h1>
                <p class="page-subtitle">@state.Stokvel.Name</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a class="sisonke-btn sisonke-btn-outline" href="@($"/stokvel/{StokvelId}/loans")">
                    <i class="bi bi-bank2 me-1"></i>Loans
                </a>
                <a class="sisonke-btn sisonke-btn-outline" href="@($"/stokvel-dashboard/{StokvelId}")">
                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                </a>
            </div>
        </div>

        @if (errors.Count > 0)
        {
            <div class="sisonke-alert sisonke-alert-red mb-3">
                <ul class="mb-0 ps-3">@foreach (var e in errors) { <li>@e</li> }</ul>
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(success))
        {
            <div class="sisonke-alert sisonke-alert-green mb-3">@success</div>
        }

        @* ── Wallet summary cards ── *@
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="sisonke-card h-100"><div class="sisonke-card-body">
                    <div class="detail-mini-label">Available Balance</div>
                    <div class="h4 mb-0 fw-bold">@Money(state.Wallet?.AvailableBalance ?? 0)</div>
                </div></div>
            </div>
            <div class="col-md-4">
                <div class="sisonke-card h-100"><div class="sisonke-card-body">
                    <div class="detail-mini-label">Total Credited</div>
                    <div class="fw-semibold">@Money(state.Wallet?.TotalCredits ?? 0)</div>
                </div></div>
            </div>
            <div class="col-md-4">
                <div class="sisonke-card h-100"><div class="sisonke-card-body">
                    <div class="detail-mini-label">Total Withdrawn</div>
                    <div class="fw-semibold">@Money(state.Wallet?.TotalWithdrawals ?? 0)</div>
                </div></div>
            </div>
        </div>

        @* ── Request Withdrawal ── *@
        @if ((state.Wallet?.AvailableBalance ?? 0) > 0)
        {
            <section class="sisonke-card mb-3">
                <div class="sisonke-card-body">
                    <h2>Request Withdrawal</h2>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Amount (R)</label>
                            <InputNumber class="form-control" @bind-Value="withdrawalAmount" />
                            <div class="form-text">Available: @Money(state.Wallet?.AvailableBalance ?? 0)</div>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Reason</label>
                            <InputText class="form-control" @bind-Value="withdrawalReason" />
                        </div>
                    </div>
                    <button class="sisonke-btn sisonke-btn-primary mt-3" @onclick="RequestWithdrawalAsync">
                        <i class="bi bi-send me-1"></i>Request Withdrawal
                    </button>
                </div>
            </section>
        }

        @* ── Withdrawal Requests ── *@
        <section class="sisonke-card mb-3">
            <div class="sisonke-card-body">
                <h2>@(state.CanViewAll ? "Surplus Withdrawal Requests" : "My Withdrawal Requests")</h2>
                @if (state.Withdrawals.Count == 0)
                {
                    <div class="text-muted">No withdrawal requests.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="sisonke-table">
                            <thead>
                                <tr>
                                    <th>Member</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>Reason</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in state.Withdrawals)
                                {
                                    <tr>
                                        <td class="fw-semibold">@item.Member.FullName</td>
                                        <td>@Money(item.RequestedAmount)</td>
                                        <td><span class="sisonke-badge @WithdrawalStatusBadge(item.WithdrawalStatus)">@item.WithdrawalStatus</span></td>
                                        <td class="text-muted small">@item.RequestReason</td>
                                        <td class="text-end">
                                            @if (state.CanApprove && item.WithdrawalStatus == SurplusWithdrawalStatus.PendingApproval)
                                            {
                                                <button class="sisonke-btn sisonke-btn-primary sisonke-btn-sm me-1" @onclick="() => ApproveWithdrawalAsync(item.Id)">Approve</button>
                                                <button class="sisonke-btn sisonke-btn-outline sisonke-btn-sm" style="color:var(--sk-danger)" @onclick="() => OpenWithdrawalRejection(item)">Reject</button>
                                            }
                                            @if (state.CanConfirmMoney && item.WithdrawalStatus == SurplusWithdrawalStatus.PaymentPending)
                                            {
                                                <button class="sisonke-btn sisonke-btn-primary sisonke-btn-sm" @onclick="() => OpenWithdrawalPayment(item)">Confirm Paid</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>

        @* ── Transaction History ── *@
        <section class="sisonke-card mb-3">
            <div class="sisonke-card-body">
                <h2>Recent Transactions</h2>
                @if (state.Transactions.Count == 0)
                {
                    <div class="text-muted">
                        No transactions yet. Your surplus wallet is credited when contribution overpayments occur.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="sisonke-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Description</th>
                                    <th class="text-end">Amount</th>
                                    <th class="text-end">Balance After</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tx in state.Transactions)
                                {
                                    <tr>
                                        <td class="text-muted small">@tx.CreatedAt.ToString("dd MMM yyyy")</td>
                                        <td><span class="sisonke-badge sisonke-badge-blue">@tx.TransactionType</span></td>
                                        <td>@tx.Description</td>
                                        <td class="text-end fw-semibold">@Money(tx.Amount)</td>
                                        <td class="text-end text-muted">@Money(tx.BalanceAfterTransaction)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </section>
    }
}

@* ── Action Dialogs ── *@
@if (dialogKind is not null)
{
    <div class="modal d-block" style="background:rgba(0,0,0,.45)" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@dialogTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseDialog"></button>
                </div>
                <div class="modal-body">
                    @if (dialogKind == "withdraw-reject")
                    {
                        <div class="mb-3">
                            <label class="form-label">Rejection Reason</label>
                            <InputTextArea class="form-control" rows="3" @bind-Value="actionReason" />
                        </div>
                    }
                    else if (dialogKind == "withdraw-pay")
                    {
                        <div class="mb-3">
                            <label class="form-label">Payment Method</label>
                            <InputSelect class="form-select" @bind-Value="actionMethod">
                                <option value="@PaymentMethod.EFT">EFT</option>
                                <option value="@PaymentMethod.Cash">Cash</option>
                                <option value="@PaymentMethod.BankDeposit">Bank Deposit</option>
                                <option value="@PaymentMethod.Other">Other</option>
                            </InputSelect>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Reference</label>
                            <InputText class="form-control" @bind-Value="actionReference" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Date</label>
                            <InputDate class="form-control" @bind-Value="actionDate" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes</label>
                            <InputTextArea class="form-control" rows="2" @bind-Value="actionNotes" />
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="sisonke-btn sisonke-btn-outline" @onclick="CloseDialog">Cancel</button>
                    <button class="sisonke-btn sisonke-btn-primary" @onclick="SubmitDialogAsync">Confirm</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid StokvelId { get; set; }
    private LoansWalletPageState? state;
    private bool isLoading = true;
    private string currentUserId = "";
    private List<string> errors = [];
    private string? success;
    private decimal withdrawalAmount;
    private string withdrawalReason = "";
    private string? dialogKind;
    private string dialogTitle = "";
    private Guid actionId;
    private string actionReason = "";
    private PaymentMethod? actionMethod = PaymentMethod.EFT;
    private string actionReference = "";
    private DateTime? actionDate = DateTime.Today;
    private string actionNotes = "";

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errors = [];
        success = null;
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "";
        state = await Service.GetPageStateAsync(StokvelId, currentUserId);
        isLoading = false;
    }

    private async Task RunAsync(Task<FinanceOperationResult> task, string message)
    {
        errors = [];
        success = null;
        var result = await task;
        errors = result.Errors;
        if (result.Success) { success = message; CloseDialog(); state = await Service.GetPageStateAsync(StokvelId, currentUserId); }
    }

    private Task RequestWithdrawalAsync() => RunAsync(Service.RequestWithdrawalAsync(StokvelId, currentUserId, withdrawalAmount, withdrawalReason), "Withdrawal request submitted.");
    private Task ApproveWithdrawalAsync(Guid id) => RunAsync(Service.ApproveWithdrawalAsync(id, currentUserId), "Withdrawal approved for payment.");
    private void OpenWithdrawalRejection(MemberSurplusWithdrawalRequest x) { dialogKind = "withdraw-reject"; dialogTitle = "Reject Surplus Withdrawal"; actionId = x.Id; actionReason = ""; }
    private void OpenWithdrawalPayment(MemberSurplusWithdrawalRequest x) { dialogKind = "withdraw-pay"; dialogTitle = "Confirm Surplus Withdrawal Paid"; actionId = x.Id; actionMethod = PaymentMethod.EFT; actionReference = ""; actionDate = DateTime.Today; actionNotes = ""; }
    private void CloseDialog() => dialogKind = null;

    private async Task SubmitDialogAsync()
    {
        if (dialogKind == "withdraw-reject") await RunAsync(Service.RejectWithdrawalAsync(actionId, currentUserId, actionReason), "Withdrawal rejected.");
        else if (dialogKind == "withdraw-pay") await RunAsync(Service.ConfirmWithdrawalPaidAsync(actionId, currentUserId, actionMethod, actionReference, actionDate, actionNotes), "Withdrawal payment confirmed.");
    }

    private static string Money(decimal x) => x.ToString("C2", new System.Globalization.CultureInfo("en-ZA"));
    private static string WithdrawalStatusBadge(SurplusWithdrawalStatus s) => s switch {
        SurplusWithdrawalStatus.Paid => "sisonke-badge-green",
        SurplusWithdrawalStatus.PendingApproval or SurplusWithdrawalStatus.PaymentPending => "sisonke-badge-gold",
        SurplusWithdrawalStatus.Rejected => "sisonke-badge-gray",
        _ => "sisonke-badge-gray"
    };
}
