@page "/register-stokvel"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Sisonke.Web.Data
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Helpers
@using Sisonke.Web.Services

@inject StokvelService StokvelService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject MemberAccountLinkingService MemberAccountLinkingService
@inject MemberService MemberService

<PageTitle>Register New Stokvel</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading stokvel registration...
    </div>
}
else if (currentUser is null)
{
    <AlertBanner Type="warning" Title="Please sign in to register a stokvel." Message="" Icon="bi bi-exclamation-triangle-fill" />
}
else
{
    <section class="sisonke-hero-card mb-4">
        <div>
            <span class="sisonke-badge sisonke-badge-gold">Organisation Registration</span>
            <h1>Register a New Stokvel</h1>
            <p>Create a stokvel and become the first office bearer.</p>
        </div>
        <div class="register-creator-summary">
            <div><span>Full name</span><strong>@Display(currentUser.FullName)</strong></div>
            <div><span>Email</span><strong>@Display(currentUser.Email)</strong></div>
            <div><span>ID Number</span><strong>@Display(currentUser.IdNumber)</strong></div>
            <div><span>Cellphone</span><strong>@Display(currentUser.CellphoneNumber)</strong></div>
        </div>
    </section>

    <div class="mb-4">
        <a class="sisonke-btn sisonke-btn-outline" href="/my-workspace">
            <i class="bi bi-arrow-left me-2"></i>Back to Workspace
        </a>
    </div>
}

@if (!isLoading && currentUser is not null && saveFailed)
{
    <AlertBanner Type="danger" Title="Unable to register stokvel." Message="Please check the details and try again." Icon="bi bi-x-circle-fill" />
}

@if (!isLoading && currentUser is not null && packageSelectionFailed)
{
    <AlertBanner Type="danger" Title="Please select a subscription package." Message="" Icon="bi bi-x-circle-fill" />
}

@if (!isLoading && currentUser is not null)
{
    <div class="form-page">
        <div class="sisonke-card mb-3">
            <div class="sisonke-card-body">
                <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                    <div>
                        <div class="form-section-title">Review & Create</div>
                        <p class="text-muted mb-0">
                            Use this page to create a new stokvel or society. You will become the first office bearer for this stokvel.
                        </p>
                    </div>
                    <div class="text-lg-end">
                        <div class="text-muted small">Organisation registration</div>
                        <span class="sisonke-badge sisonke-badge-green">Office bearer setup</span>
                    </div>
                </div>

                <div class="row g-3 mt-3">
                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="detail-mini-label">Full name</div>
                        <div class="fw-600">@Display(currentUser.FullName)</div>
                    </div>
                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="detail-mini-label">Email</div>
                        <div class="fw-600">@Display(currentUser.Email)</div>
                    </div>
                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="detail-mini-label">ID number</div>
                        <div class="fw-600">@Display(currentUser.IdNumber)</div>
                    </div>
                    <div class="col-12 col-md-6 col-xl-3">
                        <div class="detail-mini-label">Cellphone</div>
                        <div class="fw-600">@Display(currentUser.CellphoneNumber)</div>
                    </div>
                </div>
            </div>
        </div>

        @if (string.IsNullOrWhiteSpace(currentUser.IdNumber))
        {
            <div class="sisonke-alert sisonke-alert-gold">
                Your ID number is not captured on your account. Please update your profile before registering a stokvel.
            </div>
        }

        <EditForm Model="@model" OnValidSubmit="@HandleValidSubmit" FormName="RegisterStokvelForm">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />

        <!-- ── Section: Stokvel identity ── -->
        <div class="sisonke-card mb-3">
            <div class="sisonke-card-body">
                <div class="sisonke-card-head">
                    <div>
                        <h2>Stokvel Details</h2>
                        <p>Capture the organisation name, type and expected membership size.</p>
                    </div>
                </div>
                <div class="sisonke-grid sisonke-grid-2">
                    <div class="member-form-field">
                        <label class="form-label" for="stokvel-name">
                            Stokvel name <span class="text-danger">*</span>
                        </label>
                        <InputText id="stokvel-name" class="form-control" placeholder="e.g. Mahlalela Burial Society" @bind-Value="model.Name" />
                    </div>

                    <div class="member-form-field">
                        <label class="form-label" for="stokvel-type">Stokvel type</label>
                        <InputSelect id="stokvel-type" class="form-select" @bind-Value="model.Type">
                            @foreach (var stokvelType in Enum.GetValues<StokvelType>())
                            {
                                <option value="@stokvelType">@stokvelType</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="member-form-field">
                        <label class="form-label" for="expected-member-count">Expected total members</label>
                        <InputNumber id="expected-member-count" class="form-control" TValue="int?"
                            Value="@model.ExpectedMemberCount"
                            ValueChanged="@((int? v) => OnExpectedMemberCountChangedAsync(v))"
                            ValueExpression="@(() => model.ExpectedMemberCount)" />
                        <div class="form-text">Helps Sisonke recommend the right package and track member capture progress.</div>
                    </div>

                    <div class="member-form-field">
                        <label class="form-label" for="established-date">Established date</label>
                        <InputDate id="established-date" class="form-control" @bind-Value="model.EstablishedDate" />
                    </div>

                    <div class="member-form-field">
                        <label class="form-label" for="province">Province</label>
                        <select id="province" class="form-select" value="@model.Province" @onchange="OnProvinceChanged">
                            <option value="">— Select province —</option>
                            @foreach (var province in provinces)
                            {
                                <option value="@province">@province</option>
                            }
                        </select>
                    </div>

                    <div class="member-form-field">
                        <label class="form-label" for="town-or-area">Town or area</label>
                        <select id="town-or-area" class="form-select" @bind="model.TownOrArea" disabled="@(!towns.Any())">
                            <option value="">— Select town/area —</option>
                            @foreach (var town in towns)
                            {
                                <option value="@town">@town</option>
                            }
                        </select>
                    </div>

                    <div class="member-form-field register-form-wide">
                        <label class="form-label" for="description">Description <span class="text-muted fw-normal">(optional)</span></label>
                        <InputTextArea id="description" class="form-control" rows="3" placeholder="Brief description of the stokvel's purpose and goals." @bind-Value="model.Description" />
                    </div>
                </div>
            </div>
        </div>

            <!-- ── Section: Creator details ── -->
            <div class="sisonke-card mb-3">
                <div class="sisonke-card-body">
                    <div class="sisonke-card-head">
                        <div>
                            <h2>Review & Create</h2>
                            <p>You will be linked to this stokvel as the creator so you can complete setup and manage the organisation.</p>
                        </div>
                    </div>
                    <div class="sisonke-grid sisonke-grid-2">
                        <div class="member-form-field">
                            <label class="form-label" for="creator-full-name">Full name <span class="text-danger">*</span></label>
                            <InputText id="creator-full-name" class="form-control" @bind-Value="model.CreatorFullName" />
                        </div>
                        <div class="member-form-field">
                            <label class="form-label" for="creator-cellphone">Cellphone number <span class="text-danger">*</span></label>
                            <InputText id="creator-cellphone" class="form-control" placeholder="e.g. 0821234567" @bind-Value="model.CreatorCellphoneNumber" />
                        </div>
                        <div class="member-form-field">
                            <label class="form-label" for="creator-email">Email address</label>
                            <InputText id="creator-email" class="form-control" @bind-Value="model.CreatorEmail" />
                        </div>
                        <div class="member-form-field">
                            <label class="form-label" for="creator-id-number">SA ID number</label>
                            <InputText id="creator-id-number" class="form-control" placeholder="13-digit SA ID" @bind-Value="model.CreatorIdNumber" />
                            <div class="form-text">Used to link this office bearer record to your login account.</div>
                        </div>
                        <div class="member-form-field register-form-wide">
                            <label class="form-label" for="creator-area">Residential area</label>
                            <InputText id="creator-area" class="form-control" placeholder="e.g. Soweto, Gauteng" @bind-Value="model.CreatorResidentialArea" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Section: Subscription package ── -->
            <div class="sisonke-card mb-3">
                <div class="sisonke-card-body">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <div class="form-section-title mb-0">Membership Size & Package</div>
                        @if (model.SubscriptionPlanId is null)
                        {
                            <span class="text-danger small fw-semibold">Selection required</span>
                        }
                    </div>
                    <p class="text-muted small mb-3">Choose a plan that fits your expected membership size. Enter the member count above for a recommendation.</p>

                    <div class="row g-3">
                        @foreach (var plan in subscriptionPlans)
                        {
                            var isSelected    = model.SubscriptionPlanId == plan.Id;
                            var isRecommended = recommendedPlanId == plan.Id;

                            <div class="col-12 col-md-4">
                                <div class="plan-card @(isSelected ? "plan-selected" : "") @(isRecommended ? "plan-recommended" : "") h-100"
                                     @onclick="@(() => SelectSubscriptionPlan(plan.Id))" style="cursor:pointer;">
                                    <div class="card-body d-flex flex-column p-3">
                                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                            <h3 class="h6 mb-0 fw-700">@plan.Name</h3>
                                            @if (isRecommended && !isSelected)
                                            {
                                                <StatusBadge Text="Recommended" Type="success" />
                                            }
                                            @if (isSelected)
                                            {
                                                <span class="sisonke-badge sisonke-badge-green">
                                                    <i class="bi bi-check2 me-1"></i>Selected
                                                </span>
                                            }
                                        </div>
                                        <p class="text-muted small mb-2">@GetMemberRangeText(plan)</p>
                                        <div class="mt-auto">
                                            <div class="plan-price">@FormatCurrency(plan.MonthlyPrice)<span class="text-muted fw-normal" style="font-size:.875rem">/mo</span></div>
                                            <div class="text-muted small">Annual: @FormatCurrency(plan.AnnualPrice)</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- ── Submit ── -->
            <div class="d-flex gap-2 flex-wrap">
                <button class="sisonke-btn sisonke-btn-primary" type="submit">
                    <i class="bi bi-check-circle me-2"></i>Register Stokvel
                </button>
                <a class="sisonke-btn sisonke-btn-outline" href="/my-workspace">Cancel</a>
            </div>
        </EditForm>
    </div>
}

<style>
    .register-creator-summary {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .75rem;
        min-width: min(28rem, 100%);
        padding: 1rem;
        border: 1px solid rgb(255 255 255 / .28);
        border-radius: var(--r-md);
        background: rgb(255 255 255 / .12);
    }

    .register-creator-summary div {
        display: grid;
        gap: .15rem;
    }

    .register-creator-summary span {
        color: rgb(255 255 255 / .78);
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .register-creator-summary strong {
        color: #fff;
        font-size: .92rem;
    }

    .register-form-wide {
        grid-column: 1 / -1;
    }

    @@media (max-width: 768px) {
        .register-creator-summary {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private readonly RegisterStokvelFormModel model = new();
    private List<string> provinces = SouthAfricanLocations.GetProvinces();
    private List<string> towns = new();
    private List<SubscriptionPlan> subscriptionPlans = [];
    private ApplicationUser? currentUser;
    private Guid? recommendedPlanId;
    private bool saveFailed;
    private bool packageSelectionFailed;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUser = await UserManager.GetUserAsync(authState.User);

        if (currentUser is not null)
        {
            model.CreatorFullName = currentUser.FullName ?? string.Empty;
            model.CreatorCellphoneNumber = currentUser.CellphoneNumber ?? string.Empty;
            model.CreatorEmail = currentUser.Email;
            model.CreatorIdNumber = currentUser.IdNumber;
            model.CreatorResidentialArea = currentUser.ResidentialArea;
        }

        subscriptionPlans = await StokvelService.GetPublicSubscriptionPlansAsync();
        isLoading = false;
    }

    private void OnProvinceChanged(ChangeEventArgs args)
    {
        model.Province = args.Value?.ToString();
        towns = SouthAfricanLocations.GetTownsByProvince(model.Province);
        model.TownOrArea = null;
    }

    private async Task OnExpectedMemberCountChangedAsync(int? expectedMemberCount)
    {
        model.ExpectedMemberCount = expectedMemberCount;
        var recommendedPlan = await StokvelService.GetRecommendedSubscriptionPlanAsync(model.ExpectedMemberCount);
        recommendedPlanId = recommendedPlan?.Id;
        if (recommendedPlan is not null)
        {
            model.SubscriptionPlanId = recommendedPlan.Id;
            packageSelectionFailed = false;
        }
    }

    private void SelectSubscriptionPlan(Guid subscriptionPlanId)
    {
        model.SubscriptionPlanId = subscriptionPlanId;
        packageSelectionFailed = false;
    }

    private async Task HandleValidSubmit()
    {
        saveFailed = false;
        packageSelectionFailed = false;

        if (currentUser is null) { saveFailed = true; return; }

        if (model.SubscriptionPlanId is null) { packageSelectionFailed = true; return; }

        var createdStokvel = await StokvelService.RegisterStokvelAsync(
            model.Name, model.Type, model.Province, model.TownOrArea,
            model.EstablishedDate, model.ExpectedMemberCount,
            model.SubscriptionPlanId.Value, model.Description);

        if (createdStokvel is null) { saveFailed = true; return; }

        var creatorMember = await MemberService.EnsureCreatorMemberForStokvelAsync(
            createdStokvel.Id,
            currentUser.Id,
            model.CreatorFullName,
            model.CreatorEmail ?? currentUser.Email,
            model.CreatorCellphoneNumber,
            model.CreatorIdNumber,
            model.CreatorResidentialArea);

        if (creatorMember is null)
        {
            saveFailed = true;
            return;
        }

        await MemberAccountLinkingService.RefreshUserMembershipLinksAsync(currentUser.Id, model.CreatorIdNumber);
        NavigationManager.NavigateTo($"/stokvel-questionnaire/{createdStokvel.Id}");
    }

    private sealed class RegisterStokvelFormModel
    {
        [Required][MaxLength(150)] public string Name { get; set; } = string.Empty;
        public StokvelType Type { get; set; } = StokvelType.BurialSociety;
        [MaxLength(100)] public string? Province { get; set; }
        [MaxLength(100)] public string? TownOrArea { get; set; }
        public DateTime? EstablishedDate { get; set; }
        public int? ExpectedMemberCount { get; set; }
        public Guid? SubscriptionPlanId { get; set; }
        [MaxLength(500)] public string? Description { get; set; }
        [Required][MaxLength(150)] public string CreatorFullName { get; set; } = string.Empty;
        [Required][MaxLength(30)] public string CreatorCellphoneNumber { get; set; } = string.Empty;
        [EmailAddress][MaxLength(150)] public string? CreatorEmail { get; set; }
        [MaxLength(30)] public string? CreatorIdNumber { get; set; }
        [MaxLength(150)] public string? CreatorResidentialArea { get; set; }
    }

    private static string FormatCurrency(decimal amount) =>
        amount.ToString("C0", new System.Globalization.CultureInfo("en-ZA"));

    private static string GetMemberRangeText(SubscriptionPlan plan) =>
        plan.MaxMembers is null ? $"{plan.MinMembers}+ members" : $"{plan.MinMembers}–{plan.MaxMembers} members";

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not captured" : value;
    }
}
