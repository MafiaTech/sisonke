@code {
    private readonly RegisterStokvelFormModel model = new();
    private List<string> provinces = SouthAfricanLocations.GetProvinces();
    private List<string> towns = new();
    private List<SubscriptionPlan> subscriptionPlans = [];
    private ApplicationUser? currentUser;
    private Guid? recommendedPlanId;
    private bool saveFailed;
    private bool packageSelectionFailed;
    private bool isLoading = true;
    private int currentWizardStep = 1;
    private string? wizardValidationMessage;

    private ArchetypeOption? SelectedArchetypeOption =>
        archetypeOptions.FirstOrDefault(a => a.Archetype == model.Archetype);

    private SubscriptionPlan? SelectedPlan =>
        model.SubscriptionPlanId is null ? null
        : subscriptionPlans.FirstOrDefault(p => p.Id == model.SubscriptionPlanId);

    private void GoToStep2()
    {
        wizardValidationMessage = null;
        packageSelectionFailed = false;

        if (string.IsNullOrWhiteSpace(model.Name))
        {
            wizardValidationMessage = "Please enter a stokvel name to continue.";
            return;
        }
        if (string.IsNullOrWhiteSpace(model.CreatorFullName))
        {
            wizardValidationMessage = "Please enter the office bearer's full name to continue.";
            return;
        }
        if (string.IsNullOrWhiteSpace(model.CreatorCellphoneNumber))
        {
            wizardValidationMessage = "Please enter the office bearer's cellphone number to continue.";
            return;
        }
        var bankingValidation = ValidateBankingDetails();
        if (bankingValidation is not null)
        {
            wizardValidationMessage = bankingValidation;
            return;
        }
        currentWizardStep = 2;
    }

    private void GoToStep3()
    {
        wizardValidationMessage = null;
        if (model.SubscriptionPlanId is null)
        {
            packageSelectionFailed = true;
            return;
        }
        packageSelectionFailed = false;
        currentWizardStep = 3;
    }

    private void GoBackToStep1()
    {
        wizardValidationMessage = null;
        currentWizardStep = 1;
    }

    private void GoBackToStep2()
    {
        wizardValidationMessage = null;
        currentWizardStep = 2;
    }

    private readonly List<ArchetypeOption> archetypeOptions =
    [
        new(StokvelArchetype.BurialSociety, "Burial Society",       "Manage funeral support, dependents, claims and member contributions.",              "Full support", false, "bi-heart-fill"),
        new(StokvelArchetype.Rotational,    "Rotational Stokvel",   "Members contribute regularly and the full pot is paid to one member in turn.",     "Demo ready",  false, "bi-arrow-repeat"),
        new(StokvelArchetype.SavingsClub,   "Savings Club",         "Save towards year-end, school fees, holidays or shared goals.",                     "Basic setup",  false, "bi-piggy-bank-fill"),
        new(StokvelArchetype.Grocery,       "Grocery Stokvel",      "Plan bulk grocery contributions, purchases and distribution.",                      "Coming soon",  true,  "bi-bag-fill"),
        new(StokvelArchetype.InvestmentClub,"Investment Club",      "Pool funds for long-term wealth and asset growth.",                                 "Coming soon",  true,  "bi-graph-up"),
        new(StokvelArchetype.Education,     "Education Stokvel",    "Save for school fees, uniforms, stationery and education costs.",                   "Coming soon",  true,  "bi-mortarboard-fill"),
        new(StokvelArchetype.Borrowing,     "Borrowing Stokvel",    "Manage member borrowing, limits, interest and repayments.",                        "Coming soon",  true,  "bi-cash-coin"),
        new(StokvelArchetype.Travel,        "Travel Stokvel",       "Save together for group trips, holidays and travel goals.",                         "Coming soon",  true,  "bi-airplane"),
        new(StokvelArchetype.SocialClub,    "Social Club",          "Manage events, celebrations and community activities.",                             "Coming soon",  true,  "bi-people-fill")
    ];

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);

        if (!string.IsNullOrWhiteSpace(userId))
        {
            currentUser = await LoadCurrentUserAsync(userId);
        }

        if (currentUser is not null)
        {
            model.CreatorFullName = currentUser.FullName ?? string.Empty;
            model.CreatorCellphoneNumber = currentUser.CellphoneNumber ?? string.Empty;
            model.CreatorEmail = currentUser.Email;
            model.CreatorIdNumber = currentUser.IdNumber;
            model.CreatorResidentialArea = currentUser.ResidentialArea;
        }

        subscriptionPlans = await LoadPublicSubscriptionPlansAsync();
        isLoading = false;
    }

    private void OnProvinceChanged(ChangeEventArgs args)
    {
        model.Province = args.Value?.ToString();
        towns = SouthAfricanLocations.GetTownsByProvince(model.Province);
        model.TownOrArea = null;
    }

    private async Task OnExpectedMemberCountChangedAsync(int? expectedMemberCount)
    {
        model.ExpectedMemberCount = expectedMemberCount;
        var recommendedPlan = await LoadRecommendedSubscriptionPlanAsync(model.ExpectedMemberCount);
        recommendedPlanId = recommendedPlan?.Id;
        if (recommendedPlan is not null)
        {
            model.SubscriptionPlanId = recommendedPlan.Id;
            packageSelectionFailed = false;
        }
    }

    private void SelectSubscriptionPlan(Guid subscriptionPlanId)
    {
        model.SubscriptionPlanId = subscriptionPlanId;
        packageSelectionFailed = false;
    }

    private async Task HandleValidSubmit()
    {
        saveFailed = false;
        packageSelectionFailed = false;

        if (currentUser is null) { saveFailed = true; return; }
        if (model.SubscriptionPlanId is null) { packageSelectionFailed = true; currentWizardStep = 2; return; }
        var bankingValidation = ValidateBankingDetails();
        if (bankingValidation is not null)
        {
            wizardValidationMessage = bankingValidation;
            currentWizardStep = 1;
            return;
        }

        var createdStokvel = await StokvelService.RegisterStokvelAsync(
            model.Name, StokvelService.MapArchetypeToStokvelType(model.Archetype), model.Archetype, model.Province, model.TownOrArea,
            model.EstablishedDate, model.ExpectedMemberCount,
            model.SubscriptionPlanId.Value, model.Description, BuildBankingDetailsForCreate(), currentUser.Id);

        if (createdStokvel is null) { saveFailed = true; return; }

        var creatorMember = await MemberService.EnsureCreatorMemberForStokvelAsync(
            createdStokvel.Id,
            currentUser.Id,
            model.CreatorFullName,
            model.CreatorEmail ?? currentUser.Email,
            model.CreatorCellphoneNumber,
            model.CreatorIdNumber,
            model.CreatorResidentialArea);

        if (creatorMember is null) { saveFailed = true; return; }

        await MemberAccountLinkingService.RefreshUserMembershipLinksAsync(currentUser.Id, model.CreatorIdNumber);
        NavigationManager.NavigateTo($"/stokvel-questionnaire/{createdStokvel.Id}");
    }

    private async Task<ApplicationUser?> LoadCurrentUserAsync(string currentUserId)
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        return await db.Users.AsNoTracking().FirstOrDefaultAsync(user => user.Id == currentUserId);
    }

    private async Task<List<SubscriptionPlan>> LoadPublicSubscriptionPlansAsync()
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        return await db.SubscriptionPlans
            .AsNoTracking()
            .Where(p => p.IsActive && p.Name != "Pilot")
            .OrderBy(p => p.MinMembers)
            .ToListAsync();
    }

    private async Task<SubscriptionPlan?> LoadRecommendedSubscriptionPlanAsync(int? expectedMemberCount)
    {
        if (expectedMemberCount is null || expectedMemberCount < 1) return null;
        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();
        return await db.SubscriptionPlans
            .AsNoTracking()
            .Where(p =>
                p.IsActive && p.Name != "Pilot" &&
                expectedMemberCount >= p.MinMembers &&
                (p.MaxMembers == null || expectedMemberCount <= p.MaxMembers))
            .OrderBy(p => p.MinMembers)
            .FirstOrDefaultAsync();
    }

    private sealed class RegisterStokvelFormModel
    {
        [Required][MaxLength(150)] public string Name { get; set; } = string.Empty;
        public StokvelArchetype Archetype { get; set; } = StokvelArchetype.BurialSociety;
        [MaxLength(100)] public string? Province { get; set; }
        [MaxLength(100)] public string? TownOrArea { get; set; }
        public DateTime? EstablishedDate { get; set; }
        public int? ExpectedMemberCount { get; set; }
        public Guid? SubscriptionPlanId { get; set; }
        [MaxLength(500)] public string? Description { get; set; }
        [Required][MaxLength(150)] public string CreatorFullName { get; set; } = string.Empty;
        [Required][MaxLength(30)] public string CreatorCellphoneNumber { get; set; } = string.Empty;
        [EmailAddress][MaxLength(150)] public string? CreatorEmail { get; set; }
        [MaxLength(30)] public string? CreatorIdNumber { get; set; }
        [MaxLength(150)] public string? CreatorResidentialArea { get; set; }
        [MaxLength(100)] public string? BankName { get; set; }
        [MaxLength(150)] public string? AccountHolderName { get; set; }
        [MaxLength(50)] public string? AccountNumber { get; set; }
        public BankAccountType AccountType { get; set; } = BankAccountType.Savings;
        [MaxLength(20)] public string? BranchCode { get; set; }
        [MaxLength(100)] public string? BranchName { get; set; }
        [MaxLength(200)] public string? PaymentReferenceFormat { get; set; }
    }

    private static string FormatCurrency(decimal amount) =>
        amount.ToString("C0", new System.Globalization.CultureInfo("en-ZA"));

    private static string GetMemberRangeText(SubscriptionPlan plan) =>
        plan.MaxMembers is null ? $"{plan.MinMembers}+ members" : $"{plan.MinMembers}–{plan.MaxMembers} members";

    private static string Display(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "Not captured" : value;

    private static bool IsMostPopularPlan(string? planName) =>
        string.Equals(planName, "standard", StringComparison.OrdinalIgnoreCase);

    private static IReadOnlyList<string> GetPlanFeatures(string? planName) =>
        planName?.ToLowerInvariant() switch
        {
            "basic"    => ["Up to 20 members", "Basic reporting", "Mobile app access", "Email support"],
            "standard" => ["Up to 50 members", "Advanced reporting", "Mobile app access", "Priority email support", "Data backup"],
            "premium"  => ["Up to 100 members", "Advanced reporting & analytics", "Mobile app access", "Priority support (email & phone)", "Data backup & export"],
            _          => []
        };

    private static string GetArchetypeBadgeClass(ArchetypeOption option) =>
        option.IsComingSoon                               ? "sisonke-badge sisonke-badge-gray"  :
        option.Archetype == StokvelArchetype.Rotational   ? "sisonke-badge sisonke-badge-blue"  :
        option.Archetype == StokvelArchetype.BurialSociety? "sisonke-badge sisonke-badge-green" :
        "sisonke-badge sisonke-badge-gold";

    private bool HasBankingDetails() =>
        !string.IsNullOrWhiteSpace(model.BankName) ||
        !string.IsNullOrWhiteSpace(model.AccountHolderName) ||
        !string.IsNullOrWhiteSpace(model.AccountNumber) ||
        !string.IsNullOrWhiteSpace(model.BranchCode) ||
        !string.IsNullOrWhiteSpace(model.BranchName) ||
        !string.IsNullOrWhiteSpace(model.PaymentReferenceFormat);

    private string? ValidateBankingDetails()
    {
        if (!HasBankingDetails())
        {
            return null;
        }

        if (string.IsNullOrWhiteSpace(model.BankName)) return "Please enter the bank name or clear the banking details section.";
        if (string.IsNullOrWhiteSpace(model.AccountHolderName)) return "Please enter the account holder name or clear the banking details section.";
        if (string.IsNullOrWhiteSpace(model.AccountNumber)) return "Please enter the account number or clear the banking details section.";
        if (!model.AccountNumber.All(char.IsDigit)) return "Account number must contain digits only.";
        if (!string.IsNullOrWhiteSpace(model.BranchCode) && !model.BranchCode.All(char.IsDigit)) return "Branch code must contain digits only.";
        return null;
    }

    private StokvelBankingDetails? BuildBankingDetailsForCreate() =>
        !HasBankingDetails()
            ? null
            : new StokvelBankingDetails
            {
                BankName = model.BankName ?? string.Empty,
                AccountHolderName = model.AccountHolderName ?? string.Empty,
                AccountNumber = model.AccountNumber ?? string.Empty,
                AccountType = model.AccountType,
                BranchCode = model.BranchCode,
                BranchName = model.BranchName,
                PaymentReferenceFormat = model.PaymentReferenceFormat
            };

    private static string GetBankAccountTypeLabel(BankAccountType accountType) =>
        accountType switch
        {
            BankAccountType.Savings       => "Savings",
            BankAccountType.Current       => "Current",
            BankAccountType.Transmission  => "Transmission",
            BankAccountType.ChequeAccount => "Cheque Account",
            _                             => accountType.ToString()
        };

    private sealed record ArchetypeOption(
        StokvelArchetype Archetype,
        string Title,
        string Description,
        string StatusText,
        bool IsComingSoon,
        string Icon = "bi-grid");
}
