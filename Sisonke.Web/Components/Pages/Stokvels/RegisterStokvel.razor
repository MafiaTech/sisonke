@page "/register-stokvel"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Sisonke.Web.Data
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Helpers
@using Sisonke.Web.Services

@inject StokvelService StokvelService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject MemberAccountLinkingService MemberAccountLinkingService
@inject MemberService MemberService
@inject IServiceScopeFactory ScopeFactory

<PageTitle>Register New Stokvel</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading stokvel registration...
    </div>
}
else if (currentUser is null)
{
    <AlertBanner Type="warning" Title="Please sign in to register a stokvel." Message="" Icon="bi bi-exclamation-triangle-fill" />
}
else
{
    <!-- ── Wizard header ── -->
    <div class="rw-wizard-header mb-4">
        <div class="rw-brand">
            <div class="rw-brand-mark"><i class="bi bi-piggy-bank-fill"></i></div>
            <div>
                <div class="rw-brand-name">Sisonke</div>
                <div class="rw-brand-tagline">Together we save. Together we grow.</div>
            </div>
        </div>

        <div class="rw-steps">
            <div class="rw-step @(currentWizardStep == 1 ? "rw-step-active" : currentWizardStep > 1 ? "rw-step-done" : "")">
                <div class="rw-step-circle">
                    @if (currentWizardStep > 1) { <i class="bi bi-check-lg"></i> } else { <span>1</span> }
                </div>
                <div class="rw-step-label">User Details</div>
            </div>
            <div class="rw-step-connector @(currentWizardStep > 1 ? "rw-step-connector-done" : "")"></div>
            <div class="rw-step @(currentWizardStep == 2 ? "rw-step-active" : currentWizardStep > 2 ? "rw-step-done" : "")">
                <div class="rw-step-circle">
                    @if (currentWizardStep > 2) { <i class="bi bi-check-lg"></i> } else { <span>2</span> }
                </div>
                <div class="rw-step-label">Stokvel Type</div>
            </div>
            <div class="rw-step-connector @(currentWizardStep > 2 ? "rw-step-connector-done" : "")"></div>
            <div class="rw-step @(currentWizardStep == 3 ? "rw-step-active" : "")">
                <div class="rw-step-circle"><span>3</span></div>
                <div class="rw-step-label">Review</div>
            </div>
        </div>

        <a class="sisonke-btn sisonke-btn-outline" href="/my-workspace">
            <i class="bi bi-arrow-left me-2"></i>Cancel
        </a>
    </div>

    <!-- ── Feedback banners ── -->
    @if (saveFailed)
    {
        <AlertBanner Type="danger" Title="Unable to register stokvel." Message="Please check the details and try again." Icon="bi bi-x-circle-fill" />
    }
    @if (!string.IsNullOrWhiteSpace(wizardValidationMessage))
    {
        <AlertBanner Type="warning" Title="@wizardValidationMessage" Message="" Icon="bi bi-exclamation-triangle-fill" />
    }

    <EditForm Model="@model" OnValidSubmit="@HandleValidSubmit" FormName="RegisterStokvelForm">
        <DataAnnotationsValidator />

        <!-- ══════════════ STEP 1 — User Details ══════════════ -->
        @if (currentWizardStep == 1)
        {
            <div class="rw-step-panel">
                <div class="rw-step-title">
                    <h1>Stokvel Details</h1>
                    <p>Tell us about your stokvel and who will be the first office bearer.</p>
                </div>

                @if (string.IsNullOrWhiteSpace(currentUser.IdNumber))
                {
                    <div class="sisonke-alert sisonke-alert-gold mb-3">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Your ID number is not on your account. Please update your profile before registering a stokvel.
                    </div>
                }

                <!-- Stokvel identity -->
                <div class="sisonke-card mb-3">
                    <div class="sisonke-card-body">
                        <div class="sisonke-card-head mb-3">
                            <div>
                                <h2>Stokvel Identity</h2>
                                <p>Give your stokvel a name and describe its purpose.</p>
                            </div>
                        </div>
                        <div class="sisonke-grid sisonke-grid-2">
                            <div class="member-form-field">
                                <label class="form-label" for="stokvel-name">
                                    Stokvel name <span class="text-danger">*</span>
                                </label>
                                <InputText id="stokvel-name" class="form-control" placeholder="e.g. Mahlalela Burial Society" @bind-Value="model.Name" />
                                <ValidationMessage For="@(() => model.Name)" class="text-danger small" />
                            </div>
                            <div class="member-form-field">
                                <label class="form-label" for="expected-member-count">Expected total members</label>
                                <InputNumber id="expected-member-count" class="form-control" TValue="int?"
                                    Value="@model.ExpectedMemberCount"
                                    ValueChanged="@((int? v) => OnExpectedMemberCountChangedAsync(v))"
                                    ValueExpression="@(() => model.ExpectedMemberCount)" />
                                <div class="form-text">Helps Sisonke recommend the right plan.</div>
                            </div>
                            <div class="member-form-field">
                                <label class="form-label" for="province">Province</label>
                                <select id="province" class="form-select" value="@model.Province" @onchange="OnProvinceChanged">
                                    <option value="">— Select province —</option>
                                    @foreach (var province in provinces)
                                    {
                                        <option value="@province">@province</option>
                                    }
                                </select>
                            </div>
                            <div class="member-form-field">
                                <label class="form-label" for="town-or-area">Town or area</label>
                                <select id="town-or-area" class="form-select" @bind="model.TownOrArea" disabled="@(!towns.Any())">
                                    <option value="">— Select town/area —</option>
                                    @foreach (var town in towns)
                                    {
                                        <option value="@town">@town</option>
                                    }
                                </select>
                            </div>
                            <div class="member-form-field">
                                <label class="form-label" for="established-date">Established date</label>
                                <InputDate id="established-date" class="form-control" @bind-Value="model.EstablishedDate" />
                            </div>
                            <div class="member-form-field register-form-wide">
                                <label class="form-label" for="description">
                                    Description <span class="text-muted fw-normal">(optional)</span>
                                </label>
                                <InputTextArea id="description" class="form-control" rows="2"
                                    placeholder="Brief description of the stokvel's purpose and goals."
                                    @bind-Value="model.Description" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Office bearer -->
                <div class="sisonke-card mb-3">
                    <div class="sisonke-card-body">
                        <div class="sisonke-card-head mb-3">
                            <div>
                                <h2>Office Bearer Details</h2>
                                <p>You will be linked to this stokvel as the first office bearer and creator.</p>
                            </div>
                            <div class="rw-creator-pill">
                                <i class="bi bi-person-check-fill me-1"></i>
                                @SensitiveDataMasker.MaskEmail(currentUser.Email)
                            </div>
                        </div>
                        <div class="sisonke-grid sisonke-grid-2">
                            <div class="member-form-field">
                                <label class="form-label" for="creator-full-name">
                                    Full name <span class="text-danger">*</span>
                                </label>
                                <InputText id="creator-full-name" class="form-control" @bind-Value="model.CreatorFullName" />
                                <ValidationMessage For="@(() => model.CreatorFullName)" class="text-danger small" />
                            </div>
                            <div class="member-form-field">
                                <label class="form-label" for="creator-cellphone">
                                    Cellphone <span class="text-danger">*</span>
                                </label>
                                <InputText id="creator-cellphone" class="form-control" placeholder="e.g. 0821234567" @bind-Value="model.CreatorCellphoneNumber" />
                                <ValidationMessage For="@(() => model.CreatorCellphoneNumber)" class="text-danger small" />
                            </div>
                            <div class="member-form-field">
                                <label class="form-label" for="creator-email">Email address</label>
                                <InputText id="creator-email" class="form-control" @bind-Value="model.CreatorEmail" />
                            </div>
                            <div class="member-form-field">
                                <label class="form-label" for="creator-id-number">SA ID number</label>
                                <InputText id="creator-id-number" class="form-control" placeholder="13-digit SA ID" @bind-Value="model.CreatorIdNumber" />
                                <div class="form-text">Links this record to your login account.</div>
                            </div>
                            <div class="member-form-field register-form-wide">
                                <label class="form-label" for="creator-area">Residential area</label>
                                <InputText id="creator-area" class="form-control" placeholder="e.g. Soweto, Gauteng" @bind-Value="model.CreatorResidentialArea" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Banking details -->
                <div class="sisonke-card mb-3">
                    <div class="sisonke-card-body">
                        <div class="sisonke-card-head mb-3">
                            <div>
                                <h2>Banking Details</h2>
                                <p>Add the stokvel bank account members should use for deposits and payouts.</p>
                            </div>
                            <span class="sisonke-badge sisonke-badge-gray">Optional</span>
                        </div>
                        <div class="sisonke-grid sisonke-grid-2">
                            <div class="member-form-field">
                                <label class="form-label" for="bank-name">Bank name</label>
                                <InputText id="bank-name" class="form-control" maxlength="100" placeholder="e.g. FNB" @bind-Value="model.BankName" />
                            </div>
                            <div class="member-form-field">
                                <label class="form-label" for="account-holder-name">Account holder name</label>
                                <InputText id="account-holder-name" class="form-control" maxlength="150" placeholder="e.g. Local Test Stokvel" @bind-Value="model.AccountHolderName" />
                            </div>
                            <div class="member-form-field">
                                <label class="form-label" for="account-number">Account number</label>
                                <InputText id="account-number" class="form-control" maxlength="50" inputmode="numeric" @bind-Value="model.AccountNumber" />
                            </div>
                            <div class="member-form-field">
                                <label class="form-label" for="account-type">Account type</label>
                                <InputSelect id="account-type" class="form-select" @bind-Value="model.AccountType">
                                    @foreach (var accountType in Enum.GetValues<BankAccountType>())
                                    {
                                        <option value="@accountType">@GetBankAccountTypeLabel(accountType)</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="member-form-field">
                                <label class="form-label" for="branch-code">Branch code</label>
                                <InputText id="branch-code" class="form-control" maxlength="20" inputmode="numeric" @bind-Value="model.BranchCode" />
                            </div>
                            <div class="member-form-field">
                                <label class="form-label" for="branch-name">Branch name</label>
                                <InputText id="branch-name" class="form-control" maxlength="100" @bind-Value="model.BranchName" />
                            </div>
                            <div class="member-form-field register-form-wide">
                                <label class="form-label" for="payment-reference">Payment reference format</label>
                                <InputText id="payment-reference" class="form-control" maxlength="200" placeholder="e.g. Member number + month" @bind-Value="model.PaymentReferenceFormat" />
                                <div class="form-text">This helps members use consistent references when making payments.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="rw-step-actions">
                    <a class="sisonke-btn sisonke-btn-outline" href="/my-workspace">Cancel</a>
                    <button type="button" class="sisonke-btn sisonke-btn-primary rw-btn-next" @onclick="GoToStep2">
                        Continue to Stokvel Type <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </div>
            </div>
        }

        <!-- ══════════════ STEP 2 — Stokvel Type & Package ══════════════ -->
        @if (currentWizardStep == 2)
        {
            <div class="rw-step-panel">
                <div class="rw-step-title">
                    <h1>Choose Your Stokvel Type</h1>
                    <p>Select the type that best describes how your group will save and share money.</p>
                </div>

                <!-- Archetype selector -->
                <div class="sisonke-card mb-3">
                    <div class="sisonke-card-body">
                        <InputRadioGroup @bind-Value="model.Archetype">
                            <div class="archetype-grid">
                                @foreach (var option in archetypeOptions)
                                {
                                    var isSelected = model.Archetype == option.Archetype && !option.IsComingSoon;
                                    <label class="archetype-card @(isSelected ? "archetype-card-selected" : "") @(option.IsComingSoon ? "archetype-card-soon" : "")">
                                        <InputRadio class="visually-hidden" Value="@option.Archetype" disabled="@option.IsComingSoon" />
                                        <div class="archetype-card-top">
                                            <div class="archetype-icon-wrap">
                                                <i class="bi @option.Icon"></i>
                                            </div>
                                            @if (isSelected)
                                            {
                                                <div class="archetype-check">
                                                    <i class="bi bi-check-circle-fill"></i>
                                                </div>
                                            }
                                        </div>
                                        <div class="archetype-title">@option.Title</div>
                                        <div class="archetype-description">@option.Description</div>
                                        <span class="@GetArchetypeBadgeClass(option)">@option.StatusText</span>
                                    </label>
                                }
                            </div>
                        </InputRadioGroup>

                        @if (model.Archetype == StokvelArchetype.Rotational)
                        {
                            <div class="sisonke-alert sisonke-alert-blue mt-3 d-flex align-items-start gap-2">
                                <i class="bi bi-lightbulb-fill mt-1" style="flex-shrink:0"></i>
                                <div>
                                    <strong>Rotational Stokvels</strong> help members track contributions, payout order and next recipient transparently.
                                    Members contribute regularly and the full pot is paid to one member in turn.
                                </div>
                            </div>
                        }
                        else if (model.Archetype == StokvelArchetype.BurialSociety)
                        {
                            <div class="sisonke-alert sisonke-alert-green mt-3 d-flex align-items-start gap-2">
                                <i class="bi bi-heart-fill mt-1" style="flex-shrink:0"></i>
                                <div>
                                    <strong>Burial Society</strong> enables funeral claims, dependents and member contributions.
                                    Rotation and lending features stay off for this stokvel type.
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Subscription plans -->
                <div class="sisonke-card mb-3">
                    <div class="sisonke-card-body">
                        <div class="sisonke-card-head mb-3">
                            <div>
                                <h2>Choose Your Plan</h2>
                                <p>Select the package that fits your expected membership size.</p>
                            </div>
                            @if (packageSelectionFailed)
                            {
                                <span class="text-danger small fw-semibold">Plan selection required</span>
                            }
                        </div>

                        @if (subscriptionPlans.Count == 0)
                        {
                            <AlertBanner Type="info" Title="No subscription packages are configured yet."
                                Message="Please ask the platform administrator to configure packages."
                                Icon="bi bi-info-circle-fill" />
                        }
                        else
                        {
                            <div class="row g-3">
                                @foreach (var plan in subscriptionPlans)
                                {
                                    var isPlanSelected = model.SubscriptionPlanId == plan.Id;
                                    var isPopular      = IsMostPopularPlan(plan.Name);
                                    var features       = GetPlanFeatures(plan.Name);

                                    <div class="col-12 col-md-4">
                                        <div class="plan-card @(isPlanSelected ? "plan-selected" : "") @(isPopular && !isPlanSelected ? "plan-recommended" : "") @(isPopular ? "plan-popular-wrap" : "") h-100"
                                             @onclick="@(() => SelectSubscriptionPlan(plan.Id))">
                                            <div class="card-body p-4 d-flex flex-column">
                                                @if (isPopular)
                                                {
                                                    <div class="text-center mb-2">
                                                        <span class="sisonke-badge sisonke-badge-gold">Most Popular</span>
                                                    </div>
                                                }
                                                <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                                                    <h3 class="h6 mb-0 fw-700">@plan.Name</h3>
                                                    @if (isPlanSelected)
                                                    {
                                                        <i class="bi bi-check-circle-fill" style="color:var(--sk-success);font-size:1.1rem;flex-shrink:0"></i>
                                                    }
                                                </div>
                                                <p class="text-muted small mb-2">@GetMemberRangeText(plan)</p>
                                                <div class="plan-price mb-3">
                                                    @FormatCurrency(plan.MonthlyPrice)<span class="text-muted fw-normal" style="font-size:.875rem">/mo</span>
                                                </div>
                                                <ul class="plan-features mt-auto mb-0">
                                                    @foreach (var feat in features)
                                                    {
                                                        <li>
                                                            <i class="bi bi-check2 me-2" style="color:var(--sk-success)"></i>@feat
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <div class="rw-step-actions">
                    <button type="button" class="sisonke-btn sisonke-btn-outline" @onclick="GoBackToStep1">
                        <i class="bi bi-arrow-left me-2"></i>Back to User Details
                    </button>
                    <button type="button" class="sisonke-btn sisonke-btn-primary rw-btn-next" @onclick="GoToStep3">
                        Continue to Review <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </div>
            </div>
        }

        <!-- ══════════════ STEP 3 — Final Review ══════════════ -->
        @if (currentWizardStep == 3)
        {
            <div class="rw-step-panel">
                <div class="rw-step-title">
                    <h1>Review &amp; Confirm</h1>
                    <p>Check the details before creating your stokvel.</p>
                </div>

                <ValidationSummary class="alert alert-danger mb-3" />

                <!-- Type + plan summary row -->
                <div class="row g-3 mb-3">
                    <div class="col-12 col-md-6">
                        <div class="sisonke-card h-100">
                            <div class="sisonke-card-body">
                                <div class="detail-mini-label mb-2">Stokvel Type</div>
                                @if (SelectedArchetypeOption is not null)
                                {
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <div class="rw-review-icon">
                                            <i class="bi @SelectedArchetypeOption.Icon"></i>
                                        </div>
                                        <div>
                                            <div class="fw-700">@SelectedArchetypeOption.Title</div>
                                            <span class="@GetArchetypeBadgeClass(SelectedArchetypeOption)">@SelectedArchetypeOption.StatusText</span>
                                        </div>
                                    </div>
                                    <p class="text-muted small mb-0">@SelectedArchetypeOption.Description</p>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-md-6">
                        <div class="sisonke-card h-100">
                            <div class="sisonke-card-body">
                                <div class="detail-mini-label mb-2">Selected Plan</div>
                                @if (SelectedPlan is not null)
                                {
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <div class="fw-700">@SelectedPlan.Name</div>
                                        @if (IsMostPopularPlan(SelectedPlan.Name))
                                        {
                                            <span class="sisonke-badge sisonke-badge-gold">Most Popular</span>
                                        }
                                    </div>
                                    <div class="plan-price" style="font-size:1.35rem">
                                        @FormatCurrency(SelectedPlan.MonthlyPrice)<span class="text-muted fw-normal" style="font-size:.875rem">/mo</span>
                                    </div>
                                    <p class="text-muted small mt-1 mb-0">@GetMemberRangeText(SelectedPlan)</p>
                                }
                                else
                                {
                                    <span class="text-danger small">No plan selected — go back to Step 2.</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stokvel details summary -->
                <div class="sisonke-card mb-3">
                    <div class="sisonke-card-body">
                        <div class="form-section-title mb-3">Stokvel Details</div>
                        <div class="row g-3">
                            <div class="col-6 col-md-3">
                                <div class="detail-mini-label">Stokvel Name</div>
                                <div class="fw-600">@Display(model.Name)</div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="detail-mini-label">Province</div>
                                <div class="fw-600">@Display(model.Province)</div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="detail-mini-label">Town / Area</div>
                                <div class="fw-600">@Display(model.TownOrArea)</div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="detail-mini-label">Expected Members</div>
                                <div class="fw-600">@(model.ExpectedMemberCount?.ToString() ?? "Not specified")</div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(model.Description))
                            {
                                <div class="col-12">
                                    <div class="detail-mini-label">Description</div>
                                    <div class="text-muted small">@model.Description</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @if (HasBankingDetails())
                {
                    <div class="sisonke-card mb-3">
                        <div class="sisonke-card-body">
                            <div class="form-section-title mb-3">Banking Details</div>
                            <div class="row g-3">
                                <div class="col-6 col-md-3">
                                    <div class="detail-mini-label">Bank</div>
                                    <div class="fw-600">@Display(model.BankName)</div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="detail-mini-label">Account Holder</div>
                                    <div class="fw-600">@Display(model.AccountHolderName)</div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="detail-mini-label">Account Number</div>
                                    <div class="fw-600">@StokvelBankingDetailsService.MaskAccountNumber(model.AccountNumber)</div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="detail-mini-label">Account Type</div>
                                    <div class="fw-600">@GetBankAccountTypeLabel(model.AccountType)</div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="detail-mini-label">Branch Code</div>
                                    <div class="fw-600">@Display(model.BranchCode)</div>
                                </div>
                                <div class="col-6 col-md-3">
                                    <div class="detail-mini-label">Payment Reference</div>
                                    <div class="fw-600">@Display(model.PaymentReferenceFormat)</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Creator summary -->
                <div class="sisonke-card mb-3">
                    <div class="sisonke-card-body">
                        <div class="form-section-title mb-3">Office Bearer</div>
                        <div class="row g-3">
                            <div class="col-6 col-md-3">
                                <div class="detail-mini-label">Full Name</div>
                                <div class="fw-600">@Display(model.CreatorFullName)</div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="detail-mini-label">Cellphone</div>
                                <div class="fw-600">@SensitiveDataMasker.MaskPhoneNumber(model.CreatorCellphoneNumber)</div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="detail-mini-label">Email</div>
                                <div class="fw-600">@SensitiveDataMasker.MaskEmail(model.CreatorEmail)</div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="detail-mini-label">ID Number</div>
                                <div class="fw-600">@SensitiveDataMasker.MaskIdNumber(model.CreatorIdNumber)</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="rw-step-actions">
                    <button type="button" class="sisonke-btn sisonke-btn-outline" @onclick="GoBackToStep2">
                        <i class="bi bi-arrow-left me-2"></i>Back to Stokvel Type
                    </button>
                    <button class="sisonke-btn sisonke-btn-primary rw-btn-next" type="submit">
                        <i class="bi bi-check-circle me-2"></i>Register Stokvel
                    </button>
                </div>
            </div>
        }
    </EditForm>
}

