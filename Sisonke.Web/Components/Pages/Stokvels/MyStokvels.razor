@page "/my-stokvels"
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services
@inject StokvelService StokvelService

<PageTitle>My Stokvels</PageTitle>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1>My Stokvels</h1>
        <p class="text-muted mb-0">Manage your registered stokvels and continue any incomplete setup.</p>
    </div>
    <a class="btn btn-primary" href="/register-stokvel">Register New Stokvel</a>
</div>

@if (stokvels is null)
{
    <p>Loading...</p>
}
else
{
    <section class="mb-5">
        <h2 class="h4 mb-2">Ready Stokvels</h2>
        <p class="text-muted">These stokvels are ready for day-to-day management.</p>

        @if (ReadyStokvels.Count == 0)
        {
            <p class="text-muted">No completed stokvels yet.</p>
        }
        else
        {
            <div class="row g-3">
                @foreach (var stokvel in ReadyStokvels)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card h-100">
                            <div class="card-body d-flex flex-column">
                                <h3 class="h5 card-title">@stokvel.Name</h3>
                                <p class="card-text mb-1"><strong>Type:</strong> @stokvel.Type</p>
                                <p class="card-text mb-1"><strong>Tenant:</strong> @stokvel.Tenant.Name</p>
                                <p class="card-text"><strong>Status:</strong> @(stokvel.IsActive ? "Active" : "Inactive")</p>
                                <a class="btn btn-primary mt-auto align-self-start" href="@($"/stokvel-dashboard/{stokvel.Id}")">Open Dashboard</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <section>
        <h2 class="h4 mb-2">Incomplete Setup</h2>
        <p class="text-muted">These stokvels have been created but registration has not been submitted yet.</p>

        @if (IncompleteSetupStokvels.Count == 0)
        {
            <p class="text-muted">No incomplete setup items.</p>
        }
        else
        {
            <div class="row g-3">
                @foreach (var stokvel in IncompleteSetupStokvels)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card h-100">
                            <div class="card-body d-flex flex-column">
                                <h3 class="h5 card-title">@stokvel.Name</h3>
                                <p class="card-text mb-1"><strong>Type:</strong> @stokvel.Type</p>
                                <p class="card-text mb-1"><strong>Tenant:</strong> @stokvel.Tenant.Name</p>
                                <p class="card-text mb-1"><strong>Status:</strong> @(stokvel.IsActive ? "Active" : "Inactive")</p>
                                <p class="card-text"><strong>Setup completion:</strong> @(stokvel.IsSetupComplete ? "Complete" : "Incomplete")</p>
                                <a class="btn btn-primary mt-auto align-self-start" href="@($"/stokvel-questionnaire/{stokvel.Id}")">Continue Registration</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
}

@code {
    private List<Stokvel>? stokvels;
    private List<Stokvel> ReadyStokvels => stokvels?.Where(stokvel => stokvel.IsSetupComplete).ToList() ?? [];
    private List<Stokvel> IncompleteSetupStokvels => stokvels?.Where(stokvel => !stokvel.IsSetupComplete).ToList() ?? [];

    protected override async Task OnInitializedAsync()
    {
        stokvels = await StokvelService.GetAllStokvelsAsync();
    }
}
