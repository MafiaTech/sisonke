    // ── Payment section ────────────────────────────────────────────────

    private async Task PreparePaymentRegisterAsync()
    {
        if (string.IsNullOrWhiteSpace(currentUserId)) return;
        isPreparingPayments = true;
        paymentErrors = [];
        paymentSuccessMessage = null;

        var result = await PaymentService.EnsurePaymentRecordsForStokvelAsync(StokvelId, currentUserId);
        if (result.Success)
        {
            paymentSuccessMessage = result.RecordsCreated > 0
                ? $"Payment register prepared: {result.RecordsCreated} records created."
                : "Payment register is already up to date.";
            if (cycleSummary?.CurrentCycle is not null)
            {
                cyclePayments = await PaymentService.GetPaymentsForCycleAsync(cycleSummary.CurrentCycle.Id);
                if (cyclePayments.Count > 0)
                    contributionSummary = await PaymentService.GetCycleContributionSummaryAsync(cycleSummary.CurrentCycle.Id);
            }
        }
        else
        {
            paymentErrors = result.Errors;
        }

        isPreparingPayments = false;
    }

    private void OpenPaymentForm(RotationalContributionPayment payment)
    {
        selectedPaymentId = payment.Id;
        paymentFormPaidAmount = payment.PaidAmount > 0 ? payment.PaidAmount : payment.ExpectedAmount;
        paymentFormDate = payment.PaymentDate ?? DateTime.Today;
        paymentFormMethod = payment.PaymentMethod;
        paymentFormReference = payment.ReferenceNumber;
        paymentFormNotes = payment.Notes;
        paymentFormStatus = payment.PaymentStatus is ContributionPaymentStatus.Unpaid or ContributionPaymentStatus.PartiallyPaid
            ? ContributionPaymentStatus.Paid
            : payment.PaymentStatus;
        paymentErrors = [];
        paymentSuccessMessage = null;
    }

    private void ClosePaymentForm()
    {
        selectedPaymentId = null;
        paymentErrors = [];
    }

    private async Task SavePaymentAsync(Guid paymentId)
    {
        if (string.IsNullOrWhiteSpace(currentUserId)) return;
        isConfirmingPayment = true;
        paymentErrors = [];
        paymentSuccessMessage = null;

        var request = new ConfirmPaymentRequest(
            PaidAmount: paymentFormStatus == ContributionPaymentStatus.Waived ? 0 : paymentFormPaidAmount,
            PaymentDate: paymentFormStatus == ContributionPaymentStatus.Waived ? null : paymentFormDate,
            PaymentMethod: paymentFormStatus == ContributionPaymentStatus.Waived ? null : paymentFormMethod,
            ReferenceNumber: paymentFormReference,
            Notes: paymentFormNotes,
            PaymentStatus: paymentFormStatus);

        var result = await PaymentService.ConfirmPaymentAsync(paymentId, request, currentUserId);

        if (result.Success)
        {
            selectedPaymentId = null;
            paymentSuccessMessage = result.PenaltyApplied > 0
                ? $"Payment recorded. Penalty applied: {FormatZAR(result.PenaltyApplied)}."
                : "Payment recorded successfully.";
            if (cycleSummary?.CurrentCycle is not null)
            {
                cyclePayments = await PaymentService.GetPaymentsForCycleAsync(cycleSummary.CurrentCycle.Id);
                contributionSummary = await PaymentService.GetCycleContributionSummaryAsync(cycleSummary.CurrentCycle.Id);
                cycleSummary = await CycleService.GetCycleSummaryAsync(StokvelId, currentUserId);
                payoutSummary = await PayoutService.GetPayoutSummaryAsync(StokvelId, currentUserId);
            }
        }
        else
        {
            paymentErrors = result.Errors;
        }

        isConfirmingPayment = false;
    }

