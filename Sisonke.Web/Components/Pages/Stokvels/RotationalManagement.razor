@code {
    [Parameter]
    public Guid StokvelId { get; set; }

    private Stokvel? stokvel;
    private bool FinancialProductsAllowed => stokvel is not null &&
        stokvel.Archetype != StokvelArchetype.BurialSociety &&
        stokvel.Type != StokvelType.BurialSociety;
    private Member? linkedMember;
    private List<RotationalPayoutOrderItem> activeOrder = [];
    private List<RotationalPayoutOrderItem> editableOrder = [];
    private List<RotationalPayoutOrderItem> previewOrder = [];
    private RotationalStokvelConfiguration? activeConfig;
    private bool isLoading = true;
    private bool isSaving;
    private bool isEditing;
    private bool isGeneratingPreview;
    private bool canManage;
    private bool showConfirmModal;
    private int eligibleMemberCount;
    private RotationOrderMethod pendingPreviewMethod;
    private string previewMethodLabel = string.Empty;
    private string confirmTitle = string.Empty;
    private string confirmMessage = string.Empty;
    private string confirmButtonText = "Confirm";
    private string? currentUserId;
    private string? successMessage;
    private List<string> errors = [];
    private CycleSummary? cycleSummary;
    private bool isGeneratingCycles;
    private bool showCycleRegenConfirm;
    private List<string> cycleErrors = [];
    private string? cycleSuccessMessage;

    // Payment section state
    private List<RotationalContributionPayment> cyclePayments = [];
    private CycleContributionSummary? contributionSummary;
    private bool isTreasurer;
    private bool canViewPayments;
    private RotationalContributionPayment? myPayment;
    private Guid? selectedPaymentId;
    private decimal paymentFormPaidAmount;
    private DateTime? paymentFormDate;
    private ContributionPaymentMethod? paymentFormMethod;
    private string? paymentFormReference;
    private string? paymentFormNotes;
    private ContributionPaymentStatus paymentFormStatus = ContributionPaymentStatus.Paid;
    private bool isConfirmingPayment;
    private bool isPreparingPayments;
    private List<string> paymentErrors = [];
    private string? paymentSuccessMessage;
    private PayoutSummary? payoutSummary;
    private bool showPayoutConfirmationModal;
    private bool isProcessingPayout;
    private RotationalPayoutDecision payoutDecision = RotationalPayoutDecision.Approve;
    private string? payoutDecisionNotes;
    private PaymentMethod? payoutPaymentMethod;
    private string? payoutPaymentReference;
    private DateTime? payoutPaidAt;
    private string? payoutNotes;
    private List<string> payoutErrors = [];
    private string PayoutDecisionNotesPlaceholder => payoutDecision == RotationalPayoutDecision.Approve
        ? "Decision notes (optional)"
        : "Notes required";
    private bool CanSubmitPayoutDecision =>
        !isProcessingPayout &&
        (payoutDecision == RotationalPayoutDecision.Approve || !string.IsNullOrWhiteSpace(payoutDecisionNotes));
    private bool CanResubmitReturnedPayout =>
        linkedMember?.DefaultRole is SisonkeRole.Secretary or SisonkeRole.Creator or SisonkeRole.StokvelAdmin;

    private RotationalPayoutOrderItem? NextRecipient =>
        activeOrder.FirstOrDefault(item => !item.HasReceivedPayout);

    private int CompletedPayouts =>
        activeOrder.Count(item => item.HasReceivedPayout);

    private bool IsCurrentMember(Guid memberId) =>
        linkedMember?.Id == memberId;

    private (string Text, string Type) GetCurrentStatus()
    {
        if (payoutSummary?.Payout is not null)
        {
            return payoutSummary.Payout.PayoutStatus switch
            {
                RotationalPayoutStatus.ReadyForApproval => ("Waiting for payout approval", "warning"),
                RotationalPayoutStatus.Approved => ("Payout approved", "success"),
                RotationalPayoutStatus.Rejected => ("Payout rejected", "danger"),
                RotationalPayoutStatus.Paid => ("Payout paid", "success"),
                RotationalPayoutStatus.ReturnedToSecretary => ("Changes requested", "warning"),
                _ => ("Payout pending", "warning")
            };
        }
        if (cycleSummary?.CurrentCycle is not null)
        {
            return cycleSummary.CurrentCycle.Status switch
            {
                RotationalCycleStatus.Open => ("Cycle open", "success"),
                RotationalCycleStatus.ContributionsDue => ("Contributions due", "warning"),
                RotationalCycleStatus.ReadyForPayout => ("Ready for payout", "success"),
                RotationalCycleStatus.PayoutPending => ("Payout pending", "warning"),
                _ => ("Cycle active", "success")
            };
        }
        if (cycleSummary?.IsGenerated == true) return ("Cycles generated", "success");
        if (activeOrder.Count > 0) return ("Order ready", "success");
        if (activeConfig is null) return ("Configuration required", "warning");
        if (eligibleMemberCount < 2) return ("Add members", "warning");
        return ("Order not configured", "secondary");
    }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        errors = [];
        successMessage = null;
        isEditing = false;
        previewOrder = [];
        activeOrder = [];
        editableOrder = [];
        activeConfig = null;
        eligibleMemberCount = 0;
        linkedMember = null;
        canManage = false;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var summary = await RotationOrderService.GetRotationalManagementSummaryAsync(StokvelId, currentUserId);
        stokvel = summary?.Stokvel;

        if (summary is null || !summary.Stokvel.EnableRotation)
        {
            isLoading = false;
            return;
        }

        linkedMember = summary.LinkedMember;
        canManage = summary.CanManage;
        activeConfig = summary.ActiveConfiguration;
        activeOrder = summary.ActiveOrder;
        eligibleMemberCount = summary.EligibleMemberCount;

        cycleSummary = await CycleService.GetCycleSummaryAsync(StokvelId, currentUserId);
        payoutSummary = await PayoutService.GetPayoutSummaryAsync(StokvelId, currentUserId);

        // Load payment section
        isTreasurer = currentUserId != null && await MemberAccessService.CanManagePaymentsAsync(currentUserId, StokvelId);
        canViewPayments = canManage || isTreasurer;
        cyclePayments = [];
        contributionSummary = null;
        myPayment = null;
        selectedPaymentId = null;
        paymentErrors = [];
        paymentSuccessMessage = null;

        if (cycleSummary?.CurrentCycle is not null && currentUserId != null)
        {
            if (canViewPayments)
            {
                cyclePayments = await PaymentService.GetPaymentsForCycleAsync(cycleSummary.CurrentCycle.Id);
                if (cyclePayments.Count > 0)
                    contributionSummary = await PaymentService.GetCycleContributionSummaryAsync(cycleSummary.CurrentCycle.Id);
            }
            else if (linkedMember is not null)
            {
                myPayment = await PaymentService.GetMyPaymentForCycleAsync(cycleSummary.CurrentCycle.Id, linkedMember.Id);
            }
        }

        isLoading = false;
    }

    private async Task GenerateCyclesAsync()
    {
        if (string.IsNullOrWhiteSpace(currentUserId)) return;
        isGeneratingCycles = true;
        cycleErrors = [];
        cycleSuccessMessage = null;

        var result = await CycleService.GenerateContributionCyclesAsync(StokvelId, currentUserId);
        if (result.Success)
        {
            cycleSuccessMessage = $"{result.CyclesGenerated} contribution cycles generated successfully.";
            cycleSummary = await CycleService.GetCycleSummaryAsync(StokvelId, currentUserId);
        }
        else
        {
            cycleErrors = result.Errors;
        }

        isGeneratingCycles = false;
    }

    private async Task ConfirmRegenerateCyclesAsync()
    {
        showCycleRegenConfirm = true;
    }

    private async Task DoRegenerateCyclesAsync()
    {
        showCycleRegenConfirm = false;
        if (string.IsNullOrWhiteSpace(currentUserId)) return;
        isGeneratingCycles = true;
        cycleErrors = [];
        cycleSuccessMessage = null;

        var result = await CycleService.RegenerateContributionCyclesAsync(StokvelId, currentUserId);
        if (result.Success)
        {
            cycleSuccessMessage = $"Contribution cycles regenerated ({result.CyclesGenerated} cycles).";
            cycleSummary = await CycleService.GetCycleSummaryAsync(StokvelId, currentUserId);
        }
        else
        {
            cycleErrors = result.Errors;
        }

        isGeneratingCycles = false;
    }

    private void CancelCycleRegen() => showCycleRegenConfirm = false;

    private async Task GeneratePreviewAsync(RotationOrderMethod method)
    {
        if (!canManage)
        {
            errors = ["Only office bearers can generate or edit the rotation order."];
            return;
        }

        if (activeOrder.Count > 0)
        {
            pendingPreviewMethod = method;
            confirmTitle = "Replace Rotation Order";
            confirmMessage = "This will generate a new order preview. The current active order will only be replaced when you click Save. Historical records will be preserved.";
            confirmButtonText = "Generate Preview";
            showConfirmModal = true;
            return;
        }

        await DoGeneratePreviewAsync(method);
    }

    private async Task ConfirmReplaceAndSaveAsync()
    {
        showConfirmModal = false;
        await DoGeneratePreviewAsync(pendingPreviewMethod);
    }

    private async Task DoGeneratePreviewAsync(RotationOrderMethod method)
    {
        isGeneratingPreview = true;
        pendingPreviewMethod = method;
        errors = [];
        successMessage = null;

        var (items, previewErrors) = await RotationOrderService.PreviewRotationOrderAsync(StokvelId, method);

        if (previewErrors.Count > 0)
        {
            errors = previewErrors;
            isGeneratingPreview = false;
            return;
        }

        previewOrder = items;
        previewMethodLabel = method switch
        {
            RotationOrderMethod.ByJoiningDate => "By Joining Date",
            RotationOrderMethod.Random => "Random",
            _ => "Generated"
        };
        isEditing = false;
        editableOrder = [];
        isGeneratingPreview = false;
    }

    private void CancelPreview()
    {
        previewOrder = [];
        pendingPreviewMethod = default;
        previewMethodLabel = string.Empty;
        errors = [];
    }

    private async Task SavePreviewOrderAsync()
    {
        if (string.IsNullOrWhiteSpace(currentUserId))
        {
            errors = ["Current user could not be identified."];
            return;
        }

        isSaving = true;
        var orderedMemberIds = previewOrder.Select(item => item.MemberId).ToList();
        var result = await RotationOrderService.SaveManualRotationOrderAsync(StokvelId, orderedMemberIds, currentUserId);
        await HandleSaveResultAsync(result, $"Rotation order saved ({previewMethodLabel}).");
        if (result.Success) previewOrder = [];
        isSaving = false;
    }

    private async Task StartManualCreate()
    {
        if (!canManage)
        {
            errors = ["Only office bearers can create or edit the rotation order."];
            return;
        }

        editableOrder = activeOrder.Count > 0
            ? activeOrder.Select(item => item with { }).ToList()
            : await RotationOrderService.GetEligibleMembersAsync(StokvelId);

        for (var i = 0; i < editableOrder.Count; i++)
            editableOrder[i] = editableOrder[i] with { Position = i + 1 };

        isEditing = true;
        previewOrder = [];
        errors = [];
        successMessage = null;
    }

    private void StartEdit()
    {
        if (!canManage)
        {
            errors = ["Only office bearers can edit the rotation order."];
            return;
        }

        editableOrder = activeOrder.Select(item => item with { }).ToList();
        isEditing = true;
        previewOrder = [];
        errors = [];
        successMessage = null;
    }

    private async Task SaveManualOrderAsync()
    {
        if (string.IsNullOrWhiteSpace(currentUserId))
        {
            errors = ["Current user could not be identified."];
            return;
        }

        isSaving = true;
        var orderedMemberIds = editableOrder.Select(item => item.MemberId).ToList();
        var result = activeOrder.Count > 0
            ? await RotationOrderService.ReorderRotationOrderAsync(StokvelId, orderedMemberIds, currentUserId)
            : await RotationOrderService.SaveManualRotationOrderAsync(StokvelId, orderedMemberIds, currentUserId);

        await HandleSaveResultAsync(result, "Manual rotation order saved.");
        isSaving = false;
    }

    private async Task SaveFromQuickActionsAsync()
    {
        if (previewOrder.Count > 0)
            await SavePreviewOrderAsync();
        else if (isEditing)
            await SaveManualOrderAsync();
    }

    private void CancelCurrentAction()
    {
        if (previewOrder.Count > 0) CancelPreview();
        else if (isEditing) CancelEdit();
    }

    private async Task HandleSaveResultAsync(RotationOrderSaveResult result, string message)
    {
        if (!result.Success)
        {
            errors = result.Errors;
            return;
        }

        activeOrder = await RotationOrderService.GetActiveRotationOrderAsync(StokvelId);
        eligibleMemberCount = await RotationOrderService.GetEligibleMemberCountAsync(StokvelId);
        editableOrder = [];
        isEditing = false;
        errors = [];
        successMessage = message;
    }

    private void MoveUp(int index)
    {
        if (index <= 0) return;
        (editableOrder[index - 1], editableOrder[index]) = (editableOrder[index], editableOrder[index - 1]);
        RecalculatePositions();
    }

    private void MoveDown(int index)
    {
        if (index >= editableOrder.Count - 1) return;
        (editableOrder[index + 1], editableOrder[index]) = (editableOrder[index], editableOrder[index + 1]);
        RecalculatePositions();
    }

    private void RecalculatePositions()
    {
        for (var i = 0; i < editableOrder.Count; i++)
            editableOrder[i] = editableOrder[i] with { Position = i + 1 };
    }

    private void CancelEdit()
    {
        isEditing = false;
        editableOrder = [];
        errors = [];
    }

    private void CancelConfirm() => showConfirmModal = false;

    private RenderFragment RenderReadOnlyTable(IReadOnlyList<RotationalPayoutOrderItem> rows) => builder =>
    {
        var seq = 0;
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "table-responsive");
        builder.OpenElement(seq++, "table");
        builder.AddAttribute(seq++, "class", "table align-middle");
        builder.OpenElement(seq++, "thead");
        builder.OpenElement(seq++, "tr");
        foreach (var h in new[] { "#", "Member", "Status" })
        {
            builder.OpenElement(seq++, "th");
            builder.AddContent(seq++, h);
            builder.CloseElement();
        }
        builder.CloseElement();
        builder.CloseElement();
        builder.OpenElement(seq++, "tbody");

        foreach (var row in rows)
        {
            var isCurrent = linkedMember?.Id == row.MemberId;
            builder.OpenElement(seq++, "tr");
            builder.AddAttribute(seq++, "class", isCurrent ? "table-success" : null);

            builder.OpenElement(seq++, "td");
            builder.AddAttribute(seq++, "class", "fw-bold text-muted");
            builder.AddContent(seq++, row.Position);
            builder.CloseElement();

            builder.OpenElement(seq++, "td");
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "fw-semibold");
            builder.AddContent(seq++, row.MemberName);
            if (isCurrent)
            {
                builder.AddMarkupContent(seq++, " <span class=\"sisonke-badge sisonke-badge-green ms-2\">You</span>");
            }
            builder.CloseElement();
            builder.OpenElement(seq++, "div");
            builder.AddAttribute(seq++, "class", "text-muted small");
            builder.AddContent(seq++, row.MemberNumber);
            builder.CloseElement();
            builder.CloseElement();

            builder.OpenElement(seq++, "td");
            builder.AddAttribute(seq++, "class", "text-muted small");
            builder.AddContent(seq++, $"{row.MemberStatus} / {row.GovernanceStatus}");
            builder.CloseElement();

            builder.CloseElement();
        }

        builder.CloseElement();
        builder.CloseElement();
        builder.CloseElement();
    };

    private async Task RefreshPayoutAsync()
    {
        payoutSummary = await PayoutService.GetPayoutSummaryAsync(StokvelId, currentUserId);
        cycleSummary = await CycleService.GetCycleSummaryAsync(StokvelId, currentUserId);
        activeOrder = await RotationOrderService.GetActiveRotationOrderAsync(StokvelId);
    }

    private async Task SubmitPayoutDecisionAsync()
    {
        if (payoutSummary?.Payout is null || string.IsNullOrWhiteSpace(currentUserId)) return;
        payoutErrors = [];
        if (payoutDecision != RotationalPayoutDecision.Approve && string.IsNullOrWhiteSpace(payoutDecisionNotes))
        {
            payoutErrors = ["Decision notes are required for reject or request changes."];
            return;
        }
        isProcessingPayout = true;
        var result = await PayoutService.SubmitChairpersonDecisionAsync(
            payoutSummary.Payout.Id, currentUserId, payoutDecision, payoutDecisionNotes);
        payoutErrors = result.Errors; isProcessingPayout = false;
        if (!result.Success) return;
        payoutDecision = RotationalPayoutDecision.Approve;
        payoutDecisionNotes = null;
        await RefreshPayoutAsync();
    }

    private async Task ResubmitPayoutForApprovalAsync()
    {
        if (payoutSummary?.Payout is null || string.IsNullOrWhiteSpace(currentUserId)) return;
        payoutErrors = [];
        isProcessingPayout = true;
        var result = await PayoutService.ResubmitPayoutForApprovalAsync(payoutSummary.Payout.Id, currentUserId);
        payoutErrors = result.Errors;
        isProcessingPayout = false;
        if (!result.Success) return;
        await RefreshPayoutAsync();
    }

    private void OpenPayoutConfirmation()
    {
        payoutPaymentMethod = PaymentMethod.EFT;
        payoutPaymentReference = null;
        payoutPaidAt = DateTime.Today;
        payoutNotes = null;
        payoutErrors = [];
        showPayoutConfirmationModal = true;
    }

    private async Task ConfirmPayoutPaidAsync()
    {
        if (payoutSummary?.Payout is null || string.IsNullOrWhiteSpace(currentUserId)) return;
        isProcessingPayout = true;
        var result = await PayoutService.ConfirmPayoutPaidAsync(
            payoutSummary.Payout.Id, currentUserId,
            new ConfirmPayoutPaidRequest(payoutPaymentMethod, payoutPaymentReference, payoutPaidAt, payoutNotes));
        payoutErrors = result.Errors; isProcessingPayout = false;
        if (!result.Success) return;
        showPayoutConfirmationModal = false;
        await RefreshPayoutAsync();
    }

