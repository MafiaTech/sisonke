    private IReadOnlyList<ReportDatum> GetRotationalContributionSegments()
    {
        if (contributionSummary is null)
        {
            return [];
        }

        return
        [
            new("Received", contributionSummary.ReceivedTotal, "#0F8A50", $"{contributionSummary.PaidCount} paid"),
            new("Outstanding", contributionSummary.OutstandingTotal, "#D97706", $"{contributionSummary.UnpaidCount + contributionSummary.PartialCount} open"),
            new("Penalties", contributionSummary.PenaltyTotal, "#B94242", $"{contributionSummary.LateCount} late")
        ];
    }

    private IReadOnlyList<ReportDatum> GetRotationalPaymentStatusBars()
    {
        if (contributionSummary is null)
        {
            return [];
        }

        return
        [
            new("Paid", contributionSummary.PaidCount, "#0F8A50"),
            new("Partial", contributionSummary.PartialCount, "#D97706"),
            new("Late", contributionSummary.LateCount, "#B94242"),
            new("Unpaid", contributionSummary.UnpaidCount, "#64746B")
        ];
    }

    private IReadOnlyList<ReportDatum> GetRotationProgressSegments()
    {
        var total = Math.Max(0, activeOrder.Count);
        var remaining = Math.Max(0, total - CompletedPayouts);

        return
        [
            new("Paid out", CompletedPayouts, "#0F8A50", "Completed payout turns"),
            new("Remaining", remaining, "#D97706", "Upcoming payout turns")
        ];
    }

