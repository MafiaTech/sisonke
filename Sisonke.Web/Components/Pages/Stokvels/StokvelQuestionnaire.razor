@page "/stokvel-questionnaire/{StokvelId:guid}"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using Sisonke.Web.Components.Shared
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject StokvelService StokvelService
@inject QuestionnaireService QuestionnaireService
@inject NavigationManager NavigationManager

<PageTitle>Quick Stokvel Setup</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading questionnaire…
    </div>
}
else if (stokvel is null)
{
    <AlertBanner Type="danger" Title="Stokvel not found." Message="" Icon="bi bi-x-circle-fill" />
}
else
{
    <!-- ── Page header ── -->
    <section class="sisonke-hero-card mb-4">
        <div>
            <span class="sisonke-badge sisonke-badge-gold me-2">@GetArchetypeLabel(stokvel.Archetype)</span>
            <h1>Quick Stokvel Setup</h1>
            <p>@stokvel.Name — Together we save. Together we grow.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="sisonke-btn sisonke-btn-outline" href="@BackLinkHref">
                <i class="bi bi-arrow-left me-2"></i>@BackLinkText
            </a>
        </div>
    </section>

    <!-- Feedback banners -->
    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <AlertBanner Type="success" Title="Saved" Message="@successMessage" Icon="bi bi-check-circle-fill" />
    }
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <AlertBanner Type="danger" Title="Action failed" Message="@errorMessage" Icon="bi bi-x-circle-fill" />
    }

    <!-- ── Progress bar ── -->
    <div class="qs-progress-wrap mb-4">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="fw-600 small">Setup completion</span>
            <span class="fw-700 small" style="color:var(--sk-green-700)">@completionPercentage%</span>
        </div>
        <div class="progress">
            <div class="progress-bar @(completionPercentage == 100 ? "bg-success" : "")"
                 role="progressbar"
                 style="width:@(completionPercentage)%"
                 aria-valuenow="@completionPercentage" aria-valuemin="0" aria-valuemax="100">
            </div>
        </div>
    </div>

    <!-- ── Step indicators ── -->
    <div class="row g-2 mb-4">
        @for (var step = 1; step <= 4; step++)
        {
            var s = step;
            <div class="col-6 col-lg-3">
                <div class="wizard-step @GetStepClass(s)">
                    <div class="wizard-step-num">
                        @if (s < currentStep)
                        {
                            <i class="bi bi-check2"></i>
                        }
                        else
                        {
                            @s
                        }
                    </div>
                    <div>
                        <div class="wizard-step-label">@GetStepName(s)</div>
                        <div class="wizard-step-sub">Step @s of 4</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- ── Step content ── -->
    @if (currentStep < 4)
    {
        @if (!CurrentStepSections.Any())
        {
            <div class="sisonke-alert sisonke-alert-blue">
                <i class="bi bi-info-circle me-2"></i>
                This step has no questions for your stokvel type. Click <strong>Next</strong> to continue.
            </div>
        }

        <div class="d-flex flex-column gap-3">
            @foreach (var section in CurrentStepSections)
            {
                <div class="sisonke-card">
                    <div class="sisonke-card-body">
                        <div class="form-section-title">@section.Name</div>
                        @if (!string.IsNullOrWhiteSpace(section.Description))
                        {
                            <p class="text-muted small mb-3">@section.Description</p>
                        }

                        @foreach (var question in GetApplicableQuestions(section))
                        {
                            <div class="mb-3">
                                <label class="form-label" for="@GetQuestionInputId(question.Id)">
                                    @question.QuestionText
                                    @if (question.IsRequired)
                                    {
                                        <span class="text-danger">*</span>
                                    }
                                </label>

                                @if (!string.IsNullOrWhiteSpace(question.HelpText))
                                {
                                    <div class="form-text mb-1">@question.HelpText</div>
                                }

                                @switch (question.QuestionType)
                                {
                                    case QuestionType.Number:
                                        <InputNumber id="@GetQuestionInputId(question.Id)" class="form-control" TValue="int?"
                                            Value="@GetIntAnswer(question.Id)"
                                            ValueChanged="@((int? v) => SetAnswer(question.Id, v?.ToString()))"
                                            ValueExpression="@(() => intValueExpression)" />
                                        break;
                                    case QuestionType.Currency:
                                        <div class="input-group">
                                            <span class="input-group-text">R</span>
                                            <InputNumber id="@GetQuestionInputId(question.Id)" class="form-control" TValue="decimal?"
                                                Value="@GetDecimalAnswer(question.Id)"
                                                ValueChanged="@((decimal? v) => SetAnswer(question.Id, v?.ToString()))"
                                                ValueExpression="@(() => decimalValueExpression)" />
                                        </div>
                                        break;
                                    case QuestionType.Date:
                                        <InputDate id="@GetQuestionInputId(question.Id)" class="form-control" TValue="DateTime?"
                                            Value="@GetDateAnswer(question.Id)"
                                            ValueChanged="@((DateTime? v) => SetAnswer(question.Id, v?.ToString("yyyy-MM-dd")))"
                                            ValueExpression="@(() => dateValueExpression)" />
                                        break;
                                    case QuestionType.YesNo:
                                        <InputSelect id="@GetQuestionInputId(question.Id)" class="form-select" TValue="string"
                                            Value="@GetAnswer(question.Id)"
                                            ValueChanged="@((string? v) => SetAnswer(question.Id, v))"
                                            ValueExpression="@(() => stringValueExpression)">
                                            <option value="">Select an answer</option>
                                            <option value="Yes">Yes</option>
                                            <option value="No">No</option>
                                        </InputSelect>
                                        break;
                                    case QuestionType.SingleSelect:
                                        <InputSelect id="@GetQuestionInputId(question.Id)" class="form-select" TValue="string"
                                            Value="@GetAnswer(question.Id)"
                                            ValueChanged="@((string? v) => SetAnswer(question.Id, v))"
                                            ValueExpression="@(() => stringValueExpression)">
                                            <option value="">Select an answer</option>
                                            @foreach (var option in question.Options)
                                            {
                                                <option value="@(option.OptionValue ?? option.OptionText)">@option.OptionText</option>
                                            }
                                        </InputSelect>
                                        break;
                                    case QuestionType.MultiSelect:
                                        <InputText id="@GetQuestionInputId(question.Id)" class="form-control"
                                            Value="@GetAnswer(question.Id)"
                                            ValueChanged="@((string? v) => SetAnswer(question.Id, v))"
                                            ValueExpression="@(() => stringValueExpression)" />
                                        <div class="form-text">Enter comma-separated values.</div>
                                        break;
                                    default:
                                        <InputText id="@GetQuestionInputId(question.Id)" class="form-control"
                                            Value="@GetAnswer(question.Id)"
                                            ValueChanged="@((string? v) => SetAnswer(question.Id, v))"
                                            ValueExpression="@(() => stringValueExpression)" />
                                        break;
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- ── Review step ── -->
        <div class="card mb-4">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="wizard-step-num" style="background:var(--sk-green-800);color:#fff;border-radius:50%;width:1.75rem;height:1.75rem;display:flex;align-items:center;justify-content:center;font-size:.875rem;font-weight:700;flex-shrink:0">4</div>
                    <h3 class="h5 mb-0">Review &amp; Sign Off</h3>
                </div>
                <p class="text-muted small mb-4">Review all setup answers before completing setup. You can go back to any step to make corrections.</p>

                <div class="qs-progress-wrap mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-600 small">Completion</span>
                        <span class="fw-700 small" style="color:@(completionPercentage == 100 ? "var(--sk-success)" : "var(--sk-gold-dark)")">@completionPercentage%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar @(completionPercentage == 100 ? "bg-success" : "bg-warning")"
                             style="width:@(completionPercentage)%"></div>
                    </div>
                </div>

                @foreach (var section in ReviewSections)
                {
                    <div class="review-section mb-3">
                        <div class="review-section-title">@section.Name</div>
                        @foreach (var question in GetApplicableQuestions(section))
                        {
                            <div class="review-row">
                                <span class="review-q">@question.QuestionText</span>
                                <span class="review-a @(GetAnswer(question.Id) == "" ? "review-a-empty" : "")">@GetReviewAnswer(question.Id)</span>
                            </div>
                        }
                    </div>
                }

                @if (completionPercentage < 100)
                {
                    <AlertBanner Type="warning" Title="Setup incomplete" Message="Please complete all required questions before submitting." Icon="bi bi-exclamation-triangle-fill" />
                }
            </div>
        </div>
    }

    <!-- ── Navigation buttons ── -->
    <div class="d-flex flex-wrap gap-2 mt-2">
        @if (currentStep > 1)
        {
            <button type="button" class="btn btn-outline-secondary" @onclick="GoToPreviousStep">
                <i class="bi bi-chevron-left me-1"></i>Previous
            </button>
        }

        <button type="button" class="btn btn-outline-primary" @onclick="SaveQuestionnaireAsync">
            <i class="bi bi-floppy me-2"></i>Save Draft
        </button>

        @if (currentStep < 4)
        {
            <button type="button" class="btn btn-primary" @onclick="GoToNextStep">
                Next<i class="bi bi-chevron-right ms-2"></i>
            </button>
        }
        else if (completionPercentage == 100)
        {
            <button type="button" class="btn btn-accent" @onclick="ShowSubmitRegistrationConfirmation">
                <i class="bi bi-check2-circle me-2"></i>Complete Setup
            </button>
        }
    </div>

    <ConfirmationModal
        IsVisible="@showSubmitConfirmation"
        Title="Complete Stokvel Setup"
        Message="You are about to complete this stokvel setup. Sisonke will use these answers to configure the stokvel for day-to-day management. You can still create or upload a constitution later."
        ConfirmButtonText="Confirm Complete Setup"
        CancelButtonText="Cancel"
        ModalType="warning"
        OnConfirm="@ConfirmSubmitRegistrationAsync"
        OnCancel="@CancelSubmitRegistration" />
}

<style>
    .qs-progress-wrap { max-width: 640px; }
    .wizard-step-sub { font-size: .6875rem; color: var(--sk-text-muted); margin-top: .1rem; }
    .wizard-step.step-active .wizard-step-sub { color: rgba(27,67,50,.6); }
    .wizard-step.step-done  .wizard-step-sub { color: #065f46; }

    .review-section {
        border: 1px solid var(--sk-border);
        border-radius: var(--sk-radius-sm);
        overflow: hidden;
    }
    .review-section-title {
        font-size: .6875rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: var(--sk-text-muted);
        background: #F9FAFB;
        padding: .625rem 1rem;
        border-bottom: 1px solid var(--sk-border);
    }
    .review-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        padding: .625rem 1rem;
        border-bottom: 1px solid var(--sk-border);
        font-size: .875rem;
    }
    .review-row:last-child { border-bottom: none; }
    .review-q { color: var(--sk-text-muted); flex: 1; }
    .review-a { font-weight: 500; color: var(--sk-text); flex: 1; text-align: right; }
    .review-a-empty { color: var(--sk-text-muted); font-style: italic; font-weight: 400; }
    .fw-600 { font-weight: 600; }
    .fw-700 { font-weight: 700; }
</style>

@code {
    private Stokvel? stokvel;
    private List<QuestionnaireSection> sections = [];
    private Dictionary<Guid, string> answers = [];
    private int currentStep = 1;
    private int completionPercentage;
    private bool isLoading = true;
    private bool showSubmitConfirmation;
    private string? successMessage;
    private string? errorMessage;
    private string stringValueExpression = string.Empty;
    private int? intValueExpression = null;
    private decimal? decimalValueExpression = null;
    private DateTime? dateValueExpression = null;

    [Parameter]
    public Guid StokvelId { get; set; }

    private string BackLinkHref => stokvel?.IsSetupComplete == true ? $"/stokvel-dashboard/{StokvelId}" : "/my-stokvels";
    private string BackLinkText => stokvel?.IsSetupComplete == true ? "Back to Dashboard" : "Back to My Stokvels";

    private List<QuestionnaireSection> CurrentStepSections =>
        sections
            .Where(s => GetSectionStep(s.Name) == currentStep && IsSectionApplicable(s))
            .ToList();

    private IEnumerable<QuestionnaireSection> ReviewSections =>
        sections.Where(IsSectionApplicable);

    private bool IsSectionApplicable(QuestionnaireSection section) =>
        section.Name switch
        {
            "Claims and Payouts" => stokvel?.EnableClaims == true,
            _ => true
        };

    private IEnumerable<QuestionnaireQuestion> GetApplicableQuestions(QuestionnaireSection section)
    {
        if (stokvel?.EnableDependents == true && stokvel?.EnableClaims == true)
            return section.Questions;

        return section.Questions
            .Where(q =>
                !q.QuestionText.Contains("beneficiaries", StringComparison.OrdinalIgnoreCase) &&
                !q.QuestionText.Contains("dependents", StringComparison.OrdinalIgnoreCase));
    }

    private void PrePopulateAutoAnswers()
    {
        if (stokvel is null) return;

        foreach (var section in sections)
        {
            if (!IsSectionApplicable(section))
            {
                foreach (var q in section.Questions.Where(q => q.IsRequired))
                {
                    if (!answers.TryGetValue(q.Id, out var existing) || string.IsNullOrWhiteSpace(existing))
                        answers[q.Id] = "N/A";
                }
                continue;
            }

            var applicableIds = GetApplicableQuestions(section).Select(q => q.Id).ToHashSet();
            foreach (var q in section.Questions.Where(q => q.IsRequired && !applicableIds.Contains(q.Id)))
            {
                if (!answers.TryGetValue(q.Id, out var existing) || string.IsNullOrWhiteSpace(existing))
                    answers[q.Id] = "N/A";
            }
        }
    }

    private void RecomputeLocalCompletion()
    {
        var required = sections
            .Where(IsSectionApplicable)
            .SelectMany(GetApplicableQuestions)
            .Where(q => q.IsRequired)
            .ToList();

        completionPercentage = required.Count == 0
            ? 100
            : required.Count(q => !string.IsNullOrWhiteSpace(GetAnswer(q.Id))) * 100 / required.Count;
    }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        successMessage = null;
        errorMessage = null;
        showSubmitConfirmation = false;

        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);

        if (stokvel is not null)
        {
            sections = await QuestionnaireService.GetActiveQuestionnaireAsync();
            answers  = await QuestionnaireService.GetAnswersByStokvelIdAsync(StokvelId);
            PrePopulateAutoAnswers();
            RecomputeLocalCompletion();
        }

        isLoading = false;
    }

    private string GetAnswer(Guid questionId) =>
        answers.TryGetValue(questionId, out var a) ? a : string.Empty;

    private string GetReviewAnswer(Guid questionId)
    {
        var a = GetAnswer(questionId);
        return string.IsNullOrWhiteSpace(a) ? "Not answered" : a;
    }

    private void SetAnswer(Guid questionId, string? value) =>
        answers[questionId] = value ?? string.Empty;

    private int? GetIntAnswer(Guid questionId) =>
        int.TryParse(GetAnswer(questionId), out var v) ? v : null;

    private decimal? GetDecimalAnswer(Guid questionId) =>
        decimal.TryParse(GetAnswer(questionId), out var v) ? v : null;

    private DateTime? GetDateAnswer(Guid questionId) =>
        DateTime.TryParse(GetAnswer(questionId), out var v) ? v : null;

    private static string GetQuestionInputId(Guid questionId) => $"question-{questionId}";

    private async Task SaveQuestionnaireAsync()
    {
        successMessage = null;
        errorMessage = null;
        showSubmitConfirmation = false;

        PrePopulateAutoAnswers();
        var saved = await QuestionnaireService.SaveAnswersAsync(StokvelId, answers);
        if (!saved) { errorMessage = "Could not save questionnaire."; return; }

        RecomputeLocalCompletion();
        successMessage = "Setup draft saved successfully.";
    }

    private void ShowSubmitRegistrationConfirmation()
    {
        successMessage = null;
        errorMessage = null;
        if (completionPercentage < 100) return;
        showSubmitConfirmation = true;
    }

    private void CancelSubmitRegistration() => showSubmitConfirmation = false;

    private async Task ConfirmSubmitRegistrationAsync()
    {
        successMessage = null;
        errorMessage = null;

        // Save auto-populated answers first so the service's completion check passes
        PrePopulateAutoAnswers();
        await QuestionnaireService.SaveAnswersAsync(StokvelId, answers);

        var submitted = await QuestionnaireService.SubmitRegistrationAsync(StokvelId);

        if (!submitted)
        {
            showSubmitConfirmation = false;
            errorMessage = "Registration could not be submitted. Please complete all required questions.";
            RecomputeLocalCompletion();
            return;
        }

        showSubmitConfirmation = false;
        successMessage = "Registration submitted successfully. This stokvel is now ready for management.";
        NavigationManager.NavigateTo($"/stokvel-dashboard/{StokvelId}");
    }

    private void GoToPreviousStep() => currentStep = Math.Max(1, currentStep - 1);
    private void GoToNextStep()     => currentStep = Math.Min(4, currentStep + 1);

    private static int GetSectionStep(string sectionName) =>
        sectionName switch
        {
            "Stokvel Identity"          => 1,
            "Membership Rules"          => 1,
            "Contributions and Fines"   => 2,
            "Meetings and Decisions"    => 3,
            "Claims and Payouts"        => 3,
            _                           => 4
        };

    private static string GetStepName(int step) =>
        step switch { 1 => "Basics", 2 => "Money", 3 => "Rules", 4 => "Sign-off", _ => string.Empty };

    private static string GetArchetypeLabel(StokvelArchetype archetype) =>
        archetype switch
        {
            StokvelArchetype.BurialSociety  => "Burial Society",
            StokvelArchetype.Rotational     => "Rotational Stokvel",
            StokvelArchetype.Grocery        => "Grocery Stokvel",
            StokvelArchetype.SavingsClub    => "Savings Club",
            StokvelArchetype.InvestmentClub => "Investment Club",
            StokvelArchetype.Education      => "Education Stokvel",
            StokvelArchetype.Borrowing      => "Borrowing Stokvel",
            StokvelArchetype.Travel         => "Travel Stokvel",
            StokvelArchetype.SocialClub     => "Social Club",
            _                               => "Stokvel"
        };

    private string GetStepClass(int step)
    {
        if (step == currentStep) return "step-active";
        if (step < currentStep)  return "step-done";
        return string.Empty;
    }
}
