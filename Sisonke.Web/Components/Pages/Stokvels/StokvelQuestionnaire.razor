@page "/stokvel-questionnaire/{StokvelId:guid}"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using Sisonke.Web.Components.Shared
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject StokvelService StokvelService
@inject QuestionnaireService QuestionnaireService
@inject NavigationManager NavigationManager

<PageTitle>Quick Stokvel Setup</PageTitle>

@if (isLoading)
{
    <p>Loading questionnaire...</p>
}
else if (stokvel is null)
{
    <AlertBanner Type="danger" Title="Stokvel not found." Message="" Icon="bi bi-x-circle-fill" />
}
else
{
    <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
        <PageHeader
            Title="Quick Stokvel Setup"
            Subtitle="@($"{stokvel.Name} - Complete the key setup details Sisonke needs to configure this stokvel for day-to-day management. You can create or upload a constitution later from the dashboard.")" />
        <a class="btn btn-outline-secondary" href="@BackLinkHref">@BackLinkText</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <AlertBanner Type="success" Title="Saved" Message="@successMessage" Icon="bi bi-check-circle-fill" />
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <AlertBanner Type="danger" Title="Action failed" Message="@errorMessage" Icon="bi bi-x-circle-fill" />
    }

    <div class="mb-4">
        <div class="d-flex justify-content-between mb-1">
            <span class="fw-semibold">Questionnaire completion: @completionPercentage%</span>
        </div>
        <div class="progress" role="progressbar" aria-label="Questionnaire completion" aria-valuenow="@completionPercentage" aria-valuemin="0" aria-valuemax="100">
            <div class="progress-bar" style="@($"width: {completionPercentage}%")">@completionPercentage%</div>
        </div>
    </div>

    <div class="row g-2 mb-4">
        @for (var step = 1; step <= 4; step++)
        {
            <div class="col-6 col-lg-3">
                <div class="border rounded p-3 h-100 @(GetStepIndicatorClass(step))">
                    <div class="small fw-semibold">Step @step</div>
                    <div>@GetStepName(step)</div>
                </div>
            </div>
        }
    </div>

    @if (currentStep < 4)
    {
        <div class="row">
            @foreach (var section in CurrentStepSections)
            {
                <div class="col-12 col-md-6 mb-4">
                    <section class="card h-100">
                        <div class="card-body">
                            <h3 class="h5">@section.Name</h3>

                            @if (!string.IsNullOrWhiteSpace(section.Description))
                            {
                                <p class="text-muted">@section.Description</p>
                            }

                            @foreach (var question in section.Questions)
                            {
                                <div class="mb-3">
                                    <label class="form-label fw-semibold" for="@GetQuestionInputId(question.Id)">
                                        @question.QuestionText
                                        @if (question.IsRequired)
                                        {
                                            <span class="text-danger">*</span>
                                        }
                                    </label>

                                    @if (!string.IsNullOrWhiteSpace(question.HelpText))
                                    {
                                        <div class="form-text mb-1">@question.HelpText</div>
                                    }

                                    @switch (question.QuestionType)
                                    {
                                        case QuestionType.Number:
                                            <InputNumber id="@GetQuestionInputId(question.Id)" class="form-control" TValue="int?"
                                                Value="@GetIntAnswer(question.Id)"
                                                ValueChanged="@((int? value) => SetAnswer(question.Id, value?.ToString()))"
                                                ValueExpression="@(() => intValueExpression)" />
                                            break;
                                        case QuestionType.Currency:
                                            <InputNumber id="@GetQuestionInputId(question.Id)" class="form-control" TValue="decimal?"
                                                Value="@GetDecimalAnswer(question.Id)"
                                                ValueChanged="@((decimal? value) => SetAnswer(question.Id, value?.ToString()))"
                                                ValueExpression="@(() => decimalValueExpression)" />
                                            break;
                                        case QuestionType.Date:
                                            <InputDate id="@GetQuestionInputId(question.Id)" class="form-control" TValue="DateTime?"
                                                Value="@GetDateAnswer(question.Id)"
                                                ValueChanged="@((DateTime? value) => SetAnswer(question.Id, value?.ToString("yyyy-MM-dd")))"
                                                ValueExpression="@(() => dateValueExpression)" />
                                            break;
                                        case QuestionType.YesNo:
                                            <InputSelect id="@GetQuestionInputId(question.Id)" class="form-select" TValue="string"
                                                Value="@GetAnswer(question.Id)"
                                                ValueChanged="@((string? value) => SetAnswer(question.Id, value))"
                                                ValueExpression="@(() => stringValueExpression)">
                                                <option value="">Select an answer</option>
                                                <option value="Yes">Yes</option>
                                                <option value="No">No</option>
                                            </InputSelect>
                                            break;
                                        case QuestionType.SingleSelect:
                                            <InputSelect id="@GetQuestionInputId(question.Id)" class="form-select" TValue="string"
                                                Value="@GetAnswer(question.Id)"
                                                ValueChanged="@((string? value) => SetAnswer(question.Id, value))"
                                                ValueExpression="@(() => stringValueExpression)">
                                                <option value="">Select an answer</option>
                                                @foreach (var option in question.Options)
                                                {
                                                    <option value="@(option.OptionValue ?? option.OptionText)">@option.OptionText</option>
                                                }
                                            </InputSelect>
                                            break;
                                        case QuestionType.MultiSelect:
                                            <InputText id="@GetQuestionInputId(question.Id)" class="form-control"
                                                Value="@GetAnswer(question.Id)"
                                                ValueChanged="@((string? value) => SetAnswer(question.Id, value))"
                                                ValueExpression="@(() => stringValueExpression)" />
                                            <div class="form-text">Enter comma-separated values.</div>
                                            break;
                                        default:
                                            <InputText id="@GetQuestionInputId(question.Id)" class="form-control"
                                                Value="@GetAnswer(question.Id)"
                                                ValueChanged="@((string? value) => SetAnswer(question.Id, value))"
                                                ValueExpression="@(() => stringValueExpression)" />
                                            break;
                                    }
                                </div>
                            }
                        </div>
                    </section>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card mb-4">
            <div class="card-body">
                <h3 class="h5">Review and Submit</h3>
                <p class="text-muted">Review your setup answers before completing setup.</p>

                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="fw-semibold">Completion: @completionPercentage%</span>
                    </div>
                    <div class="progress" role="progressbar" aria-label="Setup completion" aria-valuenow="@completionPercentage" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar" style="@($"width: {completionPercentage}%")">@completionPercentage%</div>
                    </div>
                </div>

                @foreach (var section in sections)
                {
                    <section class="border rounded p-3 mb-3">
                        <h4 class="h6">@section.Name</h4>
                        <dl class="row mb-0">
                            @foreach (var question in section.Questions)
                            {
                                <dt class="col-12 col-lg-6 fw-normal text-muted">@question.QuestionText</dt>
                                <dd class="col-12 col-lg-6">@GetReviewAnswer(question.Id)</dd>
                            }
                        </dl>
                    </section>
                }

                @if (completionPercentage < 100)
                {
                    <AlertBanner Type="warning" Title="Setup incomplete" Message="Please complete all required questions before completing setup." Icon="bi bi-exclamation-triangle-fill" />
                }
            </div>
        </div>
    }

    <div class="d-flex flex-wrap gap-2 mb-2">
        @if (currentStep > 1)
        {
            <button type="button" class="btn btn-outline-secondary" @onclick="GoToPreviousStep">Previous</button>
        }

        <button type="button" class="btn btn-primary" @onclick="SaveQuestionnaireAsync">Save Draft</button>

        @if (currentStep < 4)
        {
            <button type="button" class="btn btn-primary" @onclick="GoToNextStep">Next</button>
        }
        else if (completionPercentage == 100)
        {
            <button type="button" class="btn btn-success" @onclick="ShowSubmitRegistrationConfirmation">
                Complete Setup
            </button>
        }

        <a class="btn btn-outline-secondary" href="@BackLinkHref">@BackLinkText</a>
    </div>

    <ConfirmationModal
        IsVisible="@showSubmitConfirmation"
        Title="Complete Stokvel Setup"
        Message="You are about to complete this stokvel setup. Sisonke will use these answers to configure the stokvel for day-to-day management. You can still create or upload a constitution later."
        ConfirmButtonText="Confirm Complete Setup"
        CancelButtonText="Cancel"
        ModalType="warning"
        OnConfirm="@ConfirmSubmitRegistrationAsync"
        OnCancel="@CancelSubmitRegistration" />
}

@code {
    private Stokvel? stokvel;
    private List<QuestionnaireSection> sections = [];
    private Dictionary<Guid, string> answers = [];
    private int currentStep = 1;
    private int completionPercentage;
    private bool isLoading = true;
    private bool showSubmitConfirmation;
    private string? successMessage;
    private string? errorMessage;
    private string stringValueExpression = string.Empty;
    private int? intValueExpression = null;
    private decimal? decimalValueExpression = null;
    private DateTime? dateValueExpression = null;

    [Parameter]
    public Guid StokvelId { get; set; }

    private string BackLinkHref => stokvel?.IsSetupComplete == true
        ? $"/stokvel-dashboard/{StokvelId}"
        : "/my-stokvels";

    private string BackLinkText => stokvel?.IsSetupComplete == true
        ? "Back to Dashboard"
        : "Back to My Stokvels";

    private List<QuestionnaireSection> CurrentStepSections => sections
        .Where(section => GetSectionStep(section.Name) == currentStep)
        .ToList();

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        successMessage = null;
        errorMessage = null;
        showSubmitConfirmation = false;

        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);

        if (stokvel is not null)
        {
            sections = await QuestionnaireService.GetActiveQuestionnaireAsync();
            answers = await QuestionnaireService.GetAnswersByStokvelIdAsync(StokvelId);
            completionPercentage = await QuestionnaireService.GetCompletionPercentageAsync(StokvelId);
        }

        isLoading = false;
    }

    private string GetAnswer(Guid questionId)
    {
        return answers.TryGetValue(questionId, out var answer)
            ? answer
            : string.Empty;
    }

    private string GetReviewAnswer(Guid questionId)
    {
        var answer = GetAnswer(questionId);

        return string.IsNullOrWhiteSpace(answer)
            ? "Not answered"
            : answer;
    }

    private void SetAnswer(Guid questionId, string? value)
    {
        answers[questionId] = value ?? string.Empty;
    }

    private int? GetIntAnswer(Guid questionId)
    {
        return int.TryParse(GetAnswer(questionId), out var value)
            ? value
            : null;
    }

    private decimal? GetDecimalAnswer(Guid questionId)
    {
        return decimal.TryParse(GetAnswer(questionId), out var value)
            ? value
            : null;
    }

    private DateTime? GetDateAnswer(Guid questionId)
    {
        return DateTime.TryParse(GetAnswer(questionId), out var value)
            ? value
            : null;
    }

    private static string GetQuestionInputId(Guid questionId)
    {
        return $"question-{questionId}";
    }

    private async Task SaveQuestionnaireAsync()
    {
        successMessage = null;
        errorMessage = null;
        showSubmitConfirmation = false;

        var saved = await QuestionnaireService.SaveAnswersAsync(StokvelId, answers);

        if (!saved)
        {
            errorMessage = "Could not save questionnaire.";
            return;
        }

        completionPercentage = await QuestionnaireService.GetCompletionPercentageAsync(StokvelId);
        successMessage = "Setup draft saved successfully.";
    }

    private void ShowSubmitRegistrationConfirmation()
    {
        successMessage = null;
        errorMessage = null;

        if (completionPercentage < 100)
        {
            return;
        }

        showSubmitConfirmation = true;
    }

    private void CancelSubmitRegistration()
    {
        showSubmitConfirmation = false;
    }

    private async Task ConfirmSubmitRegistrationAsync()
    {
        successMessage = null;
        errorMessage = null;

        var submitted = await QuestionnaireService.SubmitRegistrationAsync(StokvelId);

        if (!submitted)
        {
            showSubmitConfirmation = false;
            errorMessage = "Registration could not be submitted. Please complete all required questions.";
            completionPercentage = await QuestionnaireService.GetCompletionPercentageAsync(StokvelId);
            return;
        }

        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);
        completionPercentage = await QuestionnaireService.GetCompletionPercentageAsync(StokvelId);
        showSubmitConfirmation = false;
        successMessage = "Registration submitted successfully. This stokvel is now ready for management.";
        NavigationManager.NavigateTo($"/stokvel-dashboard/{StokvelId}");
    }

    private void GoToPreviousStep()
    {
        currentStep = Math.Max(1, currentStep - 1);
    }

    private void GoToNextStep()
    {
        currentStep = Math.Min(4, currentStep + 1);
    }

    private static int GetSectionStep(string sectionName)
    {
        return sectionName switch
        {
            "Stokvel Identity" => 1,
            "Membership Rules" => 1,
            "Contributions and Fines" => 2,
            "Meetings and Decisions" => 3,
            "Claims and Payouts" => 3,
            _ => 4
        };
    }

    private static string GetStepName(int step)
    {
        return step switch
        {
            1 => "Basics",
            2 => "Money",
            3 => "Rules",
            4 => "Sign-off",
            _ => string.Empty
        };
    }

    private string GetStepIndicatorClass(int step)
    {
        if (step == currentStep)
        {
            return "border-primary bg-primary text-white";
        }

        if (step < currentStep)
        {
            return "border-success bg-success-subtle text-success";
        }

        return "bg-light text-muted";
    }
}
