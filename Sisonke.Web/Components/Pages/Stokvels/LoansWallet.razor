@code {
    [Parameter] public Guid StokvelId { get; set; }
    private LoansWalletPageState? state;
    private bool isLoading = true;
    private string currentUserId = "";
    private List<string> errors = [];
    private string? success;
    private bool showConfigForm = false;
    private bool showConfigConfirm = false;
    private StokvelLoanConfiguration configForm = NewConfig();
    private decimal loanAmount;
    private int loanMonths = 1;
    private string loanReason = "";
    private decimal withdrawalAmount;
    private string withdrawalReason = "";
    private string? dialogKind;
    private string dialogTitle = "";
    private Guid actionId;
    private decimal actionAmount;
    private int actionMonths;
    private string actionReason = "";
    private PaymentMethod? actionMethod = PaymentMethod.EFT;
    private string actionReference = "";
    private DateTime? actionDate = DateTime.Today;
    private string actionNotes = "";
    private bool actionApplyFine;
    private bool actionWaive;
    private decimal WalletBalance => state?.Wallet?.AvailableBalance ?? 0;
    private bool CanRequestLoan => state?.EligibilityMessage.StartsWith("Eligible", StringComparison.OrdinalIgnoreCase) == true && state.Configuration?.LoansEnabled == true;
    private decimal WalletEarlyPayoutAmount => loanAmount <= 0 ? 0 : Math.Min(loanAmount, WalletBalance);
    private decimal NetLoanAmount => loanAmount <= 0 ? 0 : Math.Max(0, loanAmount - WalletEarlyPayoutAmount);
    private MemberLoan? MyActiveLoan => state?.Loans.FirstOrDefault(x => x.MemberId == state.CurrentMember?.Id && x.LoanStatus is MemberLoanStatus.Active or MemberLoanStatus.Overdue);
    private decimal EstimatedMonthly => loanMonths <= 0 || NetLoanAmount <= 0 ? 0 : Math.Round(NetLoanAmount / loanMonths, 2);

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        showConfigForm = false;
        showConfigConfirm = false;
        errors = [];
        success = null;
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "";
        await ReloadAsync();
        isLoading = false;
    }

    private async Task ReloadAsync()
    {
        state = await Service.GetPageStateAsync(StokvelId, currentUserId);
        configForm = state?.Configuration is not null ? Clone(state.Configuration) : NewConfig();
        loanMonths = state?.Configuration?.DefaultRepaymentMonths ?? 1;
    }

    private void OpenConfigConfirmation() => showConfigConfirm = true;

    private void CancelConfigEdit()
    {
        showConfigForm = false;
        errors = [];
        success = null;
        configForm = state?.Configuration is not null ? Clone(state.Configuration) : NewConfig();
    }

    private async Task ExecuteSaveConfigurationAsync()
    {
        showConfigConfirm = false;
        var r = await Service.SaveConfigurationAsync(StokvelId, configForm, currentUserId);
        errors = r.Errors;
        if (r.Success)
        {
            success = "Loan rules saved successfully.";
            showConfigForm = false;
            await ReloadAsync();
        }
    }

    private async Task RunAsync(Task<FinanceOperationResult> task, string message)
    {
        errors = [];
        success = null;
        var result = await task;
        errors = result.Errors;
        if (result.Success) { success = result.Message ?? message; CloseDialog(); await ReloadAsync(); }
    }

    private Task RequestLoanAsync() => RunAsync(Service.RequestLoanAsync(StokvelId, currentUserId, loanAmount, loanMonths, loanReason), "Loan request submitted.");
    private Task RequestWithdrawalAsync() => RunAsync(Service.RequestWithdrawalAsync(StokvelId, currentUserId, withdrawalAmount, withdrawalReason), "Withdrawal request submitted.");
    private Task ApproveWithdrawalAsync(Guid id) => RunAsync(Service.ApproveWithdrawalAsync(id, currentUserId), "Withdrawal approved for payment.");
    private void OpenLoanApproval(MemberLoan x) { dialogKind = "loan-approve"; dialogTitle = "Approve Loan"; actionId = x.Id; actionAmount = x.RequestedAmount; actionMonths = x.RepaymentMonths; }
    private void OpenLoanRejection(MemberLoan x) { dialogKind = "loan-reject"; dialogTitle = "Reject Loan"; actionId = x.Id; actionReason = ""; }
    private void OpenDisbursement(MemberLoan x) { dialogKind = "disburse"; dialogTitle = "Confirm Loan Disbursement"; actionId = x.Id; ResetPayment(); }
    private void OpenRepayment(MemberLoanRepayment x) { dialogKind = "repayment"; dialogTitle = "Confirm Loan Repayment"; actionId = x.Id; actionAmount = x.ExpectedAmount; ResetPayment(); }
    private void OpenWithdrawalRejection(MemberSurplusWithdrawalRequest x) { dialogKind = "withdraw-reject"; dialogTitle = "Reject Surplus Withdrawal"; actionId = x.Id; actionReason = ""; }
    private void OpenWithdrawalPayment(MemberSurplusWithdrawalRequest x) { dialogKind = "withdraw-pay"; dialogTitle = "Confirm Surplus Withdrawal Paid"; actionId = x.Id; ResetPayment(); }
    private void ResetPayment() { actionMethod = PaymentMethod.EFT; actionReference = ""; actionDate = DateTime.Today; actionNotes = ""; actionApplyFine = false; actionWaive = false; }
    private void CloseDialog() => dialogKind = null;
    private async Task SubmitDialogAsync()
    {
        if (dialogKind == "loan-approve") await RunAsync(Service.ApproveLoanAsync(actionId, currentUserId, actionAmount, actionMonths), "Loan approved.");
        else if (dialogKind == "loan-reject") await RunAsync(Service.RejectLoanAsync(actionId, currentUserId, actionReason), "Loan rejected.");
        else if (dialogKind == "disburse") await RunAsync(Service.ConfirmDisbursementAsync(actionId, currentUserId, actionMethod, actionReference, actionDate, actionNotes), "Loan disbursed and repayment schedule generated.");
        else if (dialogKind == "repayment") await RunAsync(Service.ConfirmRepaymentAsync(actionId, currentUserId, actionAmount, actionDate, actionMethod, actionReference, actionWaive, actionApplyFine, actionNotes), "Repayment confirmed.");
        else if (dialogKind == "withdraw-reject") await RunAsync(Service.RejectWithdrawalAsync(actionId, currentUserId, actionReason), "Withdrawal rejected.");
        else if (dialogKind == "withdraw-pay") await RunAsync(Service.ConfirmWithdrawalPaidAsync(actionId, currentUserId, actionMethod, actionReference, actionDate, actionNotes), "Withdrawal payment confirmed.");
    }
    private static string Money(decimal x) => x.ToString("C2", new System.Globalization.CultureInfo("en-ZA"));
    private static string LoanStatusBadge(MemberLoanStatus s) => s switch
    {
        MemberLoanStatus.Active or MemberLoanStatus.FullyRepaid => "sisonke-badge-green",
        MemberLoanStatus.PendingApproval or MemberLoanStatus.Approved or MemberLoanStatus.DisbursementPending => "sisonke-badge-gold",
        MemberLoanStatus.Overdue or MemberLoanStatus.Rejected => "sisonke-badge-red",
        _ => "sisonke-badge-gray"
    };

    private static string RepaymentStatusBadge(LoanRepaymentStatus s) => s switch
    {
        LoanRepaymentStatus.Paid or LoanRepaymentStatus.Late => "sisonke-badge-green",
        LoanRepaymentStatus.PartiallyPaid => "sisonke-badge-gold",
        LoanRepaymentStatus.Waived => "sisonke-badge-blue",
        _ => "sisonke-badge-gray"
    };

    private static string WithdrawalStatusBadge(SurplusWithdrawalStatus s) => s switch
    {
        SurplusWithdrawalStatus.Paid => "sisonke-badge-green",
        SurplusWithdrawalStatus.PendingApproval or SurplusWithdrawalStatus.Approved or SurplusWithdrawalStatus.PaymentPending => "sisonke-badge-gold",
        SurplusWithdrawalStatus.Rejected => "sisonke-badge-red",
        _ => "sisonke-badge-gray"
    };

    private static StokvelLoanConfiguration NewConfig() => new()
    {
        LoansEnabled = false, MinLoanAmount = 0, MaxLoanAmount = 0,
        MaxRepaymentMonths = 1, DefaultRepaymentMonths = 1,
        LoanInterestType = LoanInterestType.None, LoanInterestRate = 0,
        LateRepaymentFineType = LatePenaltyType.None, LateRepaymentFineAmount = null,
        GracePeriodDays = 0, FreezePeriodAfterFullRepaymentDays = 30,
        RequireChairpersonApproval = true, RequireTreasurerDisbursementConfirmation = true
    };
    private static StokvelLoanConfiguration Clone(StokvelLoanConfiguration x) => new()
    {
        LoansEnabled = x.LoansEnabled, MinLoanAmount = x.MinLoanAmount, MaxLoanAmount = x.MaxLoanAmount,
        MaxRepaymentMonths = x.MaxRepaymentMonths, DefaultRepaymentMonths = x.DefaultRepaymentMonths,
        LoanInterestType = x.LoanInterestType, LoanInterestRate = x.LoanInterestRate,
        LateRepaymentFineType = x.LateRepaymentFineType, LateRepaymentFineAmount = x.LateRepaymentFineAmount,
        GracePeriodDays = x.GracePeriodDays, FreezePeriodAfterFullRepaymentDays = x.FreezePeriodAfterFullRepaymentDays,
        RequireChairpersonApproval = x.RequireChairpersonApproval,
        RequireTreasurerDisbursementConfirmation = x.RequireTreasurerDisbursementConfirmation
    };
