@page "/stokvel/loans-wallet/{StokvelId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services
@inject LoansWalletService Service
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Loans &amp; Wallet</PageTitle>

@if (isLoading)
{
    <div class="loading-state"><span class="spinner-border spinner-border-sm me-2"></span>Loading loans and surplus wallet…</div>
}
else if (state is null)
{
    <div class="sisonke-alert sisonke-alert-gold">Stokvel or linked membership not found.</div>
}
else if (state.Stokvel.Archetype == StokvelArchetype.BurialSociety)
{
    <div class="sisonke-card">
        <div class="sisonke-card-body">
            <div class="sisonke-alert sisonke-alert-blue mb-0">
                <strong>Loans not available.</strong> Loans and surplus wallets are not available for Burial Societies.
            </div>
        </div>
    </div>
}
else
{
    <StokvelSubNav StokvelId="@StokvelId" IsRotational="@(state.Stokvel.Archetype == StokvelArchetype.Rotational)" />

    <section class="sisonke-hero-card mb-4">
        <div>
            <span class="sisonke-badge sisonke-badge-gold">Finance</span>
            <h1>Loans &amp; Wallet</h1>
            <p>@state.Stokvel.Name</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="sisonke-btn sisonke-btn-outline" href="@($"/stokvel/{StokvelId}/loans")">
                <i class="bi bi-bank2 me-1"></i>Loans
            </a>
            <a class="sisonke-btn sisonke-btn-outline" href="@($"/stokvel/{StokvelId}/wallet")">
                <i class="bi bi-wallet2 me-1"></i>Wallet
            </a>
            <a class="sisonke-btn sisonke-btn-outline" href="@($"/stokvel-dashboard/{StokvelId}")">Back to Dashboard</a>
        </div>
    </section>

    @if (errors.Count > 0)
    {
        <div class="sisonke-alert sisonke-alert-red">
            <ul class="mb-0">
                @foreach (var e in errors) { <li>@e</li> }
            </ul>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(success))
    {
        <div class="sisonke-alert sisonke-alert-green">@success</div>
    }

    @* Summary strip *@
    <div class="loans-wallet-summary mb-4">
        <div class="sisonke-card">
            <div class="sisonke-card-body">
                <div class="detail-mini-label">Loan eligibility</div>
                <div class="fw-semibold">@state.EligibilityMessage</div>
            </div>
        </div>
        <div class="sisonke-card">
            <div class="sisonke-card-body">
                <div class="detail-mini-label">Available wallet</div>
                <div class="h4 mb-0">@Money(WalletBalance)</div>
            </div>
        </div>
        <div class="sisonke-card">
            <div class="sisonke-card-body">
                <div class="detail-mini-label">Active loan</div>
                <div class="fw-semibold">@(MyActiveLoan is null ? "None" : $"{Money(MyActiveLoan.OutstandingBalance)} outstanding")</div>
            </div>
        </div>
    </div>

    @* ── Loan Configuration ── *@
    <section class="sisonke-card mb-3">
        <div class="sisonke-card-body">
            @if (state.Configuration is null)
            {
                <h2>Loan Rules</h2>
                <div class="sisonke-alert sisonke-alert-blue mb-3">
                    Loan rules have not been configured yet for this stokvel.
                </div>
                @if (state.CanConfigure)
                {
                    <button class="sisonke-btn sisonke-btn-primary" type="button" @onclick="() => { showConfigForm = true; errors = []; success = null; }">
                        <i class="bi bi-gear-fill me-1"></i>Configure Loan Rules
                    </button>
                }
                else
                {
                    <p class="text-muted mb-0">Loan rules will appear once office bearers configure them.</p>
                }
            }
            else if (showConfigForm && state.CanConfigure)
            {
                <h2>Edit Loan Rules</h2>
                <EditForm Model="configForm" OnSubmit="OpenConfigConfirmation">
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" id="loansEnabled" @bind-Value="configForm.LoansEnabled" />
                                <label class="form-check-label fw-semibold" for="loansEnabled">Enable loans for this stokvel</label>
                            </div>
                        </div>
                        @if (configForm.LoansEnabled)
                        {
                            <div class="col-md-4">
                                <label class="form-label">Minimum Loan Amount (R)</label>
                                <InputNumber class="form-control" @bind-Value="configForm.MinLoanAmount" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Maximum Loan Amount (R)</label>
                                <InputNumber class="form-control" @bind-Value="configForm.MaxLoanAmount" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Default Repayment Months</label>
                                <InputNumber class="form-control" @bind-Value="configForm.DefaultRepaymentMonths" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Maximum Repayment Months</label>
                                <InputNumber class="form-control" @bind-Value="configForm.MaxRepaymentMonths" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Loan Interest Type</label>
                                <InputSelect class="form-select" @bind-Value="configForm.LoanInterestType">
                                    <option value="@LoanInterestType.None">None</option>
                                    <option value="@LoanInterestType.FixedAmount">Fixed Amount</option>
                                    <option value="@LoanInterestType.Percentage">Percentage</option>
                                </InputSelect>
                            </div>
                            @if (configForm.LoanInterestType != LoanInterestType.None)
                            {
                                <div class="col-md-4">
                                    <label class="form-label">@(configForm.LoanInterestType == LoanInterestType.Percentage ? "Interest Rate (%)" : "Interest Amount (R)")</label>
                                    <InputNumber class="form-control" @bind-Value="configForm.LoanInterestRate" />
                                </div>
                            }
                            <div class="col-md-4">
                                <label class="form-label">Late Repayment Fine Type</label>
                                <InputSelect class="form-select" @bind-Value="configForm.LateRepaymentFineType">
                                    <option value="@LatePenaltyType.None">None</option>
                                    <option value="@LatePenaltyType.FixedAmount">Fixed Amount</option>
                                    <option value="@LatePenaltyType.Percentage">Percentage</option>
                                </InputSelect>
                            </div>
                            @if (configForm.LateRepaymentFineType != LatePenaltyType.None)
                            {
                                <div class="col-md-4">
                                    <label class="form-label">@(configForm.LateRepaymentFineType == LatePenaltyType.Percentage ? "Late Fine Rate (%)" : "Late Fine Amount (R)")</label>
                                    <InputNumber class="form-control" @bind-Value="configForm.LateRepaymentFineAmount" />
                                </div>
                            }
                            <div class="col-md-4">
                                <label class="form-label">Grace Period (days)</label>
                                <InputNumber class="form-control" @bind-Value="configForm.GracePeriodDays" />
                                <div class="form-text">Days after due date before a late fine applies.</div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Freeze Period After Full Repayment (days)</label>
                                <InputNumber class="form-control" @bind-Value="configForm.FreezePeriodAfterFullRepaymentDays" />
                                <div class="form-text">Days before a member can request a new loan after full repayment.</div>
                            </div>
                        }
                        <div class="col-12 col-md-6">
                            <div class="form-check">
                                <InputCheckbox class="form-check-input" id="reqChairperson" @bind-Value="configForm.RequireChairpersonApproval" />
                                <label class="form-check-label" for="reqChairperson">Require Chairperson approval for loans</label>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <div class="form-check">
                                <InputCheckbox class="form-check-input" id="reqTreasurer" @bind-Value="configForm.RequireTreasurerDisbursementConfirmation" />
                                <label class="form-check-label" for="reqTreasurer">Require Treasurer disbursement confirmation</label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex gap-2 mt-3">
                        <button class="sisonke-btn sisonke-btn-primary" type="submit">
                            <i class="bi bi-check2 me-1"></i>Save Loan Rules
                        </button>
                        <button class="sisonke-btn sisonke-btn-outline" type="button" @onclick="CancelConfigEdit">Cancel</button>
                    </div>
                </EditForm>
            }
            else
            {
                @* Summary view — shown to all roles when config exists and not editing *@
                <div class="sisonke-card-head mb-3">
                    <div>
                        <span class="sisonke-badge @(state.Configuration.LoansEnabled ? "sisonke-badge-green" : "sisonke-badge-gray")">
                            Loans @(state.Configuration.LoansEnabled ? "Enabled" : "Disabled")
                        </span>
                        <h2 class="mt-2">Loan Rules</h2>
                    </div>
                    @if (state.CanConfigure)
                    {
                        <button class="sisonke-btn sisonke-btn-primary" type="button" @onclick="() => { showConfigForm = true; errors = []; success = null; }">
                            <i class="bi bi-pencil me-1"></i>Edit Loan Rules
                        </button>
                    }
                </div>
                <div class="row g-3">
                    <div class="col-6 col-md-4">
                        <div class="detail-mini-label">Loans Enabled</div>
                        <div class="detail-mini-value">@(state.Configuration.LoansEnabled ? "Yes" : "No")</div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="detail-mini-label">Minimum Loan Amount</div>
                        <div class="detail-mini-value">@Money(state.Configuration.MinLoanAmount)</div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="detail-mini-label">Maximum Loan Amount</div>
                        <div class="detail-mini-value">@Money(state.Configuration.MaxLoanAmount)</div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="detail-mini-label">Default Repayment Months</div>
                        <div class="detail-mini-value">@state.Configuration.DefaultRepaymentMonths month(s)</div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="detail-mini-label">Maximum Repayment Months</div>
                        <div class="detail-mini-value">@state.Configuration.MaxRepaymentMonths month(s)</div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="detail-mini-label">Interest Type</div>
                        <div class="detail-mini-value">@state.Configuration.LoanInterestType</div>
                    </div>
                    @if (state.Configuration.LoanInterestType != LoanInterestType.None)
                    {
                        <div class="col-6 col-md-4">
                            <div class="detail-mini-label">@(state.Configuration.LoanInterestType == LoanInterestType.Percentage ? "Interest Rate" : "Interest Amount")</div>
                            <div class="detail-mini-value">
                                @(state.Configuration.LoanInterestType == LoanInterestType.Percentage
                                    ? $"{state.Configuration.LoanInterestRate}%"
                                    : Money(state.Configuration.LoanInterestRate))
                            </div>
                        </div>
                    }
                    <div class="col-6 col-md-4">
                        <div class="detail-mini-label">Late Repayment Fine</div>
                        <div class="detail-mini-value">@state.Configuration.LateRepaymentFineType</div>
                    </div>
                    @if (state.Configuration.LateRepaymentFineType != LatePenaltyType.None)
                    {
                        <div class="col-6 col-md-4">
                            <div class="detail-mini-label">@(state.Configuration.LateRepaymentFineType == LatePenaltyType.Percentage ? "Late Fine Rate" : "Late Fine Amount")</div>
                            <div class="detail-mini-value">
                                @(state.Configuration.LateRepaymentFineType == LatePenaltyType.Percentage
                                    ? $"{state.Configuration.LateRepaymentFineAmount}%"
                                    : Money(state.Configuration.LateRepaymentFineAmount ?? 0))
                            </div>
                        </div>
                    }
                    <div class="col-6 col-md-4">
                        <div class="detail-mini-label">Grace Period</div>
                        <div class="detail-mini-value">@state.Configuration.GracePeriodDays day(s)</div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="detail-mini-label">Freeze Period After Full Repayment</div>
                        <div class="detail-mini-value">@state.Configuration.FreezePeriodAfterFullRepaymentDays day(s)</div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="detail-mini-label">Chairperson Approval Required</div>
                        <div class="detail-mini-value">@(state.Configuration.RequireChairpersonApproval ? "Yes" : "No")</div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="detail-mini-label">Treasurer Disbursement Confirmation Required</div>
                        <div class="detail-mini-value">@(state.Configuration.RequireTreasurerDisbursementConfirmation ? "Yes" : "No")</div>
                    </div>
                </div>
            }
        </div>
    </section>

    @if (CanRequestLoan)
    {
        <section class="sisonke-card mb-3">
            <div class="sisonke-card-body">
                <div class="sisonke-card-head mb-3">
                    <div>
                        <h2>Request Loan</h2>
                        <p>Your wallet balance is applied first as an early payout. Only the remaining amount becomes a loan.</p>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Amount needed</label>
                        <InputNumber class="form-control" @bind-Value="loanAmount" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Repayment months</label>
                        <InputNumber class="form-control" @bind-Value="loanMonths" disabled="@(NetLoanAmount <= 0)" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Reason</label>
                        <InputText class="form-control" @bind-Value="loanReason" />
                    </div>
                </div>
                @if (loanAmount > 0)
                {
                    <div class="loan-estimate-grid mt-3">
                        <div>
                            <div class="detail-mini-label">Wallet early payout</div>
                            <div class="detail-mini-value">@Money(WalletEarlyPayoutAmount)</div>
                        </div>
                        <div>
                            <div class="detail-mini-label">Loan amount after wallet</div>
                            <div class="detail-mini-value">@Money(NetLoanAmount)</div>
                        </div>
                        <div>
                            <div class="detail-mini-label">Estimated monthly repayment</div>
                            <div class="detail-mini-value">@Money(EstimatedMonthly)</div>
                        </div>
                    </div>
                }
                <button class="sisonke-btn sisonke-btn-primary mt-3" type="button" @onclick="RequestLoanAsync">
                    <i class="bi bi-send me-1"></i>Submit Request
                </button>
            </div>
        </section>
    }

    <section class="sisonke-card mb-3"><div class="sisonke-card-body"><h2>@(state.CanViewAll ? "Loan Requests & Active Loans" : "My Loans")</h2>
        @if (state.Loans.Count == 0) { <div class="text-muted">No loan records.</div> }
        else { <div class="table-responsive"><table class="sisonke-table mb-0"><thead><tr><th>Member</th><th>Borrowed Amount</th><th>Approved</th><th>Months</th><th>Status</th><th>Outstanding</th><th></th></tr></thead><tbody>
            @foreach (var loan in state.Loans) { <tr><td class="fw-semibold">@loan.Member.FullName</td><td><div>@Money(loan.RequestedAmount)</div>@if (!string.IsNullOrWhiteSpace(loan.Notes)) { <div class="text-muted small">@loan.Notes</div> }</td><td>@Money(loan.ApprovedAmount ?? 0)</td><td>@loan.RepaymentMonths</td><td><span class="sisonke-badge @LoanStatusBadge(loan.LoanStatus)">@loan.LoanStatus</span></td><td>@Money(loan.OutstandingBalance)</td><td class="text-end">
                @if (state.CanApprove && loan.LoanStatus == MemberLoanStatus.PendingApproval) { <button class="sisonke-btn sisonke-btn-primary sisonke-btn-sm me-1" @onclick="() => OpenLoanApproval(loan)">Approve</button><button class="sisonke-btn sisonke-btn-outline sisonke-btn-sm" style="color:var(--sk-danger)" @onclick="() => OpenLoanRejection(loan)">Reject</button> }
                @if (state.CanConfirmMoney && loan.LoanStatus == MemberLoanStatus.DisbursementPending) { <button class="sisonke-btn sisonke-btn-primary sisonke-btn-sm" @onclick="() => OpenDisbursement(loan)">Confirm Disbursement</button> }
            </td></tr> }
        </tbody></table></div> }
    </div></section>

    <section class="sisonke-card mb-3"><div class="sisonke-card-body"><h2>Loan Repayment Register</h2>
        @if (state.Repayments.Count == 0) { <div class="text-muted">No repayment schedule yet.</div> }
        else { <div class="table-responsive"><table class="sisonke-table mb-0"><thead><tr><th>Due</th><th>Expected</th><th>Paid</th><th>Fine</th><th>Status</th><th></th></tr></thead><tbody>@foreach (var repayment in state.Repayments) { var isOverdue = repayment.PaymentStatus == LoanRepaymentStatus.Pending && repayment.DueDate.Date < DateTime.Today; <tr><td>@repayment.DueDate.ToString("dd MMM yyyy")</td><td>@Money(repayment.ExpectedAmount)</td><td>@Money(repayment.PaidAmount)</td><td>@Money(repayment.FineAmount)</td><td><span class="sisonke-badge @(isOverdue ? "sisonke-badge-red" : RepaymentStatusBadge(repayment.PaymentStatus))">@(isOverdue ? "Overdue" : repayment.PaymentStatus.ToString())</span></td><td>@if (state.CanConfirmMoney && repayment.PaymentStatus is not (LoanRepaymentStatus.Paid or LoanRepaymentStatus.Waived)) { <button class="sisonke-btn sisonke-btn-primary sisonke-btn-sm" @onclick="() => OpenRepayment(repayment)">Confirm</button> }</td></tr> }</tbody></table></div> }
    </div></section>

    <section class="sisonke-card mb-3"><div class="sisonke-card-body"><h2>My Surplus Wallet</h2><div class="loan-estimate-grid"><div><div class="detail-mini-label">Available</div><div class="detail-mini-value">@Money(WalletBalance)</div></div><div><div class="detail-mini-label">Total credited</div><div class="detail-mini-value">@Money(state.Wallet?.TotalCredits ?? 0)</div></div><div><div class="detail-mini-label">Total withdrawn</div><div class="detail-mini-value">@Money(state.Wallet?.TotalWithdrawals ?? 0)</div></div></div>
        @if (WalletBalance > 0) { <div class="row g-2 mt-3"><div class="col-md-3"><label class="form-label">Amount</label><InputNumber class="form-control" @bind-Value="withdrawalAmount" /></div><div class="col-md-6"><label class="form-label">Reason</label><InputText class="form-control" @bind-Value="withdrawalReason" /></div><div class="col-md-3 d-flex align-items-end"><button class="sisonke-btn sisonke-btn-primary w-100" @onclick="RequestWithdrawalAsync">Request Withdrawal</button></div></div> }
        @if (state.Transactions.Count > 0) { <h3 class="h6 mt-3">Recent transactions</h3><div class="table-responsive"><table class="sisonke-table mb-0"><thead><tr><th>Type</th><th>Description</th><th>Amount</th><th>Balance After</th></tr></thead><tbody>@foreach (var tx in state.Transactions) { <tr><td><span class="sisonke-badge sisonke-badge-blue">@tx.TransactionType</span></td><td>@tx.Description</td><td>@Money(tx.Amount)</td><td>@Money(tx.BalanceAfterTransaction)</td></tr> }</tbody></table></div> }
    </div></section>

    <section class="sisonke-card mb-3"><div class="sisonke-card-body"><h2>@(state.CanViewAll ? "Surplus Withdrawal Requests" : "My Withdrawal Requests")</h2>
        @if (state.Withdrawals.Count == 0) { <div class="text-muted">No withdrawal requests.</div> }
        else { <div class="table-responsive"><table class="sisonke-table mb-0"><thead><tr><th>Member</th><th>Amount</th><th>Status</th><th>Reason</th><th></th></tr></thead><tbody>@foreach (var item in state.Withdrawals) { <tr><td class="fw-semibold">@item.Member.FullName</td><td>@Money(item.RequestedAmount)</td><td><span class="sisonke-badge @WithdrawalStatusBadge(item.WithdrawalStatus)">@item.WithdrawalStatus</span></td><td>@item.RequestReason</td><td>@if (state.CanApprove && item.WithdrawalStatus == SurplusWithdrawalStatus.PendingApproval) { <button class="sisonke-btn sisonke-btn-primary sisonke-btn-sm me-1" @onclick="() => ApproveWithdrawalAsync(item.Id)">Approve</button><button class="sisonke-btn sisonke-btn-outline sisonke-btn-sm" style="color:var(--sk-danger)" @onclick="() => OpenWithdrawalRejection(item)">Reject</button> } @if (state.CanConfirmMoney && item.WithdrawalStatus == SurplusWithdrawalStatus.PaymentPending) { <button class="sisonke-btn sisonke-btn-primary sisonke-btn-sm" @onclick="() => OpenWithdrawalPayment(item)">Confirm Paid</button> }</td></tr> }</tbody></table></div> }
    </div></section>
}

@* Config save confirmation modal *@
@if (showConfigConfirm)
{
    <div class="modal d-block" style="background:rgba(0,0,0,.45)" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Save Loan Rules</h5>
                </div>
                <div class="modal-body">
                    <p>You are about to save the loan configuration for this stokvel.</p>
                    <p class="mb-0 text-muted">Any existing active configuration will be replaced. Are you sure you want to continue?</p>
                </div>
                <div class="modal-footer">
                    <button class="sisonke-btn sisonke-btn-outline" @onclick="() => showConfigConfirm = false">Cancel</button>
                    <button class="sisonke-btn sisonke-btn-primary" @onclick="ExecuteSaveConfigurationAsync">
                        <i class="bi bi-check2 me-1"></i>Confirm &amp; Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* Workflow action dialogs *@
@if (dialogKind is not null)
{
    <div class="modal d-block" style="background:rgba(0,0,0,.45)" tabindex="-1"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><div class="modal-header"><h5>@dialogTitle</h5></div><div class="modal-body">
        @if (dialogKind == "loan-approve") { <label>Approved amount</label><InputNumber class="form-control mb-2" @bind-Value="actionAmount" /><label>Repayment months</label><InputNumber class="form-control" @bind-Value="actionMonths" /> }
        else if (dialogKind is "loan-reject" or "withdraw-reject") { <label>Rejection reason</label><InputTextArea class="form-control" @bind-Value="actionReason" /> }
        else if (dialogKind is "disburse" or "withdraw-pay" or "repayment")
        {
            @if (dialogKind == "repayment") { <label>Paid amount</label><InputNumber class="form-control mb-2" @bind-Value="actionAmount" /> }
            <div class="mb-2"><label>Payment method</label><InputSelect class="form-select" @bind-Value="actionMethod"><option value="@PaymentMethod.EFT">EFT</option><option value="@PaymentMethod.Cash">Cash</option><option value="@PaymentMethod.BankDeposit">Bank deposit</option><option value="@PaymentMethod.Other">Other</option></InputSelect></div>
            <div class="mb-2"><label>Reference</label><InputText class="form-control" @bind-Value="actionReference" /></div>
            <div class="mb-2"><label>Date</label><InputDate class="form-control" @bind-Value="actionDate" /></div>
            <div><label>Notes</label><InputTextArea class="form-control" @bind-Value="actionNotes" /></div>
            @if (dialogKind == "repayment") { <div class="form-check mt-2"><InputCheckbox class="form-check-input" @bind-Value="actionApplyFine" /><label class="form-check-label">Apply suggested late fine</label></div><div class="form-check"><InputCheckbox class="form-check-input" @bind-Value="actionWaive" /><label class="form-check-label">Waive repayment</label></div> }
        }
    </div><div class="modal-footer"><button class="sisonke-btn sisonke-btn-outline" @onclick="CloseDialog">Cancel</button><button class="sisonke-btn sisonke-btn-primary" @onclick="SubmitDialogAsync">Confirm</button></div></div></div></div>
}

<style>
    .loans-wallet-summary,
    .loan-estimate-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    }

    .loan-estimate-grid {
