@code {
    private Stokvel? stokvel;
    private int memberCount;
    private int activeMemberCount;
    private int activeDependentCount;
    private decimal expectedMonthlyContributions;
    private decimal outstandingFinesTotal;
    private int upcomingMeetingCount;
    private int recentMeetingCount;
    private Meeting? nextMeeting;
    private int openClaimCount;
    private int openVoteCount;
    private int closedVoteCount;
    private TenantSubscription? activeSubscription;
    private Member? linkedMember;
    private string memberLimitMessage = string.Empty;
    private string constitutionStatus = "Not Created";
    private ContributionMonthSummaryDto monthlyContributionSummary = new();
    private List<ContributionMonthlyTrendDto> contributionTrends = [];
    private decimal totalContributionOutstanding;
    private bool isLoading = true;
    private bool canManageDashboard;
    private bool canViewSecretaryTasks;
    private bool canViewChairpersonTasks;
    private bool canManageMeetings;
    private bool canReviewClaims;
    private bool canManageAttendance;
    private bool canViewTreasurerTasks;
    private bool canManagePayments;
    private bool canViewFinancials;
    private int pendingApologyCount;
    private int claimsToReviewCount;
    private int claimsAwaitingChairpersonApprovalCount;
    private int approvedClaimsAwaitingPayoutCount;
    private int attendanceToCaptureCount;
    private int openWarningCount;
    private int outstandingFineCount;
    private RotationalPayoutOrderSummary rotationOrderSummary = new(false, 0, null, null, null);
    private RotationalTaskState? rotationalTaskState;
    private int SecretaryTaskTotal => pendingApologyCount + claimsToReviewCount + attendanceToCaptureCount + openWarningCount;
    private int TreasurerTaskTotal => outstandingFineCount + approvedClaimsAwaitingPayoutCount +
        (rotationalTaskState?.ApprovedPayout is not null ? 1 : 0) +
        (rotationalTaskState?.HasContributionTask == true ? 1 : 0);
    private int ExecutiveTaskTotal => pendingApologyCount + claimsToReviewCount + claimsAwaitingChairpersonApprovalCount + attendanceToCaptureCount + openWarningCount + TreasurerTaskTotal +
        (rotationalTaskState?.PendingApprovalPayout is not null ? 1 : 0);

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        var loadStopwatch = System.Diagnostics.Stopwatch.StartNew();
        isLoading = true;
        memberCount = 0;
        activeMemberCount = 0;
        activeDependentCount = 0;
        expectedMonthlyContributions = 0;
        outstandingFinesTotal = 0;
        upcomingMeetingCount = 0;
        recentMeetingCount = 0;
        nextMeeting = null;
        openClaimCount = 0;
        openVoteCount = 0;
        closedVoteCount = 0;
        activeSubscription = null;
        linkedMember = null;
        memberLimitMessage = string.Empty;
        constitutionStatus = "Not Created";
        monthlyContributionSummary = new();
        contributionTrends = [];
        totalContributionOutstanding = 0;
        canManageDashboard = false;
        canViewSecretaryTasks = false;
        canViewChairpersonTasks = false;
        canManageMeetings = false;
        canReviewClaims = false;
        canManageAttendance = false;
        canViewTreasurerTasks = false;
        canManagePayments = false;
        canViewFinancials = false;
        pendingApologyCount = 0;
        claimsToReviewCount = 0;
        claimsAwaitingChairpersonApprovalCount = 0;
        approvedClaimsAwaitingPayoutCount = 0;
        attendanceToCaptureCount = 0;
        openWarningCount = 0;
        outstandingFineCount = 0;
        rotationOrderSummary = new(false, 0, null, null, null);
        rotationalTaskState = null;

        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);

        if (stokvel is null) { isLoading = false; LogLoadTime(loadStopwatch.ElapsedMilliseconds); return; }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            isLoading = false;
            LogLoadTime(loadStopwatch.ElapsedMilliseconds);
            return;
        }

        var access = await MemberAccessService.GetDashboardAccessAsync(userId, StokvelId);
        canManageDashboard = access.CanManageDashboard;
        linkedMember = access.LinkedMember;

        if (!canManageDashboard)
        {
            isLoading = false;
            LogLoadTime(loadStopwatch.ElapsedMilliseconds);
            return;
        }

        activeSubscription = await StokvelService.GetActiveSubscriptionByStokvelIdAsync(StokvelId);
        canViewSecretaryTasks = access.CanViewSecretaryTasks;
        canViewChairpersonTasks = access.CanViewChairpersonTasks;
        canManageMeetings = access.CanManageMeetings;
        canReviewClaims = access.CanReviewClaims;
        canManageAttendance = access.CanManageAttendance;
        canViewTreasurerTasks = access.CanViewTreasurerTasks;
        canManagePayments = access.CanManagePayments;
        canViewFinancials = access.CanViewFinancials;
        memberLimitMessage = await StokvelService.GetMemberLimitMessageAsync(StokvelId);
        constitutionStatus = await ConstitutionService.GetConstitutionStatusAsync(StokvelId);
        memberCount = await MemberService.GetMemberCountByStokvelIdAsync(StokvelId);
        activeMemberCount = await MemberService.GetActiveMemberCountByStokvelIdAsync(StokvelId);
        activeDependentCount = await MemberService.GetActiveDependentCountByStokvelIdAsync(StokvelId);
        expectedMonthlyContributions = await ContributionService.GetExpectedMonthlyContributionsByStokvelIdAsync(StokvelId);
        monthlyContributionSummary = await ContributionPaymentService.GetMonthlyContributionSummaryAsync(
            StokvelId,
            DateTime.Today.Year,
            DateTime.Today.Month);
        contributionTrends = await ContributionPaymentService.GetContributionTrendsAsync(StokvelId);
        totalContributionOutstanding = await ContributionPaymentService.GetTotalOutstandingByStokvelIdAsync(StokvelId);
        outstandingFinesTotal = await FineService.GetOutstandingFinesTotalByStokvelIdAsync(StokvelId);
        outstandingFineCount = await FineService.GetOutstandingFineCountByStokvelIdAsync(StokvelId);
        if (stokvel.EnableRotation)
        {
            rotationOrderSummary = await RotationalPayoutOrderService.GetSummaryAsync(StokvelId, linkedMember?.Id);
            rotationalTaskState = await RotationalTaskService.GetTaskStateAsync(StokvelId);
        }
        upcomingMeetingCount = await MeetingService.GetUpcomingMeetingCountByStokvelIdAsync(StokvelId);
        recentMeetingCount = await MeetingService.GetRecentMeetingCountByStokvelIdAsync(StokvelId);
        nextMeeting = await MeetingService.GetNextUpcomingMeetingAsync(StokvelId);
        pendingApologyCount = await MeetingApologyService.GetPendingApologyCountByStokvelIdAsync(StokvelId);
        openClaimCount = await FuneralClaimService.GetOpenClaimCountByStokvelIdAsync(StokvelId);
        claimsToReviewCount = await FuneralClaimService.GetClaimsRequiringSecretaryReviewCountByStokvelIdAsync(StokvelId);
        claimsAwaitingChairpersonApprovalCount = await FuneralClaimService.GetClaimsRequiringChairpersonApprovalCountByStokvelIdAsync(StokvelId);
        approvedClaimsAwaitingPayoutCount = await FuneralClaimService.GetApprovedClaimsAwaitingPayoutCountByStokvelIdAsync(StokvelId);
        attendanceToCaptureCount = await MeetingService.GetMeetingsNeedingAttendanceCountByStokvelIdAsync(StokvelId);
        openWarningCount = (await MemberWarningService.GetOpenWarningsByStokvelIdAsync(StokvelId)).Count;
        var voteMotions = await VotingService.GetVotesByStokvelIdAsync(StokvelId);
        openVoteCount = voteMotions.Count(vote => vote.Status == "Open");
        closedVoteCount = voteMotions.Count(vote => vote.Status == "Closed");
        isLoading = false;
        LogLoadTime(loadStopwatch.ElapsedMilliseconds);
    }

    private void LogLoadTime(long elapsedMilliseconds)
    {
        if (HostEnvironment.IsDevelopment())
            LoggerFactory.CreateLogger("Sisonke.Performance").LogInformation(
                "[Performance] Dashboard load for stokvel {StokvelId} completed in {ElapsedMilliseconds} ms.",
                StokvelId, elapsedMilliseconds);
    }

    private static string FormatZAR(decimal amount) =>
        amount.ToString("C0", new System.Globalization.CultureInfo("en-ZA"));

    private static string FormatPercentage(decimal percentage) =>
        $"{percentage:0.#}%";

    private static string GetMemberRangeText(SubscriptionPlan plan) =>
        plan.MaxMembers is null
            ? $"{plan.MinMembers}+ members"
            : $"{plan.MinMembers}–{plan.MaxMembers} members";

    private int GetMemberLimitProgress(int maxMembers) =>
        maxMembers <= 0 ? 0 : Math.Min(100, memberCount * 100 / maxMembers);

    private int GetCollectionRateProgress() =>
        Math.Clamp((int)Math.Round(monthlyContributionSummary.CollectionRatePercentage), 0, 100);

    private static int GetCollectionRateProgress(decimal collectionRatePercentage) =>
        Math.Clamp((int)Math.Round(collectionRatePercentage), 0, 100);

    private List<ContributionMonthlyTrendDto> GetContributionInsightTrends() =>
        contributionTrends
            .Where(trend =>
                trend.ExpectedContributions > 0 ||
                trend.ActualContributions > 0 ||
                trend.OutstandingContributions > 0 ||
                trend.PaidCount > 0 ||
                trend.PartiallyPaidCount > 0 ||
                trend.OverdueCount > 0 ||
                trend.UnpaidCount > 0)
            .ToList();

    private ContributionMonthlyTrendDto? GetBestCollectionTrend() =>
        GetContributionInsightTrends()
            .OrderByDescending(trend => trend.CollectionRatePercentage)
            .ThenByDescending(trend => trend.Year)
            .ThenByDescending(trend => trend.Month)
            .FirstOrDefault();

    private ContributionMonthlyTrendDto? GetLowestCollectionTrend() =>
        GetContributionInsightTrends()
            .OrderBy(trend => trend.CollectionRatePercentage)
            .ThenBy(trend => trend.Year)
            .ThenBy(trend => trend.Month)
            .FirstOrDefault();

    private decimal GetAverageCollectionRate()
    {
        var insightTrends = GetContributionInsightTrends();

        return insightTrends.Count == 0
            ? 0
            : insightTrends.Average(trend => trend.CollectionRatePercentage);
    }

    private static string GetConstitutionButtonText(string status) =>
        status switch
        {
            "Draft" => "Continue Constitution",
            "Uploaded" => "Review Uploaded Constitution",
            "Approved" => "View Constitution",
            _ => "Create Constitution"
        };

    private static string GetConstitutionStatusBadgeType(string status) =>
        status switch { "Draft" => "warning", "Uploaded" => "info", "Approved" => "success", _ => "secondary" };

    private static string GetResponsibilityLabel(string? role)
    {
        return role?.Trim() switch
        {
            "Chairperson" => "Final approvals",
            "Secretary" => "Administration & reviews",
            "Treasurer" => "Finance",
            "Creator" => "Full setup and administration",
            "Admin" => "Full setup and administration",
            "StokvelAdmin" => "Full setup and administration",
            _ => "Office bearer administration"
        };
    }

    private static bool IsCreatorOrAdminRole(string? role)
    {
        var normalizedRole = role?.Trim();

        return normalizedRole?.Equals("Creator", StringComparison.OrdinalIgnoreCase) == true ||
            normalizedRole?.Equals("Admin", StringComparison.OrdinalIgnoreCase) == true ||
            normalizedRole?.Equals("StokvelAdmin", StringComparison.OrdinalIgnoreCase) == true;
    }

    private static bool IsChairpersonRole(string? role)
    {
        return role?.Trim().Equals("Chairperson", StringComparison.OrdinalIgnoreCase) == true;
    }

    private static bool IsSecretaryRole(string? role)
    {
        return role?.Trim().Equals("Secretary", StringComparison.OrdinalIgnoreCase) == true;
    }

    private static bool IsTreasurerRole(string? role)
    {
        return role?.Trim().Equals("Treasurer", StringComparison.OrdinalIgnoreCase) == true;
    }

    private static bool IsConstitutionRulesManagerRole(string? role)
    {
        var normalizedRole = role?.Trim();

        return normalizedRole?.Equals("Creator", StringComparison.OrdinalIgnoreCase) == true ||
            normalizedRole?.Equals("Admin", StringComparison.OrdinalIgnoreCase) == true ||
            normalizedRole?.Equals("StokvelAdmin", StringComparison.OrdinalIgnoreCase) == true ||
            normalizedRole?.Equals("Chairperson", StringComparison.OrdinalIgnoreCase) == true ||
            normalizedRole?.Equals("Secretary", StringComparison.OrdinalIgnoreCase) == true;
    }

    private static string GetArchetypeLabel(StokvelArchetype archetype) =>
        archetype switch
        {
            StokvelArchetype.Rotational => "Rotational Stokvel",
            StokvelArchetype.Grocery => "Grocery Stokvel",
            StokvelArchetype.SavingsClub => "Savings Club",
            StokvelArchetype.InvestmentClub => "Investment Club",
            StokvelArchetype.Education => "Education Stokvel",
            StokvelArchetype.Borrowing => "Borrowing Stokvel",
            StokvelArchetype.Travel => "Travel Stokvel",
            StokvelArchetype.SocialClub => "Social Club",
            _ => archetype.ToString()
        };

    private static string GetArchetypeDescription(StokvelArchetype archetype) =>
        archetype switch
        {
            StokvelArchetype.Rotational => "Rotating lump-sum payouts to members in a defined order.",
            StokvelArchetype.Grocery => "Bulk grocery saving and distribution for members.",
            StokvelArchetype.SavingsClub => "Year-end or target savings for members.",
            StokvelArchetype.InvestmentClub => "Pooled long-term investment planning.",
            StokvelArchetype.Education => "School fees and education-related costs.",
            StokvelArchetype.Borrowing => "Member lending with interest rules.",
            StokvelArchetype.Travel => "Group travel savings.",
            StokvelArchetype.SocialClub => "Events and community activities.",
            _ => string.Empty
        };
}
