@page "/stokvel-dashboard/{StokvelId:guid}"
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject StokvelService StokvelService
@inject MemberService MemberService
@inject FineService FineService
@inject ContributionService ContributionService
@inject ConstitutionService ConstitutionService
@inject MeetingService MeetingService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccessService MemberAccessService
@inject NavigationManager NavigationManager

<PageTitle>Dashboard</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading dashboard…
    </div>
}
else if (stokvel is null)
{
    <AlertBanner Type="warning" Title="Stokvel not found." Message="" Icon="bi bi-exclamation-triangle-fill" />
    <a class="back-nav" href="/my-stokvels"><i class="bi bi-chevron-left"></i>Back to My Stokvels</a>
}
else if (!canViewFullDashboard)
{
    <div class="d-flex flex-column gap-3">
        <AlertBanner Type="warning"
                     Title="Access restricted."
                     Message="You do not have access to the management dashboard for this stokvel."
                     Icon="bi bi-exclamation-triangle-fill" />

        <div class="d-flex flex-wrap gap-2">
            @if (linkedMember is not null)
            {
                <a class="btn btn-primary" href="@($"/member-home/{linkedMember.Id}")">
                    <i class="bi bi-person-circle me-1"></i>Go to My Member View
                </a>
            }
            <a class="btn btn-outline-secondary" href="/my-memberships">
                <i class="bi bi-grid me-1"></i>Back to My Memberships
            </a>
        </div>
    </div>
}
else
{
    <!-- ── Page header ── -->
    <div class="page-header">
        <div class="page-header-text">
            <h1>@stokvel.Name</h1>
            <p class="page-subtitle d-flex align-items-center gap-2 flex-wrap">
                <StatusBadge Text="@stokvel.Type.ToString()" Type="secondary" />
                @if (stokvel.IsActive)
                {
                    <StatusBadge Text="Active" Type="success" />
                }
                else
                {
                    <StatusBadge Text="Inactive" Type="secondary" />
                }
                @if (activeSubscription is not null)
                {
                    <span class="text-muted small">· @activeSubscription.SubscriptionPlan.Name</span>
                }
            </p>
        </div>
        <a class="btn btn-outline-secondary btn-sm" href="/my-stokvels">
            <i class="bi bi-grid me-1"></i>My Stokvels
        </a>
    </div>

    @if (!stokvel.IsSetupComplete)
    {
        <!-- ── Setup incomplete banner ── -->
        <div class="setup-incomplete-banner mb-4">
            <div class="sib-icon">
                <i class="bi bi-clipboard2-check-fill"></i>
            </div>
            <div class="sib-body">
                <div class="sib-title">Complete your stokvel setup</div>
                <div class="sib-text">Finish the quick setup questionnaire so Sisonke can configure this stokvel for day-to-day management.</div>
            </div>
            <a class="btn btn-accent btn-sm" href="@($"/stokvel-questionnaire/{StokvelId}")">
                <i class="bi bi-arrow-right me-1"></i>Complete Setup
            </a>
        </div>
    }
    else
    {
        <!-- ══ KPI row ════════════════════════════════════════════ -->
        <div class="row g-3 mb-3">

            <!-- Members -->
            <div class="col-6 col-lg-3">
                <div class="card stat-card stat-members h-100">
                    <div class="card-body">
                        <div class="stat-icon-wrap">
                            <i class="bi bi-people-fill" aria-hidden="true"></i>
                        </div>
                        <div class="stat-label">Members</div>
                        <p class="stat-value">@memberCount</p>
                        @if (!string.IsNullOrWhiteSpace(memberLimitMessage))
                        {
                            <p class="stat-detail">@memberLimitMessage</p>
                        }
                        @if (activeSubscription?.SubscriptionPlan.MaxMembers is int maxM)
                        {
                            <div class="progress mt-2" role="progressbar" aria-label="Member limit" aria-valuenow="@GetMemberLimitProgress(maxM)" aria-valuemin="0" aria-valuemax="100">
                                <div class="progress-bar" style="width:@(GetMemberLimitProgress(maxM))%"></div>
                            </div>
                        }
                        <a class="btn btn-primary btn-sm mt-3" href="@($"/members/{StokvelId}")">
                            <i class="bi bi-people-fill me-1"></i>Manage Members
                        </a>
                    </div>
                </div>
            </div>

            <!-- Monthly contributions -->
            <div class="col-6 col-lg-3">
                <div class="card stat-card stat-contributions h-100">
                    <div class="card-body">
                        <div class="stat-icon-wrap">
                            <i class="bi bi-cash-coin" aria-hidden="true"></i>
                        </div>
                        <div class="stat-label">Monthly Contributions</div>
                        <p class="stat-value">@FormatZAR(expectedMonthlyContributions)</p>
                        <p class="stat-detail">Expected per cycle</p>
                        <a class="btn btn-outline-primary btn-sm mt-3" href="@($"/contribution-rules/{StokvelId}")">
                            <i class="bi bi-sliders me-1"></i>Contribution Rules
                        </a>
                    </div>
                </div>
            </div>

            <!-- Outstanding fines -->
            <div class="col-6 col-lg-3">
                <div class="card stat-card stat-fines h-100">
                    <div class="card-body">
                        <div class="stat-icon-wrap">
                            <i class="bi bi-exclamation-circle-fill" aria-hidden="true"></i>
                        </div>
                        <div class="stat-label">Outstanding Fines</div>
                        <p class="stat-value @(outstandingFinesTotal > 0 ? "text-danger" : "")">@FormatZAR(outstandingFinesTotal)</p>
                        <p class="stat-detail">Total unpaid</p>
                    </div>
                </div>
            </div>

            <!-- Constitution -->
            <div class="col-6 col-lg-3">
                <div class="card stat-card stat-constitution h-100">
                    <div class="card-body">
                        <div class="stat-icon-wrap">
                            <i class="bi bi-file-earmark-text-fill" aria-hidden="true"></i>
                        </div>
                        <div class="stat-label">Constitution</div>
                        <div class="mt-1">
                            <StatusBadge Text="@constitutionStatus" Type="@GetConstitutionStatusBadgeType(constitutionStatus)" />
                        </div>
                        <p class="stat-detail mt-1">
                            @(constitutionStatus == "Approved" ? "Document approved" : constitutionStatus == "Uploaded" ? "Uploaded for review" : constitutionStatus == "Draft" ? "Draft in progress" : "Not yet created")
                        </p>
                        <a class="btn btn-outline-primary btn-sm mt-3" href="@($"/constitution-builder/{StokvelId}")">
                            <i class="bi bi-file-earmark-text me-1"></i>@GetConstitutionButtonText(constitutionStatus)
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- ══ Main content row ═══════════════════════════════════ -->
        <div class="row g-3">

            <!-- Subscription package -->
            <div class="col-12 col-lg-6">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="dash-card-icon-sm" style="background:#FEF3C7;color:#D97706">
                                <i class="bi bi-patch-check-fill"></i>
                            </div>
                            <h2 class="h6 mb-0 fw-700">Subscription Package</h2>
                        </div>
                        @if (activeSubscription is null)
                        {
                            <p class="text-muted small mb-0">No active subscription found.</p>
                        }
                        else
                        {
                            <div class="sub-plan-display">
                                <div class="sub-plan-name">@activeSubscription.SubscriptionPlan.Name</div>
                                <StatusBadge Text="@activeSubscription.Status.ToString()" Type="success" />
                            </div>
                            <div class="row g-0 mt-3">
                                <div class="col-6">
                                    <div class="detail-mini-label">Monthly</div>
                                    <div class="detail-mini-value">@FormatZAR(activeSubscription.SubscriptionPlan.MonthlyPrice)</div>
                                </div>
                                <div class="col-6">
                                    <div class="detail-mini-label">Member Range</div>
                                    <div class="detail-mini-value">@GetMemberRangeText(activeSubscription.SubscriptionPlan)</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Constitution card -->
            <div class="col-12 col-lg-6">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="dash-card-icon-sm" style="background:var(--sk-green-50);color:var(--sk-green-700)">
                                <i class="bi bi-file-earmark-ruled-fill"></i>
                            </div>
                            <h2 class="h6 mb-0 fw-700">Constitution</h2>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="text-muted small">Status:</span>
                            <StatusBadge Text="@constitutionStatus" Type="@GetConstitutionStatusBadgeType(constitutionStatus)" />
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-primary btn-sm" href="@($"/constitution-builder/{StokvelId}")">
                                <i class="bi bi-pencil-square me-1"></i>@GetConstitutionButtonText(constitutionStatus)
                            </a>
                            <a class="btn btn-outline-secondary btn-sm" href="@($"/upload-constitution/{StokvelId}")">
                                <i class="bi bi-upload me-1"></i>Upload Existing
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Coming soon: Group Balance / Wallet -->
            <div class="col-12 col-lg-4">
                <div class="card h-100 card-coming-soon">
                    <span class="coming-soon-badge">Coming Soon</span>
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="dash-card-icon-sm" style="background:#F0FDF4;color:#10B981">
                                <i class="bi bi-wallet2"></i>
                            </div>
                            <h2 class="h6 mb-0 fw-700">Wallet &amp; Transactions</h2>
                        </div>
                        <p class="stat-value-lg">R 0.00</p>
                        <p class="stat-detail">Group balance</p>
                        <div class="mt-3">
                            <div class="cs-row"><span>Last deposit</span><span>—</span></div>
                            <div class="cs-row"><span>Last payout</span><span>—</span></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Meetings -->
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="dash-card-icon-sm" style="background:var(--sk-purple-light);color:var(--sk-purple)">
                                <i class="bi bi-calendar-event-fill"></i>
                            </div>
                            <h2 class="h6 mb-0 fw-700">Meetings &amp; Agenda</h2>
                        </div>
                        <p class="stat-value">@upcomingMeetingCount</p>
                        <p class="stat-detail">Upcoming meetings</p>
                        <p class="text-muted small mt-3 mb-0">Manage meetings, set agendas, vote on items and log all decisions in one place.</p>
                        <a class="btn btn-purple btn-sm mt-3" href="@($"/meetings/{StokvelId}")">
                            <i class="bi bi-calendar-event me-1"></i>Open Meetings
                        </a>
                    </div>
                </div>
            </div>

            <!-- Voting (inside meetings) -->
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100" style="background:linear-gradient(135deg,#f6f4ff,var(--sk-purple-light));border-color:rgba(124,111,224,.2);">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="dash-card-icon-sm" style="background:white;color:var(--sk-purple)">
                                <i class="bi bi-check2-square"></i>
                            </div>
                            <h2 class="h6 mb-0 fw-700">Voting &amp; Decisions</h2>
                            <span class="ms-auto" style="font-size:.68rem;font-weight:700;color:var(--sk-purple);background:white;padding:3px 10px;border-radius:20px;letter-spacing:.03em;white-space:nowrap;">Inside Meetings</span>
                        </div>
                        @if (openVoteCount > 0)
                        {
                            <p class="stat-value mb-1">@openVoteCount</p>
                            <p class="stat-detail">Open polls</p>
                        }
                        <p class="text-muted small mb-0 @(openVoteCount > 0 ? "mt-2" : "")" style="line-height:1.65;">
                            Votes and decisions are managed inside each meeting agenda.
                        </p>
                        <a class="btn btn-purple btn-sm mt-3" href="@($"/meetings/{StokvelId}")">
                            <i class="bi bi-check2-square me-1"></i>Open Meetings
                        </a>
                    </div>
                </div>
            </div>

        </div>
    }
}

<style>
    .setup-incomplete-banner {
        background: linear-gradient(135deg, var(--sk-green-800), var(--sk-green-700));
        border-radius: var(--sk-radius);
        padding: 1.5rem 1.75rem;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
        color: #fff;
        box-shadow: var(--sk-shadow);
    }
    .sib-icon { font-size: 2rem; opacity: .85; flex-shrink: 0; }
    .sib-body { flex: 1; min-width: 0; }
    .sib-title { font-size: 1rem; font-weight: 700; margin-bottom: .25rem; }
    .sib-text  { font-size: .875rem; opacity: .8; margin: 0; }

    .dash-card-icon-sm {
        width: 2rem;
        height: 2rem;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .875rem;
        flex-shrink: 0;
    }

    .sub-plan-display {
        display: flex;
        align-items: center;
        gap: .75rem;
    }
    .sub-plan-name {
        font-size: 1.125rem;
        font-weight: 700;
        color: var(--sk-text);
    }
    .detail-mini-label {
        font-size: .6875rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--sk-text-muted);
        font-weight: 600;
        margin-bottom: .15rem;
    }
    .detail-mini-value {
        font-size: .9375rem;
        font-weight: 600;
        color: var(--sk-text);
    }
    .stat-value-lg {
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: -.02em;
        color: var(--sk-text);
        margin: 0;
    }
    .cs-row {
        display: flex;
        justify-content: space-between;
        font-size: .8125rem;
        color: var(--sk-text-muted);
        padding: .25rem 0;
        border-top: 1px solid var(--sk-border);
    }
</style>

@code {
    private Stokvel? stokvel;
    private int memberCount;
    private decimal expectedMonthlyContributions;
    private decimal outstandingFinesTotal;
    private int upcomingMeetingCount;
    private int openVoteCount;
    private TenantSubscription? activeSubscription;
    private Member? linkedMember;
    private string memberLimitMessage = string.Empty;
    private string constitutionStatus = "Not Created";
    private bool isLoading = true;
    private bool canViewFullDashboard;

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        memberCount = 0;
        expectedMonthlyContributions = 0;
        outstandingFinesTotal = 0;
        upcomingMeetingCount = 0;
        openVoteCount = 0;
        activeSubscription = null;
        linkedMember = null;
        memberLimitMessage = string.Empty;
        constitutionStatus = "Not Created";
        canViewFullDashboard = false;

        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);

        if (stokvel is null) { isLoading = false; return; }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            isLoading = false;
            return;
        }

        canViewFullDashboard = await MemberAccessService.CanViewFullDashboardAsync(userId, StokvelId);

        if (!canViewFullDashboard)
        {
            linkedMember = await MemberAccessService.GetLinkedMemberForUserAsync(userId, StokvelId);
            isLoading = false;
            return;
        }

        activeSubscription = await StokvelService.GetActiveSubscriptionByStokvelIdAsync(StokvelId);
        memberLimitMessage = await StokvelService.GetMemberLimitMessageAsync(StokvelId);
        constitutionStatus = await ConstitutionService.GetConstitutionStatusAsync(StokvelId);
        memberCount = await MemberService.GetMemberCountByStokvelIdAsync(StokvelId);
        expectedMonthlyContributions = await ContributionService.GetExpectedMonthlyContributionsByStokvelIdAsync(StokvelId);
        outstandingFinesTotal = await FineService.GetOutstandingFinesTotalByStokvelIdAsync(StokvelId);
        upcomingMeetingCount = await MeetingService.GetUpcomingMeetingCountByStokvelIdAsync(StokvelId);
        openVoteCount = 0;
        isLoading = false;
    }

    private static string FormatZAR(decimal amount) =>
        amount.ToString("C0", new System.Globalization.CultureInfo("en-ZA"));

    private static string GetMemberRangeText(SubscriptionPlan plan) =>
        plan.MaxMembers is null
            ? $"{plan.MinMembers}+ members"
            : $"{plan.MinMembers}–{plan.MaxMembers} members";

    private int GetMemberLimitProgress(int maxMembers) =>
        maxMembers <= 0 ? 0 : Math.Min(100, memberCount * 100 / maxMembers);

    private static string GetConstitutionButtonText(string status) =>
        status switch
        {
            "Draft" => "Continue Constitution",
            "Uploaded" => "Review Uploaded Constitution",
            "Approved" => "View Constitution",
            _ => "Create Constitution"
        };

    private static string GetConstitutionStatusBadgeType(string status) =>
        status switch { "Draft" => "warning", "Uploaded" => "info", "Approved" => "success", _ => "secondary" };
}
