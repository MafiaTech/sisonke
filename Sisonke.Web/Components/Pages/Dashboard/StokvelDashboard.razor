@page "/stokvel-dashboard/{StokvelId:guid}"
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services
@using Sisonke.Web.Services.Dto

@inject StokvelService StokvelService
@inject MemberService MemberService
@inject FineService FineService
@inject ContributionService ContributionService
@inject ContributionPaymentService ContributionPaymentService
@inject ConstitutionService ConstitutionService
@inject MeetingService MeetingService
@inject MeetingApologyService MeetingApologyService
@inject MemberWarningService MemberWarningService
@inject FuneralClaimService FuneralClaimService
@inject VotingService VotingService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccessService MemberAccessService
@inject RotationalPayoutOrderService RotationalPayoutOrderService
@inject RotationalTaskService RotationalTaskService
@inject NavigationManager NavigationManager
@inject IWebHostEnvironment HostEnvironment
@inject ILoggerFactory LoggerFactory

<PageTitle>Dashboard</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading dashboard…
    </div>
}
else if (stokvel is null)
{
    <AlertBanner Type="warning" Title="Stokvel not found." Message="" Icon="bi bi-exclamation-triangle-fill" />
    <a class="back-nav" href="/my-workspace"><i class="bi bi-chevron-left"></i>Back to My Workspace</a>
}
else if (!canManageDashboard && linkedMember is not null)
{
    <div class="d-flex flex-column gap-3">
        <AlertBanner Type="warning"
                     Title="Access restricted."
                     Message="You do not have access to the management dashboard for this stokvel."
                     Icon="bi bi-exclamation-triangle-fill" />

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" href="@($"/member-home/{linkedMember.Id}")">
                <i class="bi bi-person-circle me-1"></i>Go to My Member View
            </a>
            <a class="btn btn-outline-secondary" href="/my-workspace">
                <i class="bi bi-columns-gap me-1"></i>Back to My Workspace
            </a>
        </div>
    </div>
}
else if (!canManageDashboard)
{
    <div class="d-flex flex-column gap-3">
        <AlertBanner Type="warning"
                     Title="Access restricted."
                     Message="You do not have access to this stokvel."
                     Icon="bi bi-exclamation-triangle-fill" />

        <div>
            <a class="btn btn-outline-secondary" href="/my-workspace">
                <i class="bi bi-columns-gap me-1"></i>Back to My Workspace
            </a>
        </div>
    </div>
}
else
{
    <!-- ── Page header ── -->
    <div class="page-header">
        <div class="page-header-text">
            <h1>Executive Workspace</h1>
            <p class="page-subtitle d-flex align-items-center gap-2 flex-wrap">
                <span class="fw-semibold">@stokvel.Name</span>
                <StatusBadge Text="@stokvel.Type.ToString()" Type="secondary" />
                @if (stokvel.IsActive)
                {
                    <StatusBadge Text="Active" Type="success" />
                }
                else
                {
                    <StatusBadge Text="Inactive" Type="secondary" />
                }
                @if (activeSubscription is not null)
                {
                    <span class="text-muted small">· @activeSubscription.SubscriptionPlan.Name</span>
                }
            </p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            @if (canManageDashboard)
            {
                <a class="btn btn-outline-secondary btn-sm" href="@($"/stokvel-settings/{StokvelId}")">
                    <i class="bi bi-gear me-1"></i>Settings
                </a>
            }
            <a class="btn btn-outline-secondary btn-sm" href="/my-stokvels">
                <i class="bi bi-grid me-1"></i>My Stokvels
            </a>
        </div>
    </div>

    <!-- ── Archetype awareness banner ── -->
    @if (stokvel.Archetype != StokvelArchetype.BurialSociety)
    {
        <div class="sisonke-alert sisonke-alert-blue mb-3 d-flex align-items-center gap-3 flex-wrap">
            <div>
                <span class="sisonke-badge sisonke-badge-blue me-2">@GetArchetypeLabel(stokvel.Archetype)</span>
                <span>@GetArchetypeDescription(stokvel.Archetype)</span>
            </div>
            @if (stokvel.EnableRotation)
            {
                <a class="sisonke-btn sisonke-btn-primary ms-auto" href="@($"/rotational/management/{StokvelId}")">
                    <i class="bi bi-arrow-repeat me-1"></i>Rotation Management
                </a>
            }
            @if (stokvel.Archetype != StokvelArchetype.BurialSociety)
            {
                <a class="sisonke-btn sisonke-btn-outline" href="@($"/stokvel/loans-wallet/{StokvelId}")">
                    <i class="bi bi-wallet2 me-1"></i>Loans &amp; Wallet
                </a>
            }
        </div>
    }

    @if (linkedMember is not null)
    {
        <section class="card border-0 shadow-sm mb-3">
            <div class="card-body p-4">
                <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-center">
                    <div>
                        <div class="detail-mini-label">Logged-in Office Bearer</div>
                        <div class="sub-plan-name">@linkedMember.FullName</div>
                    </div>
                    <div>
                        <div class="detail-mini-label">Role</div>
                        <div class="detail-mini-value">@linkedMember.DefaultRole</div>
                    </div>
                    <div>
                        <div class="detail-mini-label">Responsibility</div>
                        <div class="detail-mini-value">@GetResponsibilityLabel(linkedMember.DefaultRole.ToString())</div>
                    </div>
                </div>
            </div>
        </section>
    }

    @if (stokvel.EnableRotation)
    {
        <section class="sisonke-card mb-4">
            <div class="sisonke-card-body">
                <div class="sisonke-card-head mb-3">
                    <div>
                        <span class="sisonke-badge @(rotationOrderSummary.IsConfigured ? "sisonke-badge-green" : "sisonke-badge-gold")">
                            @(rotationOrderSummary.IsConfigured ? "Configured" : "Not configured")
                        </span>
                        <h2 class="mt-2">Rotation Order</h2>
                    </div>
                    <a class="sisonke-btn sisonke-btn-primary" href="@($"/rotational/management/{StokvelId}")">
                        <i class="bi bi-arrow-repeat me-2"></i>Rotation Management
                    </a>
                </div>
                <div class="row g-3">
                    <div class="col-6 col-md-4">
                        <div class="detail-mini-label">Members in Order</div>
                        <div class="detail-mini-value">@rotationOrderSummary.MemberCount</div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="detail-mini-label">Next Payout Member</div>
                        <div class="detail-mini-value">@(rotationOrderSummary.NextPayoutMemberName ?? "Not set")</div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="detail-mini-label">Status</div>
                        <div class="detail-mini-value">@(rotationOrderSummary.IsConfigured ? "Active order ready" : "Setup required")</div>
                    </div>
                </div>
            </div>
        </section>
    }

    @if (linkedMember is not null)
    {
        @if (IsCreatorOrAdminRole(linkedMember.DefaultRole.ToString()))
        {
            <section class="executive-task-panel mb-4">
                <div class="executive-task-panel-header">
                    <div>
                        <h2>Executive Task Overview</h2>
                        <p>Combined workflow overview for this stokvel.</p>
                    </div>
                    <span class="sisonke-badge sisonke-badge-blue">@ExecutiveTaskTotal pending</span>
                </div>
                <div class="sisonke-card-body">
                    @if (ExecutiveTaskTotal == 0)
                    {
                        <div class="sisonke-alert sisonke-alert-green mb-3">
                            No pending workflow tasks. Everything is up to date.
                        </div>
                    }
                    <div class="executive-task-grid">
                        <div class="executive-task-card task-accent-blue">
                            <div class="detail-mini-label">Pending Apologies</div>
                            <div class="executive-task-count">@pendingApologyCount</div>
                            <p class="text-muted small mb-3">Submitted meeting apologies awaiting attendance review.</p>
                            <a class="sisonke-btn sisonke-btn-outline executive-task-action" href="@($"/secretary-tasks/{StokvelId}")">Review Apologies</a>
                        </div>
                        @if (stokvel.EnableClaims)
                        {
                            <div class="executive-task-card task-accent-gold">
                                <div class="detail-mini-label">Claims to Review</div>
                                <div class="executive-task-count">@claimsToReviewCount</div>
                                <p class="text-muted small mb-3">Claims still needing secretary review.</p>
                                <a class="sisonke-btn sisonke-btn-outline executive-task-action" href="@($"/secretary-tasks/{StokvelId}")">Review Claims</a>
                            </div>
                            <div class="executive-task-card task-accent-green">
                                <div class="detail-mini-label">Claims Awaiting Approval</div>
                                <div class="executive-task-count">@claimsAwaitingChairpersonApprovalCount</div>
                                <p class="text-muted small mb-3">Secretary-reviewed claims ready for final decision.</p>
                                <a class="sisonke-btn sisonke-btn-gold executive-task-action" href="@($"/chairperson-tasks/{StokvelId}")">View Approval Tasks</a>
                            </div>
                        }
                        @if (stokvel.EnableRotation)
                        {
                            <div class="executive-task-card task-accent-blue">
                                <div class="detail-mini-label">Rotation Management</div>
                                @if (rotationalTaskState?.RotationalPendingCount > 0)
                                {
                                    <div class="executive-task-count text-warning">@rotationalTaskState.RotationalPendingCount action@(rotationalTaskState.RotationalPendingCount == 1 ? "" : "s")</div>
                                    <p class="text-muted small mb-3">
                                        @(rotationalTaskState.PendingApprovalPayout is not null ? "Payout awaiting Chairperson approval. " : "")
                                        @(rotationalTaskState.ApprovedPayout is not null ? "Payout awaiting Treasurer confirmation. " : "")
                                        @(rotationalTaskState.HasContributionTask ? $"{rotationalTaskState.UnpaidContributionCount} unpaid contribution(s)." : "")
                                    </p>
                                }
                                else
                                {
                                    <div class="executive-task-count text-muted">@(rotationOrderSummary.IsConfigured ? "Ready" : "Open")</div>
                                    <p class="text-muted small mb-3">Manage payout order, rotation schedule, configuration and member turns in one place.</p>
                                }
                                <a class="sisonke-btn sisonke-btn-primary executive-task-action" href="@($"/rotational/management/{StokvelId}")">Open</a>
                            </div>
                            <div class="executive-task-card task-accent-green">
                                <div class="detail-mini-label">Rotational Configuration</div>
                                <div class="executive-task-count text-muted">Setup</div>
                                <p class="text-muted small mb-3">Define contribution rules, payout amount, rotation order and late payment penalties.</p>
                                <a class="sisonke-btn sisonke-btn-primary executive-task-action" href="@($"/rotational-configuration/{StokvelId}")">Configure</a>
                            </div>
                        }
                        <div class="executive-task-card task-accent-red">
                            <div class="detail-mini-label">Finance Follow-up</div>
                            <div class="executive-task-count">@TreasurerTaskTotal</div>
                            <p class="text-muted small mb-3">Outstanding fines and approved claims awaiting payout.</p>
                            <a class="sisonke-btn sisonke-btn-outline executive-task-action" href="@($"/treasurer-tasks/{StokvelId}")">View Finance Tasks</a>
                        </div>
                        <div class="executive-task-card task-accent-purple">
                            <div class="detail-mini-label">Attendance to Capture</div>
                            <div class="executive-task-count">@attendanceToCaptureCount</div>
                            <p class="text-muted small mb-3">Recent meetings where attendance appears uncaptured.</p>
                            <a class="sisonke-btn sisonke-btn-outline executive-task-action" href="@($"/meetings/{StokvelId}")">Capture Attendance</a>
                        </div>
                        <div class="executive-task-card task-accent-gold">
                            <div class="detail-mini-label">Attendance Warnings</div>
                            <div class="executive-task-count">@openWarningCount</div>
                            <p class="text-muted small mb-3">Open absence warnings requiring office bearer review.</p>
                            <a class="sisonke-btn sisonke-btn-gold executive-task-action" href="@($"/member-warnings/{StokvelId}")">Review Warnings</a>
                        </div>
                        <div class="executive-task-card task-accent-muted">
                            <div class="detail-mini-label">Minutes to Complete</div>
                            <div class="executive-task-count text-muted">Soon</div>
                            <p class="text-muted small mb-3">Minutes completion status is not captured yet.</p>
                            <button class="sisonke-btn sisonke-btn-outline executive-task-action" type="button" disabled>Coming Soon</button>
                        </div>
                        <div class="executive-task-card task-accent-green">
                            <div class="detail-mini-label">Setup / Configuration</div>
                            <div class="executive-task-count">@(stokvel.IsSetupComplete ? "Done" : "Open")</div>
                            <p class="text-muted small mb-3">Quick setup and configuration status.</p>
                            @if (!stokvel.IsSetupComplete)
                            {
                                <a class="sisonke-btn sisonke-btn-primary executive-task-action" href="@($"/stokvel-questionnaire/{StokvelId}")">Complete Setup</a>
                            }
                            else
                            {
                                <button class="sisonke-btn sisonke-btn-outline executive-task-action" type="button" disabled>Setup Complete</button>
                            }
                        </div>
                    </div>
                </div>
            </section>
        }
        else if (canViewChairpersonTasks && IsChairpersonRole(linkedMember.DefaultRole.ToString()))
        {
            <section class="executive-task-panel mb-4">
                <div class="executive-task-panel-header">
                    <div>
                        <h2>Chairperson Approval Tasks</h2>
                        <p>Final decisions and approvals requiring attention.</p>
                    </div>
                    <a class="sisonke-btn sisonke-btn-primary" href="@($"/chairperson-tasks/{StokvelId}")">View Approval Tasks</a>
                </div>
                <div class="sisonke-card-body">
                    @if (claimsAwaitingChairpersonApprovalCount == 0)
                    {
                        <div class="sisonke-alert sisonke-alert-green mb-3">
                            No claims are currently awaiting chairperson approval.
                        </div>
                    }
                    <div class="executive-task-grid">
                        @if (stokvel.EnableClaims)
                        {
                            <div class="executive-task-card task-accent-green">
                                <div class="detail-mini-label">Claims Awaiting Approval</div>
                                <div class="executive-task-count">@claimsAwaitingChairpersonApprovalCount</div>
                                <p class="text-muted small mb-3">Secretary-reviewed claims ready for final decision.</p>
                                <a class="sisonke-btn sisonke-btn-gold executive-task-action" href="@($"/chairperson-tasks/{StokvelId}")">View Approval Tasks</a>
                            </div>
                        }
                        @if (stokvel.EnableRotation && rotationalTaskState?.PendingApprovalPayout is not null)
                        {
                            var approvalPayout = rotationalTaskState.PendingApprovalPayout;
                            <div class="executive-task-card task-accent-green" style="border-top:3px solid var(--sk-green-700)">
                                <div class="detail-mini-label">
                                    <span class="sisonke-badge sisonke-badge-green me-1">Rotational</span>
                                    Payout Approval Required
                                </div>
                                <div class="executive-task-count text-success">1</div>
                                <p class="text-muted small mb-3">
                                    @approvalPayout.Cycle.CycleName — @approvalPayout.PayoutMember.FullName is waiting for your approval.
                                    Payout: @FormatZAR(approvalPayout.PayoutAmount).
                                </p>
                                <a class="sisonke-btn sisonke-btn-gold executive-task-action" href="@($"/rotational/management/{StokvelId}")">
                                    <i class="bi bi-check2-circle me-1"></i>Review Payout
                                </a>
                            </div>
                        }
                        <div class="executive-task-card task-accent-gold">
                            <div class="detail-mini-label">Constitution Approval</div>
                            <div class="executive-task-count text-muted">Soon</div>
                            <p class="text-muted small mb-3">Constitution approval workflow will appear here.</p>
                            <button class="sisonke-btn sisonke-btn-outline executive-task-action" type="button" disabled>Coming Soon</button>
                        </div>
                        <div class="executive-task-card task-accent-red">
                            <div class="detail-mini-label">Attendance Warnings</div>
                            <div class="executive-task-count">@openWarningCount</div>
                            <p class="text-muted small mb-3">Open absence warnings that may require executive committee review.</p>
                            <a class="sisonke-btn sisonke-btn-gold executive-task-action" href="@($"/member-warnings/{StokvelId}")">Review Warnings</a>
                        </div>
                        <div class="executive-task-card task-accent-purple">
                            <div class="detail-mini-label">Meeting Decisions</div>
                            <div class="executive-task-count text-muted">Soon</div>
                            <p class="text-muted small mb-3">Meeting decision approvals will appear here.</p>
                            <button class="sisonke-btn sisonke-btn-outline executive-task-action" type="button" disabled>Coming Soon</button>
                        </div>
                    </div>
                </div>
            </section>
        }
        else if (canViewSecretaryTasks && IsSecretaryRole(linkedMember.DefaultRole.ToString()))
        {
            <section class="executive-task-panel mb-4">
                <div class="executive-task-panel-header">
                    <div>
                        <h2>Secretary Task List</h2>
                        <p>Workflow items requiring administration or review.</p>
                    </div>
                    <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                        <span class="sisonke-badge sisonke-badge-blue">@SecretaryTaskTotal pending</span>
                        <a class="sisonke-btn sisonke-btn-primary" href="@($"/secretary-tasks/{StokvelId}")">View All Tasks</a>
                    </div>
                </div>
                <div class="sisonke-card-body">
                    @if (SecretaryTaskTotal == 0)
                    {
                        <div class="sisonke-alert sisonke-alert-green mb-3">
                            No pending secretary tasks. Everything is up to date.
                        </div>
                    }
                    <div class="executive-task-grid">
                        <div class="executive-task-card task-accent-blue">
                            <div class="detail-mini-label">Pending Apologies</div>
                            <div class="executive-task-count">@pendingApologyCount</div>
                            <p class="text-muted small mb-3">Submitted meeting apologies awaiting attendance review.</p>
                            <a class="sisonke-btn sisonke-btn-outline executive-task-action" href="@($"/secretary-tasks/{StokvelId}")">Review Apologies</a>
                        </div>
                        @if (stokvel.EnableClaims)
                        {
                            <div class="executive-task-card task-accent-gold">
                                <div class="detail-mini-label">Claims to Review</div>
                                <div class="executive-task-count">@claimsToReviewCount</div>
                                <p class="text-muted small mb-3">Submitted or on-hold claims still needing secretary review.</p>
                                <a class="sisonke-btn sisonke-btn-outline executive-task-action" href="@($"/secretary-tasks/{StokvelId}")">Review Claims</a>
                            </div>
                        }
                        <div class="executive-task-card task-accent-purple">
                            <div class="detail-mini-label">Attendance to Capture</div>
                            <div class="executive-task-count">@attendanceToCaptureCount</div>
                            <p class="text-muted small mb-3">Recent meetings where attendance appears uncaptured.</p>
                            <a class="sisonke-btn sisonke-btn-gold executive-task-action" href="@($"/meetings/{StokvelId}")">Capture Attendance</a>
                        </div>
                        <div class="executive-task-card task-accent-gold">
                            <div class="detail-mini-label">Attendance Warnings</div>
                            <div class="executive-task-count">@openWarningCount</div>
                            <p class="text-muted small mb-3">Open absence warnings requiring review.</p>
                            <a class="sisonke-btn sisonke-btn-gold executive-task-action" href="@($"/member-warnings/{StokvelId}")">Review Warnings</a>
                        </div>
                        <div class="executive-task-card task-accent-muted">
                            <div class="detail-mini-label">Minutes to Complete</div>
                            <div class="executive-task-count text-muted">Soon</div>
                            <p class="text-muted small mb-3">Minutes completion status is not captured yet.</p>
                            <button class="sisonke-btn sisonke-btn-outline executive-task-action" type="button" disabled>Coming Soon</button>
                        </div>
                    </div>
                </div>
            </section>
        }
        else if (canViewTreasurerTasks && IsTreasurerRole(linkedMember.DefaultRole.ToString()))
        {
            <section class="executive-task-panel mb-4">
                <div class="executive-task-panel-header">
                    <div>
                        <h2>Treasurer Task List</h2>
                        <p>Financial items requiring capture, confirmation or follow-up.</p>
                    </div>
                    <a class="sisonke-btn sisonke-btn-primary" href="@($"/treasurer-tasks/{StokvelId}")">View Finance Tasks</a>
                </div>
                <div class="sisonke-card-body">
                    <div class="executive-task-grid">
                        <div class="executive-task-card task-accent-red">
                            <div class="detail-mini-label">Outstanding Fines</div>
                            <div class="executive-task-count">@FormatZAR(outstandingFinesTotal)</div>
                            <p class="text-muted small mb-3">@outstandingFineCount unpaid fine(s) currently recorded.</p>
                            <a class="sisonke-btn sisonke-btn-outline executive-task-action" href="@($"/treasurer-tasks/{StokvelId}")">View Fines</a>
                        </div>
                        <div class="executive-task-card task-accent-green">
                            <div class="detail-mini-label">Contributions to Capture</div>
                            <div class="executive-task-count">@(monthlyContributionSummary.UnpaidCount + monthlyContributionSummary.OverdueCount + monthlyContributionSummary.PartiallyPaidCount)</div>
                            @if (monthlyContributionSummary.RecordsGenerated == 0)
                            {
                                <p class="text-muted small mb-3">Generate monthly records to begin capture.</p>
                            }
                            else
                            {
                                <p class="text-muted small mb-3">@monthlyContributionSummary.PaidCount of @monthlyContributionSummary.RecordsGenerated paid · @FormatZAR(monthlyContributionSummary.ActualContributions) collected.</p>
                            }
                            <a class="sisonke-btn sisonke-btn-outline executive-task-action" href="@($"/contribution-capture/{StokvelId}")">Capture Contributions</a>
                        </div>
                        @if (stokvel.EnableClaims)
                        {
                            <div class="executive-task-card task-accent-gold">
                                <div class="detail-mini-label">Approved Claims Awaiting Payout</div>
                                <div class="executive-task-count">@approvedClaimsAwaitingPayoutCount</div>
                                <p class="text-muted small mb-3">Approved claims needing finance follow-up.</p>
                                <a class="sisonke-btn sisonke-btn-gold executive-task-action" href="@($"/treasurer-tasks/{StokvelId}")">Open Claims</a>
                            </div>
                        }
                        @if (stokvel.EnableRotation && rotationalTaskState?.ApprovedPayout is not null)
                        {
                            var approvedPayout = rotationalTaskState.ApprovedPayout;
                            <div class="executive-task-card task-accent-green" style="border-top:3px solid var(--sk-green-700)">
                                <div class="detail-mini-label">
                                    <span class="sisonke-badge sisonke-badge-blue me-1">Rotational</span>
                                    Confirm Payout Payment
                                </div>
                                <div class="executive-task-count text-success">1</div>
                                <p class="text-muted small mb-3">
                                    @approvedPayout.Cycle.CycleName — Approved payout of @FormatZAR(approvedPayout.PayoutAmount) to @approvedPayout.PayoutMember.FullName.
                                </p>
                                <a class="sisonke-btn sisonke-btn-primary executive-task-action" href="@($"/rotational/management/{StokvelId}")">
                                    <i class="bi bi-cash-coin me-1"></i>Confirm Payment
                                </a>
                            </div>
                        }
                        @if (stokvel.EnableRotation && rotationalTaskState?.HasContributionTask == true)
                        {
                            var ts = rotationalTaskState;
                            <div class="executive-task-card task-accent-gold" style="border-top:3px solid #d97706">
                                <div class="detail-mini-label">
                                    <span class="sisonke-badge sisonke-badge-gold me-1">Rotational</span>
                                    Confirm Contribution Payments
                                </div>
                                <div class="executive-task-count">@ts.UnpaidContributionCount</div>
                                <p class="text-muted small mb-3">
                                    @ts.CurrentCycle!.CycleName — @ts.UnpaidContributionCount of @ts.TotalContributionCount members still outstanding.
                                    @FormatZAR(ts.OutstandingContributionAmount) to collect.
                                </p>
                                <a class="sisonke-btn sisonke-btn-gold executive-task-action" href="@($"/rotational/management/{StokvelId}")">
                                    <i class="bi bi-list-check me-1"></i>Open Contributions
                                </a>
                            </div>
                        }
                        <div class="executive-task-card task-accent-blue">
                            <div class="detail-mini-label">Financial Reports</div>
                            <div class="executive-task-count">@FormatPercentage(monthlyContributionSummary.CollectionRatePercentage)</div>
                            <p class="text-muted small mb-3">Monthly contribution, arrears and payment overview.</p>
                            <a class="sisonke-btn sisonke-btn-outline executive-task-action" href="@($"/finance-summary/{StokvelId}")">Finance Summary</a>
                        </div>
                    </div>
                </div>
            </section>
        }
    }

    @if (!stokvel.IsSetupComplete)
    {
        <!-- ── Setup incomplete banner ── -->
        <div class="setup-incomplete-banner mb-4">
            <div class="sib-icon">
                <i class="bi bi-clipboard2-check-fill"></i>
            </div>
            <div class="sib-body">
                <div class="sib-title">Complete your stokvel setup</div>
                <div class="sib-text">Finish the quick setup questionnaire so Sisonke can configure this stokvel for day-to-day management.</div>
            </div>
            <a class="btn btn-accent btn-sm" href="@($"/stokvel-questionnaire/{StokvelId}")">
                <i class="bi bi-arrow-right me-1"></i>Complete Setup
            </a>
        </div>
    }
    else
    {
        @if (stokvel.Archetype == StokvelArchetype.BurialSociety)
        {
            <section class="sisonke-card mb-3 burial-readiness-panel">
                <div class="sisonke-card-body">
                    <div class="sisonke-card-head">
                        <div>
                            <span class="sisonke-badge sisonke-badge-green">Burial Society Readiness</span>
                            <h2 class="mt-2">Funeral support overview</h2>
                            <p>Manage funeral support, dependents, claims and member contributions.</p>
                        </div>
                        <a class="sisonke-btn sisonke-btn-primary" href="@($"/members/{StokvelId}")">
                            <i class="bi bi-people-fill me-1"></i>Open Members
                        </a>
                    </div>

                    <div class="sisonke-alert sisonke-alert-blue mb-3">
                        New members may be subject to the society waiting period before claims are payable.
                    </div>

                    <div class="burial-readiness-grid">
                        <div class="burial-readiness-card">
                            <div class="detail-mini-label">Total Members</div>
                            <div class="burial-readiness-value">@memberCount</div>
                            <div class="text-muted small">All member records captured in this society.</div>
                        </div>
                        <div class="burial-readiness-card">
                            <div class="detail-mini-label">Active Members</div>
                            <div class="burial-readiness-value">@activeMemberCount</div>
                            <div class="text-muted small">Members in good standing for society workflow.</div>
                        </div>
                        <div class="burial-readiness-card">
                            <div class="detail-mini-label">Covered Lives / Dependents</div>
                            <div class="burial-readiness-value">@activeDependentCount</div>
                            @if (activeDependentCount == 0)
                            {
                                <div class="text-muted small">No dependents captured yet.</div>
                            }
                            else
                            {
                                <div class="text-muted small">Active, non-deceased dependents linked to members.</div>
                            }
                        </div>
                        <div class="burial-readiness-card">
                            <div class="detail-mini-label">Expected Monthly Contributions</div>
                            <div class="burial-readiness-value">@FormatZAR(monthlyContributionSummary.ExpectedContributions)</div>
                            @if (monthlyContributionSummary.RecordsGenerated == 0)
                            {
                                <div class="text-muted small">No contributions captured for this month.</div>
                            }
                            else
                            {
                                <div class="text-muted small">@DateTime.Today.ToString("MMMM yyyy") expected collections.</div>
                            }
                        </div>
                        <div class="burial-readiness-card">
                            <div class="detail-mini-label">Outstanding Contributions</div>
                            <div class="burial-readiness-value">@FormatZAR(totalContributionOutstanding)</div>
                            @if (monthlyContributionSummary.RecordsGenerated == 0)
                            {
                                <div class="text-muted small">No contributions captured for this month.</div>
                            }
                            else
                            {
                                <div class="text-muted small">@monthlyContributionSummary.OverdueCount overdue record(s).</div>
                            }
                        </div>
                        <div class="burial-readiness-card">
                            <div class="detail-mini-label">Open Claims</div>
                            <div class="burial-readiness-value">@openClaimCount</div>
                            @if (openClaimCount == 0)
                            {
                                <div class="text-muted small">No claims submitted yet.</div>
                            }
                            else
                            {
                                <a class="sisonke-btn sisonke-btn-outline btn-sm mt-2" href="@($"/secretary-tasks/{StokvelId}")">Review Claims</a>
                            }
                        </div>
                        <div class="burial-readiness-card">
                            <div class="detail-mini-label">Claims Awaiting Secretary Review</div>
                            <div class="burial-readiness-value">@claimsToReviewCount</div>
                            @if (claimsToReviewCount == 0)
                            {
                                <div class="text-muted small">No claims awaiting review.</div>
                            }
                            else
                            {
                                <div class="text-muted small">Secretary review queue.</div>
                                <a class="sisonke-btn sisonke-btn-outline btn-sm mt-2" href="@($"/secretary-tasks/{StokvelId}")">Review</a>
                            }
                        </div>
                        <div class="burial-readiness-card">
                            <div class="detail-mini-label">Claims Awaiting Chairperson Approval</div>
                            <div class="burial-readiness-value">@claimsAwaitingChairpersonApprovalCount</div>
                            @if (claimsAwaitingChairpersonApprovalCount == 0)
                            {
                                <div class="text-muted small">No claims awaiting approval.</div>
                            }
                            else
                            {
                                <a class="sisonke-btn sisonke-btn-outline btn-sm mt-2" href="@($"/chairperson-tasks/{StokvelId}")">Open Approvals</a>
                            }
                        </div>
                        <div class="burial-readiness-card">
                            <div class="detail-mini-label">Recent Meetings</div>
                            <div class="burial-readiness-value">@recentMeetingCount</div>
                            @if (recentMeetingCount == 0)
                            {
                                <div class="text-muted small">No recent meetings recorded yet.</div>
                            }
                            else
                            {
                                <div class="text-muted small">@upcomingMeetingCount upcoming meeting(s).</div>
                            }
                        </div>
                        <div class="burial-readiness-card">
                            <div class="detail-mini-label">Next Meeting Host</div>
                            @if (nextMeeting is null)
                            {
                                <div class="burial-readiness-value text-muted">—</div>
                                <div class="text-muted small">No upcoming meetings scheduled.</div>
                            }
                            else
                            {
                                <div class="burial-readiness-value" style="font-size:1.05rem">@(nextMeeting.HostMember?.FullName ?? "Not assigned")</div>
                                <div class="text-muted small">@nextMeeting.MeetingDate.ToString("dd MMM yyyy")</div>
                            }
                        </div>
                    </div>
                </div>
            </section>
        }

        <!-- ══ KPI row ════════════════════════════════════════════ -->
        <div class="row g-3 mb-3">

            <!-- Members -->
            <div class="col-6 col-lg-3">
                <div class="card stat-card stat-members h-100">
                    <div class="card-body">
                        <div class="stat-icon-wrap">
                            <i class="bi bi-people-fill" aria-hidden="true"></i>
                        </div>
                        <div class="stat-label">Members</div>
                        <p class="stat-value">@memberCount</p>
                        @if (!string.IsNullOrWhiteSpace(memberLimitMessage))
                        {
                            <p class="stat-detail">@memberLimitMessage</p>
                        }
                        @if (activeSubscription?.SubscriptionPlan.MaxMembers is int maxM)
                        {
                            <div class="progress mt-2" role="progressbar" aria-label="Member limit" aria-valuenow="@GetMemberLimitProgress(maxM)" aria-valuemin="0" aria-valuemax="100">
                                <div class="progress-bar" style="width:@(GetMemberLimitProgress(maxM))%"></div>
                            </div>
                        }
                        <a class="btn btn-primary btn-sm mt-3" href="@($"/members/{StokvelId}")">
                            <i class="bi bi-people-fill me-1"></i>Manage Members
                        </a>
                    </div>
                </div>
            </div>

            <!-- Monthly contributions -->
            <div class="col-6 col-lg-3">
                <div class="card stat-card stat-contributions h-100">
                    <div class="card-body">
                        <div class="stat-icon-wrap">
                            <i class="bi bi-cash-coin" aria-hidden="true"></i>
                        </div>
                        <div class="stat-label">Monthly Contributions</div>
                        <p class="stat-value">@FormatZAR(monthlyContributionSummary.ExpectedContributions)</p>
                        <p class="stat-detail">
                            @DateTime.Today.ToString("MMMM yyyy") expected · @monthlyContributionSummary.ActiveMemberCount active members
                        </p>
                        @if (monthlyContributionSummary.RecordsGenerated == 0)
                        {
                            <div class="sisonke-alert sisonke-alert-blue mt-3 mb-0">
                                No contributions captured for this month.
                            </div>
                        }
                        else
                        {
                            <div class="mt-3">
                                <div class="cs-row"><span>Actual contributions</span><span>@FormatZAR(monthlyContributionSummary.ActualContributions)</span></div>
                                <div class="cs-row"><span>Outstanding</span><span>@FormatZAR(monthlyContributionSummary.OutstandingContributions)</span></div>
                                <div class="cs-row"><span>Overdue records</span><span>@monthlyContributionSummary.OverdueCount</span></div>
                                <div class="cs-row"><span>Total outstanding</span><span>@FormatZAR(totalContributionOutstanding)</span></div>
                                <div class="cs-row"><span>Monthly amount</span><span>@FormatZAR(monthlyContributionSummary.MonthlyContributionAmount)</span></div>
                                <div class="cs-row"><span>Collection rate</span><span>@monthlyContributionSummary.CollectionRatePercentage.ToString("0.#")%</span></div>
                                <div class="cs-row"><span>Paid records</span><span>@monthlyContributionSummary.PaidCount / @monthlyContributionSummary.RecordsGenerated</span></div>
                                <div class="progress mt-2" role="progressbar" aria-label="Contribution collection rate" aria-valuenow="@GetCollectionRateProgress()" aria-valuemin="0" aria-valuemax="100">
                                    <div class="progress-bar" style="width:@(GetCollectionRateProgress())%"></div>
                                </div>
                                <div class="d-flex flex-wrap gap-2 mt-2">
                                    <span class="sisonke-badge sisonke-badge-green">@monthlyContributionSummary.PaidCount Paid</span>
                                    <span class="sisonke-badge sisonke-badge-gold">@monthlyContributionSummary.PartiallyPaidCount Partial</span>
                                    <span class="sisonke-badge sisonke-badge-red">@monthlyContributionSummary.OverdueCount Overdue</span>
                                    <span class="sisonke-badge sisonke-badge-gray">@monthlyContributionSummary.UnpaidCount Unpaid</span>
                                </div>
                            </div>
                        }
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            @if (canManagePayments)
                            {
                                <a class="btn btn-outline-primary btn-sm" href="@($"/contribution-capture/{StokvelId}")">
                                    <i class="bi bi-cash-stack me-1"></i>Capture Contributions
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Outstanding fines -->
            <div class="col-6 col-lg-3">
                <div class="card stat-card stat-fines h-100">
                    <div class="card-body">
                        <div class="stat-icon-wrap">
                            <i class="bi bi-exclamation-circle-fill" aria-hidden="true"></i>
                        </div>
                        <div class="stat-label">Outstanding Fines</div>
                        <p class="stat-value @(outstandingFinesTotal > 0 ? "text-danger" : "")">@FormatZAR(outstandingFinesTotal)</p>
                        <p class="stat-detail">Total unpaid</p>
                    </div>
                </div>
            </div>

            <!-- Constitution -->
            <div class="col-6 col-lg-3">
                <div class="card stat-card stat-constitution h-100">
                    <div class="card-body">
                        <div class="stat-icon-wrap">
                            <i class="bi bi-file-earmark-text-fill" aria-hidden="true"></i>
                        </div>
                        <div class="stat-label">Constitution</div>
                        <div class="mt-1">
                            <StatusBadge Text="@constitutionStatus" Type="@GetConstitutionStatusBadgeType(constitutionStatus)" />
                        </div>
                        <p class="stat-detail mt-1">
                            @(constitutionStatus == "Approved" ? "Document approved" : constitutionStatus == "Uploaded" ? "Uploaded for review" : constitutionStatus == "Draft" ? "Draft in progress" : "Not yet created")
                        </p>
                        <a class="btn btn-outline-primary btn-sm mt-3" href="@($"/constitution-builder/{StokvelId}")">
                            <i class="bi bi-file-earmark-text me-1"></i>@GetConstitutionButtonText(constitutionStatus)
                        </a>
                    </div>
                </div>
            </div>
        </div>

        @if (canViewFinancials)
        {
            <section class="sisonke-card mb-3">
                <div class="sisonke-card-body">
                    <div class="sisonke-card-head">
                        <div>
                            <h2>Monthly Contribution Performance</h2>
                            <p>Expected versus actual member contributions for the current month.</p>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="sisonke-btn sisonke-btn-outline" href="@($"/finance-summary/{StokvelId}")">Finance Summary</a>
                            @if (canManagePayments)
                            {
                                <a class="sisonke-btn sisonke-btn-primary" href="@($"/contribution-capture/{StokvelId}")">Capture Contributions</a>
                            }
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6 col-xl-3">
                            <div class="sisonke-stat-card h-100">
                                <div class="stat-label">Expected Contributions</div>
                                <p class="stat-value">@FormatZAR(monthlyContributionSummary.ExpectedContributions)</p>
                            </div>
                        </div>
                        <div class="col-6 col-xl-3">
                            <div class="sisonke-stat-card h-100">
                                <div class="stat-label">Actual Contributions</div>
                                <p class="stat-value">@FormatZAR(monthlyContributionSummary.ActualContributions)</p>
                            </div>
                        </div>
                        <div class="col-6 col-xl-3">
                            <div class="sisonke-stat-card h-100">
                                <div class="stat-label">Outstanding</div>
                                <p class="stat-value">@FormatZAR(monthlyContributionSummary.OutstandingContributions)</p>
                            </div>
                        </div>
                        <div class="col-6 col-xl-3">
                            <div class="sisonke-stat-card h-100">
                                <div class="stat-label">Collection Rate</div>
                                <p class="stat-value">@monthlyContributionSummary.CollectionRatePercentage.ToString("0.#")%</p>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="detail-mini-label mb-0">Collection Rate %</span>
                            <span class="detail-mini-value">@monthlyContributionSummary.CollectionRatePercentage.ToString("0.#")%</span>
                        </div>
                        <div class="progress" role="progressbar" aria-label="Contribution collection rate" aria-valuenow="@GetCollectionRateProgress()" aria-valuemin="0" aria-valuemax="100">
                            <div class="progress-bar" style="width:@($"{Math.Min(monthlyContributionSummary.CollectionRatePercentage, 100)}%")"></div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 mb-3">
                        <span class="sisonke-badge sisonke-badge-blue">@monthlyContributionSummary.ActiveMemberCount Active Members</span>
                        <span class="sisonke-badge sisonke-badge-blue">@FormatZAR(monthlyContributionSummary.MonthlyContributionAmount) Monthly Amount</span>
                        <span class="sisonke-badge sisonke-badge-green">@monthlyContributionSummary.PaidCount Paid</span>
                        <span class="sisonke-badge sisonke-badge-red">@monthlyContributionSummary.OverdueCount Overdue</span>
                        <span class="sisonke-badge sisonke-badge-gray">@monthlyContributionSummary.UnpaidCount Unpaid</span>
                    </div>

                    @if (monthlyContributionSummary.RecordsGenerated == 0)
                    {
                        <div class="sisonke-alert sisonke-alert-blue mb-0">
                            No contributions captured for this month.
                            @if (canManagePayments)
                            {
                                <div class="mt-2">
                                    <a class="sisonke-btn sisonke-btn-outline" href="@($"/contribution-capture/{StokvelId}")">Open Contribution Capture</a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </section>
        }

        @if (canViewFinancials)
        {
            <section class="sisonke-card mb-3">
                <div class="sisonke-card-body">
                    <div class="sisonke-card-head">
                        <div>
                            <h2>Contribution Trends</h2>
                            <p>Expected versus actual collections over recent months.</p>
                        </div>
                        @if (canManagePayments)
                        {
                            <a class="sisonke-btn sisonke-btn-primary" href="@($"/contribution-capture/{StokvelId}")">Open Contribution Capture</a>
                        }
                    </div>

                    @if (contributionTrends.Count == 0)
                    {
                        <div class="sisonke-alert sisonke-alert-blue mb-0">
                            Not enough contribution history yet.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive mb-3">
                            <table class="sisonke-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Month</th>
                                        <th>Expected</th>
                                        <th>Actual</th>
                                        <th>Outstanding</th>
                                        <th>Collection Rate</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in contributionTrends)
                                    {
                                        <tr>
                                            <td class="fw-semibold">@item.MonthName</td>
                                            <td>@FormatZAR(item.ExpectedContributions)</td>
                                            <td>@FormatZAR(item.ActualContributions)</td>
                                            <td>@FormatZAR(item.OutstandingContributions)</td>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="sisonke-badge sisonke-badge-blue">@item.CollectionRatePercentage.ToString("0.#")%</span>
                                                    <div class="progress flex-grow-1" role="progressbar" aria-label="@($"{item.MonthName} collection rate")" aria-valuenow="@GetCollectionRateProgress(item.CollectionRatePercentage)" aria-valuemin="0" aria-valuemax="100">
                                                        <div class="progress-bar" style="width:@($"{Math.Min(item.CollectionRatePercentage, 100)}%")"></div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (GetContributionInsightTrends().Count < 2)
                        {
                            <div class="sisonke-alert sisonke-alert-blue mb-0">
                                Not enough contribution history yet.
                            </div>
                        }
                        else
                        {
                            <div class="sisonke-grid sisonke-grid-3">
                                <div class="sisonke-alert sisonke-alert-green mb-0">
                                    <div class="detail-mini-label">Best collection month</div>
                                    <strong>@GetBestCollectionTrend()?.MonthName</strong>
                                    <div>@FormatPercentage(GetBestCollectionTrend()?.CollectionRatePercentage ?? 0)</div>
                                </div>
                                <div class="sisonke-alert sisonke-alert-gold mb-0">
                                    <div class="detail-mini-label">Lowest collection month</div>
                                    <strong>@GetLowestCollectionTrend()?.MonthName</strong>
                                    <div>@FormatPercentage(GetLowestCollectionTrend()?.CollectionRatePercentage ?? 0)</div>
                                </div>
                                <div class="sisonke-alert sisonke-alert-blue mb-0">
                                    <div class="detail-mini-label">Average collection rate</div>
                                    <strong>@FormatPercentage(GetAverageCollectionRate())</strong>
                                </div>
                            </div>
                        }
                    }
                </div>
            </section>
        }

        <!-- ══ Main content row ═══════════════════════════════════ -->
        <div class="row g-3">

            <!-- Subscription package -->
            <div class="col-12 col-lg-6">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="dash-card-icon-sm" style="background:#FEF3C7;color:#D97706">
                                <i class="bi bi-patch-check-fill"></i>
                            </div>
                            <h2 class="h6 mb-0 fw-700">Subscription Package</h2>
                        </div>
                        @if (activeSubscription is null)
                        {
                            <p class="text-muted small mb-0">No active subscription found.</p>
                        }
                        else
                        {
                            <div class="sub-plan-display">
                                <div class="sub-plan-name">@activeSubscription.SubscriptionPlan.Name</div>
                                <StatusBadge Text="@activeSubscription.Status.ToString()" Type="success" />
                            </div>
                            <div class="row g-0 mt-3">
                                <div class="col-6">
                                    <div class="detail-mini-label">Monthly</div>
                                    <div class="detail-mini-value">@FormatZAR(activeSubscription.SubscriptionPlan.MonthlyPrice)</div>
                                </div>
                                <div class="col-6">
                                    <div class="detail-mini-label">Member Range</div>
                                    <div class="detail-mini-value">@GetMemberRangeText(activeSubscription.SubscriptionPlan)</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Constitution card -->
            <div class="col-12 col-lg-6">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="dash-card-icon-sm" style="background:var(--sk-green-50);color:var(--sk-green-700)">
                                <i class="bi bi-file-earmark-ruled-fill"></i>
                            </div>
                            <h2 class="h6 mb-0 fw-700">Constitution</h2>
                        </div>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="text-muted small">Status:</span>
                            <StatusBadge Text="@constitutionStatus" Type="@GetConstitutionStatusBadgeType(constitutionStatus)" />
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-primary btn-sm" href="@($"/constitution-builder/{StokvelId}")">
                                <i class="bi bi-pencil-square me-1"></i>@GetConstitutionButtonText(constitutionStatus)
                            </a>
                            <a class="btn btn-outline-secondary btn-sm" href="@($"/upload-constitution/{StokvelId}")">
                                <i class="bi bi-upload me-1"></i>Upload Existing
                            </a>
                            @if (linkedMember is not null && IsConstitutionRulesManagerRole(linkedMember.DefaultRole.ToString()))
                            {
                                <a class="btn btn-outline-secondary btn-sm" href="@($"/stokvel-operating-rules/{StokvelId}")">
                                    <i class="bi bi-sliders me-1"></i>Manage Operating Rules
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Coming soon: Group Balance / Wallet -->
            <div class="col-12 col-lg-4">
                <div class="card h-100 card-coming-soon">
                    <span class="coming-soon-badge">Coming Soon</span>
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="dash-card-icon-sm" style="background:#F0FDF4;color:#10B981">
                                <i class="bi bi-wallet2"></i>
                            </div>
                            <h2 class="h6 mb-0 fw-700">Wallet &amp; Transactions</h2>
                        </div>
                        <p class="stat-value-lg">R 0.00</p>
                        <p class="stat-detail">Group balance</p>
                        <div class="mt-3">
                            <div class="cs-row"><span>Last deposit</span><span>—</span></div>
                            <div class="cs-row"><span>Last payout</span><span>—</span></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Meetings -->
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="dash-card-icon-sm" style="background:var(--sk-purple-light);color:var(--sk-purple)">
                                <i class="bi bi-calendar-event-fill"></i>
                            </div>
                            <h2 class="h6 mb-0 fw-700">Meetings &amp; Agenda</h2>
                        </div>
                        <p class="stat-value">@upcomingMeetingCount</p>
                        <p class="stat-detail">Upcoming meetings</p>
                        @if (nextMeeting is not null)
                        {
                            <div class="mt-3">
                                <div class="detail-mini-label">Next Meeting</div>
                                <div class="detail-mini-value">@nextMeeting.MeetingDate.ToString("dd MMM yyyy")</div>
                                @if (!string.IsNullOrWhiteSpace(nextMeeting.Venue))
                                {
                                    <div class="text-muted small">@nextMeeting.Venue</div>
                                }
                                <div class="detail-mini-label mt-2">Meeting Host</div>
                                <div class="detail-mini-value">@(nextMeeting.HostMember?.FullName ?? "Not assigned")</div>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted small mt-3 mb-0">No upcoming meetings scheduled.</p>
                        }
                        <a class="btn btn-purple btn-sm mt-3" href="@($"/meetings/{StokvelId}")">
                            <i class="bi bi-calendar-event me-1"></i>Open Meetings
                        </a>
                    </div>
                </div>
            </div>

            <!-- Voting (inside meetings) -->
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100" style="background:linear-gradient(135deg,#f6f4ff,var(--sk-purple-light));border-color:rgba(124,111,224,.2);">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="dash-card-icon-sm" style="background:white;color:var(--sk-purple)">
                                <i class="bi bi-check2-square"></i>
                            </div>
                            <h2 class="h6 mb-0 fw-700">Voting &amp; Decisions</h2>
                            <span class="ms-auto" style="font-size:.68rem;font-weight:700;color:var(--sk-purple);background:white;padding:3px 10px;border-radius:20px;letter-spacing:.03em;white-space:nowrap;">Inside Meetings</span>
                        </div>
                        @if (openVoteCount > 0)
                        {
                            <p class="stat-value mb-1">@openVoteCount</p>
                            <p class="stat-detail">Open polls</p>
                        }
                        else
                        {
                            <p class="stat-value mb-1">0</p>
                            <p class="stat-detail">Open polls</p>
                        }
                        <div class="d-flex flex-wrap gap-2 mt-2">
                            <span class="sisonke-badge sisonke-badge-green">@openVoteCount Open</span>
                            <span class="sisonke-badge sisonke-badge-gray">@closedVoteCount Closed</span>
                        </div>
                        <p class="text-muted small mb-0 @(openVoteCount > 0 ? "mt-2" : "")" style="line-height:1.65;">
                            Open governance votes and review closed decisions for this stokvel.
                        </p>
                        <a class="btn btn-purple btn-sm mt-3" href="@($"/votes/{StokvelId}")">
                            <i class="bi bi-check2-square me-1"></i>Open Voting
                        </a>
                    </div>
                </div>
            </div>

        </div>
    }
}

