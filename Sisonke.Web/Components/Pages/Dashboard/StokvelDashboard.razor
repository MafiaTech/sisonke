@page "/stokvel-dashboard/{StokvelId:guid}"

@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject StokvelService StokvelService
@inject MemberService MemberService
@inject FineService FineService
@inject ContributionService ContributionService

<PageTitle>Dashboard</PageTitle>

@if (isLoading)
{
    <p>Loading dashboard...</p>
}
else if (stokvel is null)
{
    <div class="alert alert-warning" role="alert">
        Stokvel not found.
    </div>

    <a class="btn btn-link px-0" href="/my-stokvels">Back to My Stokvels</a>
}
else
{
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1>Dashboard</h1>
            <h2 class="h4">@stokvel.Name</h2>
            <p class="text-muted mb-0">Manage this stokvel's activity and overview.</p>
        </div>
        <a class="btn btn-outline-secondary" href="/my-stokvels">Back to My Stokvels</a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Stokvel type</dt>
                <dd class="col-sm-9">@stokvel.Type</dd>

                <dt class="col-sm-3">Tenant</dt>
                <dd class="col-sm-9">@stokvel.Tenant.Name</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@(stokvel.IsActive ? "Active" : "Inactive")</dd>
            </dl>
        </div>
    </div>

    @if (!stokvel.IsSetupComplete)
    {
        <div class="alert alert-warning" role="alert">
            This stokvel setup is not complete. Please complete the setup questionnaire before accessing the dashboard.
        </div>

        <a class="btn btn-primary" href="@($"/stokvel-questionnaire/{StokvelId}")">Complete Setup Questionnaire</a>
    }
    else
    {
        <div class="mb-4">
            <a class="btn btn-primary" href="@($"/members/{StokvelId}")">Manage Members</a>
            <a class="btn btn-outline-primary ms-2" href="@($"/contribution-rules/{StokvelId}")">Contribution Rules</a>
        </div>

        <div class="row g-3">
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="h6 text-muted">Members</h3>
                        <p class="display-6 mb-0">@memberCount</p>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="h6 text-muted">Contributions</h3>
                        <p class="display-6 mb-0">@expectedMonthlyContributions.ToString("C", new System.Globalization.CultureInfo("en-ZA"))</p>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="h6 text-muted">Outstanding Fines</h3>
                        <p class="display-6 mb-0">@outstandingFinesTotal.ToString("C", new System.Globalization.CultureInfo("en-ZA"))</p>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h3 class="h6 text-muted">Upcoming Meetings</h3>
                        <p class="display-6 mb-0">0</p>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private Stokvel? stokvel;
    private int memberCount;
    private decimal expectedMonthlyContributions;
    private decimal outstandingFinesTotal;
    private bool isLoading = true;

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);
        memberCount = await MemberService.GetMemberCountByStokvelIdAsync(StokvelId);
        expectedMonthlyContributions = await ContributionService.GetExpectedMonthlyContributionsByStokvelIdAsync(StokvelId);
        outstandingFinesTotal = await FineService.GetOutstandingFinesTotalByStokvelIdAsync(StokvelId);
        isLoading = false;
    }
}
