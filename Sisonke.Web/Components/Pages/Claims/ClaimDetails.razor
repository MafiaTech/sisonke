    private static string FormatEligibilityStatus(string? status) =>
        status switch
        {
            "Eligible" => "Eligible",
            "EligibleWithWarnings" => "Eligible with warnings",
            "NotEligible" => "Not eligible",
            "RequiresReview" => "Requires review",
            _ => "Not assessed"
        };

    private static string GetEligibilityCheckLabel(bool value, string passedLabel, string failedLabel) =>
        value ? passedLabel : failedLabel;

    private static string GetDependentCoverageLabel(ClaimEligibilityAssessmentDto assessment)
    {
        if (!assessment.IsDependentClaim)
        {
            return "Not applicable";
        }

        return assessment.IsDependentCovered ? "Covered" : "Requires review";
    }

    private static bool RequiresEligibilityReview(ClaimEligibilityAssessmentDto assessment) =>
        assessment.EligibilityStatus is "NotEligible" or "RequiresReview";

    private static bool HasEligibilityFindings(ClaimEligibilityAssessmentDto assessment) =>
        assessment.EligibilityStatus is "NotEligible" or "RequiresReview" or "EligibleWithWarnings";

    private static string FormatCurrency(decimal? amount)
    {
        return amount?.ToString("C0", new System.Globalization.CultureInfo("en-ZA")) ?? "-";
    }

    private static bool IsClaimSubmittableByStatus(FuneralClaimStatus status)
    {
        return status is FuneralClaimStatus.Draft or FuneralClaimStatus.OnHold;
    }

    private static bool IsClaimUploadableByMemberStatus(FuneralClaimStatus status)
    {
        return status is FuneralClaimStatus.Draft or FuneralClaimStatus.OnHold or FuneralClaimStatus.Submitted;
    }

    private static string GetRecommendationLabel(bool? recommendation) =>
        recommendation switch
        {
            true => "Yes – Recommend for approval",
            false => "No – Do not recommend for approval",
            _ => "Not recorded"
        };

    private static string GetRecommendationBadgeClass(bool? recommendation) =>
        recommendation switch
        {
            true => "sisonke-badge sisonke-badge-green",
            false => "sisonke-badge sisonke-badge-red",
            _ => "sisonke-badge sisonke-badge-gray"
        };

    private static string GetRecommendationAlertClass(bool? recommendation) =>
        recommendation switch
        {
            true => "green",
            false => "gold",
            _ => "blue"
        };

    private static bool IsClaimReviewableBySecretary(FuneralClaim claim)
    {
        return claim.SecretaryReviewedAt is null &&
            claim.Status is FuneralClaimStatus.Submitted or FuneralClaimStatus.UnderReview or FuneralClaimStatus.OnHold;
    }

    private static bool IsClaimInChairpersonApprovalStage(FuneralClaim claim)
    {
        return claim.SecretaryReviewedAt is not null &&
            claim.Status == FuneralClaimStatus.UnderReview;
    }

