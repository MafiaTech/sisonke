@page "/claim/{ClaimId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject FuneralClaimService FuneralClaimService
@inject MemberService MemberService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccessService MemberAccessService
@inject NavigationManager NavigationManager

<PageTitle>Claim Details</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading claim...
    </div>
}
else if (claim is null)
{
    <AlertBanner Type="danger" Title="Claim not found." Message="" Icon="bi bi-x-circle-fill" />
}
else if (!canViewClaim)
{
    <AlertBanner
        Type="warning"
        Title="You do not have access to this claim."
        Message=""
        Icon="bi bi-exclamation-triangle-fill" />

    <a class="btn btn-outline-secondary btn-sm" href="/my-workspace">
        <i class="bi bi-columns-gap me-1"></i>Back to My Workspace
    </a>
}
else
{
    <section class="sisonke-hero-card mb-4">
        <div class="claim-hero-content">
            <span class="sisonke-badge sisonke-badge-gold">Funeral Claim</span>
            <h1>@claim.DeceasedFullName</h1>
            <p>@claim.SubjectType claim for @claim.Member.FullName</p>
            <div class="claim-hero-badges">
                <span class="@GetClaimStatusBadgeClass(claim.Status)">@claim.Status</span>
                <span class="@GetBooleanBadgeClass(claim.IsWaitingPeriodSatisfied)">Waiting period: @(claim.IsWaitingPeriodSatisfied ? "Satisfied" : "Not satisfied")</span>
                <span class="@GetBooleanBadgeClass(claim.IsMemberStatusEligible)">Member eligibility: @(claim.IsMemberStatusEligible ? "Eligible" : "Not eligible")</span>
            </div>
        </div>
        <div class="claim-hero-meta">
            <div>
                <span>Subject</span>
                <strong>@claim.SubjectType</strong>
            </div>
            <div>
                <span>Date of Death</span>
                <strong>@(claim.DateOfDeath?.ToString("dd MMM yyyy") ?? "-")</strong>
            </div>
            <div>
                <span>Member</span>
                <strong>@claim.Member.FullName</strong>
            </div>
        </div>
    </section>

    @if (!claim.IsWaitingPeriodSatisfied)
    {
        <AlertBanner
            Type="warning"
            Title="Waiting period has not been satisfied."
            Message="This claim should remain on hold."
            Icon="bi bi-exclamation-triangle-fill" />
    }

    @if (!claim.IsMemberStatusEligible)
    {
        <AlertBanner
            Type="warning"
            Title="Member status is not eligible."
            Message="This claim should remain on hold until status is resolved."
            Icon="bi bi-exclamation-triangle-fill" />
    }

    @if (!hasDeathCertificate)
    {
        <AlertBanner
            Type="warning"
            Title="Death Certificate is required before this claim can be submitted."
            Message=""
            Icon="bi bi-exclamation-triangle-fill" />
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <AlertBanner Type="success" Title="@successMessage" Message="" Icon="bi bi-check-circle-fill" />
    }

    @if (!string.IsNullOrWhiteSpace(warningMessage))
    {
        <AlertBanner Type="warning" Title="@warningMessage" Message="" Icon="bi bi-exclamation-triangle-fill" />
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <AlertBanner Type="danger" Title="@errorMessage" Message="" Icon="bi bi-x-circle-fill" />
    }

    <div class="sisonke-grid sisonke-grid-2 claim-page-grid">
        <div class="sisonke-card h-100">
            <div class="sisonke-card-body">
                    <div class="sisonke-card-head">
                        <div>
                            <h2>Claim Information</h2>
                            <p>Current claim details and eligibility checks.</p>
                        </div>
                    </div>
                    <dl class="claim-dl">
                        <div class="claim-dl-row"><dt>Deceased full name</dt><dd>@claim.DeceasedFullName</dd></div>
                        <div class="claim-dl-row"><dt>Claim subject type</dt><dd>@claim.SubjectType</dd></div>
                        <div class="claim-dl-row"><dt>Member name</dt><dd>@claim.Member.FullName</dd></div>
                        @if (claim.Dependent is not null)
                        {
                            <div class="claim-dl-row"><dt>Dependent name</dt><dd>@claim.Dependent.FullName</dd></div>
                        }
                        <div class="claim-dl-row"><dt>Date of death</dt><dd>@(claim.DateOfDeath?.ToString("dd MMM yyyy") ?? "-")</dd></div>
                        <div class="claim-dl-row">
                            <dt>Claim status</dt>
                            <dd><span class="@GetClaimStatusBadgeClass(claim.Status)">@claim.Status</span></dd>
                        </div>
                        <div class="claim-dl-row">
                            <dt>Waiting period satisfied</dt>
                            <dd><span class="@GetBooleanBadgeClass(claim.IsWaitingPeriodSatisfied)">@(claim.IsWaitingPeriodSatisfied ? "Yes" : "No")</span></dd>
                        </div>
                        <div class="claim-dl-row">
                            <dt>Member status eligible</dt>
                            <dd><span class="@GetBooleanBadgeClass(claim.IsMemberStatusEligible)">@(claim.IsMemberStatusEligible ? "Yes" : "No")</span></dd>
                        </div>
                        <div class="claim-dl-row"><dt>Claim reason</dt><dd>@(claim.ClaimReason ?? "-")</dd></div>
                        <div class="claim-dl-row last"><dt>Review notes</dt><dd>@(claim.ReviewNotes ?? "-")</dd></div>
                    </dl>
            </div>
        </div>

        <div class="sisonke-card h-100">
            <div class="sisonke-card-body">
                    <div class="sisonke-card-head">
                        <div>
                            <h2>Claim Actions</h2>
                            <p>Submit, review and decide claims according to your role.</p>
                        </div>
                    </div>

                    @if (canAttemptSubmitClaim)
                    {
                        <button class="sisonke-btn sisonke-btn-primary w-100 mb-4" type="button" @onclick="SubmitClaimAsync" disabled="@(!canSubmitClaim)">
                            <i class="bi bi-send me-2"></i>Submit Claim
                        </button>
                    }

                    <div class="workflow-section">
                        <div class="sisonke-card-head compact">
                            <div>
                                <h2>Secretary Review</h2>
                                <p>Administrative review and recommendation.</p>
                            </div>
                        </div>

                        @if (claim.SecretaryReviewedAt is not null)
                        {
                            <dl class="claim-dl mb-3">
                                <div class="claim-dl-row">
                                    <dt>Review status</dt>
                                    <dd><span class="sisonke-badge sisonke-badge-green">Complete</span></dd>
                                </div>
                                <div class="claim-dl-row"><dt>Reviewed by</dt><dd>@(claim.SecretaryReviewedByName ?? "-")</dd></div>
                                <div class="claim-dl-row"><dt>Reviewed at</dt><dd>@claim.SecretaryReviewedAt.Value.ToString("dd MMM yyyy HH:mm")</dd></div>
                                <div class="claim-dl-row last"><dt>Notes</dt><dd>@(claim.SecretaryReviewNotes ?? "-")</dd></div>
                            </dl>
                        }

                        @if (canCompleteSecretaryReview)
                        {
                            <EditForm Model="@secretaryReviewModel" OnValidSubmit="@SaveSecretaryReviewAsync" FormName="SecretaryReviewForm">
                                <DataAnnotationsValidator />

                                <div class="mb-3">
                                    <label class="form-label" for="secretary-review-notes">Review Notes</label>
                                    <InputTextArea id="secretary-review-notes" class="form-control" rows="3" @bind-Value="secretaryReviewModel.ReviewNotes" />
                                </div>

                                <button class="sisonke-btn sisonke-btn-outline" type="submit" disabled="@string.IsNullOrWhiteSpace(secretaryReviewModel.ReviewNotes)">
                                    <i class="bi bi-clipboard-check me-2"></i>Complete Review
                                </button>
                            </EditForm>
                        }
                    </div>

                    <div class="workflow-section">
                        <div class="sisonke-card-head compact">
                            <div>
                                <h2>Chairperson Decision</h2>
                                <p>Final claim outcome and decision notes.</p>
                            </div>
                        </div>

                        @if (claim.ChairpersonDecisionAt is not null)
                        {
                            <dl class="claim-dl mb-3">
                                <div class="claim-dl-row"><dt>Decision by</dt><dd>@(claim.ChairpersonDecisionByName ?? "-")</dd></div>
                                <div class="claim-dl-row"><dt>Decision at</dt><dd>@claim.ChairpersonDecisionAt.Value.ToString("dd MMM yyyy HH:mm")</dd></div>
                                <div class="claim-dl-row last"><dt>Decision notes</dt><dd>@(claim.ChairpersonDecisionNotes ?? "-")</dd></div>
                            </dl>
                        }

                        @if (canMakeChairpersonDecision)
                        {
                            <EditForm Model="@chairpersonDecisionModel" FormName="ChairpersonDecisionForm">
                                <DataAnnotationsValidator />

                                <div class="mb-3">
                                    <label class="form-label" for="chairperson-decision-notes">Decision Notes</label>
                                    <InputTextArea id="chairperson-decision-notes" class="form-control" rows="3" @bind-Value="chairpersonDecisionModel.DecisionNotes" />
                                </div>

                                <div class="d-flex gap-2 flex-wrap">
                                    <button class="sisonke-btn sisonke-btn-primary" type="button" @onclick="ShowApproveConfirmation">
                                        <i class="bi bi-check2-circle me-2"></i>Approve Claim
                                    </button>
                                    <button class="sisonke-btn sisonke-btn-outline" type="button" @onclick="ShowRejectConfirmation">
                                        <i class="bi bi-x-circle me-2"></i>Reject Claim
                                    </button>
                                </div>
                            </EditForm>
                        }
                    </div>

                    @if (ShouldShowPayoutSection)
                    {
                        <div class="workflow-section">
                            <div class="sisonke-card-head compact">
                                <div>
                                    <h2>Treasurer Payout</h2>
                                    <p>Approved claim payout status and payment capture.</p>
                                </div>
                            </div>

                            @if (claim.Status == FuneralClaimStatus.Approved)
                            {
                                <div class="sisonke-alert sisonke-alert-gold mb-3">
                                    This approved claim is awaiting treasurer payout.
                                </div>
                            }
                            else if (claim.Status == FuneralClaimStatus.Paid)
                            {
                                <div class="sisonke-alert sisonke-alert-green mb-3">
                                    This claim payout has been marked paid.
                                </div>
                            }

                            <dl class="claim-dl mb-3">
                                <div class="claim-dl-row"><dt>Payout amount</dt><dd>@(claim.PayoutAmount?.ToString("C0", new System.Globalization.CultureInfo("en-ZA")) ?? "-")</dd></div>
                                <div class="claim-dl-row"><dt>Payout reference</dt><dd>@(claim.PayoutReference ?? "-")</dd></div>
                                <div class="claim-dl-row"><dt>Payout paid date</dt><dd>@(claim.PayoutPaidAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "-")</dd></div>
                                <div class="claim-dl-row"><dt>Payout notes</dt><dd>@(claim.PayoutNotes ?? "-")</dd></div>
                                <div class="claim-dl-row last"><dt>Captured by</dt><dd>@(payoutCapturedByMemberName ?? "-")</dd></div>
                            </dl>

                            @if (claim.Status == FuneralClaimStatus.Approved && canManagePayments)
                            {
                                <EditForm Model="@payoutModel" OnValidSubmit="@MarkPayoutPaidAsync" FormName="ClaimPayoutForm">
                                    <DataAnnotationsValidator />

                                    <div class="row g-3">
                                        <div class="col-12 col-md-6">
                                            <label class="form-label" for="payout-amount">Payout amount</label>
                                            <InputNumber id="payout-amount" class="form-control" @bind-Value="payoutModel.PayoutAmount" />
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label" for="payout-reference">Payout reference</label>
                                            <InputText id="payout-reference" class="form-control" @bind-Value="payoutModel.PayoutReference" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label" for="payout-notes">Notes</label>
                                            <InputTextArea id="payout-notes" class="form-control" rows="3" @bind-Value="payoutModel.PayoutNotes" />
                                        </div>
                                    </div>

                                    <button class="sisonke-btn sisonke-btn-gold mt-3" type="submit" disabled="@(!CanSubmitPayout)">
                                        <i class="bi bi-cash-coin me-2"></i>Mark Payout Paid
                                    </button>
                                </EditForm>
                            }
                        </div>
                    }
            </div>
        </div>

        @if (canViewPayoutAuditTrail)
        {
            <div class="sisonke-card claim-audit-card">
                <div class="sisonke-card-body">
                    <div class="sisonke-card-head">
                        <div>
                            <h2>Payout Audit Trail</h2>
                            <p>Recorded payout actions for this claim.</p>
                        </div>
                    </div>

                    @if (payoutAuditTrail.Count == 0)
                    {
                        <div class="sisonke-alert sisonke-alert-blue mb-0">No payout audit records have been captured yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="sisonke-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Date/time</th>
                                        <th>Action</th>
                                        <th>Previous amount</th>
                                        <th>New amount</th>
                                        <th>Previous status</th>
                                        <th>New status</th>
                                        <th>Reference</th>
                                        <th>Notes</th>
                                        <th>Captured by</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var audit in payoutAuditTrail)
                                    {
                                        <tr>
                                            <td class="text-muted small">@audit.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                            <td><span class="sisonke-badge sisonke-badge-gold">@audit.Action</span></td>
                                            <td>@FormatCurrency(audit.PreviousPayoutAmount)</td>
                                            <td>@FormatCurrency(audit.NewPayoutAmount)</td>
                                            <td>@(audit.PreviousStatus ?? "-")</td>
                                            <td>@(audit.NewStatus ?? "-")</td>
                                            <td>@(audit.PayoutReference ?? "-")</td>
                                            <td>@(audit.Notes ?? "-")</td>
                                            <td>@(audit.CapturedByMember?.FullName ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="sisonke-card claim-documents-card">
            <div class="sisonke-card-body">
                    <div class="sisonke-card-head">
                        <div>
                            <h2>Required Documents</h2>
                            <p>Death Certificate is required before submission. Other documents are optional for now.</p>
                        </div>
                    </div>

                    <div class="table-responsive mb-4">
                        <table class="sisonke-table mb-0">
                            <thead>
                                <tr>
                                    <th>Document</th>
                                    <th>Requirement</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-semibold">Death Certificate</td>
                                    <td>Required</td>
                                    <td>
                                        <span class="@GetBooleanBadgeClass(hasDeathCertificate)">@(hasDeathCertificate ? "Uploaded" : "Missing")</span>
                                    </td>
                                </tr>
                                <tr><td>BI-1663</td><td>Optional</td><td><span class="sisonke-badge sisonke-badge-gray">Optional</span></td></tr>
                                <tr><td>ID Copy</td><td>Optional</td><td><span class="sisonke-badge sisonke-badge-gray">Optional</span></td></tr>
                                <tr><td>Proof of Membership</td><td>Optional</td><td><span class="sisonke-badge sisonke-badge-gray">Optional</span></td></tr>
                                <tr><td>Proof of Payment</td><td>Optional</td><td><span class="sisonke-badge sisonke-badge-gray">Optional</span></td></tr>
                                <tr><td>Other</td><td>Optional</td><td><span class="sisonke-badge sisonke-badge-gray">Optional</span></td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="sisonke-card-head compact">
                        <div>
                            <h2>Documents</h2>
                            <p>Upload and view supporting claim documents.</p>
                        </div>
                    </div>

                    @if (canUploadDocuments)
                    {
                        <div class="row g-3 align-items-end mb-4">
                            <div class="col-12 col-md-4">
                                <label class="form-label" for="document-type">Document type</label>
                                <InputSelect id="document-type" class="form-select" @bind-Value="selectedDocumentType">
                                    @foreach (var documentType in Enum.GetValues<ClaimDocumentType>())
                                    {
                                        <option value="@documentType">@documentType</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-12 col-md-5">
                                <label class="form-label" for="claim-document">Document</label>
                                <InputFile id="claim-document" class="form-control" OnChange="@OnFileSelected" />
                            </div>
                            <div class="col-12 col-md-3">
                                <button class="sisonke-btn sisonke-btn-primary w-100" type="button" @onclick="UploadDocumentAsync">
                                    <i class="bi bi-upload me-2"></i>Upload
                                </button>
                            </div>
                        </div>
                    }

                    @if (claim.Documents.Count == 0)
                    {
                        <div class="sisonke-alert sisonke-alert-blue mb-0">No documents uploaded yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="sisonke-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Document type</th>
                                        <th>Original file name</th>
                                        <th>Uploaded date</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var document in claim.Documents.OrderByDescending(document => document.UploadedAt))
                                    {
                                        <tr>
                                            <td>@document.DocumentType</td>
                                            <td class="text-muted small">@document.OriginalFileName</td>
                                            <td class="text-muted small">@document.UploadedAt.ToString("dd MMM yyyy")</td>
                                            <td>
                                                <a class="sisonke-btn sisonke-btn-outline" href="@document.StoredFilePath" target="_blank" rel="noopener noreferrer">Open</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

    <ConfirmationModal
        IsVisible="@showApproveConfirmation"
        Title="Approve Claim"
        Message="Are you sure you want to approve this claim?"
        ConfirmButtonText="Approve Claim"
        CancelButtonText="Cancel"
        ModalType="success"
        OnConfirm="@ConfirmApproveClaimAsync"
        OnCancel="@HideApproveConfirmation" />

    <ConfirmationModal
        IsVisible="@showRejectConfirmation"
        Title="Reject Claim"
        Message="Are you sure you want to reject this claim?"
        ConfirmButtonText="Reject Claim"
        CancelButtonText="Cancel"
        ModalType="danger"
        OnConfirm="@ConfirmRejectClaimAsync"
        OnCancel="@HideRejectConfirmation" />
}

<style>
    .claim-page-grid {
        align-items: stretch;
    }

    .claim-documents-card,
    .claim-audit-card {
        grid-column: 1 / -1;
    }

    .claim-hero-content {
        display: grid;
        gap: .75rem;
    }

    .claim-hero-badges {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .claim-hero-meta {
        display: grid;
        gap: .75rem;
        min-width: min(18rem, 100%);
        padding: 1rem;
        border: 1px solid rgb(255 255 255 / .28);
        border-radius: var(--r-md);
        background: rgb(255 255 255 / .12);
    }

    .claim-hero-meta div {
        display: grid;
        gap: .15rem;
    }

    .claim-hero-meta span {
        color: rgb(255 255 255 / .78);
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .claim-hero-meta strong {
        color: #fff;
        font-size: .98rem;
    }

    .sisonke-card-head.compact {
        margin-top: .25rem;
        margin-bottom: 1rem;
        padding-bottom: .75rem;
    }

    .claim-dl { margin: 0; }
    .claim-dl-row {
        display: flex;
        gap: 1rem;
        padding: .625rem 0;
        border-bottom: 1px solid var(--border);
        font-size: .9rem;
    }
    .claim-dl-row.last { border-bottom: none; }
    .claim-dl-row dt {
        flex: 0 0 42%;
        color: var(--muted);
        font-size: .875rem;
        font-weight: 400;
    }
    .claim-dl-row dd {
        flex: 1;
        margin: 0;
        color: var(--text);
        font-weight: 500;
    }
    .workflow-section {
        border-top: 1px solid var(--border);
        margin-top: 1.25rem;
        padding-top: 1.25rem;
    }
    @@media (max-width: 768px) {
        .claim-dl-row {
            flex-direction: column;
            gap: .25rem;
        }
        .claim-dl-row dt {
            flex: 0 0 auto;
        }
    }
</style>

@code {
    private FuneralClaim? claim;
    private List<ClaimPayoutAudit> payoutAuditTrail = [];
    private SecretaryReviewModel secretaryReviewModel = new();
    private ChairpersonDecisionModel chairpersonDecisionModel = new();
    private ClaimPayoutModel payoutModel = new();
    private ClaimDocumentType selectedDocumentType = ClaimDocumentType.DeathCertificate;
    private IBrowserFile? selectedFile;
    private bool isLoading = true;
    private bool hasDeathCertificate;
    private bool canViewClaim;
    private bool canReviewClaim;
    private bool canCompleteSecretaryReview;
    private bool canApproveClaim;
    private bool canMakeChairpersonDecision;
    private bool canManagePayments;
    private bool canAttemptSubmitClaim;
    private bool canSubmitClaim;
    private bool canUploadDocuments;
    private bool canViewPayoutAuditTrail;
    private bool showApproveConfirmation;
    private bool showRejectConfirmation;
    private string? currentUserId;
    private Guid? currentStokvelId;
    private string? payoutCapturedByMemberName;
    private string? successMessage;
    private string? warningMessage;
    private string? errorMessage;
    private bool CanSubmitPayout => payoutModel.PayoutAmount > 0 && !string.IsNullOrWhiteSpace(payoutModel.PayoutReference);
    private bool ShouldShowPayoutSection =>
        claim is not null &&
        (claim.Status is FuneralClaimStatus.Approved or FuneralClaimStatus.Paid ||
            claim.PayoutAmount is not null ||
            claim.PayoutPaidAt is not null ||
            !string.IsNullOrWhiteSpace(claim.PayoutReference));

    [Parameter]
    public Guid ClaimId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await LoadClaimAsync();
    }

    private async Task LoadClaimAsync()
    {
        isLoading = true;
        canViewClaim = false;
        canReviewClaim = false;
        canCompleteSecretaryReview = false;
        canApproveClaim = false;
        canMakeChairpersonDecision = false;
        canManagePayments = false;
        canAttemptSubmitClaim = false;
        canSubmitClaim = false;
        canUploadDocuments = false;
        canViewPayoutAuditTrail = false;
        payoutAuditTrail = [];
        currentUserId = null;
        currentStokvelId = null;
        payoutCapturedByMemberName = null;
        claim = await FuneralClaimService.GetClaimByIdAsync(ClaimId);
        hasDeathCertificate = claim is not null && await FuneralClaimService.HasDeathCertificateAsync(ClaimId);

        if (claim is not null)
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
            var stokvelId = await MemberAccessService.GetStokvelIdForMemberAsync(claim.MemberId);
            currentUserId = userId;
            currentStokvelId = stokvelId;

            if (!string.IsNullOrWhiteSpace(userId))
            {
                var isOwnMemberClaim = await MemberAccessService.CanViewOwnMemberProfileAsync(userId, claim.MemberId);
                canViewClaim = await MemberAccessService.CanViewMemberProfileAsync(userId, claim.MemberId);
                var canManageStokvel = false;

                if (stokvelId is not null)
                {
                    canManageStokvel = await MemberAccessService.CanManageStokvelAsync(userId, stokvelId.Value);
                    canReviewClaim = await MemberAccessService.CanReviewClaimsAsync(userId, stokvelId.Value);
                    canApproveClaim = await MemberAccessService.CanApproveClaimsAsync(userId, stokvelId.Value);
                    canManagePayments = await MemberAccessService.CanManagePaymentsAsync(userId, stokvelId.Value);
                    canViewPayoutAuditTrail = await MemberAccessService.CanViewFinancialsAsync(userId, stokvelId.Value);
                    canCompleteSecretaryReview = canReviewClaim && IsClaimReviewableBySecretary(claim);
                    canMakeChairpersonDecision = canApproveClaim && IsClaimInChairpersonApprovalStage(claim);
                }

                canViewClaim = canViewClaim || canManageStokvel;

                canAttemptSubmitClaim =
                    IsClaimSubmittableByStatus(claim.Status) &&
                    (isOwnMemberClaim || canManageStokvel);

                canSubmitClaim = hasDeathCertificate && canAttemptSubmitClaim;

                canUploadDocuments =
                    (isOwnMemberClaim && IsClaimUploadableByMemberStatus(claim.Status)) ||
                    canManageStokvel;
            }

            secretaryReviewModel.ReviewNotes = claim.SecretaryReviewNotes;
            chairpersonDecisionModel.DecisionNotes = claim.ChairpersonDecisionNotes;
            payoutModel = new ClaimPayoutModel
            {
                PayoutAmount = claim.PayoutAmount ?? 0,
                PayoutReference = claim.PayoutReference,
                PayoutNotes = claim.PayoutNotes
            };

            if (claim.PayoutCapturedByMemberId is not null)
            {
                var capturedByMember = await MemberService.GetMemberByIdAsync(claim.PayoutCapturedByMemberId.Value);
                payoutCapturedByMemberName = capturedByMember?.FullName;
            }

            if (canViewPayoutAuditTrail)
            {
                payoutAuditTrail = await FuneralClaimService.GetClaimPayoutAuditTrailAsync(claim.Id);
            }
        }

        isLoading = false;
    }

    private void OnFileSelected(InputFileChangeEventArgs args)
    {
        selectedFile = args.File;
        errorMessage = null;
        warningMessage = null;
        successMessage = null;
    }

    private async Task UploadDocumentAsync()
    {
        successMessage = null;
        warningMessage = null;
        errorMessage = null;

        if (selectedFile is null)
        {
            errorMessage = "Please select a document to upload.";
            return;
        }

        if (!canUploadDocuments)
        {
            errorMessage = "You do not have permission to upload documents for this claim.";
            return;
        }

        var document = await FuneralClaimService.UploadClaimDocumentAsync(
            ClaimId,
            selectedDocumentType,
            selectedFile);

        if (document is null)
        {
            errorMessage = "Document could not be uploaded.";
            return;
        }

        selectedFile = null;
        successMessage = "Document uploaded.";
        await LoadClaimAsync();
    }

    private async Task MarkPayoutPaidAsync()
    {
        successMessage = null;
        warningMessage = null;
        errorMessage = null;

        if (!canManagePayments)
        {
            errorMessage = "Only the Treasurer can mark a claim payout as paid.";
            return;
        }

        if (claim is null || claim.Status != FuneralClaimStatus.Approved)
        {
            errorMessage = "Only approved claims can be marked as paid.";
            return;
        }

        if (!CanSubmitPayout)
        {
            errorMessage = "Payout amount and reference are required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(currentUserId) || currentStokvelId is null)
        {
            errorMessage = "Treasurer member record could not be resolved.";
            return;
        }

        var treasurerMember = await MemberAccessService.GetLinkedMemberForUserAsync(currentUserId, currentStokvelId.Value);

        if (treasurerMember is null)
        {
            errorMessage = "Treasurer member record could not be resolved.";
            return;
        }

        var markedPaid = await FuneralClaimService.MarkClaimPayoutPaidAsync(
            ClaimId,
            payoutModel.PayoutAmount,
            payoutModel.PayoutReference ?? string.Empty,
            payoutModel.PayoutNotes,
            treasurerMember.Id);

        if (!markedPaid)
        {
            errorMessage = "Claim payout could not be marked as paid.";
            return;
        }

        successMessage = "Claim payout marked as paid.";
        await LoadClaimAsync();
    }

    private async Task SubmitClaimAsync()
    {
        successMessage = null;
        warningMessage = null;
        errorMessage = null;

        if (!canSubmitClaim)
        {
            if (!hasDeathCertificate)
            {
                warningMessage = "Death Certificate is required before submitting this claim.";
                return;
            }

            errorMessage = "This claim cannot be submitted from your current access or status.";
            return;
        }

        var updatedClaim = await FuneralClaimService.SubmitClaimAsync(ClaimId);

        if (updatedClaim is null)
        {
            hasDeathCertificate = await FuneralClaimService.HasDeathCertificateAsync(ClaimId);

            if (!hasDeathCertificate)
            {
                warningMessage = "Death Certificate is required before submitting this claim.";
                return;
            }

            errorMessage = "Claim could not be submitted.";
            return;
        }

        NavigationManager.NavigateTo($"/member-profile/{updatedClaim.MemberId}");
    }

    private async Task SaveSecretaryReviewAsync()
    {
        successMessage = null;
        warningMessage = null;
        errorMessage = null;

        if (!canCompleteSecretaryReview)
        {
            errorMessage = "You do not have permission to review this claim.";
            return;
        }

        if (string.IsNullOrWhiteSpace(secretaryReviewModel.ReviewNotes))
        {
            errorMessage = "Review notes are required before completing the secretary review.";
            return;
        }

        if (string.IsNullOrWhiteSpace(currentUserId) || currentStokvelId is null)
        {
            errorMessage = "Secretary reviewer could not be resolved.";
            return;
        }

        var secretaryMember = await MemberAccessService.GetLinkedMemberForUserAsync(currentUserId, currentStokvelId.Value);

        if (secretaryMember is null)
        {
            errorMessage = "Secretary member record could not be resolved.";
            return;
        }

        var reviewCompleted = await FuneralClaimService.CompleteSecretaryReviewAsync(
            ClaimId,
            secretaryReviewModel.ReviewNotes,
            secretaryMember.Id);

        if (!reviewCompleted)
        {
            errorMessage = "Secretary review could not be saved.";
            return;
        }

        successMessage = "Secretary review saved.";
        await LoadClaimAsync();
    }

    private void ShowApproveConfirmation()
    {
        successMessage = null;
        warningMessage = null;
        errorMessage = null;

        if (!canMakeChairpersonDecision)
        {
            errorMessage = "You do not have permission to approve this claim.";
            return;
        }

        showApproveConfirmation = true;
    }

    private void HideApproveConfirmation()
    {
        showApproveConfirmation = false;
    }

    private async Task ConfirmApproveClaimAsync()
    {
        showApproveConfirmation = false;
        successMessage = null;
        warningMessage = null;
        errorMessage = null;

        if (!canMakeChairpersonDecision)
        {
            errorMessage = "You do not have permission to approve this claim.";
            return;
        }

        if (string.IsNullOrWhiteSpace(currentUserId) || currentStokvelId is null)
        {
            errorMessage = "Chairperson reviewer could not be resolved.";
            return;
        }

        var chairpersonMember = await MemberAccessService.GetLinkedMemberForUserAsync(currentUserId, currentStokvelId.Value);

        if (chairpersonMember is null)
        {
            errorMessage = "Chairperson member record could not be resolved.";
            return;
        }

        var approved = await FuneralClaimService.ApproveClaimAsync(
            ClaimId,
            chairpersonMember.Id,
            chairpersonDecisionModel.DecisionNotes);

        if (!approved)
        {
            errorMessage = "Claim could not be approved. Ensure the Death Certificate is uploaded.";
            return;
        }

        successMessage = "Claim approved.";
        await LoadClaimAsync();
    }

    private void ShowRejectConfirmation()
    {
        successMessage = null;
        warningMessage = null;
        errorMessage = null;

        if (!canMakeChairpersonDecision)
        {
            errorMessage = "You do not have permission to reject this claim.";
            return;
        }

        showRejectConfirmation = true;
    }

    private void HideRejectConfirmation()
    {
        showRejectConfirmation = false;
    }

    private async Task ConfirmRejectClaimAsync()
    {
        showRejectConfirmation = false;
        successMessage = null;
        warningMessage = null;
        errorMessage = null;

        if (!canMakeChairpersonDecision)
        {
            errorMessage = "You do not have permission to reject this claim.";
            return;
        }

        if (string.IsNullOrWhiteSpace(chairpersonDecisionModel.DecisionNotes))
        {
            errorMessage = "Decision notes are required when rejecting a claim.";
            return;
        }

        if (string.IsNullOrWhiteSpace(currentUserId) || currentStokvelId is null)
        {
            errorMessage = "Chairperson reviewer could not be resolved.";
            return;
        }

        var chairpersonMember = await MemberAccessService.GetLinkedMemberForUserAsync(currentUserId, currentStokvelId.Value);

        if (chairpersonMember is null)
        {
            errorMessage = "Chairperson member record could not be resolved.";
            return;
        }

        var rejected = await FuneralClaimService.RejectClaimAsync(
            ClaimId,
            chairpersonMember.Id,
            chairpersonDecisionModel.DecisionNotes);

        if (!rejected)
        {
            errorMessage = "Claim could not be rejected.";
            return;
        }

        successMessage = "Claim rejected.";
        await LoadClaimAsync();
    }

    private static string GetClaimStatusBadgeType(FuneralClaimStatus status) =>
        status switch
        {
            FuneralClaimStatus.Draft => "secondary",
            FuneralClaimStatus.Submitted => "info",
            FuneralClaimStatus.UnderReview => "info",
            FuneralClaimStatus.OnHold => "warning",
            FuneralClaimStatus.Approved => "success",
            FuneralClaimStatus.Rejected => "danger",
            FuneralClaimStatus.Paid => "success",
            FuneralClaimStatus.Cancelled => "secondary",
            _ => "secondary"
        };

    private static string GetClaimStatusBadgeClass(FuneralClaimStatus status) =>
        status switch
        {
            FuneralClaimStatus.Draft => "sisonke-badge sisonke-badge-gray",
            FuneralClaimStatus.Submitted => "sisonke-badge sisonke-badge-blue",
            FuneralClaimStatus.UnderReview => "sisonke-badge sisonke-badge-teal",
            FuneralClaimStatus.OnHold => "sisonke-badge sisonke-badge-gold",
            FuneralClaimStatus.Approved => "sisonke-badge sisonke-badge-green",
            FuneralClaimStatus.Rejected => "sisonke-badge sisonke-badge-red",
            FuneralClaimStatus.Paid => "sisonke-badge sisonke-badge-green",
            FuneralClaimStatus.Cancelled => "sisonke-badge sisonke-badge-gray",
            _ => "sisonke-badge sisonke-badge-gray"
        };

    private static string GetBooleanBadgeClass(bool value) =>
        value
            ? "sisonke-badge sisonke-badge-green"
            : "sisonke-badge sisonke-badge-gold";

    private static string FormatCurrency(decimal? amount)
    {
        return amount?.ToString("C0", new System.Globalization.CultureInfo("en-ZA")) ?? "-";
    }

    private static bool IsClaimSubmittableByStatus(FuneralClaimStatus status)
    {
        return status is FuneralClaimStatus.Draft or FuneralClaimStatus.OnHold;
    }

    private static bool IsClaimUploadableByMemberStatus(FuneralClaimStatus status)
    {
        return status is FuneralClaimStatus.Draft or FuneralClaimStatus.OnHold or FuneralClaimStatus.Submitted;
    }

    private static bool IsClaimReviewableBySecretary(FuneralClaim claim)
    {
        return claim.SecretaryReviewedAt is null &&
            claim.Status is FuneralClaimStatus.Submitted or FuneralClaimStatus.UnderReview or FuneralClaimStatus.OnHold;
    }

    private static bool IsClaimInChairpersonApprovalStage(FuneralClaim claim)
    {
        return claim.SecretaryReviewedAt is not null &&
            claim.Status == FuneralClaimStatus.UnderReview;
    }

