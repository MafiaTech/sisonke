@page "/claim/{ClaimId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services
@using Sisonke.Web.Services.Dto

@inject FuneralClaimService FuneralClaimService
@inject ClaimEligibilityService ClaimEligibilityService
@inject MemberService MemberService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccessService MemberAccessService
@inject NavigationManager NavigationManager

<PageTitle>Claim Details</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading claim...
    </div>
}
else if (claim is null)
{
    <AlertBanner Type="danger" Title="Claim not found." Message="" Icon="bi bi-x-circle-fill" />
}
else if (!canViewClaim)
{
    <AlertBanner
        Type="warning"
        Title="You do not have access to this claim."
        Message=""
        Icon="bi bi-exclamation-triangle-fill" />

    <a class="btn btn-outline-secondary btn-sm" href="/my-workspace">
        <i class="bi bi-columns-gap me-1"></i>Back to My Workspace
    </a>
}
else
{
    <section class="sisonke-hero-card mb-4">
        <div class="claim-hero-content">
            <span class="sisonke-badge sisonke-badge-gold">Funeral Claim</span>
            <h1>@claim.DeceasedFullName</h1>
            <p>@GetClaimReference(claim) · @claim.SubjectType claim for @claim.Member.FullName</p>
            <div class="claim-hero-badges">
                <span class="@GetClaimStatusBadgeClass(claim.Status)">@claim.Status</span>
                <span class="@GetBooleanBadgeClass(claim.IsWaitingPeriodSatisfied)">Waiting period: @(claim.IsWaitingPeriodSatisfied ? "Satisfied" : "Not satisfied")</span>
                <span class="@GetBooleanBadgeClass(claim.IsMemberStatusEligible)">Member eligibility: @(claim.IsMemberStatusEligible ? "Eligible" : "Not eligible")</span>
            </div>
        </div>
        <div class="claim-hero-meta">
            <div>
                <span>Claim Reference</span>
                <strong>@GetClaimReference(claim)</strong>
            </div>
            <div>
                <span>Subject</span>
                <strong>@claim.SubjectType</strong>
            </div>
            <div>
                <span>Date of Death</span>
                <strong>@(claim.DateOfDeath?.ToString("dd MMM yyyy") ?? "-")</strong>
            </div>
            <div>
                <span>Member</span>
                <strong>@claim.Member.FullName</strong>
            </div>
        </div>
    </section>

    @if (!claim.IsWaitingPeriodSatisfied)
    {
        <AlertBanner
            Type="warning"
            Title="Waiting period has not been satisfied."
            Message="This claim should remain on hold."
            Icon="bi bi-exclamation-triangle-fill" />
    }

    @if (!claim.IsMemberStatusEligible)
    {
        <AlertBanner
            Type="warning"
            Title="Member status is not eligible."
            Message="This claim should remain on hold until status is resolved."
            Icon="bi bi-exclamation-triangle-fill" />
    }

    @if (!hasDeathCertificate)
    {
        <AlertBanner
            Type="warning"
            Title="Death Certificate is required before this claim can be submitted."
            Message=""
            Icon="bi bi-exclamation-triangle-fill" />
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <AlertBanner Type="success" Title="@successMessage" Message="" Icon="bi bi-check-circle-fill" />
    }

    @if (!string.IsNullOrWhiteSpace(warningMessage))
    {
        <AlertBanner Type="warning" Title="@warningMessage" Message="" Icon="bi bi-exclamation-triangle-fill" />
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <AlertBanner Type="danger" Title="@errorMessage" Message="" Icon="bi bi-x-circle-fill" />
    }

    @if (claim.Status == FuneralClaimStatus.Rejected)
    {
        <div class="sisonke-alert sisonke-alert-red mb-4">
            This claim was rejected by the Chairperson. No payout action is available.
        </div>
    }
    else if (canManagePayments && !IsChairpersonApprovedForPayout(claim) && claim.Status != FuneralClaimStatus.Paid)
    {
        <div class="sisonke-alert sisonke-alert-blue mb-4">
            This claim has not yet been approved by the Chairperson. Payout is not available.
        </div>
    }

    @if (canViewClaimEligibilityAssessment && eligibilityAssessment is not null)
    {
        <div class="sisonke-card mb-4">
            <div class="sisonke-card-head">
                <div>
                    <h2>Claim Eligibility Assessment</h2>
                    <p>This assessment supports decision-making. It does not automatically approve or reject the claim.</p>
                </div>
                <span class="@GetEligibilityStatusBadgeClass(eligibilityAssessment.EligibilityStatus)">
                    @FormatEligibilityStatus(eligibilityAssessment.EligibilityStatus)
                </span>
            </div>
            <div class="sisonke-card-body">
                <div class="table-responsive mb-3">
                    <table class="sisonke-table mb-0">
                        <tbody>
                            <tr>
                                <th>Claim subject</th>
                                <td>@eligibilityAssessment.ClaimSubjectName</td>
                            </tr>
                            <tr>
                                <th>Member status</th>
                                <td><span class="@GetBooleanBadgeClass(eligibilityAssessment.IsMemberActive)">@GetEligibilityCheckLabel(eligibilityAssessment.IsMemberActive, "Active", "Requires review")</span></td>
                            </tr>
                            <tr>
                                <th>Suspension status</th>
                                <td><span class="@GetBooleanBadgeClass(!eligibilityAssessment.IsMemberSuspended)">@(eligibilityAssessment.IsMemberSuspended ? "Suspended" : "Not suspended")</span></td>
                            </tr>
                            <tr>
                                <th>Dependent coverage</th>
                                <td><span class="@GetBooleanBadgeClass(eligibilityAssessment.IsDependentCovered)">@GetDependentCoverageLabel(eligibilityAssessment)</span></td>
                            </tr>
                            <tr>
                                <th>Waiting period</th>
                                <td><span class="@GetBooleanBadgeClass(eligibilityAssessment.WaitingPeriodSatisfied)">@GetEligibilityCheckLabel(eligibilityAssessment.WaitingPeriodSatisfied, "Satisfied", "Requires review")</span></td>
                            </tr>
                            <tr>
                                <th>Contribution arrears</th>
                                <td>
                                    <span class="@GetBooleanBadgeClass(!eligibilityAssessment.HasOutstandingContributionArrears)">
                                        @(eligibilityAssessment.HasOutstandingContributionArrears ? FormatCurrency(eligibilityAssessment.OutstandingContributionBalance) : "None found")
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <th>Outstanding fines</th>
                                <td>
                                    <span class="@GetBooleanBadgeClass(!eligibilityAssessment.HasOutstandingFines)">
                                        @(eligibilityAssessment.HasOutstandingFines ? FormatCurrency(eligibilityAssessment.OutstandingFinesBalance) : "None found")
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <th>Required documents</th>
                                <td><span class="@GetBooleanBadgeClass(eligibilityAssessment.HasRequiredDocuments)">@GetEligibilityCheckLabel(eligibilityAssessment.HasRequiredDocuments, "Death certificate uploaded", "Requires review")</span></td>
                            </tr>
                            <tr>
                                <th>Duplicate active claim</th>
                                <td><span class="@GetBooleanBadgeClass(!eligibilityAssessment.HasDuplicateActiveClaim)">@(eligibilityAssessment.HasDuplicateActiveClaim ? "Found" : "None found")</span></td>
                            </tr>
                            <tr>
                                <th>Assessed at</th>
                                <td>@eligibilityAssessment.AssessedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="sisonke-grid sisonke-grid-3 claim-eligibility-grid">
                    <div>
                        <h3 class="claim-section-mini-title">Passed checks</h3>
                        @if (eligibilityAssessment.PassedChecks.Count == 0)
                        {
                            <p class="text-muted small mb-0">No passed checks recorded.</p>
                        }
                        else
                        {
                            <ul class="claim-check-list">
                                @foreach (var check in eligibilityAssessment.PassedChecks)
                                {
                                    <li>@check</li>
                                }
                            </ul>
                        }
                    </div>
                    <div>
                        <h3 class="claim-section-mini-title">Failed checks</h3>
                        @if (eligibilityAssessment.FailedChecks.Count == 0)
                        {
                            <p class="text-muted small mb-0">No failed checks recorded.</p>
                        }
                        else
                        {
                            <ul class="claim-check-list claim-check-list-danger">
                                @foreach (var check in eligibilityAssessment.FailedChecks)
                                {
                                    <li>@check</li>
                                }
                            </ul>
                        }
                    </div>
                    <div>
                        <h3 class="claim-section-mini-title">Warnings</h3>
                        @if (eligibilityAssessment.Warnings.Count == 0)
                        {
                            <p class="text-muted small mb-0">No warnings recorded.</p>
                        }
                        else
                        {
                            <ul class="claim-check-list claim-check-list-warning">
                                @foreach (var warning in eligibilityAssessment.Warnings)
                                {
                                    <li>@warning</li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (canViewClaim)
    {
        <div class="sisonke-alert sisonke-alert-blue mb-4">
            Your claim is being assessed according to society rules.
        </div>
    }

    <div class="sisonke-card mb-4">
        <div class="sisonke-card-head">
            <div>
                <h2>Claim File Checklist</h2>
                <p>Required documents for claim reference @GetClaimReference(claim)</p>
            </div>
            <span class="@GetDocumentChecklistSummaryBadgeClass()">@GetDocumentChecklistSummaryText()</span>
        </div>
        <div class="sisonke-card-body">
            <div class="table-responsive mb-3">
                <table class="sisonke-table mb-0">
                    <tbody>
                        <tr>
                            <th>Claim reference</th>
                            <td>@GetClaimReference(claim)</td>
                        </tr>
                        <tr>
                            <th>Claim status</th>
                            <td><span class="@GetClaimStatusBadgeClass(claim.Status)">@claim.Status</span></td>
                        </tr>
                        <tr>
                            <th>Secretary recommendation</th>
                            <td><span class="@GetRecommendationBadgeClass(claim.SecretaryRecommendedApproval)">@GetRecommendationLabel(claim.SecretaryRecommendedApproval)</span></td>
                        </tr>
                        <tr>
                            <th>Chairperson decision</th>
                            <td>@GetChairpersonDecisionLabel(claim)</td>
                        </tr>
                        <tr>
                            <th>Treasurer payout reference</th>
                            <td>@(claim.PayoutReference ?? GetDefaultPayoutReference(claim))</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="table-responsive">
                <table class="sisonke-table mb-0">
                    <thead>
                        <tr>
                            <th>Document Type</th>
                            <th>Required</th>
                            <th>Submitted</th>
                            <th>Status</th>
                            <th>File Name</th>
                            <th>Uploaded At</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in claimDocumentChecklist)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@item.DocumentType</div>
                                    <div class="text-muted small">@item.Description</div>
                                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                                    {
                                        <div class="text-muted small">@item.Notes</div>
                                    }
                                </td>
                                <td><span class="@GetBooleanBadgeClass(item.IsRequired)">@(item.IsRequired ? "Required" : "Optional")</span></td>
                                <td><span class="@GetBooleanBadgeClass(item.IsSubmitted)">@(item.IsSubmitted ? "Submitted" : "Missing")</span></td>
                                <td><span class="@GetDocumentChecklistStatusBadgeClass(item.Status)">@item.Status</span></td>
                                <td>@(item.FileName ?? "-")</td>
                                <td>@(item.UploadedAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Claim Workflow Timeline -->
    <div class="sisonke-card mb-4">
        <div class="sisonke-card-head">
            <div>
                <h2>Claim Workflow</h2>
                <p>Progress of this claim through each review stage.</p>
            </div>
            <span class="@GetClaimStatusBadgeClass(claim.Status)">@claim.Status</span>
        </div>
        <div class="sisonke-card-body">
            <div class="claim-timeline">

                @{
                    var tlSubmitted = claim.SubmittedAt is not null;
                }
                <div class="claim-timeline-step @(tlSubmitted ? "claim-timeline-complete" : "claim-timeline-pending")">
                    <div class="claim-timeline-top">
                        <div class="claim-timeline-dot">
                            @if (tlSubmitted) { <i class="bi bi-check-lg" aria-hidden="true"></i> } else { <span>1</span> }
                        </div>
                        <div class="claim-timeline-connector"></div>
                    </div>
                    <div class="claim-timeline-body">
                        <div class="claim-timeline-title">Claim Submitted</div>
                        <span class="@(tlSubmitted ? "sisonke-badge sisonke-badge-green" : "sisonke-badge sisonke-badge-gold")">@(tlSubmitted ? "Complete" : "Pending")</span>
                        @if (tlSubmitted)
                        {
                            <div class="claim-timeline-meta">
                                @if (claim.SubmittedAt is not null) { <span>@claim.SubmittedAt.Value.ToLocalTime().ToString("dd MMM yyyy")</span> }
                                @if (!string.IsNullOrWhiteSpace(claim.SubmittedByName)) { <span>By @claim.SubmittedByName</span> }
                            </div>
                        }
                    </div>
                </div>

                @{
                    var tlSecDone = claim.SecretaryReviewedAt is not null;
                    var tlSecPending = !tlSecDone && tlSubmitted;
                }
                <div class="claim-timeline-step @(tlSecDone ? "claim-timeline-complete" : tlSecPending ? "claim-timeline-pending" : "claim-timeline-not-started")">
                    <div class="claim-timeline-top">
                        <div class="claim-timeline-dot">
                            @if (tlSecDone) { <i class="bi bi-check-lg" aria-hidden="true"></i> }
                            else if (tlSecPending) { <i class="bi bi-hourglass-split" aria-hidden="true"></i> }
                            else { <span>2</span> }
                        </div>
                        <div class="claim-timeline-connector"></div>
                    </div>
                    <div class="claim-timeline-body">
                        <div class="claim-timeline-title">Secretary Review</div>
                        <span class="@(tlSecDone ? "sisonke-badge sisonke-badge-green" : tlSecPending ? "sisonke-badge sisonke-badge-gold" : "sisonke-badge sisonke-badge-gray")">@(tlSecDone ? "Complete" : tlSecPending ? "Pending" : "Not started")</span>
                        @if (tlSecDone)
                        {
                            <div class="claim-timeline-meta">
                                @if (claim.SecretaryReviewedAt is not null) { <span>@claim.SecretaryReviewedAt.Value.ToLocalTime().ToString("dd MMM yyyy")</span> }
                                @if (!string.IsNullOrWhiteSpace(claim.SecretaryReviewedByName)) { <span>By @claim.SecretaryReviewedByName</span> }
                                @if (claim.SecretaryRecommendedApproval is not null)
                                {
                                    <span>@(claim.SecretaryRecommendedApproval.Value ? "Recommended" : "Not recommended")</span>
                                }
                            </div>
                        }
                    </div>
                </div>

                @{
                    var tlChairDone = claim.ChairpersonDecisionAt is not null;
                    var tlChairRejected = tlChairDone && claim.Status == FuneralClaimStatus.Rejected;
                    var tlChairApproved = tlChairDone && claim.Status is (FuneralClaimStatus.Approved or FuneralClaimStatus.Paid);
                    var tlChairPending = !tlChairDone && tlSecDone;
                }
                <div class="claim-timeline-step @(tlChairRejected ? "claim-timeline-rejected" : tlChairApproved ? "claim-timeline-complete" : tlChairPending ? "claim-timeline-pending" : "claim-timeline-not-started")">
                    <div class="claim-timeline-top">
                        <div class="claim-timeline-dot">
                            @if (tlChairRejected) { <i class="bi bi-x-lg" aria-hidden="true"></i> }
                            else if (tlChairApproved) { <i class="bi bi-check-lg" aria-hidden="true"></i> }
                            else if (tlChairPending) { <i class="bi bi-hourglass-split" aria-hidden="true"></i> }
                            else { <span>3</span> }
                        </div>
                        <div class="claim-timeline-connector"></div>
                    </div>
                    <div class="claim-timeline-body">
                        <div class="claim-timeline-title">Chairperson Decision</div>
                        <span class="@(tlChairRejected ? "sisonke-badge sisonke-badge-red" : tlChairApproved ? "sisonke-badge sisonke-badge-green" : tlChairPending ? "sisonke-badge sisonke-badge-gold" : "sisonke-badge sisonke-badge-gray")">@(tlChairRejected ? "Rejected" : tlChairApproved ? "Approved" : tlChairPending ? "Pending" : "Not started")</span>
                        @if (tlChairDone)
                        {
                            <div class="claim-timeline-meta">
                                @if (claim.ChairpersonDecisionAt is not null) { <span>@claim.ChairpersonDecisionAt.Value.ToLocalTime().ToString("dd MMM yyyy")</span> }
                                @if (!string.IsNullOrWhiteSpace(claim.ChairpersonDecisionByName)) { <span>By @claim.ChairpersonDecisionByName</span> }
                            </div>
                        }
                    </div>
                </div>

                @{
                    var tlPayoutDone = claim.PayoutPaidAt is not null;
                    var tlPayoutPending = !tlPayoutDone && IsChairpersonApprovedForPayout(claim);
                    var tlPayoutNA = claim.Status is FuneralClaimStatus.Rejected or FuneralClaimStatus.Cancelled;
                }
                <div class="claim-timeline-step @(tlPayoutDone ? "claim-timeline-complete" : tlPayoutPending ? "claim-timeline-pending" : "claim-timeline-not-started")">
                    <div class="claim-timeline-top">
                        <div class="claim-timeline-dot">
                            @if (tlPayoutDone) { <i class="bi bi-check-lg" aria-hidden="true"></i> }
                            else if (tlPayoutPending) { <i class="bi bi-hourglass-split" aria-hidden="true"></i> }
                            else { <span>4</span> }
                        </div>
                        <div class="claim-timeline-connector"></div>
                    </div>
                    <div class="claim-timeline-body">
                        <div class="claim-timeline-title">Treasurer Payout</div>
                        <span class="@(tlPayoutDone ? "sisonke-badge sisonke-badge-green" : tlPayoutNA ? "sisonke-badge sisonke-badge-gray" : tlPayoutPending ? "sisonke-badge sisonke-badge-gold" : "sisonke-badge sisonke-badge-gray")">@(tlPayoutDone ? "Paid" : tlPayoutNA ? "N/A" : tlPayoutPending ? "Pending" : "Not started")</span>
                        @if (tlPayoutDone)
                        {
                            <div class="claim-timeline-meta">
                                @if (claim.PayoutPaidAt is not null) { <span>@claim.PayoutPaidAt.Value.ToLocalTime().ToString("dd MMM yyyy")</span> }
                                @if (!string.IsNullOrWhiteSpace(payoutCapturedByMemberName)) { <span>By @payoutCapturedByMemberName</span> }
                                @if (!string.IsNullOrWhiteSpace(claim.PayoutReference)) { <span>Ref: @claim.PayoutReference</span> }
                            </div>
                        }
                    </div>
                </div>

                @{
                    var tlClosedPaid = claim.Status == FuneralClaimStatus.Paid;
                    var tlClosedRejected = claim.Status == FuneralClaimStatus.Rejected;
                    var tlClosedCancelled = claim.Status == FuneralClaimStatus.Cancelled;
                }
                <div class="claim-timeline-step @(tlClosedPaid ? "claim-timeline-complete" : tlClosedRejected ? "claim-timeline-rejected" : "claim-timeline-not-started")">
                    <div class="claim-timeline-top">
                        <div class="claim-timeline-dot">
                            @if (tlClosedPaid) { <i class="bi bi-check-lg" aria-hidden="true"></i> }
                            else if (tlClosedRejected) { <i class="bi bi-x-lg" aria-hidden="true"></i> }
                            else { <span>5</span> }
                        </div>
                        <div class="claim-timeline-connector"></div>
                    </div>
                    <div class="claim-timeline-body">
                        <div class="claim-timeline-title">Closed / Paid</div>
                        <span class="@(tlClosedPaid ? "sisonke-badge sisonke-badge-green" : tlClosedRejected ? "sisonke-badge sisonke-badge-red" : tlClosedCancelled ? "sisonke-badge sisonke-badge-gray" : "sisonke-badge sisonke-badge-gray")">@(tlClosedPaid ? "Paid" : tlClosedRejected ? "Rejected" : tlClosedCancelled ? "Cancelled" : "Not started")</span>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="sisonke-grid sisonke-grid-2 claim-page-grid">
        <div class="sisonke-card h-100">
            <div class="sisonke-card-body">
                    <div class="sisonke-card-head">
                        <div>
                            <h2>Claim Information</h2>
                            <p>Current claim details and eligibility checks.</p>
                        </div>
                    </div>
                    <dl class="claim-dl">
                        <div class="claim-dl-row"><dt>Deceased full name</dt><dd>@claim.DeceasedFullName</dd></div>
                        <div class="claim-dl-row"><dt>Claim subject type</dt><dd>@claim.SubjectType</dd></div>
                        <div class="claim-dl-row"><dt>Member name</dt><dd>@claim.Member.FullName</dd></div>
                        @if (claim.Dependent is not null)
                        {
                            <div class="claim-dl-row"><dt>Dependent name</dt><dd>@claim.Dependent.FullName</dd></div>
                        }
                        <div class="claim-dl-row"><dt>Date of death</dt><dd>@(claim.DateOfDeath?.ToString("dd MMM yyyy") ?? "-")</dd></div>
                        <div class="claim-dl-row">
                            <dt>Claim status</dt>
                            <dd><span class="@GetClaimStatusBadgeClass(claim.Status)">@claim.Status</span></dd>
                        </div>
                        <div class="claim-dl-row">
                            <dt>Waiting period satisfied</dt>
                            <dd><span class="@GetBooleanBadgeClass(claim.IsWaitingPeriodSatisfied)">@(claim.IsWaitingPeriodSatisfied ? "Yes" : "No")</span></dd>
                        </div>
                        <div class="claim-dl-row">
                            <dt>Member status eligible</dt>
                            <dd><span class="@GetBooleanBadgeClass(claim.IsMemberStatusEligible)">@(claim.IsMemberStatusEligible ? "Yes" : "No")</span></dd>
                        </div>
                        <div class="claim-dl-row"><dt>Claim reason</dt><dd>@(claim.ClaimReason ?? "-")</dd></div>
                        <div class="claim-dl-row last"><dt>Review notes</dt><dd>@(claim.ReviewNotes ?? "-")</dd></div>
                    </dl>
            </div>
        </div>

        <div class="sisonke-card h-100">
            <div class="sisonke-card-body">
                    <div class="sisonke-card-head">
                        <div>
                            <h2>Claim Actions</h2>
                            <p>Submit, review and decide claims according to your role.</p>
                        </div>
                    </div>

                    @if (canAttemptSubmitClaim)
                    {
                        <button class="sisonke-btn sisonke-btn-primary w-100 mb-4" type="button" @onclick="SubmitClaimAsync" disabled="@(!canSubmitClaim)">
                            <i class="bi bi-send me-2"></i>Submit Claim
                        </button>
                    }

                    <div class="workflow-section">
                        <div class="sisonke-card-head compact">
                            <div>
                                <h2>Secretary Review</h2>
                                <p>Administrative review and recommendation.</p>
                            </div>
                        </div>

                        @if (claim.SecretaryReviewedAt is not null)
                        {
                            <dl class="claim-dl mb-3">
                                <div class="claim-dl-row">
                                    <dt>Review status</dt>
                                    <dd><span class="sisonke-badge sisonke-badge-green">Complete</span></dd>
                                </div>
                                <div class="claim-dl-row">
                                    <dt>Recommendation</dt>
                                    <dd><span class="@GetRecommendationBadgeClass(claim.SecretaryRecommendedApproval)">@GetRecommendationLabel(claim.SecretaryRecommendedApproval)</span></dd>
                                </div>
                                <div class="claim-dl-row"><dt>Reviewed by</dt><dd>@(claim.SecretaryReviewedByName ?? "-")</dd></div>
                                <div class="claim-dl-row"><dt>Reviewed at</dt><dd>@claim.SecretaryReviewedAt.Value.ToString("dd MMM yyyy HH:mm")</dd></div>
                                <div class="claim-dl-row last"><dt>Notes</dt><dd>@(claim.SecretaryReviewNotes ?? "-")</dd></div>
                            </dl>
                        }

                        @if (canCompleteSecretaryReview)
                        {
                            @if (HasMissingRequiredDocuments)
                            {
                                <div class="sisonke-alert sisonke-alert-gold mb-3">
                                    Some required claim documents are missing. Please review before making a recommendation.
                                </div>
                            }

                            @if (eligibilityAssessment is not null)
                            {
                                <div class="sisonke-alert sisonke-alert-@GetEligibilityAlertClass(eligibilityAssessment.EligibilityStatus) mb-3">
                                    <strong>Eligibility status:</strong> @FormatEligibilityStatus(eligibilityAssessment.EligibilityStatus)
                                </div>

                                @if (RequiresEligibilityReview(eligibilityAssessment))
                                {
                                    <div class="sisonke-alert sisonke-alert-gold mb-3">
                                        Please review the eligibility findings before making a recommendation.
                                    </div>
                                }
                            }

                            <EditForm Model="@secretaryReviewModel" OnValidSubmit="@SaveSecretaryReviewAsync" FormName="SecretaryReviewForm">
                                <DataAnnotationsValidator />

                                <div class="mb-3">
                                    <label class="form-label" for="secretary-recommendation">Recommendation</label>
                                    <InputSelect id="secretary-recommendation" class="form-select" @bind-Value="secretaryReviewModel.Recommendation">
                                        <option value="">Select recommendation</option>
                                        <option value="true">Yes – Recommend for approval</option>
                                        <option value="false">No – Do not recommend for approval</option>
                                    </InputSelect>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label" for="secretary-review-notes">Review Notes</label>
                                    <InputTextArea id="secretary-review-notes" class="form-control" rows="3" @bind-Value="secretaryReviewModel.ReviewNotes" />
                                </div>

                                <button class="sisonke-btn sisonke-btn-outline" type="submit"
                                    disabled="@(string.IsNullOrWhiteSpace(secretaryReviewModel.Recommendation) || string.IsNullOrWhiteSpace(secretaryReviewModel.ReviewNotes))">
                                    <i class="bi bi-clipboard-check me-2"></i>Complete Review
                                </button>
                            </EditForm>
                        }
                    </div>

                    <div class="workflow-section">
                        <div class="sisonke-card-head compact">
                            <div>
                                <h2>Chairperson Decision</h2>
                                <p>Final claim outcome and decision notes.</p>
                            </div>
                        </div>

                        @if (claim.SecretaryReviewedAt is not null)
                        {
                            <div class="sisonke-alert sisonke-alert-@GetRecommendationAlertClass(claim.SecretaryRecommendedApproval) mb-3">
                                <strong>Secretary recommendation:</strong> @GetRecommendationLabel(claim.SecretaryRecommendedApproval)
                            </div>
                        }

                        @if (claim.ChairpersonDecisionAt is not null)
                        {
                            <dl class="claim-dl mb-3">
                                <div class="claim-dl-row"><dt>Decision by</dt><dd>@(claim.ChairpersonDecisionByName ?? "-")</dd></div>
                                <div class="claim-dl-row"><dt>Decision at</dt><dd>@claim.ChairpersonDecisionAt.Value.ToString("dd MMM yyyy HH:mm")</dd></div>
                                <div class="claim-dl-row last"><dt>Decision notes</dt><dd>@(claim.ChairpersonDecisionNotes ?? "-")</dd></div>
                            </dl>
                        }

                        @if (canMakeChairpersonDecision)
                        {
                            @if (HasMissingRequiredDocuments)
                            {
                                <div class="sisonke-alert sisonke-alert-gold mb-3">
                                    Required documents may be missing. Chairperson decision is still required.
                                </div>
                            }

                            @if (eligibilityAssessment is not null)
                            {
                                <div class="sisonke-alert sisonke-alert-@GetEligibilityAlertClass(eligibilityAssessment.EligibilityStatus) mb-3">
                                    <strong>Eligibility status:</strong> @FormatEligibilityStatus(eligibilityAssessment.EligibilityStatus)
                                </div>

                                @if (HasEligibilityFindings(eligibilityAssessment))
                                {
                                    <div class="sisonke-alert sisonke-alert-gold mb-3">
                                        This claim has eligibility findings. Chairperson decision is still required.
                                    </div>
                                }
                            }

                            <EditForm Model="@chairpersonDecisionModel" FormName="ChairpersonDecisionForm">
                                <DataAnnotationsValidator />

                                <div class="mb-3">
                                    <label class="form-label" for="chairperson-decision-notes">Decision Notes</label>
                                    <InputTextArea id="chairperson-decision-notes" class="form-control" rows="3" @bind-Value="chairpersonDecisionModel.DecisionNotes" />
                                </div>

                                <div class="d-flex gap-2 flex-wrap">
                                    <button class="sisonke-btn sisonke-btn-primary" type="button" @onclick="ShowApproveConfirmation">
                                        <i class="bi bi-check2-circle me-2"></i>Approve Claim
                                    </button>
                                    <button class="sisonke-btn sisonke-btn-outline" type="button" @onclick="ShowRejectConfirmation">
                                        <i class="bi bi-x-circle me-2"></i>Reject Claim
                                    </button>
                                </div>
                            </EditForm>
                        }
                    </div>

                    @if (ShouldShowPayoutSection)
                    {
                        <div class="workflow-section">
                            <div class="sisonke-card-head compact">
                                <div>
                                    <h2>Treasurer Payout</h2>
                                    <p>Approved claim payout status and payment capture.</p>
                                </div>
                            </div>

                            @if (claim.Status == FuneralClaimStatus.Approved && claim.ChairpersonDecisionAt is not null)
                            {
                                <div class="sisonke-alert sisonke-alert-gold mb-3">
                                    This approved claim is awaiting treasurer payout.
                                </div>
                            }
                            else if (claim.Status == FuneralClaimStatus.Paid)
                            {
                                <div class="sisonke-alert sisonke-alert-green mb-3">
                                    This claim payout has been marked paid.
                                </div>
                            }

                            <dl class="claim-dl mb-3">
                                <div class="claim-dl-row"><dt>Payout amount</dt><dd>@(claim.PayoutAmount?.ToString("C0", new System.Globalization.CultureInfo("en-ZA")) ?? "-")</dd></div>
                                <div class="claim-dl-row"><dt>Payout reference</dt><dd>@(claim.PayoutReference ?? "-")</dd></div>
                                <div class="claim-dl-row"><dt>Payout paid date</dt><dd>@(claim.PayoutPaidAt?.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "-")</dd></div>
                                <div class="claim-dl-row"><dt>Payout notes</dt><dd>@(claim.PayoutNotes ?? "-")</dd></div>
                                <div class="claim-dl-row last"><dt>Captured by</dt><dd>@(payoutCapturedByMemberName ?? "-")</dd></div>
                            </dl>

                            @if (CanCapturePayout)
                            {
                                <EditForm Model="@payoutModel" OnValidSubmit="@MarkPayoutPaidAsync" FormName="ClaimPayoutForm">
                                    <DataAnnotationsValidator />

                                    <div class="row g-3">
                                        <div class="col-12 col-md-6">
                                            <label class="form-label" for="payout-amount">Payout amount</label>
                                            <InputNumber id="payout-amount" class="form-control" @bind-Value="payoutModel.PayoutAmount" />
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label" for="payout-reference">Payout reference</label>
                                            <InputText id="payout-reference" class="form-control" @bind-Value="payoutModel.PayoutReference" />
                                        </div>
                                        <div class="col-12">
                                            <label class="form-label" for="payout-notes">Notes</label>
                                            <InputTextArea id="payout-notes" class="form-control" rows="3" @bind-Value="payoutModel.PayoutNotes" />
                                        </div>
                                    </div>

                                    <button class="sisonke-btn sisonke-btn-gold mt-3" type="submit" disabled="@(!CanSubmitPayout)">
                                        <i class="bi bi-cash-coin me-2"></i>Mark Payout Paid
                                    </button>
                                </EditForm>
                            }
                        </div>
                    }
            </div>
        </div>

        @if (canViewPayoutAuditTrail)
        {
            <div class="sisonke-card claim-audit-card">
                <div class="sisonke-card-body">
                    <div class="sisonke-card-head">
                        <div>
                            <h2>Payout Audit Trail</h2>
                            <p>Recorded payout actions for this claim.</p>
                        </div>
                    </div>

                    @if (payoutAuditTrail.Count == 0)
                    {
                        <div class="sisonke-alert sisonke-alert-blue mb-0">No payout audit records have been captured yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="sisonke-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Date/time</th>
                                        <th>Action</th>
                                        <th>Previous amount</th>
                                        <th>New amount</th>
                                        <th>Previous status</th>
                                        <th>New status</th>
                                        <th>Reference</th>
                                        <th>Notes</th>
                                        <th>Captured by</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var audit in payoutAuditTrail)
                                    {
                                        <tr>
                                            <td class="text-muted small">@audit.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</td>
                                            <td><span class="sisonke-badge sisonke-badge-gold">@audit.Action</span></td>
                                            <td>@FormatCurrency(audit.PreviousPayoutAmount)</td>
                                            <td>@FormatCurrency(audit.NewPayoutAmount)</td>
                                            <td>@(audit.PreviousStatus ?? "-")</td>
                                            <td>@(audit.NewStatus ?? "-")</td>
                                            <td>@(audit.PayoutReference ?? "-")</td>
                                            <td>@(audit.Notes ?? "-")</td>
                                            <td>@(audit.CapturedByMember?.FullName ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="sisonke-card claim-documents-card">
            <div class="sisonke-card-body">
                    <div class="sisonke-card-head">
                        <div>
                            <h2>Required Documents</h2>
                            <p>Uploaded/submitted documents attached to claim reference @GetClaimReference(claim).</p>
                        </div>
                    </div>

                    <div class="sisonke-card-head compact">
                        <div>
                            <h2>Documents</h2>
                            <p>Upload and view supporting claim documents.</p>
                        </div>
                    </div>

                    @if (canUploadDocuments)
                    {
                        <div class="row g-3 align-items-end mb-4">
                            <div class="col-12 col-md-4">
                                <label class="form-label" for="document-type">Document type</label>
                                <InputSelect id="document-type" class="form-select" @bind-Value="selectedDocumentType">
                                    @foreach (var documentType in Enum.GetValues<ClaimDocumentType>())
                                    {
                                        <option value="@documentType">@documentType</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-12 col-md-5">
                                <label class="form-label" for="claim-document">Document</label>
                                <InputFile id="claim-document" class="form-control" OnChange="@OnFileSelected" />
                            </div>
                            <div class="col-12 col-md-3">
                                <button class="sisonke-btn sisonke-btn-primary w-100" type="button" @onclick="UploadDocumentAsync">
                                    <i class="bi bi-upload me-2"></i>Upload
                                </button>
                            </div>
                        </div>
                    }

                    @if (claim.Documents.Count == 0)
                    {
                        <div class="sisonke-alert sisonke-alert-blue mb-0">No documents uploaded yet.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="sisonke-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Document type</th>
                                        <th>Original file name</th>
                                        <th>Uploaded date</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var document in claim.Documents.OrderByDescending(document => document.UploadedAt))
                                    {
                                        <tr>
                                            <td>@document.DocumentType</td>
                                            <td class="text-muted small">@document.OriginalFileName</td>
                                            <td class="text-muted small">@document.UploadedAt.ToString("dd MMM yyyy")</td>
                                            <td>
                                                <a class="sisonke-btn sisonke-btn-outline" href="@document.StoredFilePath" target="_blank" rel="noopener noreferrer">Open</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

    <ConfirmationModal
        IsVisible="@showApproveConfirmation"
        Title="Approve Claim"
        Message="Are you sure you want to approve this claim?"
        ConfirmButtonText="Approve Claim"
        CancelButtonText="Cancel"
        ModalType="success"
        OnConfirm="@ConfirmApproveClaimAsync"
        OnCancel="@HideApproveConfirmation" />

    <ConfirmationModal
        IsVisible="@showRejectConfirmation"
        Title="Reject Claim"
        Message="Are you sure you want to reject this claim?"
        ConfirmButtonText="Reject Claim"
        CancelButtonText="Cancel"
        ModalType="danger"
        OnConfirm="@ConfirmRejectClaimAsync"
        OnCancel="@HideRejectConfirmation" />
}

<style>
    .claim-page-grid {
        align-items: stretch;
    }

    .claim-documents-card,
    .claim-audit-card {
        grid-column: 1 / -1;
    }

    .claim-hero-content {
        display: grid;
        gap: .75rem;
    }

    .claim-hero-badges {
        display: flex;
        flex-wrap: wrap;
        gap: .5rem;
    }

    .claim-hero-meta {
        display: grid;
        gap: .75rem;
        min-width: min(18rem, 100%);
        padding: 1rem;
        border: 1px solid rgb(255 255 255 / .28);
        border-radius: var(--r-md);
        background: rgb(255 255 255 / .12);
    }

    .claim-hero-meta div {
        display: grid;
        gap: .15rem;
    }

    .claim-hero-meta span {
        color: rgb(255 255 255 / .78);
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .claim-hero-meta strong {
        color: #fff;
        font-size: .98rem;
    }

    .sisonke-card-head.compact {
        margin-top: .25rem;
        margin-bottom: 1rem;
        padding-bottom: .75rem;
    }

    .claim-dl { margin: 0; }
    .claim-dl-row {
        display: flex;
        gap: 1rem;
        padding: .625rem 0;
        border-bottom: 1px solid var(--border);
        font-size: .9rem;
    }
    .claim-dl-row.last { border-bottom: none; }
    .claim-dl-row dt {
        flex: 0 0 42%;
        color: var(--muted);
        font-size: .875rem;
        font-weight: 400;
    }
    .claim-dl-row dd {
        flex: 1;
        margin: 0;
        color: var(--text);
        font-weight: 500;
    }
    .workflow-section {
        border-top: 1px solid var(--border);
        margin-top: 1.25rem;
        padding-top: 1.25rem;
    }
