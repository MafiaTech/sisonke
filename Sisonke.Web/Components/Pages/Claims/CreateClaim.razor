@page "/create-claim/{MemberId:guid}"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Sisonke.Web.Data
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Data.Enums
@using Sisonke.Web.Services

@inject FuneralClaimService FuneralClaimService
@inject StokvelOperatingRulesService StokvelOperatingRulesService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MemberAccessService MemberAccessService
@inject NavigationManager NavigationManager
@inject IServiceScopeFactory ScopeFactory

<PageTitle>Create Funeral Claim</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading claim form...
    </div>
}
else if (member is null)
{
    <AlertBanner Type="danger" Title="Member not found." Message="" Icon="bi bi-x-circle-fill" />
}
else if (!IsClaimsAvailable)
{
    <AlertBanner
        Type="warning"
        Title="Claims are not enabled for this stokvel type."
        Message="@GetClaimsDisabledMessage()"
        Icon="bi bi-exclamation-triangle-fill" />

    <a class="sisonke-btn sisonke-btn-outline" href="@($"/member-profile/{MemberId}")">
        <i class="bi bi-arrow-left me-2"></i>Back to Member Profile
    </a>
}
else if (!canCreateClaim)
{
    <AlertBanner
        Type="warning"
        Title="You do not have permission to create a claim for this member."
        Message="Members can submit their own claims. Office bearers can assist members with claims."
        Icon="bi bi-exclamation-triangle-fill" />

    <a class="sisonke-btn sisonke-btn-outline" href="@($"/member-profile/{MemberId}")">
        <i class="bi bi-arrow-left me-2"></i>Back to Member Profile
    </a>
}
else
{
    <section class="sisonke-hero-card mb-4">
        <div>
            <span class="sisonke-badge sisonke-badge-gold">Funeral Claim</span>
            <h1>Create Funeral Claim</h1>
            <p>Capture claim details and supporting documents.</p>
        </div>
        <div class="claim-hero-meta">
            <span>Member</span>
            <strong>@member.FullName</strong>
        </div>
    </section>

    @if (saveFailed)
    {
        <AlertBanner
            Type="danger"
            Title="Could not create claim."
            Message="Please check the claim details."
            Icon="bi bi-x-circle-fill" />
    }

    <div class="form-page">
        <div class="sisonke-card">
            <div class="sisonke-card-body">
                <div class="sisonke-alert sisonke-alert-blue mb-3">
                    Waiting period: new members or newly covered lives may be subject to the society waiting period before claims are payable.
                </div>
                <div class="sisonke-alert sisonke-alert-gold mb-3">
                    Required death certificate guidance: create the claim first, then upload the official death certificate on the claim details page before submitting it for review.
                </div>
                <div class="sisonke-alert sisonke-alert-blue mb-3">
                    Contribution status will be checked on the claim details page once the claim is created.
                </div>
                <div class="sisonke-card mb-3">
                    <div class="sisonke-card-body">
                        <div class="sisonke-card-head px-0 pt-0">
                            <div>
                                <h2>Claim Summary</h2>
                                <p>Review the burial claim implication before creating the claim.</p>
                            </div>
                            <span class="sisonke-badge sisonke-badge-gold">@model.ClaimType</span>
                        </div>
                        <div class="sisonke-grid sisonke-grid-4">
                            @SummaryTile("Claim For", GetSelectedSubjectName())
                            @SummaryTile("Configured Benefit", FormatCurrency(GetConfiguredBenefitAmount()))
                            @SummaryTile("Member Waiting Period", $"{operatingRules?.MemberWaitingPeriodMonths ?? 0} months")
                            @SummaryTile("Dependent Waiting Period", $"{operatingRules?.DependentWaitingPeriodMonths ?? 0} months")
                        </div>
                    </div>
                </div>
                <EditForm Model="@model" OnValidSubmit="@HandleValidSubmit" FormName="CreateFuneralClaimForm">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="alert alert-danger" />

                    <div class="sisonke-card-head">
                        <div>
                            <h2>Claim Details</h2>
                            <p>Select whether this claim is for the member or a covered dependent.</p>
                        </div>
                    </div>

                    <div class="sisonke-grid sisonke-grid-2">
                        <div class="member-form-field">
                            <label class="form-label" for="claim-type">Claim Type</label>
                            <InputSelect id="claim-type" class="form-select" @bind-Value="model.ClaimType">
                                <option value="@ClaimType.Funeral">Funeral</option>
                                <option value="@ClaimType.MemberDeath">Member Death</option>
                                <option value="@ClaimType.BeneficiaryDeath">Beneficiary Death</option>
                                <option value="@ClaimType.EmergencySupport">Emergency Support</option>
                                <option value="@ClaimType.Other">Other</option>
                            </InputSelect>
                        </div>

                        <div class="member-form-field">
                            <label class="form-label" for="subject-type">Subject Type</label>
                            <InputSelect id="subject-type" class="form-select" @bind-Value="model.SubjectType">
                                <option value="@FuneralClaimSubjectType.Member">Member</option>
                                <option value="@FuneralClaimSubjectType.Dependent">Dependent</option>
                            </InputSelect>
                        </div>

                        @if (model.SubjectType == FuneralClaimSubjectType.Dependent)
                        {
                            <div class="member-form-field">
                                <label class="form-label" for="dependent">Dependent</label>
                                <InputSelect id="dependent" class="form-select" @bind-Value="model.SelectedDependentId">
                                    <option value="">Select dependent</option>
                                    @foreach (var dependent in dependents)
                                    {
                                        <option value="@dependent.Id">@dependent.FullName</option>
                                    }
                                </InputSelect>
                            </div>
                        }

                        <div class="member-form-field">
                            <label class="form-label" for="date-of-death">Date of Death</label>
                            <InputDate id="date-of-death" class="form-control" @bind-Value="model.DateOfDeath" />
                        </div>

                        <div class="member-form-field claim-form-wide">
                            <label class="form-label" for="claim-reason">Claim Reason</label>
                            <InputTextArea id="claim-reason" class="form-control" rows="4" @bind-Value="model.ClaimReason" />
                        </div>
                    </div>

                    <div class="member-form-actions mt-4">
                        <button class="sisonke-btn sisonke-btn-primary" type="submit">
                            <i class="bi bi-file-earmark-plus me-2"></i>Create Claim
                        </button>
                        <a class="sisonke-btn sisonke-btn-outline" href="@($"/member-profile/{MemberId}")">Cancel / Back</a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<style>
    .claim-hero-meta {
        display: grid;
        gap: .25rem;
        min-width: 14rem;
        padding: 1rem;
        border: 1px solid rgb(255 255 255 / .28);
        border-radius: var(--r-md);
        background: rgb(255 255 255 / .12);
    }

    .claim-hero-meta span {
        color: rgb(255 255 255 / .78);
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .claim-hero-meta strong {
        color: #fff;
        font-size: 1.05rem;
    }

    .claim-form-wide {
        grid-column: 1 / -1;
    }

    .claim-summary-tile {
        display: grid;
        gap: .25rem;
        min-height: 5.5rem;
        padding: .9rem;
        border: 1px solid var(--sk-border);
        border-radius: var(--r-md);
        background: var(--sk-surface-muted);
    }

    .claim-summary-tile span {
        color: var(--sk-muted);
        font-size: .82rem;
        font-weight: 700;
    }

    .claim-summary-tile strong {
        color: var(--sk-ink);
        font-size: 1.05rem;
    }
</style>

@code {
    private Member? member;
    private Stokvel? stokvel;
    private StokvelOperatingRules? operatingRules;
    private List<MemberDependent> dependents = [];
    private CreateClaimModel model = new();
    private bool isLoading = true;
    private bool saveFailed;
    private bool canCreateClaim;
    private bool hasAppliedRouteState;
    private bool IsClaimsAvailable => stokvel is not null &&
        (stokvel.Archetype == StokvelArchetype.BurialSociety || stokvel.EnableClaims);
    private bool IsDependentsAvailable => stokvel is not null &&
        (stokvel.Archetype == StokvelArchetype.BurialSociety || stokvel.EnableDependents);

    [Parameter]
    public Guid MemberId { get; set; }

    [SupplyParameterFromQuery]
    public Guid? DependentId { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        member = await LoadMemberAsync();
        stokvel = member is null ? null : await LoadStokvelAsync(member.TenantId);
        operatingRules = stokvel is null
            ? null
            : await StokvelOperatingRulesService.GetOrCreateDefaultRulesAsync(stokvel.Id, stokvel.Type.ToString(), null);
        dependents = member is null || !IsDependentsAvailable ? [] : await LoadDependentsAsync();
        canCreateClaim = await CanCreateClaimAsync();

        if (!hasAppliedRouteState)
        {
            model.SubjectType = DependentId.HasValue
                ? FuneralClaimSubjectType.Dependent
                : FuneralClaimSubjectType.Member;
            model.SelectedDependentId = DependentId;
            hasAppliedRouteState = true;
        }

        isLoading = false;
    }

    private async Task<Member?> LoadMemberAsync()
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

        return await db.Members
            .AsNoTracking()
            .Include(existingMember => existingMember.Tenant)
            .FirstOrDefaultAsync(existingMember => existingMember.Id == MemberId);
    }

    private async Task<List<MemberDependent>> LoadDependentsAsync()
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

        return await db.MemberDependents
            .AsNoTracking()
            .Where(dependent => dependent.MemberId == MemberId)
            .OrderBy(dependent => dependent.FullName)
            .ToListAsync();
    }

    private async Task<Stokvel?> LoadStokvelAsync(Guid tenantId)
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

        return await db.Stokvels
            .AsNoTracking()
            .Where(existingStokvel => existingStokvel.TenantId == tenantId)
            .OrderBy(existingStokvel => existingStokvel.CreatedAt)
            .ThenBy(existingStokvel => existingStokvel.Name)
            .FirstOrDefaultAsync();
    }

    private async Task<bool> CanCreateClaimAsync()
    {
        if (stokvel is null || member is null)
        {
            return false;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            return false;
        }

        return await MemberAccessService.CanManageStokvelAsync(userId, stokvel.Id) ||
            await MemberAccessService.CanViewOwnMemberProfileAsync(userId, MemberId);
    }

    private async Task HandleValidSubmit()
    {
        saveFailed = false;

        if (!IsClaimsAvailable)
        {
            saveFailed = true;
            return;
        }

        if (!canCreateClaim)
        {
            saveFailed = true;
            return;
        }

        var selectedDependentId = model.SubjectType == FuneralClaimSubjectType.Dependent
            ? model.SelectedDependentId
            : null;

        var claim = await FuneralClaimService.CreateClaimAsync(
            MemberId,
            model.SubjectType,
            selectedDependentId,
            model.DateOfDeath,
            model.ClaimReason,
            model.ClaimType);

        if (claim is null)
        {
            saveFailed = true;
            return;
        }

        NavigationManager.NavigateTo($"/claim/{claim.Id}");
    }

    private string GetClaimsDisabledMessage()
    {
        return stokvel?.Archetype == StokvelArchetype.Rotational
            ? "Claims belong to Burial Society workflows. This rotational stokvel can still use members, contributions, meetings and rotation schedule features."
            : "This group can still use the enabled member, contribution, fine and meeting features.";
    }

    private string GetSelectedSubjectName()
    {
        if (model.SubjectType == FuneralClaimSubjectType.Dependent)
        {
            var dependent = dependents.FirstOrDefault(item => item.Id == model.SelectedDependentId);
            return dependent?.FullName ?? "Covered life";
        }

        return member?.FullName ?? "Member";
    }

    private decimal GetConfiguredBenefitAmount()
    {
        return operatingRules?.DefaultClaimPayoutAmount ?? 0;
    }

    private static string FormatCurrency(decimal amount)
    {
        return amount <= 0
            ? "To be captured"
            : amount.ToString("C0", new System.Globalization.CultureInfo("en-ZA"));
    }

    private static RenderFragment SummaryTile(string label, string value) => @<div class="claim-summary-tile">
        <span>@label</span>
        <strong>@value</strong>
    </div>;

    private sealed class CreateClaimModel
    {
        [Required]
        public ClaimType ClaimType { get; set; } = ClaimType.Funeral;

        [Required]
        public FuneralClaimSubjectType SubjectType { get; set; } = FuneralClaimSubjectType.Member;

        public Guid? SelectedDependentId { get; set; }

        public DateTime? DateOfDeath { get; set; }

        [MaxLength(1000)]
        public string? ClaimReason { get; set; }
    }
}
