@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Sisonke — Stokvel Management</PageTitle>

<AuthorizeView>

    <!-- ══ Logged-in welcome ══════════════════════════════════ -->
    <Authorized>
        <div class="home-welcome">

            <div class="home-greeting-card">
                <div class="home-greeting-inner">
                    <div class="home-greeting-text">
                        <div class="home-greeting-eyebrow">
                            <i class="bi bi-sun-fill me-2" style="color:var(--sk-gold)"></i>
                            Welcome back
                        </div>
                        <h1 class="home-greeting-name">
                            @(context.User.Identity?.Name?.Split('@')[0] ?? "there")
                        </h1>
                        <p class="home-greeting-sub">
                            Manage your stokvels, track contributions, and keep your community's finances on track.
                        </p>
                        <div class="d-flex gap-2 flex-wrap mt-4">
                            <a class="btn btn-accent" href="/my-stokvels">
                                <i class="bi bi-grid-fill me-2"></i>My Stokvels
                            </a>
                            <a class="btn btn-outline-light home-btn-outline" href="/register-stokvel">
                                <i class="bi bi-plus-circle me-2"></i>Register New Stokvel
                            </a>
                        </div>
                    </div>
                    <div class="home-greeting-illustration d-none d-lg-flex">
                        <div class="hgi-icon-stack">
                            <div class="hgi-card hgi-card-1">
                                <i class="bi bi-people-fill"></i>
                                <span>Members</span>
                            </div>
                            <div class="hgi-card hgi-card-2">
                                <i class="bi bi-cash-coin"></i>
                                <span>Contributions</span>
                            </div>
                            <div class="hgi-card hgi-card-3">
                                <i class="bi bi-file-earmark-check"></i>
                                <span>Constitution</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick-action tiles -->
            <div class="row g-3 mt-2">
                <div class="col-6 col-md-3">
                    <a class="home-tile" href="/my-stokvels">
                        <div class="home-tile-icon" style="background:var(--sk-green-50);color:var(--sk-green-700)">
                            <i class="bi bi-grid-fill"></i>
                        </div>
                        <div class="home-tile-label">My Stokvels</div>
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a class="home-tile" href="/register-stokvel">
                        <div class="home-tile-icon" style="background:#F6E7B8;color:#9A7108">
                            <i class="bi bi-plus-circle-fill"></i>
                        </div>
                        <div class="home-tile-label">Register Stokvel</div>
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a class="home-tile home-tile-disabled" href="#" aria-disabled="true">
                        <div class="home-tile-icon" style="background:#F3F0FF;color:#8B5CF6">
                            <i class="bi bi-bar-chart-fill"></i>
                        </div>
                        <div class="home-tile-label">Reports</div>
                        <span class="home-tile-soon">Soon</span>
                    </a>
                </div>
                <div class="col-6 col-md-3">
                    <a class="home-tile home-tile-disabled" href="#" aria-disabled="true">
                        <div class="home-tile-icon" style="background:#EFF6FF;color:#3B82F6">
                            <i class="bi bi-wallet2"></i>
                        </div>
                        <div class="home-tile-label">Wallet</div>
                        <span class="home-tile-soon">Soon</span>
                    </a>
                </div>
            </div>

        </div>
    </Authorized>

    <!-- ══ Public landing page ════════════════════════════════ -->
    <NotAuthorized>

        <!-- Hero -->
        <div class="hero-section">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <div class="hero-eyebrow">
                        <span class="hero-flag">🇿🇦</span> South African Stokvel Management
                    </div>
                    <h1 class="hero-headline">
                        Run your stokvel<br>
                        <span class="hero-headline-accent">with confidence</span>
                    </h1>
                    <p class="hero-body">
                        Sisonke helps South African stokvels track contributions, manage members,
                        handle fines, and keep everyone accountable — all in one trusted platform.
                    </p>
                    <div class="d-flex gap-3 flex-wrap mt-4">
                        <a class="btn btn-primary btn-lg px-5" href="/Account/Register">
                            Get started free
                        </a>
                        <a class="btn btn-outline-secondary btn-lg px-4" href="/Account/Login">
                            Sign in
                        </a>
                    </div>
                    <div class="hero-trust-row mt-4">
                        <span><i class="bi bi-shield-check text-success me-1"></i>Secure &amp; private</span>
                        <span><i class="bi bi-people-fill me-1" style="color:var(--sk-green-700)"></i>Built for stokvels</span>
                        <span><i class="bi bi-phone-fill me-1" style="color:var(--sk-info)"></i>Mobile friendly</span>
                    </div>
                </div>
                <div class="col-lg-6 d-none d-lg-block">
                    <div class="hero-dashboard-preview">
                        <div class="hdp-header">
                            <div class="hdp-dot hdp-dot-red"></div>
                            <div class="hdp-dot hdp-dot-yellow"></div>
                            <div class="hdp-dot hdp-dot-green"></div>
                            <span class="hdp-title ms-2">Sisonke Dashboard</span>
                        </div>
                        <div class="hdp-body">
                            <div class="hdp-row">
                                <div class="hdp-stat hdp-stat-green">
                                    <div class="hdp-stat-icon"><i class="bi bi-people-fill"></i></div>
                                    <div>
                                        <div class="hdp-stat-val">12</div>
                                        <div class="hdp-stat-lbl">Members</div>
                                    </div>
                                </div>
                                <div class="hdp-stat hdp-stat-gold">
                                    <div class="hdp-stat-icon"><i class="bi bi-cash-coin"></i></div>
                                    <div>
                                        <div class="hdp-stat-val">R 2 400</div>
                                        <div class="hdp-stat-lbl">Monthly</div>
                                    </div>
                                </div>
                            </div>
                            <div class="hdp-row">
                                <div class="hdp-stat hdp-stat-blue">
                                    <div class="hdp-stat-icon"><i class="bi bi-file-earmark-text"></i></div>
                                    <div>
                                        <div class="hdp-stat-val">Approved</div>
                                        <div class="hdp-stat-lbl">Constitution</div>
                                    </div>
                                </div>
                                <div class="hdp-stat hdp-stat-red">
                                    <div class="hdp-stat-icon"><i class="bi bi-exclamation-circle"></i></div>
                                    <div>
                                        <div class="hdp-stat-val">R 150</div>
                                        <div class="hdp-stat-lbl">Fines due</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Features -->
        <div class="features-section">
            <div class="features-header">
                <h2 class="features-title">Everything your stokvel needs</h2>
                <p class="features-sub">From onboarding members to approving your constitution — Sisonke covers the full lifecycle.</p>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrap" style="background:var(--sk-green-50);color:var(--sk-green-700)">
                            <i class="bi bi-people-fill feature-icon"></i>
                        </div>
                        <h3 class="h5 mt-3 mb-2">Member Management</h3>
                        <p class="text-muted small mb-0">
                            Capture member profiles, track beneficiaries and next-of-kin, manage cooling periods and member limits.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrap" style="background:#F6E7B8;color:#9A7108">
                            <i class="bi bi-graph-up-arrow feature-icon"></i>
                        </div>
                        <h3 class="h5 mt-3 mb-2">Financial Tracking</h3>
                        <p class="text-muted small mb-0">
                            Set contribution rules, track payments and outstanding fines, and monitor your stokvel's financial health.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrap" style="background:#F3F0FF;color:#8B5CF6">
                            <i class="bi bi-file-earmark-check feature-icon"></i>
                        </div>
                        <h3 class="h5 mt-3 mb-2">Constitution Support</h3>
                        <p class="text-muted small mb-0">
                            Generate a governance constitution from your stokvel setup, review it as a group, and approve it formally.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrap" style="background:#EFF6FF;color:#3B82F6">
                            <i class="bi bi-shield-lock-fill feature-icon"></i>
                        </div>
                        <h3 class="h5 mt-3 mb-2">Governance &amp; Rules</h3>
                        <p class="text-muted small mb-0">
                            Define operating rules for your stokvel — contribution frequency, grace periods, late payment fines, and more.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrap" style="background:#F3E8FF;color:#7C3AED">
                            <i class="bi bi-calendar-event feature-icon"></i>
                        </div>
                        <h3 class="h5 mt-3 mb-2">Meetings &amp; Agenda</h3>
                        <p class="text-muted small mb-0">
                            Schedule meetings, set agendas, capture minutes, record votes, and track attendance for the stokvel group.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrap" style="background:#EFF6FF;color:#3B82F6">
                            <i class="bi bi-wallet2 feature-icon"></i>
                        </div>
                        <h3 class="h5 mt-3 mb-2">Surplus Wallet</h3>
                        <p class="text-muted small mb-0">
                            Every member gets a surplus wallet credited from contribution overpayments, with treasurer-confirmed withdrawals and a full transaction ledger.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrap" style="background:#FEF2F2;color:#DC2626"><i class="bi bi-cash-coin feature-icon"></i></div>
                        <h3 class="h5 mt-3 mb-2">Member Loans</h3>
                        <p class="text-muted small mb-0">
                            Members can request loans against wallet balance, surplus equity, or an accelerated payout, with guarantors, approval workflow, and repayment tracking built in.
                        </p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card">
                        <div class="feature-icon-wrap" style="background:#ECFDF5;color:#059669"><i class="bi bi-arrow-repeat feature-icon"></i></div>
                        <h3 class="h5 mt-3 mb-2">Rotational Payouts</h3>
                        <p class="text-muted small mb-0">
                            Configure rotation order, contribution cycles, and payout scheduling for grocery, savings, and rotational-payout stokvels.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- CTA strip -->
        <div class="home-cta-strip mt-5">
            <h2 class="home-cta-title">Ready to manage your stokvel properly?</h2>
            <p class="home-cta-sub">Join Sisonke and bring structure, transparency and trust to your community finances.</p>
            <a class="btn btn-accent btn-lg px-5" href="/Account/Register">
                Create your free account
            </a>
        </div>

    </NotAuthorized>

</AuthorizeView>

@code {
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo("/my-workspace", replace: true);
        }
    }
}

<style>
    /* ── Logged-in greeting card ──────────────────────────── */
    .home-greeting-card {
        background: linear-gradient(135deg, var(--sk-green-800) 0%, var(--sk-green-700) 100%);
        border-radius: var(--sk-radius-lg);
        padding: 2.5rem 2rem;
        margin-bottom: 0.5rem;
        box-shadow: var(--sk-shadow-md);
        overflow: hidden;
        position: relative;
    }

    .home-greeting-card::after {
        content: '';
        position: absolute;
        top: -60px;
        right: -60px;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        background: rgba(255,255,255,.04);
    }

    .home-greeting-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        position: relative;
        z-index: 1;
    }

    .home-greeting-text { flex: 1; min-width: 0; }

    .home-greeting-eyebrow {
        font-size: 0.8125rem;
        font-weight: 500;
        color: rgba(255,255,255,.65);
        margin-bottom: 0.375rem;
    }

    .home-greeting-name {
        font-size: 2rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.03em;
        margin-bottom: 0.5rem;
        line-height: 1.1;
        text-transform: capitalize;
    }

    .home-greeting-sub {
        font-size: 0.9375rem;
        color: rgba(255,255,255,.7);
        margin: 0;
        max-width: 480px;
        line-height: 1.6;
    }

    .home-btn-outline {
        background: rgba(255,255,255,.1);
        border-color: rgba(255,255,255,.3);
        color: #fff;
    }

    .home-btn-outline:hover {
        background: rgba(255,255,255,.2);
        border-color: rgba(255,255,255,.5);
        color: #fff;
    }

    /* ── Illustration stack (logged-in) ─────────────────── */
    .home-greeting-illustration { flex-shrink: 0; }

    .hgi-icon-stack {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .hgi-card {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(255,255,255,.15);
        border-radius: var(--sk-radius-sm);
        padding: 0.75rem 1.25rem;
        color: #fff;
        font-size: 0.875rem;
        font-weight: 500;
        min-width: 180px;
    }

    .hgi-card i { font-size: 1.1rem; }

    .hgi-card-1 { transform: translateX(8px); }
    .hgi-card-3 { transform: translateX(8px); }

    /* ── Quick-action tiles ─────────────────────────────── */
    .home-tile {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.625rem;
        padding: 1.25rem 1rem;
        background: var(--sk-card);
        border: 1px solid var(--sk-border);
        border-radius: var(--sk-radius);
        text-decoration: none;
        color: var(--sk-text);
        transition: box-shadow .15s, transform .15s, border-color .15s;
        text-align: center;
        position: relative;
    }

    .home-tile:hover {
        box-shadow: var(--sk-shadow);
        transform: translateY(-2px);
        border-color: var(--sk-green-100);
        color: var(--sk-text);
        text-decoration: none;
    }

    .home-tile-disabled {
        opacity: 0.55;
        pointer-events: none;
    }

    .home-tile-icon {
        width: 3rem;
        height: 3rem;
        border-radius: var(--sk-radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }

    .home-tile-label {
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--sk-text);
    }

    .home-tile-soon {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        font-size: 0.5625rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        background: var(--sk-border);
        color: var(--sk-text-muted);
        padding: 0.15rem 0.5rem;
        border-radius: 99px;
    }

    /* ── Public hero ────────────────────────────────────── */
    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--sk-green-700);
        background: var(--sk-green-50);
        border: 1px solid var(--sk-green-100);
        padding: 0.3rem 0.875rem;
        border-radius: 99px;
        margin-bottom: 1.25rem;
        letter-spacing: .02em;
    }

    .hero-flag { font-size: 1rem; }

    .hero-headline {
        font-size: 3rem;
        font-weight: 800;
        color: var(--sk-text);
        line-height: 1.1;
        letter-spacing: -0.03em;
        margin-bottom: 1rem;
    }

    .hero-headline-accent {
        color: var(--sk-green-700);
    }

    .hero-body {
        font-size: 1.0625rem;
        color: var(--sk-text-muted);
        max-width: 480px;
        line-height: 1.65;
        margin: 0;
    }

    .hero-trust-row {
        display: flex;
        gap: 1.25rem;
        font-size: 0.8125rem;
        color: var(--sk-text-muted);
        flex-wrap: wrap;
    }

    /* ── Dashboard preview mock ─────────────────────────── */
    .hero-dashboard-preview {
        background: var(--sk-card);
        border: 1px solid var(--sk-border);
        border-radius: var(--sk-radius-lg);
        box-shadow: var(--sk-shadow-lg);
        overflow: hidden;
    }

    .hdp-header {
        display: flex;
        align-items: center;
        padding: 0.75rem 1rem;
        background: #F9FAFB;
        border-bottom: 1px solid var(--sk-border);
        gap: 0.375rem;
    }

    .hdp-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .hdp-dot-red    { background: #EF4444; }
    .hdp-dot-yellow { background: #F59E0B; }
    .hdp-dot-green  { background: #10B981; }

    .hdp-title {
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--sk-text-muted);
    }

    .hdp-body {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.875rem;
    }

    .hdp-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.875rem;
    }

    .hdp-stat {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.875rem 1rem;
        border-radius: var(--sk-radius-sm);
        border-top: 2px solid transparent;
    }

    .hdp-stat-green { background: var(--sk-green-50); border-top-color: var(--sk-green-700); }
    .hdp-stat-gold  { background: #FFFBEB; border-top-color: var(--sk-gold); }
    .hdp-stat-blue  { background: #EFF6FF; border-top-color: var(--sk-info); }
    .hdp-stat-red   { background: var(--sk-danger-bg); border-top-color: var(--sk-danger); }

    .hdp-stat-icon {
        font-size: 1.125rem;
        width: 2rem;
        height: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .hdp-stat-green .hdp-stat-icon { color: var(--sk-green-700); }
    .hdp-stat-gold  .hdp-stat-icon { color: var(--sk-gold-dark); }
    .hdp-stat-blue  .hdp-stat-icon { color: var(--sk-info); }
    .hdp-stat-red   .hdp-stat-icon { color: var(--sk-danger); }

    .hdp-stat-val {
        font-size: 1rem;
        font-weight: 700;
        color: var(--sk-text);
        line-height: 1;
    }

    .hdp-stat-lbl {
        font-size: 0.6875rem;
        color: var(--sk-text-muted);
        text-transform: uppercase;
        letter-spacing: .05em;
        font-weight: 600;
        margin-top: 0.1rem;
    }

    /* ── Features section ───────────────────────────────── */
    .features-section {
        margin-top: 4rem;
    }

    .features-header {
        text-align: center;
        margin-bottom: 2.5rem;
    }

    .features-title {
        font-size: 1.875rem;
        font-weight: 800;
        color: var(--sk-text);
        letter-spacing: -0.02em;
        margin-bottom: 0.625rem;
    }

    .features-sub {
        color: var(--sk-text-muted);
        font-size: 1rem;
        max-width: 480px;
        margin: 0 auto;
        line-height: 1.6;
    }

    .feature-icon-wrap {
        width: 3rem;
        height: 3rem;
        border-radius: var(--sk-radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .feature-icon { font-size: 1.375rem; }

    /* ── CTA strip ──────────────────────────────────────── */
    .home-cta-strip {
        background: linear-gradient(135deg, var(--sk-green-800), var(--sk-green-700));
        border-radius: var(--sk-radius-lg);
        padding: 3rem 2rem;
        text-align: center;
        color: #fff;
        box-shadow: var(--sk-shadow-md);
    }

    .home-cta-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
    }

    .home-cta-sub {
        color: rgba(255,255,255,.75);
        font-size: 1rem;
        max-width: 420px;
        margin: 0 auto 1.75rem;
        line-height: 1.6;
    }

    @@media (max-width: 640px) {
        .hero-headline { font-size: 2.25rem; }
        .home-greeting-name { font-size: 1.625rem; }
        .home-cta-title { font-size: 1.375rem; }
    }
</style>
