@page "/"
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>Sisonke — Stokvel Management</PageTitle>

<AuthorizeView>
    <Authorized>
        <div class="home-welcome">
            <h1 class="fw-bold mb-2" style="font-size: 1.9rem; color: #1a1a2e;">
                Welcome back, @(context.User.Identity?.Name?.Split('@')[0] ?? "there")
            </h1>
            <p class="text-muted mb-4" style="font-size: 1.05rem;">
                Manage your stokvels and keep your community's finances on track.
            </p>
            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-primary btn-lg px-4" href="/my-stokvels">
                    <i class="bi bi-grid-fill me-2"></i>My Stokvels
                </a>
                <a class="btn btn-outline-secondary btn-lg px-4" href="/register-stokvel">
                    <i class="bi bi-plus-circle me-2"></i>Register New Stokvel
                </a>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="hero-section">
            <div class="row align-items-center g-4">
                <div class="col-lg-7">
                    <h1 class="fw-bold mb-3" style="font-size: 2.5rem; color: #1a1a2e; line-height: 1.15;">
                        Run your stokvel<br>with confidence
                    </h1>
                    <p class="text-muted mb-4" style="font-size: 1.1rem; max-width: 480px;">
                        Sisonke helps South African stokvels track contributions, manage members,
                        handle fines, and keep everyone accountable — all in one place.
                    </p>
                    <div class="d-flex gap-3 flex-wrap">
                        <a class="btn btn-primary btn-lg px-4" href="/Account/Register">
                            Get started free
                        </a>
                        <a class="btn btn-outline-secondary btn-lg px-4" href="/Account/Login">
                            Sign in
                        </a>
                    </div>
                </div>
                <div class="col-lg-5 d-none d-lg-block">
                    <div class="hero-icon-group">
                        <div class="hero-icon-card">
                            <i class="bi bi-people-fill" style="font-size: 2.5rem; color: #0d6efd;"></i>
                            <div class="fw-semibold small mt-2">Member Management</div>
                        </div>
                        <div class="hero-icon-card">
                            <i class="bi bi-cash-coin" style="font-size: 2.5rem; color: #198754;"></i>
                            <div class="fw-semibold small mt-2">Contributions</div>
                        </div>
                        <div class="hero-icon-card">
                            <i class="bi bi-shield-check" style="font-size: 2.5rem; color: #6f42c1;"></i>
                            <div class="fw-semibold small mt-2">Constitution Support</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-2">
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-people-fill feature-icon" style="color: #0d6efd;"></i>
                    <h3 class="h5 mt-3 mb-2">Member Management</h3>
                    <p class="text-muted small mb-0">
                        Track all members, contributions, beneficiaries, and next-of-kin records in one place.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-graph-up-arrow feature-icon" style="color: #198754;"></i>
                    <h3 class="h5 mt-3 mb-2">Financial Tracking</h3>
                    <p class="text-muted small mb-0">
                        Manage contribution rules, track payments, and stay on top of outstanding fines.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <i class="bi bi-file-earmark-check feature-icon" style="color: #6f42c1;"></i>
                    <h3 class="h5 mt-3 mb-2">Constitution Support</h3>
                    <p class="text-muted small mb-0">
                        Complete the setup questionnaire to generate a tailored operating constitution.
                    </p>
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>
