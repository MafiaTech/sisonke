@page "/meetings/{StokvelId:guid}"
@rendermode InteractiveServer

@using System.Linq
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject StokvelService StokvelService
@inject MeetingService MeetingService

<PageTitle>Meetings</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading meetings...
    </div>
}
else if (stokvel is null)
{
    <AlertBanner Type="danger" Title="Stokvel not found." Message="" Icon="bi bi-x-circle-fill" />
}
else
{
    <div class="page-header meetings-page-header">
        <div class="page-header-text">
            <h1>Meetings &amp; Agenda</h1>
            <p class="page-subtitle">@stokvel.Name · agenda items, votes &amp; decisions all in one place</p>
        </div>
        <div class="meetings-header-actions">
            <a class="btn btn-outline-secondary btn-sm" href="@($"/stokvel-dashboard/{StokvelId}")">
                <i class="bi bi-speedometer2 me-1"></i>Dashboard
            </a>
            <a class="btn btn-purple btn-sm" href="@($"/create-meeting/{StokvelId}")">
                <i class="bi bi-plus-circle me-1"></i>Schedule Meeting
            </a>
        </div>
    </div>

    @if (meetings.Count == 0)
    {
        <AlertBanner Type="info" Title="No meetings have been created yet." Message="" Icon="bi bi-info-circle-fill" />
    }
    else
    {
        <div class="meetings-tabs mb-4" role="tablist" aria-label="Meeting views">
            <button type="button" class="meetings-tab @(activeTab == "Upcoming" ? "active" : "")" role="tab" aria-selected="@(activeTab == "Upcoming")" @onclick="@(() => activeTab = "Upcoming")">
                Upcoming
            </button>
            <button type="button" class="meetings-tab @(activeTab == "Past" ? "active" : "")" role="tab" aria-selected="@(activeTab == "Past")" @onclick="@(() => activeTab = "Past")">
                Past
            </button>
            <button type="button" class="meetings-tab @(activeTab == "Minutes" ? "active" : "")" role="tab" aria-selected="@(activeTab == "Minutes")" @onclick="@(() => activeTab = "Minutes")">
                Minutes
            </button>
        </div>

        @if (activeTab == "Minutes")
        {
            <div class="meetings-empty-state mb-4">
                <div class="meetings-empty-icon">
                    <i class="bi bi-journal-text"></i>
                </div>
                <div>
                    <div class="meetings-empty-title">No minutes yet</div>
                    <p class="meetings-empty-text">Minutes will appear here once meetings are completed.</p>
                </div>
            </div>
        }
        else
        {
            var visibleMeetings = activeTab == "Upcoming" ? UpcomingMeetings : PastMeetings;

            @if (!visibleMeetings.Any())
            {
                <div class="meetings-empty-state mb-4">
                    <div class="meetings-empty-icon">
                        <i class="bi bi-calendar2-week"></i>
                    </div>
                    <div>
                        <div class="meetings-empty-title">No @activeTab.ToLowerInvariant() meetings</div>
                        <p class="meetings-empty-text">Meetings matching this view will appear here.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="meetings-list mb-4">
                    @foreach (var meeting in visibleMeetings)
                    {
                        <div class="meeting-card">
                            <div class="meeting-card-bar @GetStatusBarClass(meeting.Status.ToString())"></div>
                            <div class="meeting-card-body">
                                <div class="meeting-card-date @(meeting.Status.ToString() == "Completed" ? "dim" : "")">
                                    <div class="meeting-card-day">@meeting.MeetingDate.Day.ToString("00")</div>
                                    <div class="meeting-card-month">@meeting.MeetingDate.ToString("MMM")</div>
                                </div>
                                <div class="meeting-card-info">
                                    <div class="meeting-card-title-row">
                                        <span class="meeting-card-title">@meeting.Title</span>
                                        <StatusBadge Text="@meeting.Status.ToString()" Type="@GetStatusBadgeType(meeting.Status.ToString())" />
                                    </div>
                                    <div class="meeting-card-meta">
                                        <span class="meeting-card-meta-item">
                                            <i class="bi bi-calendar3"></i>@meeting.MeetingDate.ToString("dd MMM yyyy, HH:mm")
                                        </span>
                                        <span class="meeting-card-meta-item">
                                            <i class="bi bi-geo-alt"></i>@DisplayOrDash(meeting.Venue)
                                        </span>
                                        <span class="meeting-card-meta-item">
                                            <i class="bi bi-list-ul"></i>@meeting.AgendaItems.Count agenda @(meeting.AgendaItems.Count == 1 ? "item" : "items")
                                        </span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(meeting.Purpose))
                                    {
                                        <div class="meeting-card-purpose">@meeting.Purpose</div>
                                    }
                                </div>
                                <div class="meeting-card-aside">
                                    <a class="btn btn-purple btn-sm" href="@($"/meeting/{meeting.Id}")">
                                        <i class="bi bi-eye me-1"></i>View
                                    </a>
                                    <a class="btn btn-outline-primary btn-sm" href="@($"/edit-meeting/{meeting.Id}")">
                                        <i class="bi bi-pencil-square me-1"></i>Edit
                                    </a>
                                </div>
                            </div>
                            <div class="meeting-card-agenda-row">
                                <i class="bi bi-check2-square"></i>
                                <span>Agenda — @meeting.AgendaItems.Count @(meeting.AgendaItems.Count == 1 ? "item" : "items")</span>
                            </div>
                        </div>
                    }
                </div>
            }
        }

        <div class="card mb-4 meetings-calendar-card">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between gap-3 flex-wrap mb-3">
                    <div>
                        <h2 class="h5 mb-1">Meeting Calendar</h2>
                        <p class="text-muted small mb-0">@visibleMonth.ToString("MMMM yyyy")</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ShowPreviousMonth">
                            <i class="bi bi-chevron-left me-1"></i>Previous Month
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="ShowNextMonth">
                            Next Month<i class="bi bi-chevron-right ms-1"></i>
                        </button>
                        <a class="btn btn-purple btn-sm" href="@($"/create-meeting/{StokvelId}")">
                            <i class="bi bi-plus-circle me-2"></i>Schedule Meeting
                        </a>
                    </div>
                </div>

                <div class="meeting-calendar">
                    @foreach (var dayName in CalendarDayNames)
                    {
                        <div class="calendar-weekday">@dayName</div>
                    }

                    @foreach (var calendarDay in GetCalendarDays())
                    {
                        <div class="calendar-day @(calendarDay.Month == visibleMonth.Month ? "" : "calendar-day-muted")">
                            <div class="calendar-day-number">@calendarDay.Day</div>
                            @foreach (var meeting in GetMeetingsForDay(calendarDay))
                            {
                                <a class="calendar-meeting-badge" href="@($"/meeting/{meeting.Id}")">@meeting.Title</a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}

@code {
    private Stokvel? stokvel;
    private List<Meeting> meetings = [];
    private DateTime visibleMonth = new(DateTime.Today.Year, DateTime.Today.Month, 1);
    private string activeTab = "Upcoming";
    private bool isLoading = true;
    private static readonly string[] CalendarDayNames =
    [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday"
    ];

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);

        if (stokvel is not null)
        {
            meetings = await MeetingService.GetMeetingsByStokvelIdAsync(StokvelId);
        }

        isLoading = false;
    }

    private static string DisplayOrDash(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private IEnumerable<Meeting> UpcomingMeetings =>
        meetings
            .Where(IsUpcomingMeeting)
            .OrderBy(meeting => meeting.MeetingDate);

    private IEnumerable<Meeting> PastMeetings =>
        meetings
            .Where(IsPastMeeting)
            .OrderByDescending(meeting => meeting.MeetingDate);

    private static bool IsUpcomingMeeting(Meeting meeting)
    {
        var status = meeting.Status.ToString();
        return meeting.MeetingDate.Date >= DateTime.Today
            && status != "Completed"
            && status != "Cancelled";
    }

    private static bool IsPastMeeting(Meeting meeting)
    {
        var status = meeting.Status.ToString();
        return meeting.MeetingDate.Date < DateTime.Today || status == "Completed";
    }

    private void ShowPreviousMonth()
    {
        visibleMonth = visibleMonth.AddMonths(-1);
    }

    private void ShowNextMonth()
    {
        visibleMonth = visibleMonth.AddMonths(1);
    }

    private IEnumerable<DateTime> GetCalendarDays()
    {
        var firstDayOfMonth = new DateTime(visibleMonth.Year, visibleMonth.Month, 1);
        var daysFromMonday = ((int)firstDayOfMonth.DayOfWeek + 6) % 7;
        var calendarStart = firstDayOfMonth.AddDays(-daysFromMonday);

        for (var index = 0; index < 42; index++)
        {
            yield return calendarStart.AddDays(index);
        }
    }

    private IEnumerable<Meeting> GetMeetingsForDay(DateTime day)
    {
        return meetings
            .Where(meeting => meeting.MeetingDate.Date == day.Date)
            .OrderBy(meeting => meeting.MeetingDate);
    }

    private static string GetStatusBadgeType(string status) =>
        status switch
        {
            "Completed" => "success",
            "InProgress" => "warning",
            "Cancelled" => "danger",
            "Planned" => "info",
            "Scheduled" => "info",
            _ => "secondary"
        };

    private static string GetStatusBarClass(string status) =>
        status switch
        {
            "Completed"  => "bar-completed",
            "InProgress" => "bar-inprogress",
            "Cancelled"  => "bar-cancelled",
            "Planned"    => "bar-planned",
            "Scheduled"  => "bar-scheduled",
            _ => "bar-planned"
        };
}
