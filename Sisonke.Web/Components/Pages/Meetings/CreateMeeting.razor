@page "/create-meeting/{StokvelId:guid}"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject StokvelService StokvelService
@inject MeetingService MeetingService
@inject NavigationManager NavigationManager

<PageTitle>Create Meeting</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading meeting form...
    </div>
}
else if (stokvel is null)
{
    <AlertBanner Type="danger" Title="Stokvel not found." Message="" Icon="bi bi-x-circle-fill" />
}
else
{
    <PageHeader
        Title="Create Meeting"
        Subtitle="@stokvel.Name"
        BackText="Back to Meetings"
        BackHref="@($"/meetings/{StokvelId}")" />

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <AlertBanner Type="danger" Title="@errorMessage" Message="" Icon="bi bi-x-circle-fill" />
    }

    <div class="form-page form-page-sm">
        <div class="card">
            <div class="card-body p-4">
                <EditForm Model="@model" OnValidSubmit="@HandleValidSubmit" FormName="CreateMeetingForm">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="alert alert-danger" />

                    <div class="form-section-title">Meeting Details</div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label" for="title">Title <span class="text-danger">*</span></label>
                            <InputText id="title" class="form-control" @bind-Value="model.Title" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" for="meeting-date">Meeting date</label>
                            <InputDate id="meeting-date" class="form-control" @bind-Value="model.MeetingDate" />
                        </div>

                        <div class="col-12 col-md-6">
                            <label class="form-label" for="venue">Venue</label>
                            <InputText id="venue" class="form-control" @bind-Value="model.Venue" />
                        </div>

                        <div class="col-12">
                            <label class="form-label" for="purpose">Purpose</label>
                            <InputTextArea id="purpose" class="form-control" rows="4" @bind-Value="model.Purpose" />
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button class="btn btn-purple" type="submit">
                            <i class="bi bi-calendar-plus me-2"></i>Create Meeting
                        </button>
                        <a class="btn btn-outline-secondary" href="@($"/meetings/{StokvelId}")">Back to Meetings</a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private Stokvel? stokvel;
    private CreateMeetingModel model = new();
    private bool isLoading = true;
    private string? errorMessage;

    [Parameter]
    public Guid StokvelId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        stokvel = await StokvelService.GetStokvelByIdAsync(StokvelId);

        if (stokvel is not null)
        {
            model.Title = $"{stokvel.Name} Meeting";
        }

        isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        errorMessage = null;

        if (await MeetingService.HasMeetingOnDateAsync(StokvelId, model.MeetingDate))
        {
            errorMessage = "A meeting already exists for this stokvel on this date. Please choose another date.";
            return;
        }

        var meeting = await MeetingService.CreateMeetingAsync(
            StokvelId,
            model.Title,
            model.MeetingDate,
            model.Venue,
            model.Purpose);

        if (meeting is null)
        {
            errorMessage = "Meeting could not be created. Please check the date and try again.";
            return;
        }

        NavigationManager.NavigateTo($"/meeting/{meeting.Id}");
    }

    private class CreateMeetingModel
    {
        [Required]
        [MaxLength(200)]
        public string Title { get; set; } = string.Empty;

        public DateTime MeetingDate { get; set; } = DateTime.Today;

        [MaxLength(150)]
        public string? Venue { get; set; }

        [MaxLength(500)]
        public string? Purpose { get; set; }
    }
}
