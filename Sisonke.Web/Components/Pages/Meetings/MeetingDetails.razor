@page "/meeting/{MeetingId:guid}"
@rendermode InteractiveServer

@using Sisonke.Web.Data.Entities
@using Sisonke.Web.Services

@inject MeetingService MeetingService
@inject StokvelService StokvelService

<PageTitle>@(meeting?.Title ?? "Meeting")</PageTitle>

@if (isLoading)
{
    <div class="loading-state">
        <div class="spinner-border spinner-border-sm" role="status" style="color:var(--sk-green-700)">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading meeting...
    </div>
}
else if (meeting is null)
{
    <AlertBanner Type="danger" Title="Meeting not found." Message="" Icon="bi bi-x-circle-fill" />
}
else
{
    <PageHeader
        Title="@meeting.Title"
        Subtitle="Meeting governance record"
        BackText="Back to Meetings"
        BackHref="@backToMeetingsHref" />

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a class="btn btn-success" href="@($"/meeting-attendance/{MeetingId}")">
            <i class="bi bi-person-check me-2"></i>Attendance Register
        </a>
        <a class="btn btn-primary" href="@($"/meeting-votes/{MeetingId}")">
            <i class="bi bi-check2-square me-2"></i>Voting and Decisions
        </a>
        <a class="btn btn-outline-secondary" href="@backToMeetingsHref">
            <i class="bi bi-arrow-left me-2"></i>Back to Meetings
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-12 col-md-3">
                    <div class="detail-mini-label">Meeting date</div>
                    <div class="fw-600">@meeting.MeetingDate.ToString("dd MMM yyyy")</div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="detail-mini-label">Venue</div>
                    <div>@DisplayOrDash(meeting.Venue)</div>
                </div>
                <div class="col-12 col-md-3">
                    <div class="detail-mini-label">Status</div>
                    <StatusBadge Text="@meeting.Status.ToString()" Type="@GetStatusBadgeType(meeting.Status.ToString())" />
                </div>
                <div class="col-12">
                    <div class="detail-mini-label">Purpose</div>
                    <div>@DisplayOrDash(meeting.Purpose)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-4">
            <div class="d-flex align-items-center justify-content-between gap-3 mb-3">
                <div>
                    <h2 class="h5 mb-1">Generated Agenda</h2>
                    <p class="text-muted small mb-0">Use Voting and Decisions to record formal approvals and meeting resolutions.</p>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-success btn-sm" href="@($"/meeting-attendance/{MeetingId}")">
                        <i class="bi bi-person-check me-1"></i>Attendance Register
                    </a>
                    <a class="btn btn-primary btn-sm" href="@($"/meeting-votes/{MeetingId}")">
                        <i class="bi bi-check2-square me-1"></i>Voting and Decisions
                    </a>
                    <a class="btn btn-outline-secondary btn-sm" href="@backToMeetingsHref">Back to Meetings</a>
                </div>
            </div>

            @if (meeting.AgendaItems.Count == 0)
            {
                <AlertBanner Type="info" Title="No agenda items yet." Message="" Icon="bi bi-info-circle-fill" />
            }
            else
            {
                <div class="list-group agenda-list">
                    @foreach (var agendaItem in meeting.AgendaItems.OrderBy(item => item.DisplayOrder))
                    {
                        <div class="list-group-item">
                            <div class="d-flex align-items-start gap-3">
                                <span class="agenda-order">@agendaItem.DisplayOrder</span>
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center justify-content-between gap-3">
                                        <div class="fw-600">@agendaItem.Title</div>
                                        <StatusBadge Text="@(agendaItem.IsCompleted ? "Completed" : "Open")" Type="@(agendaItem.IsCompleted ? "success" : "secondary")" />
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(agendaItem.Description))
                                    {
                                        <div class="text-muted small mt-1">@agendaItem.Description</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
    .fw-600 { font-weight: 600; }
    .detail-mini-label {
        font-size: .6875rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--sk-text-muted);
        font-weight: 600;
        margin-bottom: .15rem;
    }
    .agenda-list .list-group-item {
        border-color: #e5e7eb;
        padding: 1rem;
    }
    .agenda-order {
        align-items: center;
        background: var(--sk-green-50);
        border-radius: 999px;
        color: var(--sk-green-800);
        display: inline-flex;
        flex: 0 0 auto;
        font-size: .875rem;
        font-weight: 700;
        height: 2rem;
        justify-content: center;
        width: 2rem;
    }
</style>

@code {
    private Meeting? meeting;
    private string backToMeetingsHref = "/my-stokvels";
    private bool isLoading = true;

    [Parameter]
    public Guid MeetingId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        meeting = await MeetingService.GetMeetingByIdAsync(MeetingId);

        if (meeting is not null)
        {
            var stokvel = await StokvelService.GetStokvelByTenantIdAsync(meeting.TenantId);
            backToMeetingsHref = stokvel is null
                ? "/my-stokvels"
                : $"/meetings/{stokvel.Id}";
        }

        isLoading = false;
    }

    private static string DisplayOrDash(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string GetStatusBadgeType(string status) =>
        status switch
        {
            "Completed" => "success",
            "InProgress" => "warning",
            "Cancelled" => "danger",
            "Planned" => "info",
            "Scheduled" => "info",
            _ => "secondary"
        };
}
