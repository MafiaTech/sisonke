@page "/Account/Register"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout AuthLayout

@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using Sisonke.Web.Data
@using Sisonke.Web.Services

@inject UserManager<ApplicationUser> UserManager
@inject IUserStore<ApplicationUser> UserStore
@inject SignInManager<ApplicationUser> SignInManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject MemberAccountLinkingService MemberAccountLinkingService
@inject AuthSettings AuthSettings
@inject AppSettings AppSettings
@inject ILogger<Register> Logger
@inject NavigationManager NavigationManager

<PageTitle>Create Account — Sisonke</PageTitle>

<div class="auth-split">

    <!-- ══════════════════════════════════════════
         LEFT — Brand panel
    ══════════════════════════════════════════ -->
    <div class="auth-brand">

        <div class="auth-circles">
            <svg width="460" height="460" viewBox="0 0 460 460" fill="none">
                <circle cx="230" cy="230" r="190" stroke="#C9922A" stroke-width="1.4" stroke-dasharray="9 13" />
                <circle cx="230" cy="230" r="145" stroke="#C9922A" stroke-width="1"   stroke-dasharray="5 9"  opacity="0.6" />
                <circle cx="230" cy="230" r="100" stroke="#C9922A" stroke-width="0.8" stroke-dasharray="3 7"  opacity="0.4" />
                <circle cx="230" cy="230" r="55"  stroke="#C9922A" stroke-width="0.6"                        opacity="0.28" />
            </svg>
        </div>

        <div class="auth-beads">
            @for (int i = 0; i < 20; i++)
            {
                <div class="auth-bead"></div>
            }
        </div>

        <div class="auth-brand-content">

            <div class="auth-logo">
                <div class="auth-logo-mark">S</div>
                <span class="auth-logo-name">Sisonke</span>
            </div>

            <h2 class="auth-brand-headline">
                Your stokvel,<br /><em>managed with</em><br />dignity.
            </h2>

            <p class="auth-brand-sub">
                Join thousands of stokvels across South Africa already
                running with clarity, trust, and zero admin stress.
            </p>

            <div class="auth-stats">
                <div class="auth-stat">
                    <span class="auth-stat-number">12k+</span>
                    <span class="auth-stat-label">Stokvels</span>
                </div>
                <div class="auth-stat">
                    <span class="auth-stat-number">R2.4B</span>
                    <span class="auth-stat-label">Managed</span>
                </div>
                <div class="auth-stat">
                    <span class="auth-stat-number">98%</span>
                    <span class="auth-stat-label">Satisfaction</span>
                </div>
            </div>

            <blockquote class="auth-testimonial">
                <q>Sisonke removed all the stress from running our burial society.
                   Everything is transparent now.</q>
                <span class="auth-testimonial-author">Nomsa D. · Chairperson, Soweto</span>
            </blockquote>

        </div>
    </div>

    <!-- ══════════════════════════════════════════
         RIGHT — Form panel
    ══════════════════════════════════════════ -->
    <div class="auth-form-panel">
        <div class="auth-form-container">

            <!-- Mobile logo -->
            <div class="auth-mobile-logo">
                <div class="auth-mobile-logo-mark">S</div>
                <span class="auth-mobile-logo-name">Sisonke</span>
            </div>

            <!-- Tab switcher -->
            <div class="auth-tabs">
                <a href="@(NavigationManager.GetUriWithQueryParameters("Account/Login", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))" class="auth-tab">Sign In</a>
                <a href="@(NavigationManager.GetUriWithQueryParameters("Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))" class="auth-tab active">Create Account</a>
            </div>

            <h1 class="auth-form-heading">Create your account</h1>
            <p class="auth-form-subheading">Get started — it only takes a minute</p>

            <!-- ── Step indicator bar — driven by _step ─── -->
            <div class="auth-step-bar">
                <div class="auth-step-dot @(_step > 1 ? "done" : "active")">@(_step > 1 ? "✓" : "1")</div>
                <div class="auth-step-line @(_step > 1 ? "done" : "")"></div>
                <div class="auth-step-dot @(_step > 2 ? "done" : _step == 2 ? "active" : "")">@(_step > 2 ? "✓" : "2")</div>
                <div class="auth-step-line @(_step > 2 ? "done" : "")"></div>
                <div class="auth-step-dot @(_step == 3 ? "active" : "")">3</div>
            </div>
            <div class="auth-step-label">@StepLabel</div>

            <!-- Status message -->
            <StatusMessage Message="@Message" />

            <!-- ════════════════════════════════════════
                 THE SINGLE FORM — steps controlled by _step
            ════════════════════════════════════════ -->
            <EditForm EditContext="_editContext" OnValidSubmit="RegisterUser" FormName="register">
                <DataAnnotationsValidator />

                <!-- ──────────────────────────────────────
                     STEP 1 — Personal Details
                ────────────────────────────────────── -->
                @if (_step == 1)
                {
                    <div class="auth-wizard-step active">

                        <!-- Full name -->
                        <div class="auth-field">
                            <label class="auth-label" for="Input.FullName">Full Name</label>
                            <div class="auth-input-wrapper">
                                <span class="auth-input-icon">👤</span>
                                <InputText @bind-Value="Input.FullName"
                                           id="Input.FullName"
                                           class="auth-input"
                                           autocomplete="name"
                                           aria-required="true"
                                           placeholder="e.g. Thabo Nkosi" />
                            </div>
                            <ValidationMessage For="() => Input.FullName" class="auth-val-msg" />
                        </div>

                        <!-- Email -->
                        <div class="auth-field">
                            <label class="auth-label" for="Input.Email">Email Address</label>
                            <div class="auth-input-wrapper">
                                <span class="auth-input-icon">✉</span>
                                <InputText @bind-Value="Input.Email"
                                           id="Input.Email"
                                           class="auth-input"
                                           autocomplete="username"
                                           aria-required="true"
                                           placeholder="you@example.com" />
                            </div>
                            <ValidationMessage For="() => Input.Email" class="auth-val-msg" />
                        </div>

                        <!-- ID Number -->
                        <div class="auth-field">
                            <label class="auth-label" for="Input.IdNumber">ID Number</label>
                            <div class="auth-input-wrapper">
                                <span class="auth-input-icon">🪪</span>
                                <InputText @bind-Value="Input.IdNumber"
                                           id="Input.IdNumber"
                                           class="auth-input"
                                           autocomplete="off"
                                           placeholder="13-digit SA ID" />
                            </div>
                            <ValidationMessage For="() => Input.IdNumber" class="auth-val-msg" />
                        </div>

                        <!-- Cellphone number -->
                        <div class="auth-field">
                            <label class="auth-label" for="Input.CellphoneNumber">Cellphone Number</label>
                            <div class="auth-input-wrapper auth-phone-wrap">
                                <span class="auth-input-icon" style="opacity:0.65;font-size:13px;">🇿🇦 +27</span>
                                <InputText @bind-Value="Input.CellphoneNumber"
                                           id="Input.CellphoneNumber"
                                           class="auth-input phone-input"
                                           autocomplete="tel"
                                           placeholder="e.g. 0821234567" />
                            </div>
                            <ValidationMessage For="() => Input.CellphoneNumber" class="auth-val-msg" />
                        </div>

                        <!-- Residential area -->
                        <div class="auth-field">
                            <label class="auth-label" for="Input.ResidentialArea">Residential Area</label>
                            <div class="auth-input-wrapper">
                                <span class="auth-input-icon">📍</span>
                                <InputText @bind-Value="Input.ResidentialArea"
                                           id="Input.ResidentialArea"
                                           class="auth-input"
                                           autocomplete="address-level2"
                                           placeholder="e.g. Soweto, Gauteng" />
                            </div>
                            <ValidationMessage For="() => Input.ResidentialArea" class="auth-val-msg" />
                        </div>

                        <!-- Continue → Step 2 -->
                        <div style="margin-top: 8px;">
                            <button type="button" class="auth-btn-primary" @onclick="ContinueToStep2">
                                Continue →
                            </button>
                        </div>

                    </div>
                }

                <!-- ──────────────────────────────────────
                     STEP 2 — Secure Your Account
                ────────────────────────────────────── -->
                @if (_step == 2)
                {
                    <div class="auth-wizard-step active">

                        <!-- Password -->
                        <div class="auth-field">
                            <label class="auth-label" for="Input.Password">Password</label>
                            <div class="auth-input-wrapper">
                                <span class="auth-input-icon">🔒</span>
                                <InputText type="password"
                                           @bind-Value="Input.Password"
                                           id="Input.Password"
                                           class="auth-input has-toggle"
                                           autocomplete="new-password"
                                           aria-required="true"
                                           placeholder="Min. 8 characters"
                                           oninput="authUpdateStrength(this.value)" />
                                <button type="button"
                                        class="auth-pw-toggle"
                                        onclick="authTogglePw('Input.Password', this)"
                                        tabindex="-1"
                                        aria-label="Show password">👁️</button>
                            </div>
                            <ValidationMessage For="() => Input.Password" class="auth-val-msg" />

                            <!-- Strength meter -->
                            <div class="auth-strength">
                                <div class="auth-strength-bars">
                                    <div class="auth-strength-bar" id="auth-sb-1"></div>
                                    <div class="auth-strength-bar" id="auth-sb-2"></div>
                                    <div class="auth-strength-bar" id="auth-sb-3"></div>
                                    <div class="auth-strength-bar" id="auth-sb-4"></div>
                                </div>
                                <span class="auth-strength-text" id="auth-strength-label"></span>
                            </div>
                        </div>

                        <!-- Confirm password -->
                        <div class="auth-field">
                            <label class="auth-label" for="Input.ConfirmPassword">Confirm Password</label>
                            <div class="auth-input-wrapper">
                                <span class="auth-input-icon">🔒</span>
                                <InputText type="password"
                                           @bind-Value="Input.ConfirmPassword"
                                           id="Input.ConfirmPassword"
                                           class="auth-input has-toggle"
                                           autocomplete="new-password"
                                           aria-required="true"
                                           placeholder="Repeat your password" />
                                <button type="button"
                                        class="auth-pw-toggle"
                                        onclick="authTogglePw('Input.ConfirmPassword', this)"
                                        tabindex="-1"
                                        aria-label="Show confirm password">👁️</button>
                            </div>
                            <ValidationMessage For="() => Input.ConfirmPassword" class="auth-val-msg" />
                        </div>

                        @if (_passwordMismatch)
                        {
                            <div class="auth-pw-warning show">
                                ⚠ Passwords don't match — please check before continuing.
                            </div>
                        }

                        <!-- Step 2 nav: Back | Continue -->
                        <div class="auth-step-nav" style="margin-top:14px;">
                            <button type="button" class="auth-btn-back" @onclick="() => _step = 1">← Back</button>
                            <button type="button" class="auth-btn-primary" @onclick="ContinueToStep3">Continue →</button>
                        </div>

                    </div>
                }

                <!-- ──────────────────────────────────────
                     STEP 3 — Almost Done
                ────────────────────────────────────── -->
                @if (_step == 3)
                {
                    <div class="auth-wizard-step active">

                        <!-- Review box populated from C# model -->
                        <div class="auth-review-box">
                            <div class="auth-review-label">Full Name</div>
                            <div class="auth-review-value">@(string.IsNullOrWhiteSpace(Input.FullName) ? "—" : Input.FullName)</div>
                            <div class="auth-review-label mt-3">Email</div>
                            <div class="auth-review-value">@(string.IsNullOrWhiteSpace(Input.Email) ? "—" : Input.Email)</div>
                            <div class="auth-review-label mt-3">ID Number</div>
                            <div class="auth-review-value">@SensitiveDataMasker.MaskIdNumber(Input.IdNumber)</div>
                            <p class="auth-review-note">
                                @if (AuthSettings.RequireConfirmedAccount)
                                {
                                    <text>Almost done! Create your account and we'll send a verification link to your email. You must verify before signing in.</text>
                                }
                                else
                                {
                                    <text>Almost done! You'll be signed in right away. We'll also send a verification email — please confirm it when you receive it.</text>
                                }
                            </p>
                        </div>

                        <!-- REAL submit button -->
                        <button type="submit" class="auth-btn-primary">Create My Account</button>

                        <div class="auth-step-nav" style="justify-content: flex-start; margin-top: -8px; margin-bottom: 16px;">
                            <button type="button" class="auth-btn-back" @onclick="() => _step = 2">← Back</button>
                        </div>

                    </div>
                }

            </EditForm>

            <!-- External login providers -->
            <div class="auth-external">
                <div class="auth-divider" style="margin-top: 4px;"><span>or register with</span></div>
                <ExternalLoginPicker />
            </div>

            <p class="auth-switch">
                Already have an account? <a href="@(NavigationManager.GetUriWithQueryParameters("Account/Login", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))">Sign in</a>
            </p>

        </div>
    </div>

</div>

<script>
(function () {
    function updateStrength(val) {
        var bars  = [
            document.getElementById('auth-sb-1'),
            document.getElementById('auth-sb-2'),
            document.getElementById('auth-sb-3'),
            document.getElementById('auth-sb-4')
        ];
        var label = document.getElementById('auth-strength-label');

        var score = 0;
        if (val.length >= 6)  score++;
        if (val.length >= 10) score++;
        if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
        if (/[^A-Za-z0-9]/.test(val)) score++;

        var classes = ['', 's-weak', 's-fair', 's-good', 's-strong'];
        var names   = ['', 'Weak', 'Fair', 'Good', 'Strong'];

        bars.forEach(function (b, idx) {
            if (!b) return;
            b.className = 'auth-strength-bar' + (idx < score ? ' ' + classes[score] : '');
        });
        if (label) label.textContent = val.length > 0 ? names[score] || '' : '';
    }

    function togglePw(inputId, btn) {
        var el = document.getElementById(inputId);
        if (!el) return;
        if (el.type === 'password') {
            el.type = 'text';
            btn.textContent = '🙈';
        } else {
            el.type = 'password';
            btn.textContent = '👁️';
        }
    }

    window.authUpdateStrength = updateStrength;
    window.authTogglePw       = togglePw;
}());
</script>

@code {
    private IEnumerable<IdentityError>? identityErrors;
    private int _step = 1;
    private bool _passwordMismatch = false;
    private EditContext _editContext = default!;
    private ValidationMessageStore _messageStore = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private InputModel Input { get; set; } = default!;

    private string? Message => identityErrors is null ? null : $"Error: {string.Join(", ", identityErrors.Select(error => error.Description))}";

    private string StepLabel => _step switch
    {
        1 => "Personal Details",
        2 => "Secure Your Account",
        3 => "Almost Done",
        _ => "Personal Details"
    };

    protected override void OnInitialized()
    {
        Input = new();
        _editContext = new EditContext(Input);
        _messageStore = new ValidationMessageStore(_editContext);
    }

    private void ContinueToStep2()
    {
        _messageStore.Clear();
        bool valid = ValidateFields(
            nameof(Input.FullName),
            nameof(Input.Email),
            nameof(Input.IdNumber),
            nameof(Input.CellphoneNumber));
        if (valid) _step = 2;
    }

    private void ContinueToStep3()
    {
        _passwordMismatch = false;
        _messageStore.Clear();
        bool valid = ValidateFields(nameof(Input.Password), nameof(Input.ConfirmPassword));
        if (valid)
        {
            if (!string.IsNullOrEmpty(Input.Password) &&
                !string.IsNullOrEmpty(Input.ConfirmPassword) &&
                Input.Password != Input.ConfirmPassword)
            {
                _passwordMismatch = true;
                return;
            }
            _step = 3;
        }
    }

    private bool ValidateFields(params string[] fieldNames)
    {
        bool allValid = true;
        foreach (var name in fieldNames)
        {
            var prop = typeof(InputModel).GetProperty(name)!;
            var value = prop.GetValue(Input);
            var ctx = new ValidationContext(Input) { MemberName = name };
            var results = new List<ValidationResult>();
            if (!Validator.TryValidateProperty(value, ctx, results))
            {
                allValid = false;
                foreach (var r in results)
                    _messageStore.Add(_editContext.Field(name), r.ErrorMessage!);
            }
        }
        _editContext.NotifyValidationStateChanged();
        return allValid;
    }

    public async Task RegisterUser(EditContext editContext)
    {
        _messageStore.Clear();
        identityErrors = null;

        var user = CreateUser();

        await UserStore.SetUserNameAsync(user, Input.Email, CancellationToken.None);
        var emailStore = GetEmailStore();
        await emailStore.SetEmailAsync(user, Input.Email, CancellationToken.None);
        user.FullName = Input.FullName;
        user.IdNumber = Input.IdNumber;
        user.CellphoneNumber = Input.CellphoneNumber;
        user.ResidentialArea = Input.ResidentialArea;
        var result = await UserManager.CreateAsync(user, Input.Password);

        if (!result.Succeeded)
        {
            identityErrors = result.Errors;
            return;
        }

        Logger.LogInformation("User created a new account with password.");

        var userId = await UserManager.GetUserIdAsync(user);
        await MemberAccountLinkingService.LinkUserToMembersByIdNumberAsync(userId, Input.IdNumber);

        // Generate confirmation link using the configured public base URL (for Azure hosting).
        var code = await UserManager.GenerateEmailConfirmationTokenAsync(user);
        code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
        var callbackUrl = BuildEmailUrl("Account/ConfirmEmail",
            new Dictionary<string, object?> { ["userId"] = userId, ["code"] = code });

        await EmailSender.SendConfirmationLinkAsync(user, Input.Email, HtmlEncoder.Default.Encode(callbackUrl));

        if (!AuthSettings.RequireConfirmedAccount)
        {
            // Pilot mode: sign in immediately — user can access the app without confirming first.
            // RegisterConfirmation page will show the dev link and a "continue" button.
            await SignInManager.SignInAsync(user, isPersistent: false);
        }

        // Always pass through RegisterConfirmation so users see a friendly message and, in dev,
        // a clickable confirmation link (when SMTP is not configured).
        var confirmationPageUrl = BuildEmailUrl("Account/RegisterConfirmation",
            new Dictionary<string, object?> { ["email"] = Input.Email, ["returnUrl"] = GetPostRegistrationRedirectUrl() });
        NavigationManager.NavigateTo(confirmationPageUrl, forceLoad: true);
    }

    // Builds an absolute URL for email links. Uses App:PublicBaseUrl when configured so links
    // work correctly on Azure when behind a reverse proxy.
    private string BuildEmailUrl(string path, Dictionary<string, object?> parameters)
    {
        var baseUri = !string.IsNullOrWhiteSpace(AppSettings.PublicBaseUrl)
            ? $"{AppSettings.PublicBaseUrl.TrimEnd('/')}/{path}"
            : NavigationManager.ToAbsoluteUri(path).AbsoluteUri;
        return NavigationManager.GetUriWithQueryParameters(baseUri, parameters);
    }

    private ApplicationUser CreateUser()
    {
        try
        {
            return Activator.CreateInstance<ApplicationUser>();
        }
        catch
        {
            throw new InvalidOperationException($"Can't create an instance of '{nameof(ApplicationUser)}'. " +
                $"Ensure that '{nameof(ApplicationUser)}' is not an abstract class and has a parameterless constructor.");
        }
    }

    private IUserEmailStore<ApplicationUser> GetEmailStore()
    {
        if (!UserManager.SupportsUserEmail)
        {
            throw new NotSupportedException("The default UI requires a user store with email support.");
        }
        return (IUserEmailStore<ApplicationUser>)UserStore;
    }

    private sealed class InputModel
    {
        [Required]
        [Display(Name = "Full Name")]
        public string FullName { get; set; } = string.Empty;

        [Required]
        [EmailAddress]
        [Display(Name = "Email")]
        public string Email { get; set; } = "";

        [Required]
        [MaxLength(30)]
        [Display(Name = "ID Number")]
        public string IdNumber { get; set; } = string.Empty;

        [Required]
        [MaxLength(30)]
        [Display(Name = "Cellphone Number")]
        public string CellphoneNumber { get; set; } = string.Empty;

        [Display(Name = "Residential Area")]
        public string? ResidentialArea { get; set; }

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 8)]
        [DataType(DataType.Password)]
        [Display(Name = "Password")]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Display(Name = "Confirm password")]
        [Compare("Password", ErrorMessage = "The password and confirmation password do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }

    private string GetPostRegistrationRedirectUrl()
    {
        return !string.IsNullOrWhiteSpace(ReturnUrl) &&
            Uri.IsWellFormedUriString(ReturnUrl, UriKind.Relative)
            ? ReturnUrl
            : "/my-workspace";
    }
}
