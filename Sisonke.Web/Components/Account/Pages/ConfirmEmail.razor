@page "/Account/ConfirmEmail"
@layout AuthLayout

@using System.Text
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using Sisonke.Web.Data

@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager
@inject NavigationManager NavigationManager

<PageTitle>Email Confirmed — Sisonke</PageTitle>

<div class="auth-confirm-wrap">
    <div class="auth-confirm-card">
        <div class="auth-logo" style="margin-bottom:20px;">
            <div class="auth-logo-mark">S</div>
            <span class="auth-logo-name">Sisonke</span>
        </div>

        @if (_confirmed)
        {
            <div class="auth-confirm-icon" style="font-size:48px;margin-bottom:12px;">✅</div>
            <h1 class="auth-form-heading" style="text-align:center;">Email confirmed!</h1>
            <p style="text-align:center;color:var(--auth-muted,#7A6E69);margin:0 0 28px;line-height:1.6;">
                Your email address has been successfully verified.<br />
                You can now sign in to your Sisonke account.
            </p>
            <a href="Account/Login" class="auth-btn-primary" style="display:block;text-align:center;text-decoration:none;">
                Sign In
            </a>
        }
        else
        {
            <div class="auth-confirm-icon" style="font-size:48px;margin-bottom:12px;">⚠️</div>
            <h1 class="auth-form-heading" style="text-align:center;">Confirmation failed</h1>
            <p style="text-align:center;color:var(--auth-muted,#7A6E69);margin:0 0 28px;line-height:1.6;">
                We could not confirm your email address. The link may have expired or already been used.
            </p>
            <a href="Account/ResendEmailConfirmation" class="auth-btn-primary"
               style="display:block;text-align:center;text-decoration:none;">
                Resend Confirmation Email
            </a>
            <p class="auth-switch" style="text-align:center;margin-top:20px;">
                <a href="Account/Login">← Back to Sign In</a>
            </p>
        }
    </div>
</div>

@code {
    private bool _confirmed = false;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? UserId { get; set; }

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (UserId is null || Code is null)
        {
            RedirectManager.RedirectTo("");
            return;
        }

        var user = await UserManager.FindByIdAsync(UserId);
        if (user is null)
        {
            HttpContext.Response.StatusCode = StatusCodes.Status404NotFound;
            return;
        }

        try
        {
            var code = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
            var result = await UserManager.ConfirmEmailAsync(user, code);
            _confirmed = result.Succeeded;
        }
        catch
        {
            _confirmed = false;
        }
    }
}
