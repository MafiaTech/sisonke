@page "/Account/ForgotPasswordConfirmation"
@layout AuthLayout

<PageTitle>Check Your Email — Sisonke</PageTitle>

<div class="auth-confirm-wrap">
    <div class="auth-confirm-card">
        <div class="auth-logo" style="margin-bottom:20px;">
            <div class="auth-logo-mark">S</div>
            <span class="auth-logo-name">Sisonke</span>
        </div>
        <div class="auth-confirm-icon" style="font-size:48px;margin-bottom:12px;">📧</div>
        <h1 class="auth-form-heading" style="text-align:center;">Check your email</h1>
        <p style="text-align:center;color:var(--auth-muted,#7A6E69);margin:0 0 24px;line-height:1.6;">
            If that email address is registered with Sisonke, we've sent a password reset link.
            Please check your inbox (and your spam folder if you don't see it).
        </p>
        <p style="text-align:center;color:var(--auth-muted,#7A6E69);font-size:13px;margin:0 0 28px;">
            The reset link expires in <strong>1 hour</strong>.
        </p>
        <a href="Account/Login" class="auth-btn-primary" style="display:block;text-align:center;text-decoration:none;">
            Back to Sign In
        </a>
        <p class="auth-switch" style="text-align:center;margin-top:20px;">
            Didn't receive an email?
            <a href="Account/ForgotPassword">Try again</a>
        </p>
    </div>
</div>
