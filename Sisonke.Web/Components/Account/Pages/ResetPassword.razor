@page "/Account/ResetPassword"
@layout AuthLayout

@using System.ComponentModel.DataAnnotations
@using System.Text
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using Sisonke.Web.Data

@inject IdentityRedirectManager RedirectManager
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Reset Password — Sisonke</PageTitle>

<div class="auth-split">

    <div class="auth-brand">
        <div class="auth-circles">
            <svg width="460" height="460" viewBox="0 0 460 460" fill="none">
                <circle cx="230" cy="230" r="190" stroke="#C9922A" stroke-width="1.4" stroke-dasharray="9 13" />
                <circle cx="230" cy="230" r="145" stroke="#C9922A" stroke-width="1"   stroke-dasharray="5 9"  opacity="0.6" />
                <circle cx="230" cy="230" r="100" stroke="#C9922A" stroke-width="0.8" stroke-dasharray="3 7"  opacity="0.4" />
                <circle cx="230" cy="230" r="55"  stroke="#C9922A" stroke-width="0.6"                        opacity="0.28" />
            </svg>
        </div>
        <div class="auth-beads">
            @for (int i = 0; i < 20; i++) { <div class="auth-bead"></div> }
        </div>
        <div class="auth-brand-content">
            <div class="auth-logo">
                <div class="auth-logo-mark">S</div>
                <span class="auth-logo-name">Sisonke</span>
            </div>
            <h2 class="auth-brand-headline">Create a<br /><em>new password</em><br />for your account.</h2>
            <p class="auth-brand-sub">Choose a strong password you haven't used before.</p>
        </div>
    </div>

    <div class="auth-form-panel">
        <div class="auth-form-container">

            <div class="auth-mobile-logo">
                <div class="auth-mobile-logo-mark">S</div>
                <span class="auth-mobile-logo-name">Sisonke</span>
            </div>

            <h1 class="auth-form-heading">Set a new password</h1>
            <p class="auth-form-subheading">Must be at least 8 characters</p>

            @if (_tokenError)
            {
                <div class="auth-error-alert" style="display:block;">
                    <strong>Invalid or expired link.</strong><br />
                    This password reset link has expired or has already been used.
                    Please <a href="Account/ForgotPassword" style="color:inherit;font-weight:600;">request a new reset link</a>.
                </div>
            }
            else
            {
                <StatusMessage Message="@Message" />

                <EditForm Model="Input" FormName="reset-password" OnValidSubmit="OnValidSubmitAsync" method="post">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="auth-error-alert" role="alert" />

                    <input type="hidden" name="Input.Code" value="@Input.Code" />

                    <div class="auth-field">
                        <label class="auth-label" for="Input.Email">Email Address</label>
                        <div class="auth-input-wrapper">
                            <span class="auth-input-icon">✉</span>
                            <InputText @bind-Value="Input.Email"
                                       id="Input.Email"
                                       class="auth-input"
                                       autocomplete="username"
                                       aria-required="true"
                                       placeholder="you@example.com" />
                        </div>
                        <ValidationMessage For="() => Input.Email" class="auth-val-msg" />
                    </div>

                    <div class="auth-field">
                        <label class="auth-label" for="Input.Password">New Password</label>
                        <div class="auth-input-wrapper">
                            <span class="auth-input-icon">🔒</span>
                            <InputText type="password"
                                       @bind-Value="Input.Password"
                                       id="Input.Password"
                                       class="auth-input has-toggle"
                                       autocomplete="new-password"
                                       aria-required="true"
                                       placeholder="Min. 8 characters"
                                       oninput="authUpdateStrength(this.value)" />
                            <button type="button" class="auth-pw-toggle"
                                    onclick="authTogglePw('Input.Password', this)"
                                    tabindex="-1" aria-label="Show password">👁️</button>
                        </div>
                        <ValidationMessage For="() => Input.Password" class="auth-val-msg" />
                        <div class="auth-strength">
                            <div class="auth-strength-bars">
                                <div class="auth-strength-bar" id="auth-sb-1"></div>
                                <div class="auth-strength-bar" id="auth-sb-2"></div>
                                <div class="auth-strength-bar" id="auth-sb-3"></div>
                                <div class="auth-strength-bar" id="auth-sb-4"></div>
                            </div>
                            <span class="auth-strength-text" id="auth-strength-label"></span>
                        </div>
                    </div>

                    <div class="auth-field">
                        <label class="auth-label" for="Input.ConfirmPassword">Confirm New Password</label>
                        <div class="auth-input-wrapper">
                            <span class="auth-input-icon">🔒</span>
                            <InputText type="password"
                                       @bind-Value="Input.ConfirmPassword"
                                       id="Input.ConfirmPassword"
                                       class="auth-input has-toggle"
                                       autocomplete="new-password"
                                       aria-required="true"
                                       placeholder="Repeat your password" />
                            <button type="button" class="auth-pw-toggle"
                                    onclick="authTogglePw('Input.ConfirmPassword', this)"
                                    tabindex="-1" aria-label="Show confirm password">👁️</button>
                        </div>
                        <ValidationMessage For="() => Input.ConfirmPassword" class="auth-val-msg" />
                    </div>

                    <button type="submit" class="auth-btn-primary">Reset Password</button>
                </EditForm>
            }

            <p class="auth-switch" style="margin-top:24px;">
                <a href="Account/Login">← Back to Sign In</a>
            </p>

        </div>
    </div>
</div>

<script>
(function () {
    function updateStrength(val) {
        var bars = [document.getElementById('auth-sb-1'), document.getElementById('auth-sb-2'),
                    document.getElementById('auth-sb-3'), document.getElementById('auth-sb-4')];
        var label = document.getElementById('auth-strength-label');
        var score = 0;
        if (val.length >= 8) score++;
        if (val.length >= 12) score++;
        if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
        if (/[^A-Za-z0-9]/.test(val)) score++;
        var classes = ['', 's-weak', 's-fair', 's-good', 's-strong'];
        var names = ['', 'Weak', 'Fair', 'Good', 'Strong'];
        bars.forEach(function (b, idx) {
            if (!b) return;
            b.className = 'auth-strength-bar' + (idx < score ? ' ' + classes[score] : '');
        });
        if (label) label.textContent = val.length > 0 ? names[score] || '' : '';
    }
    function togglePw(inputId, btn) {
        var el = document.getElementById(inputId);
        if (!el) return;
        el.type = el.type === 'password' ? 'text' : 'password';
        btn.textContent = el.type === 'password' ? '👁️' : '🙈';
    }
    window.authUpdateStrength = updateStrength;
    window.authTogglePw = togglePw;
}());
</script>

@code {
    private IEnumerable<IdentityError>? identityErrors;
    private bool _tokenError = false;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    private string? Message => identityErrors is null
        ? null
        : $"Error: {string.Join(", ", identityErrors.Select(e => e.Description))}";

    protected override void OnInitialized()
    {
        Input ??= new();

        if (Code is null)
        {
            _tokenError = true;
            return;
        }

        try
        {
            Input.Code = Encoding.UTF8.GetString(WebEncoders.Base64UrlDecode(Code));
        }
        catch
        {
            _tokenError = true;
        }
    }

    private async Task OnValidSubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null)
        {
            // Don't reveal that the user does not exist — prevent user enumeration.
            RedirectManager.RedirectTo("Account/ResetPasswordConfirmation");
            return;
        }

        var result = await UserManager.ResetPasswordAsync(user, Input.Code, Input.Password);
        if (result.Succeeded)
        {
            RedirectManager.RedirectTo("Account/ResetPasswordConfirmation");
            return;
        }

        // Token invalid / expired — show friendly in-page message.
        if (result.Errors.Any(e => e.Code is "InvalidToken" or "TokenExpired"))
        {
            _tokenError = true;
            return;
        }

        identityErrors = result.Errors;
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 8)]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Display(Name = "Confirm password")]
        [Compare("Password", ErrorMessage = "The passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";

        [Required]
        public string Code { get; set; } = "";
    }
}
