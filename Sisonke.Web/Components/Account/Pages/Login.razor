@page "/Account/Login"
@layout AuthLayout

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using Sisonke.Web.Data

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Sign In — Sisonke</PageTitle>

<div class="auth-split">

    <!-- ══════════════════════════════════════════
         LEFT — Brand panel
    ══════════════════════════════════════════ -->
    <div class="auth-brand">

        <!-- Rotating circle motif -->
        <div class="auth-circles">
            <svg width="460" height="460" viewBox="0 0 460 460" fill="none">
                <circle cx="230" cy="230" r="190" stroke="#C9922A" stroke-width="1.4" stroke-dasharray="9 13" />
                <circle cx="230" cy="230" r="145" stroke="#C9922A" stroke-width="1"   stroke-dasharray="5 9"  opacity="0.6" />
                <circle cx="230" cy="230" r="100" stroke="#C9922A" stroke-width="0.8" stroke-dasharray="3 7"  opacity="0.4" />
                <circle cx="230" cy="230" r="55"  stroke="#C9922A" stroke-width="0.6"                        opacity="0.28" />
            </svg>
        </div>

        <!-- Beadwork dot grid 5 × 4 -->
        <div class="auth-beads">
            @for (int i = 0; i < 20; i++)
            {
                <div class="auth-bead"></div>
            }
        </div>

        <div class="auth-brand-content">

            <div class="auth-logo">
                <div class="auth-logo-mark">S</div>
                <span class="auth-logo-name">Sisonke</span>
            </div>

            <h2 class="auth-brand-headline">
                Your stokvel,<br /><em>managed with</em><br />dignity.
            </h2>

            <p class="auth-brand-sub">
                From burial societies to savings clubs — Sisonke brings transparency,
                trust, and structure to every stokvel.
            </p>

            <div class="auth-stats">
                <div class="auth-stat">
                    <span class="auth-stat-number">12k+</span>
                    <span class="auth-stat-label">Stokvels</span>
                </div>
                <div class="auth-stat">
                    <span class="auth-stat-number">R2.4B</span>
                    <span class="auth-stat-label">Managed</span>
                </div>
                <div class="auth-stat">
                    <span class="auth-stat-number">98%</span>
                    <span class="auth-stat-label">Satisfaction</span>
                </div>
            </div>

            <blockquote class="auth-testimonial">
                <q>Sisonke removed all the stress from running our burial society.
                   Everything is transparent now.</q>
                <span class="auth-testimonial-author">Nomsa D. · Chairperson, Soweto</span>
            </blockquote>

        </div>
    </div>

    <!-- ══════════════════════════════════════════
         RIGHT — Form panel
    ══════════════════════════════════════════ -->
    <div class="auth-form-panel">
        <div class="auth-form-container">

            <!-- Mobile logo (hidden ≥ 900 px) -->
            <div class="auth-mobile-logo">
                <div class="auth-mobile-logo-mark">S</div>
                <span class="auth-mobile-logo-name">Sisonke</span>
            </div>

            <!-- Tab switcher -->
            <div class="auth-tabs">
                <a href="Account/Login" class="auth-tab active">Sign In</a>
                <a href="@(NavigationManager.GetUriWithQueryParameters("Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))" class="auth-tab">Create Account</a>
            </div>

            <h1 class="auth-form-heading">Welcome back</h1>
            <p class="auth-form-subheading">Sign in to manage your stokvel</p>

            <!-- Status message (success/error from cookie) -->
            <StatusMessage Message="@errorMessage" />

            <EditForm EditContext="editContext" method="post" OnSubmit="LoginUser" FormName="login">
                <DataAnnotationsValidator />

                <!-- Validation summary styled as error box -->
                <ValidationSummary class="auth-error-alert" role="alert" />

                <!-- Email -->
                <div class="auth-field">
                    <label class="auth-label" for="Input.Email">Email Address</label>
                    <div class="auth-input-wrapper">
                        <span class="auth-input-icon">✉</span>
                        <InputText @bind-Value="Input.Email"
                                   id="Input.Email"
                                   class="auth-input"
                                   autocomplete="username webauthn"
                                   aria-required="true"
                                   placeholder="you@example.com" />
                    </div>
                    <ValidationMessage For="() => Input.Email" class="auth-val-msg" />
                </div>

                <!-- Password -->
                <div class="auth-field">
                    <div class="auth-label-row">
                        <label class="auth-label" for="Input.Password">Password</label>
                        <a href="Account/ForgotPassword" class="auth-forgot">Forgot password?</a>
                    </div>
                    <div class="auth-input-wrapper">
                        <span class="auth-input-icon">🔒</span>
                        <InputText type="password"
                                   @bind-Value="Input.Password"
                                   id="Input.Password"
                                   class="auth-input has-toggle"
                                   autocomplete="current-password"
                                   aria-required="true"
                                   placeholder="••••••••" />
                        <button type="button"
                                class="auth-pw-toggle"
                                onclick="authTogglePw('Input.Password', this)"
                                tabindex="-1"
                                aria-label="Show password">👁️</button>
                    </div>
                    <ValidationMessage For="() => Input.Password" class="auth-val-msg" />
                </div>

                <!-- Remember me -->
                <div class="auth-remember">
                    <label class="auth-checkbox-label">
                        <InputCheckbox @bind-Value="Input.RememberMe" class="auth-checkbox" />
                        <span class="auth-checkbox-text">Remember me on this device</span>
                    </label>
                </div>

                <!-- Submit -->
                <button type="submit" class="auth-btn-primary">Sign In</button>

                <div class="auth-divider"><span>or continue with</span></div>

                <div class="auth-external">
                    <ExternalLoginPicker />
                </div>

            </EditForm>

            <p class="auth-switch">
                Don't have an account?
                <a href="@(NavigationManager.GetUriWithQueryParameters("Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))">Create one free</a>
            </p>
            <p class="auth-switch small">
                <a href="Account/ResendEmailConfirmation">Resend email confirmation</a>
            </p>

        </div>
    </div>

</div>

<script>
    function authTogglePw(inputId, btn) {
        var el = document.getElementById(inputId);
        if (!el) return;
        if (el.type === 'password') {
            el.type = 'text';
            btn.textContent = '🙈';
        } else {
            el.type = 'password';
            btn.textContent = '👁️';
        }
    }
</script>

@code {
    private string? errorMessage;
    private EditContext editContext = default!;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "sessionExpired")]
    private string? SessionExpired { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();

        editContext = new EditContext(Input);

        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            // Clear the existing external cookie to ensure a clean login process
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);

            if (string.Equals(SessionExpired, "1"))
            {
                errorMessage = "Your session has expired. Please sign in again.";
            }
        }
    }

    public async Task LoginUser()
    {
        if (!editContext.Validate())
        {
            return;
        }

        var result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: true);

        if (result.Succeeded)
        {
            try
            {
                var loggedInUser = await UserManager.FindByEmailAsync(Input.Email);
                if (loggedInUser is not null)
                {
                    loggedInUser.LastLoginAt = DateTime.UtcNow;
                    loggedInUser.LastLoginIp = HttpContext.Connection.RemoteIpAddress?.ToString();
                    await UserManager.UpdateAsync(loggedInUser);
                }
            }
            catch
            {
                // audit update failure must not block login
            }
            Logger.LogInformation("User logged in.");
            RedirectManager.RedirectTo(GetPostLoginRedirectUrl());
        }
        else if (result.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo(
                "Account/LoginWith2fa",
                new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            errorMessage = "Error: Invalid login attempt.";
        }
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }
    }

    private string GetPostLoginRedirectUrl()
    {
        return !string.IsNullOrWhiteSpace(ReturnUrl) &&
            Uri.IsWellFormedUriString(ReturnUrl, UriKind.Relative)
            ? ReturnUrl
            : "/my-workspace";
    }
}
