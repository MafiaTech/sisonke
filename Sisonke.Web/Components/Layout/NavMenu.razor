@implements IDisposable

@inject NavigationManager NavigationManager

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <i class="bi bi-piggy-bank-fill brand-icon" aria-hidden="true"></i>
            <span class="brand-text">
                Sisonke
                <small class="brand-tagline">Stokvel Management</small>
            </span>
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-fill nav-icon" aria-hidden="true"></i> Home
            </NavLink>
        </div>

        <div class="nav-section-label">Stokvels</div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="my-stokvels">
                <i class="bi bi-grid-fill nav-icon" aria-hidden="true"></i> My Stokvels
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="register-stokvel">
                <i class="bi bi-plus-circle-fill nav-icon" aria-hidden="true"></i> Register Stokvel
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-section-label">Account</div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Manage">
                        <i class="bi bi-person-circle nav-icon" aria-hidden="true"></i> @context.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <i class="bi bi-box-arrow-left nav-icon" aria-hidden="true"></i> Sign Out
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-section-label">Account</div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Register">
                        <i class="bi bi-person-plus-fill nav-icon" aria-hidden="true"></i> Register
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Login">
                        <i class="bi bi-box-arrow-in-right nav-icon" aria-hidden="true"></i> Sign In
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>

    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
