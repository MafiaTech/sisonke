@implements IDisposable

@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using Sisonke.Web.Data
@using Sisonke.Web.Data.Entities

@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<aside class="@SidebarCssClass">
    <a class="sisonke-sidebar-brand" href="@HomeHref">
        <div class="sisonke-sidebar-mark">
            <img src="/brand/sisonke-mark.svg" alt="" aria-hidden="true" />
        </div>
        <div>
            <span class="sisonke-sidebar-name">Sisonke</span>
            <span class="sisonke-sidebar-tagline">Stokvel Management</span>
        </div>
    </a>

    <nav class="nav flex-column">

        <div class="nav-item px-0">
            <NavLink class="sisonke-nav-item" href="@HomeHref" Match="NavLinkMatch.All">
                <i class="bi bi-house-fill nav-icon" aria-hidden="true"></i>
                <span>Home</span>
            </NavLink>
        </div>

        @if (isAuthenticated)
        {
            <div class="sisonke-nav-section">Account</div>
            <div class="nav-item px-0">
                <NavLink class="sisonke-nav-item" href="my-memberships">
                    <i class="bi bi-person-vcard nav-icon" aria-hidden="true"></i>
                    <span>My Memberships</span>
                </NavLink>
            </div>
            <div class="nav-item px-0">
                    <NavLink class="sisonke-nav-item" href="Account/Manage">
                    <i class="bi bi-person-circle nav-icon" aria-hidden="true"></i>
                    <span>@GetAccountLabel()</span>
                    </NavLink>
                </div>

            @if (HasContextNavigation)
            {
                <div class="sisonke-nav-section">Standard</div>
                <div class="nav-item px-0">
                    <NavLink class="sisonke-nav-item" href="@DashboardHref">
                        <i class="bi bi-speedometer2 nav-icon" aria-hidden="true"></i>
                        <span>Dashboard</span>
                    </NavLink>
                </div>
                @if (contextMember is not null)
                {
                    <div class="nav-item px-0">
                        <NavLink class="sisonke-nav-item" href="@($"/member-profile/{contextMember.Id}")">
                            <i class="bi bi-person-circle nav-icon" aria-hidden="true"></i>
                            <span>My Profile</span>
                        </NavLink>
                    </div>
                }
                @if (contextMember is not null && !CanManageContextStokvel)
                {
                    <div class="nav-item px-0">
                        <NavLink class="sisonke-nav-item" href="@($"/member-home/{contextMember.Id}#member-contributions")">
                            <i class="bi bi-cash-coin nav-icon" aria-hidden="true"></i>
                            <span>Contributions</span>
                        </NavLink>
                    </div>
                }
                else if (contextStokvel is not null && CanManageContextStokvel)
                {
                    <div class="nav-item px-0">
                        <NavLink class="sisonke-nav-item" href="@($"/contribution-capture/{contextStokvel.Id}")">
                            <i class="bi bi-cash-stack nav-icon" aria-hidden="true"></i>
                            <span>Contributions</span>
                        </NavLink>
                    </div>
                }
                @if (contextStokvel is not null)
                {
                    <div class="nav-item px-0">
                        <NavLink class="sisonke-nav-item" href="@($"/meetings/{contextStokvel.Id}")">
                            <i class="bi bi-calendar3 nav-icon" aria-hidden="true"></i>
                            <span>Meetings</span>
                        </NavLink>
                    </div>
                    <div class="nav-item px-0">
                        <NavLink class="sisonke-nav-item" href="@($"/constitution-builder/{contextStokvel.Id}")">
                            <i class="bi bi-file-earmark-text nav-icon" aria-hidden="true"></i>
                            <span>Constitution</span>
                        </NavLink>
                    </div>
                }
                <div class="nav-item px-0">
                    <NavLink class="sisonke-nav-item" href="/platform-support">
                        <i class="bi bi-life-preserver nav-icon" aria-hidden="true"></i>
                        <span>Report an Issue</span>
                    </NavLink>
                </div>
            }

            @if (contextStokvel?.EnableRotation == true)
            {
                <div class="sisonke-nav-section">Rotational Module</div>
                @if (CanManageContextStokvel)
                {
                    <div class="nav-item px-0">
                        <NavLink class="sisonke-nav-item" href="@($"/rotational/management/{contextStokvel.Id}")">
                            <i class="bi bi-arrow-repeat nav-icon" aria-hidden="true"></i>
                            <span>Rotation Management</span>
                        </NavLink>
                    </div>
                }
                <div class="nav-item px-0">
                    <NavLink class="sisonke-nav-item" href="@($"/rotational/rotation-order/{contextStokvel.Id}")">
                        <i class="bi bi-list-ol nav-icon" aria-hidden="true"></i>
                        <span>Rotation Order</span>
                    </NavLink>
                </div>
                <div class="nav-item px-0">
                    <NavLink class="sisonke-nav-item" href="@($"/stokvel/{contextStokvel.Id}/wallet")">
                        <i class="bi bi-wallet2 nav-icon" aria-hidden="true"></i>
                        <span>Wallet</span>
                    </NavLink>
                </div>
                <div class="nav-item px-0">
                    <span class="sisonke-nav-item sisonke-nav-item-disabled" aria-disabled="true" title="Coming soon">
                        <i class="bi bi-bank nav-icon" aria-hidden="true"></i>
                        <span>My Payouts</span>
                        <span class="sisonke-nav-mini-badge">Soon</span>
                    </span>
                </div>
                @if (contextStokvel.EnableLending)
                {
                    <div class="nav-item px-0">
                        <NavLink class="sisonke-nav-item" href="@($"/stokvel/{contextStokvel.Id}/loans")">
                            <i class="bi bi-cash-coin nav-icon" aria-hidden="true"></i>
                            <span>Loans</span>
                        </NavLink>
                    </div>
                }
            }

            @if (HasContextNavigation)
            {
                <div class="sisonke-nav-section">Support</div>
                <div class="nav-item px-0">
                    <span class="sisonke-nav-item sisonke-nav-item-disabled" aria-disabled="true" title="Coming soon">
                        <i class="bi bi-chat-dots nav-icon" aria-hidden="true"></i>
                        <span>Contact Chairperson</span>
                        <span class="sisonke-nav-mini-badge">Soon</span>
                    </span>
                </div>
            }

            @if (hasManagedStokvels || canRegisterStokvel)
            {
                <div class="sisonke-nav-section">Stokvels</div>
                @if (hasManagedStokvels)
                {
                    <div class="nav-item px-0">
                        <NavLink class="sisonke-nav-item" href="managed-stokvels">
                            <i class="bi bi-grid-fill nav-icon" aria-hidden="true"></i>
                            <span>Stokvels I Manage</span>
                        </NavLink>
                    </div>
                }
                @if (canRegisterStokvel)
                {
                    <div class="nav-item px-0">
                        <NavLink class="sisonke-nav-item" href="register-stokvel">
                            <i class="bi bi-plus-circle-fill nav-icon" aria-hidden="true"></i>
                            <span>Register Stokvel</span>
                        </NavLink>
                    </div>
                }
            }

            @if (hasManagedStokvels)
            {
                <div class="sisonke-nav-section">Tools</div>
                <div class="nav-item px-0">
                    <NavLink class="sisonke-nav-item" href="my-workspace">
                        <i class="bi bi-bar-chart-fill nav-icon" aria-hidden="true"></i>
                        <span>Reports &amp; Workspace</span>
                    </NavLink>
                </div>
                @if (contextStokvel is not null && CanManageContextStokvel)
                {
                    <div class="nav-item px-0">
                        <NavLink class="sisonke-nav-item" href="@($"/stokvel/{contextStokvel.Id}/configuration-review")">
                            <i class="bi bi-clipboard-check nav-icon" aria-hidden="true"></i>
                            <span>Configuration Review</span>
                        </NavLink>
                    </div>
                    <div class="nav-item px-0">
                        <NavLink class="sisonke-nav-item" href="@($"/stokvel/{contextStokvel.Id}/admin/roles")">
                            <i class="bi bi-people-fill nav-icon" aria-hidden="true"></i>
                            <span>Role Management</span>
                        </NavLink>
                    </div>
                }
            }

            @if (isPlatformAdmin || isPlatformSupport)
            {
                <div class="sisonke-nav-section">Platform</div>
                @if (isPlatformAdmin)
                {
                    <div class="nav-item px-0">
                        <NavLink class="sisonke-nav-item" href="platform-admin">
                            <i class="bi bi-shield-lock-fill nav-icon" aria-hidden="true"></i>
                            <span>Platform Admin</span>
                        </NavLink>
                    </div>
                }
                <div class="nav-item px-0">
                    <NavLink class="sisonke-nav-item" href="platform-support">
                        <i class="bi bi-life-preserver nav-icon" aria-hidden="true"></i>
                        <span>Support Console</span>
                    </NavLink>
                </div>
                <div class="nav-item px-0">
                    <NavLink class="sisonke-nav-item" href="admin/production-readiness">
                        <i class="bi bi-activity nav-icon" aria-hidden="true"></i>
                        <span>Readiness</span>
                    </NavLink>
                </div>
            }

            <div class="nav-item px-0">
                <NavLink class="sisonke-nav-item" href="Account/Manage">
                    <i class="bi bi-gear-fill nav-icon" aria-hidden="true"></i>
                    <span>Settings</span>
                </NavLink>
            </div>
            <div class="nav-item px-0">
                <form action="Account/Logout" method="post" @formname="logout-form">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="/" />
                    <button type="submit" class="sisonke-nav-item w-100" style="background:transparent;border:0;text-align:left;">
                        <i class="bi bi-box-arrow-left nav-icon" aria-hidden="true"></i>
                        <span>Sign Out</span>
                    </button>
                </form>
            </div>
        }
        else
        {
            <div class="sisonke-nav-section">Account</div>
            <div class="nav-item px-0">
                <NavLink class="sisonke-nav-item" href="Account/Register">
                    <i class="bi bi-person-plus-fill nav-icon" aria-hidden="true"></i>
                    <span>Create Account</span>
                </NavLink>
            </div>
            <div class="nav-item px-0">
                <NavLink class="sisonke-nav-item" href="Account/Login">
                    <i class="bi bi-box-arrow-in-right nav-icon" aria-hidden="true"></i>
                    <span>Sign In</span>
                </NavLink>
            </div>
        }

    </nav>
</aside>

@code {
    private string? currentUrl;
    private ApplicationUser? currentUser;
    private bool isAuthenticated;
    private bool hasManagedStokvels;
    private bool isPlatformAdmin;
    private bool isPlatformSupport;
    private bool canRegisterStokvel;
    private List<Member> memberships = [];
    private Member? contextMember;
    private Stokvel? contextStokvel;
    private string HomeHref => isAuthenticated ? "/my-workspace" : "/";
    private bool HasContextNavigation => contextMember is not null || contextStokvel is not null;
    private bool CanManageContextStokvel => IsOfficeBearerRole(contextMember?.DefaultRole.ToString());
    private string DashboardHref => contextStokvel is not null && CanManageContextStokvel
        ? $"/stokvel-dashboard/{contextStokvel.Id}"
        : contextMember is not null
            ? $"/member-home/{contextMember.Id}"
            : HomeHref;
    private string SidebarCssClass => $"sisonke-sidebar {RoleCssClass}";
    private string RoleCssClass =>
        isPlatformAdmin ? "sisonke-role-platform-admin" :
        isPlatformSupport ? "sisonke-role-support" :
        hasManagedStokvels ? "sisonke-role-executive" :
        "sisonke-role-member";

    protected override async Task OnInitializedAsync()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;

        await LoadNavigationStateAsync();
    }

    private async Task LoadNavigationStateAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;

        isAuthenticated = principal.Identity?.IsAuthenticated == true;
        hasManagedStokvels = false;
        isPlatformAdmin = false;
        isPlatformSupport = false;
        canRegisterStokvel = false;
        currentUser = null;
        memberships = [];
        contextMember = null;
        contextStokvel = null;

        if (!isAuthenticated)
        {
            return;
        }

        isPlatformAdmin = principal.IsInRole("PlatformAdmin");
        isPlatformSupport = principal.IsInRole("PlatformSupport");

        var userId = principal.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            return;
        }

        currentUser = await LoadCurrentUserAsync(userId);
        canRegisterStokvel = !string.IsNullOrWhiteSpace(currentUser?.IdNumber);

        memberships = await LoadMembershipsAsync(userId);
        hasManagedStokvels = memberships.Any(member => IsOfficeBearerRole(member.DefaultRole.ToString()));
        isPlatformAdmin = isPlatformAdmin || memberships.Any(member => member.DefaultRole.ToString().Equals("PlatformSuperAdmin", StringComparison.OrdinalIgnoreCase));
        isPlatformSupport = isPlatformSupport || memberships.Any(member => member.DefaultRole.ToString().Equals("PlatformSupportAdmin", StringComparison.OrdinalIgnoreCase));
        await LoadContextNavigationAsync(userId);
    }

    private async Task<ApplicationUser?> LoadCurrentUserAsync(string currentUserId)
    {
        await using var context = await DbFactory.CreateDbContextAsync();

        return await context.Users
            .AsNoTracking()
            .FirstOrDefaultAsync(user => user.Id == currentUserId);
    }

    private async Task<List<Member>> LoadMembershipsAsync(string currentUserId)
    {
        await using var context = await DbFactory.CreateDbContextAsync();

        return await context.Members
            .AsNoTracking()
            .Include(member => member.Tenant)
            .Where(member => member.ApplicationUserId == currentUserId)
            .OrderBy(member => member.FullName)
            .ToListAsync();
    }

    private async Task LoadContextNavigationAsync(string currentUserId)
    {
        contextMember = null;
        contextStokvel = null;

        var (memberId, stokvelId) = GetRouteContextIds();

        await using var context = await DbFactory.CreateDbContextAsync();

        if (memberId is not null)
        {
            contextMember = memberships.FirstOrDefault(member => member.Id == memberId.Value);

            if (contextMember is not null)
            {
                contextStokvel = await context.Stokvels
                    .AsNoTracking()
                    .FirstOrDefaultAsync(stokvel => stokvel.TenantId == contextMember.TenantId);
                return;
            }
        }

        if (stokvelId is not null)
        {
            contextStokvel = await context.Stokvels
                .AsNoTracking()
                .FirstOrDefaultAsync(stokvel => stokvel.Id == stokvelId.Value);

            if (contextStokvel is not null)
            {
                contextMember = memberships.FirstOrDefault(member => member.TenantId == contextStokvel.TenantId);
                return;
            }
        }

        if (memberships.Count == 1)
        {
            contextMember = memberships[0];
            contextStokvel = await context.Stokvels
                .AsNoTracking()
                .FirstOrDefaultAsync(stokvel => stokvel.TenantId == contextMember.TenantId);
        }
    }

    private (Guid? MemberId, Guid? StokvelId) GetRouteContextIds()
    {
        var path = (currentUrl ?? string.Empty).Split('?', '#')[0].Trim('/');
        var segments = path.Split('/', StringSplitOptions.RemoveEmptyEntries);

        if (segments.Length == 0)
        {
            return (null, null);
        }

        if (segments.Length >= 2 &&
            (segments[0].Equals("member-home", StringComparison.OrdinalIgnoreCase) ||
             segments[0].Equals("member-profile", StringComparison.OrdinalIgnoreCase)) &&
            Guid.TryParse(segments[1], out var memberId))
        {
            return (memberId, null);
        }

        if (segments.Length >= 3 &&
            segments[0].Equals("member-statement", StringComparison.OrdinalIgnoreCase) &&
            Guid.TryParse(segments[1], out memberId) &&
            Guid.TryParse(segments[2], out var statementStokvelId))
        {
            return (memberId, statementStokvelId);
        }

        if (segments.Length >= 2 &&
            (segments[0].Equals("stokvel-dashboard", StringComparison.OrdinalIgnoreCase) ||
             segments[0].Equals("rotational-configuration", StringComparison.OrdinalIgnoreCase) ||
             segments[0].Equals("rotation-schedule", StringComparison.OrdinalIgnoreCase) ||
             segments[0].Equals("meetings", StringComparison.OrdinalIgnoreCase) ||
             segments[0].Equals("constitution-builder", StringComparison.OrdinalIgnoreCase) ||
             segments[0].Equals("contribution-capture", StringComparison.OrdinalIgnoreCase) ||
             segments[0].Equals("stokvel-settings", StringComparison.OrdinalIgnoreCase) ||
             segments[0].Equals("members", StringComparison.OrdinalIgnoreCase)) &&
            Guid.TryParse(segments[1], out var stokvelId))
        {
            return (null, stokvelId);
        }

        if (segments.Length >= 3 &&
            segments[0].Equals("rotational", StringComparison.OrdinalIgnoreCase) &&
            (segments[1].Equals("management", StringComparison.OrdinalIgnoreCase) ||
             segments[1].Equals("rotation-order", StringComparison.OrdinalIgnoreCase)) &&
            Guid.TryParse(segments[2], out stokvelId))
        {
            return (null, stokvelId);
        }

        if (segments.Length >= 3 &&
            segments[0].Equals("stokvel", StringComparison.OrdinalIgnoreCase) &&
            Guid.TryParse(segments[1], out stokvelId))
        {
            return (null, stokvelId);
        }

        return (null, null);
    }

    private static bool IsOfficeBearerRole(string? role)
    {
        return role?.Trim().Equals("Chairperson", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("Secretary", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("Treasurer", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("Admin", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("StokvelAdmin", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("Creator", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("Office Bearer", StringComparison.OrdinalIgnoreCase) == true ||
            role?.Trim().Equals("OfficeBearer", StringComparison.OrdinalIgnoreCase) == true;
    }

    private string GetAccountLabel()
    {
        if (!string.IsNullOrWhiteSpace(currentUser?.FullName))
        {
            return currentUser.FullName;
        }

        if (!string.IsNullOrWhiteSpace(currentUser?.Email))
        {
            return currentUser.Email;
        }

        return "Account";
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        _ = InvokeAsync(async () =>
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

            if (!string.IsNullOrWhiteSpace(userId))
            {
                await LoadContextNavigationAsync(userId);
            }

            StateHasChanged();
        });
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
