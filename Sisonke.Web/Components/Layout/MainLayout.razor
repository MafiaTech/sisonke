@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable

@inject NavigationManager NavigationManager
@inject IConfiguration Configuration

<div class="sisonke-app-shell sisonke-shell sisonke-role-member">
    <input id="sisonke-mobile-nav-toggle" class="sisonke-mobile-nav-toggle" type="checkbox" aria-hidden="true" />
    <label class="sisonke-mobile-menu-button sisonke-mobile-menu-button--floating" for="sisonke-mobile-nav-toggle" aria-label="Open navigation">
        <i class="bi bi-list" aria-hidden="true"></i>
    </label>
    <NavMenu />
    <label class="sisonke-mobile-scrim" for="sisonke-mobile-nav-toggle" aria-hidden="true"></label>

    <main class="sisonke-main">
        <div class="sisonke-mobile-topbar">
            <label class="sisonke-mobile-menu-button" for="sisonke-mobile-nav-toggle" aria-label="Open navigation">
                <i class="bi bi-list" aria-hidden="true"></i>
            </label>
            <a class="sisonke-mobile-brand" href="/">
                <span class="sisonke-mobile-brand-mark"><img src="/brand/sisonke-mark.svg" alt="" aria-hidden="true" /></span>
                <span>Sisonke</span>
            </a>
            <a class="sisonke-mobile-icon-link" href="Account/Manage" aria-label="Account">
                <i class="bi bi-person-circle" aria-hidden="true"></i>
            </a>
        </div>
        <div class="sisonke-topbar">
            <div class="sisonke-topbar-inner">
                <div>
                    <div class="sisonke-nav-section m-0" style="color:var(--muted);">Current Area</div>
                    <div class="fw-semibold">@CurrentAreaLabel</div>
                </div>
                <AuthorizeView>
                    <Authorized>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <button class="btn btn-sm btn-outline-secondary" type="button" aria-label="Notifications" title="Notifications coming soon">
                                <i class="bi bi-bell"></i>
                            </button>
                            <a href="Account/Manage" class="top-row-user">
                                <i class="bi bi-person-circle me-1"></i>
                                @context.User.Identity?.Name
                            </a>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <a href="Account/Register">Create Account</a>
                            <a href="Account/Login">Sign In</a>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        <div class="sisonke-content">

            @if (EnvironmentBannerEnabled && !string.IsNullOrWhiteSpace(EnvironmentBannerText))
            {
                <div class="pilot-banner">
                    @EnvironmentBannerText
                </div>
            }

            @Body
        </div>

        <nav class="sisonke-mobile-bottom-nav" aria-label="Primary mobile navigation">
            <a href="/my-workspace">
                <i class="bi bi-house-fill" aria-hidden="true"></i>
                <span>Home</span>
            </a>
            <a href="/my-memberships">
                <i class="bi bi-grid-fill" aria-hidden="true"></i>
                <span>Stokvels</span>
            </a>
            <a href="/managed-stokvels">
                <i class="bi bi-speedometer2" aria-hidden="true"></i>
                <span>Manage</span>
            </a>
            <a href="Account/Manage">
                <i class="bi bi-person-circle" aria-hidden="true"></i>
                <span>Profile</span>
            </a>
        </nav>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool EnvironmentBannerEnabled => Configuration.GetValue("EnvironmentBanner:Enabled", false);
    private string? EnvironmentBannerText => Configuration["EnvironmentBanner:Text"];

    private string CurrentAreaLabel => GetCurrentAreaLabel();

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private string GetCurrentAreaLabel()
    {
        var path = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim('/').ToLowerInvariant();

        if (string.IsNullOrWhiteSpace(path))
        {
            return "Home";
        }

        if (path.StartsWith("my-workspace"))
        {
            return "My Workspace";
        }

        if (path.StartsWith("my-memberships") || path.StartsWith("member-home") || path.StartsWith("member-profile"))
        {
            return "Member Workspace";
        }

        if (path.StartsWith("rotational/management") || path.StartsWith("stokvel/"))
        {
            return "Rotational Module";
        }

        if (path.StartsWith("managed-stokvels") || path.StartsWith("stokvel-dashboard") ||
            path.StartsWith("rotational-configuration") || path.StartsWith("rotation-schedule") ||
            path.StartsWith("stokvel-settings") || path.StartsWith("members/") ||
            path.StartsWith("contribution-capture/") || path.StartsWith("meetings/") ||
            path.StartsWith("finance-summary/"))
        {
            return "Executive Workspace";
        }

        if (path.StartsWith("platform-admin"))
        {
            return "Platform Administration";
        }

        if (path.StartsWith("platform-support"))
        {
            return "Support Console";
        }

        return "Sisonke";
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
