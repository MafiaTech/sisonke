@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable

@inject NavigationManager NavigationManager
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment WebHostEnvironment

<div class="sisonke-shell sisonke-role-member">
    <NavMenu />

    <main class="sisonke-main">
        <div class="sisonke-topbar">
            <div class="sisonke-topbar-inner">
                <div>
                    <div class="sisonke-nav-section m-0" style="color:var(--muted);">Current Area</div>
                    <div class="fw-semibold">@CurrentAreaLabel</div>
                </div>
                <AuthorizeView>
                    <Authorized>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <button class="btn btn-sm btn-outline-secondary" type="button" aria-label="Notifications" title="Notifications coming soon">
                                <i class="bi bi-bell"></i>
                            </button>
                            <a href="Account/Manage" class="top-row-user">
                                <i class="bi bi-person-circle me-1"></i>
                                @context.User.Identity?.Name
                            </a>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <a href="Account/Register">Create Account</a>
                            <a href="Account/Login">Sign In</a>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>

        <div class="sisonke-content">

             @if (WebHostEnvironment.EnvironmentName == "Staging" || WebHostEnvironment.EnvironmentName == "Development")
            {
                <div class="pilot-banner">
                    Sisonke Pilot Environment — for controlled user testing only. Do not use for final production records yet.
                </div>
            }

            @Body
        </div>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string CurrentAreaLabel => GetCurrentAreaLabel();

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private string GetCurrentAreaLabel()
    {
        var path = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Trim('/').ToLowerInvariant();

        if (string.IsNullOrWhiteSpace(path))
        {
            return "Home";
        }

        if (path.StartsWith("my-workspace"))
        {
            return "My Workspace";
        }

        if (path.StartsWith("my-memberships") || path.StartsWith("member-home") || path.StartsWith("member-profile"))
        {
            return "Member Workspace";
        }

        if (path.StartsWith("managed-stokvels") || path.StartsWith("stokvel-dashboard") ||
            path.StartsWith("rotational-configuration") || path.StartsWith("rotation-schedule") ||
            path.StartsWith("rotational/") || path.StartsWith("stokvel-settings"))
        {
            return "Executive Workspace";
        }

        if (path.StartsWith("platform-admin"))
        {
            return "Platform Administration";
        }

        if (path.StartsWith("platform-support"))
        {
            return "Support Console";
        }

        return "Sisonke";
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
